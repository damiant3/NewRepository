Chapter: Unification

  Type unification for the Codex type checker. The UnificationState
  is threaded through all operations — it tracks type variable
  substitutions, a counter for generating fresh variables,
  accumulated diagnostics, and the type definition / constructor
  maps built during type registration.

  Naming convention: the state is called a UnificationState because
  its mutations serve a specific purpose — unifying type variables
  with concrete types during type inference. It is not a general
  mutable reference.

Section: State

    UnificationState = record {
      substitutions : List SubstEntry,
      next-id : Integer,
      errors : List Diagnostic,
      type-defs : List TypeDefEntry,
      ctor-entries : List CtorEntry
    }

    SubstEntry = record {
      var-id : Integer,
      resolved-type : CodexType
    }

    TypeDefEntry = record {
      name : Text,
      resolved-type : CodexType
    }

    CtorEntry = record {
      name : Text,
      ctor-type : CodexType,
      owner-type : CodexType
    }

    UnifyResult = record {
      success : Boolean,
      state : UnificationState
    }

Section: Construction

    empty-unification-state : UnificationState
    empty-unification-state =
      UnificationState { substitutions = [], next-id = 0, errors = [], type-defs = [], ctor-entries = [] }

Section: Fresh Variables

    fresh-var : UnificationState -> CodexType
    fresh-var (st) = TypeVar st.next-id

    advance-id : UnificationState -> UnificationState
    advance-id (st) =
      UnificationState {
        substitutions = st.substitutions,
        next-id = st.next-id + 1,
        errors = st.errors,
        type-defs = st.type-defs,
        ctor-entries = st.ctor-entries
      }

    fresh-and-advance : UnificationState -> FreshResult
    fresh-and-advance (st) =
      FreshResult { var-type = TypeVar st.next-id, state = advance-id st }

    FreshResult = record {
      var-type : CodexType,
      state : UnificationState
    }

Section: Substitution Lookup

    subst-lookup : Integer -> List SubstEntry -> CodexType
    subst-lookup (var-id) (entries) =
      subst-lookup-loop var-id entries 0 (list-length entries)

    subst-lookup-loop : Integer -> List SubstEntry -> Integer -> Integer -> CodexType
    subst-lookup-loop (var-id) (entries) (i) (len) =
      if i == len then ErrorTy
      else
        let entry = list-at entries i
        in if entry.var-id == var-id then entry.resolved-type
           else subst-lookup-loop var-id entries (i + 1) len

    has-subst : Integer -> List SubstEntry -> Boolean
    has-subst (var-id) (entries) =
      has-subst-loop var-id entries 0 (list-length entries)

    has-subst-loop : Integer -> List SubstEntry -> Integer -> Integer -> Boolean
    has-subst-loop (var-id) (entries) (i) (len) =
      if i == len then False
      else
        let entry = list-at entries i
        in if entry.var-id == var-id then True
           else has-subst-loop var-id entries (i + 1) len

Section: Resolve

    resolve : UnificationState -> CodexType -> CodexType
    resolve (st) (ty) =
      when ty
        if TypeVar (id) ->
          if has-subst id st.substitutions
            then resolve st (subst-lookup id st.substitutions)
            else ty
        if _ -> ty

Section: Add Substitution

    add-subst : UnificationState -> Integer -> CodexType -> UnificationState
    add-subst (st) (var-id) (ty) =
      UnificationState {
        substitutions = st.substitutions ++ [SubstEntry { var-id = var-id, resolved-type = ty }],
        next-id = st.next-id,
        errors = st.errors,
        type-defs = st.type-defs,
        ctor-entries = st.ctor-entries
      }

Section: Add Error

    add-unify-error : UnificationState -> Text -> Text -> UnificationState
    add-unify-error (st) (code) (msg) =
      UnificationState {
        substitutions = st.substitutions,
        next-id = st.next-id,
        errors = st.errors ++ [make-error code msg],
        type-defs = st.type-defs,
        ctor-entries = st.ctor-entries
      }

Section: Type Def Lookup

    lookup-type-def : UnificationState -> Text -> CodexType
    lookup-type-def (st) (name) =
      lookup-type-def-loop st.type-defs name 0 (list-length st.type-defs)

    lookup-type-def-loop : List TypeDefEntry -> Text -> Integer -> Integer -> CodexType
    lookup-type-def-loop (entries) (name) (i) (len) =
      if i == len then ErrorTy
      else
        let e = list-at entries i
        in if e.name == name then e.resolved-type
           else lookup-type-def-loop entries name (i + 1) len

    has-type-def : UnificationState -> Text -> Boolean
    has-type-def (st) (name) =
      has-type-def-loop st.type-defs name 0 (list-length st.type-defs)

    has-type-def-loop : List TypeDefEntry -> Text -> Integer -> Integer -> Boolean
    has-type-def-loop (entries) (name) (i) (len) =
      if i == len then False
      else
        let e = list-at entries i
        in if e.name == name then True
           else has-type-def-loop entries name (i + 1) len

Section: Constructor Lookup

    lookup-ctor : UnificationState -> Text -> CtorEntry
    lookup-ctor (st) (name) =
      lookup-ctor-loop st.ctor-entries name 0 (list-length st.ctor-entries)

    lookup-ctor-loop : List CtorEntry -> Text -> Integer -> Integer -> CtorEntry
    lookup-ctor-loop (entries) (name) (i) (len) =
      if i == len then CtorEntry { name = "", ctor-type = ErrorTy, owner-type = ErrorTy }
      else
        let e = list-at entries i
        in if e.name == name then e
           else lookup-ctor-loop entries name (i + 1) len

    has-ctor : UnificationState -> Text -> Boolean
    has-ctor (st) (name) =
      has-ctor-loop st.ctor-entries name 0 (list-length st.ctor-entries)

    has-ctor-loop : List CtorEntry -> Text -> Integer -> Integer -> Boolean
    has-ctor-loop (entries) (name) (i) (len) =
      if i == len then False
      else
        let e = list-at entries i
        in if e.name == name then True
           else has-ctor-loop entries name (i + 1) len

Section: Record Field Lookup

    lookup-record-field : List RecordField -> Text -> CodexType
    lookup-record-field (fields) (name) =
      lookup-record-field-loop fields name 0 (list-length fields)

    lookup-record-field-loop : List RecordField -> Text -> Integer -> Integer -> CodexType
    lookup-record-field-loop (fields) (name) (i) (len) =
      if i == len then ErrorTy
      else
        let f = list-at fields i
        in if f.name.value == name then f.type-val
           else lookup-record-field-loop fields name (i + 1) len

Section: Occurs Check

    occurs-in : UnificationState -> Integer -> CodexType -> Boolean
    occurs-in (st) (var-id) (ty) =
      let resolved = resolve st ty
      in when resolved
        if TypeVar (id) -> id == var-id
        if FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
        if ListTy (elem) -> occurs-in st var-id elem
        if _ -> False

Section: Unify

    unify : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify (st) (a) (b) =
      let ra = resolve st a
      in let rb = resolve st b
      in unify-resolved st ra rb

    unify-resolved : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-resolved (st) (a) (b) =
      when a
        if TypeVar (id-a) ->
          if occurs-in st id-a b
            then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
            else UnifyResult { success = True, state = add-subst st id-a b }
        if _ -> unify-rhs st a b

    unify-rhs : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-rhs (st) (a) (b) =
      when b
        if TypeVar (id-b) ->
          if occurs-in st id-b a
            then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
            else UnifyResult { success = True, state = add-subst st id-b a }
        if _ -> unify-structural st a b

    unify-structural : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-structural (st) (a) (b) =
      when a
        if IntegerTy -> when b
          if IntegerTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if NumberTy -> when b
          if NumberTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if TextTy -> when b
          if TextTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if BooleanTy -> when b
          if BooleanTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if NothingTy -> when b
          if NothingTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if VoidTy -> when b
          if VoidTy -> UnifyResult { success = True, state = st }
          if _ -> unify-mismatch st a b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if FunTy (pa) (ra) -> when b
          if FunTy (pb) (rb) -> unify-fun st pa ra pb rb
          if _ -> unify-mismatch st a b
        if ListTy (ea) -> when b
          if ListTy (eb) -> unify st ea eb
          if _ -> unify-mismatch st a b
        if ConstructedTy (na) (args-a) -> when b
          if ConstructedTy (nb) (args-b) ->
            if na.value == nb.value then UnifyResult { success = True, state = st }
            else unify-mismatch st a b
          if _ -> unify-mismatch st a b
        if RecordTy (na) (fa) -> when b
          if RecordTy (nb) (fb) ->
            if na.value == nb.value then UnifyResult { success = True, state = st }
            else unify-mismatch st a b
          if _ -> unify-mismatch st a b
        if SumTy (na) (ca) -> when b
          if SumTy (nb) (cb) ->
            if na.value == nb.value then UnifyResult { success = True, state = st }
            else unify-mismatch st a b
          if _ -> unify-mismatch st a b
        if _ -> unify-mismatch st a b

    unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> UnifyResult
    unify-fun (st) (pa) (ra) (pb) (rb) =
      let r1 = unify st pa pb
      in if r1.success then unify r1.state ra rb
         else r1

    unify-mismatch : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-mismatch (st) (a) (b) =
      UnifyResult { success = False, state = add-unify-error st "CDX2001" "Type mismatch" }

Section: Deep Resolve

    deep-resolve : UnificationState -> CodexType -> CodexType
    deep-resolve (st) (ty) =
      let resolved = resolve st ty
      in when resolved
        if FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
        if ListTy (elem) -> ListTy (deep-resolve st elem)
        if ForAllTy (id) (body) -> deep-resolve st body
        if _ -> resolved
