Chapter: Lowering Types

 Type lookup, substitution, and constructor binding utilities
 used by the main lowering pass.

Section: Type Lookup

  lookup-type : List TypeBinding -> Text -> CodexType
  lookup-type (bindings) (name) =
   lookup-type-loop bindings name 0 (list-length bindings)

  lookup-type-loop : List TypeBinding -> Text -> Integer -> Integer -> CodexType
  lookup-type-loop (bindings) (name) (i) (len) =
   if i == len then ErrorTy
   else
    let b = list-at bindings i
    in if b.name == name then b.bound-type
     else lookup-type-loop bindings name (i + 1) len

  peel-fun-param : CodexType -> CodexType
  peel-fun-param (ty) =
   when ty
    if FunTy (p) (r) -> p
    if ForAllTy (id) (body) -> peel-fun-param body
    if _ -> ErrorTy

  peel-fun-return : CodexType -> CodexType
  peel-fun-return (ty) =
   when ty
    if FunTy (p) (r) -> r
    if ForAllTy (id) (body) -> peel-fun-return body
    if _ -> ErrorTy

  strip-forall-ty : CodexType -> CodexType
  strip-forall-ty (ty) =
   when ty
    if ForAllTy (id) (body) -> strip-forall-ty body
    if _ -> ty

Section: Type Substitution

  subst-type-vars-from-arg : CodexType -> CodexType -> CodexType -> CodexType
  subst-type-vars-from-arg (param-ty) (arg-ty) (target) =
   when param-ty
    if TypeVar (id) -> subst-type-var-in-target target id arg-ty
    if ListTy (pe) -> subst-from-list pe arg-ty target
    if FunTy (pp) (pr) -> subst-from-fun pp pr arg-ty target
    if _ -> target

  subst-from-list : CodexType -> CodexType -> CodexType -> CodexType
  subst-from-list (pe) (arg-ty) (target) =
   when arg-ty
    if ListTy (ae) -> subst-type-vars-from-arg pe ae target
    if _ -> target

  subst-from-fun : CodexType -> CodexType -> CodexType -> CodexType -> CodexType
  subst-from-fun (pp) (pr) (arg-ty) (target) =
   when arg-ty
    if FunTy (ap) (ar) ->
     let t2 = subst-type-vars-from-arg pp ap target
     in subst-type-vars-from-arg pr ar t2
    if _ -> target

  subst-type-var-in-target : CodexType -> Integer -> CodexType -> CodexType
  subst-type-var-in-target (ty) (var-id) (replacement) =
   when ty
    if TypeVar (id) -> if id == var-id then replacement else ty
    if FunTy (p) (r) -> FunTy (subst-type-var-in-target p var-id replacement) (subst-type-var-in-target r var-id replacement)
    if ListTy (elem) -> ListTy (subst-type-var-in-target elem var-id replacement)
    if ForAllTy (fid) (body) ->
     if fid == var-id then ty
     else ForAllTy fid (subst-type-var-in-target body var-id replacement)
    if _ -> ty

  strip-fun-args-lower : CodexType -> CodexType
  strip-fun-args-lower (ty) =
   when ty
    if FunTy (p) (r) -> strip-fun-args-lower r
    if ForAllTy (id) (body) -> strip-fun-args-lower body
    if _ -> ty

  is-text-type : CodexType -> Boolean
  is-text-type (ty) =
   when ty
    if TextTy -> True
    if _ -> False

Section: Constructor Bindings

  collect-ctor-bindings : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  collect-ctor-bindings (tdefs) (i) (len) (acc) =
   if i == len then acc
   else
    let td = list-at tdefs i
    in let bindings = ctor-bindings-for-typedef td
    in collect-ctor-bindings tdefs (i + 1) len (acc ++ bindings)

  ctor-bindings-for-typedef : ATypeDef -> List TypeBinding
  ctor-bindings-for-typedef (td) =
   when td
    if AVariantTypeDef (name) (type-params) (ctors) ->
     let result-ty = ConstructedTy name []
     in collect-variant-ctor-bindings ctors result-ty 0 (list-length ctors) []
    if ARecordTypeDef (name) (type-params) (fields) ->
     let resolved-fields = build-record-fields fields 0 (list-length fields) []
     in let result-ty = RecordTy name resolved-fields
     in let ctor-ty = build-record-ctor-type fields result-ty 0 (list-length fields)
     in [TypeBinding { name = name.value, bound-type = ctor-ty }]

  collect-variant-ctor-bindings : List AVariantCtorDef -> CodexType -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  collect-variant-ctor-bindings (ctors) (result-ty) (i) (len) (acc) =
   if i == len then acc
   else
    let ctor = list-at ctors i
    in let ctor-ty = build-ctor-type (ctor.fields) result-ty 0 (list-length (ctor.fields))
    in collect-variant-ctor-bindings ctors result-ty (i + 1) len (list-snoc acc (TypeBinding { name = ctor.name.value, bound-type = ctor-ty }))

  build-ctor-type : List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
  build-ctor-type (fields) (result) (i) (len) =
   if i == len then result
   else
    let rest = build-ctor-type fields result (i + 1) len
    in FunTy (resolve-type-expr (list-at fields i)) rest

  build-record-fields : List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
  build-record-fields (fields) (i) (len) (acc) =
   if i == len then acc
   else
    let f = list-at fields i
    in let rfield = RecordField { name = f.name, type-val = resolve-type-expr (f.type-expr) }
    in build-record-fields fields (i + 1) len (list-snoc acc rfield)

  build-record-ctor-type : List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
  build-record-ctor-type (fields) (result) (i) (len) =
   if i == len then result
   else
    let f = list-at fields i
    in let rest = build-record-ctor-type fields result (i + 1) len
    in FunTy (resolve-type-expr (f.type-expr)) rest

  resolve-type-expr : ATypeExpr -> CodexType
  resolve-type-expr (texpr) =
   when texpr
    if ANamedType (name) ->
     if name.value == "Integer" then IntegerTy
     else if name.value == "Number" then NumberTy
     else if name.value == "Text" then TextTy
     else if name.value == "Boolean" then BooleanTy
     else if name.value == "Nothing" then NothingTy
     else ConstructedTy name []
    if AFunType (param) (ret) -> FunTy (resolve-type-expr param) (resolve-type-expr ret)
    if AAppType (ctor) (args) ->
     when ctor
      if ANamedType (cname) ->
       if cname.value == "List"
        then if list-length args == 1
         then ListTy (resolve-type-expr (list-at args 0))
         else ListTy ErrorTy
        else ConstructedTy cname []
      if _ -> ErrorTy

Section: Binary Op Lowering

  lower-bin-op : BinaryOp -> CodexType -> IRBinaryOp
  lower-bin-op (op) (ty) =
   when op
    if OpAdd -> IrAddInt
    if OpSub -> IrSubInt
    if OpMul -> IrMulInt
    if OpDiv -> IrDivInt
    if OpPow -> IrPowInt
    if OpEq -> IrEq
    if OpNotEq -> IrNotEq
    if OpLt -> IrLt
    if OpGt -> IrGt
    if OpLtEq -> IrLtEq
    if OpGtEq -> IrGtEq
    if OpDefEq -> IrEq
    if OpAppend -> if is-text-type ty then IrAppendText else IrAppendList
    if OpCons -> IrConsList
    if OpAnd -> IrAnd
    if OpOr -> IrOr

  binary-result-type : BinaryOp -> CodexType -> CodexType -> CodexType
  binary-result-type (op) (left-ty) (expected-ty) =
   when op
    if OpEq -> BooleanTy
    if OpNotEq -> BooleanTy
    if OpLt -> BooleanTy
    if OpGt -> BooleanTy
    if OpLtEq -> BooleanTy
    if OpGtEq -> BooleanTy
    if OpDefEq -> BooleanTy
    if OpAnd -> BooleanTy
    if OpOr -> BooleanTy
    if OpAppend -> if is-text-type left-ty then TextTy
           else if is-text-type expected-ty then TextTy
           else left-ty
    if _ -> left-ty
