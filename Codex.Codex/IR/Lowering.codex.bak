Chapter: Lowering

  Transforms the typed AST into the intermediate representation.
  Each AST expression is lowered to an IR expression that carries
  its resolved type.

Section: Type Lookup

    lookup-type : List TypeBinding -> Text -> CodexType
    lookup-type (bindings) (name) =
      lookup-type-loop bindings name 0 (list-length bindings)

    lookup-type-loop : List TypeBinding -> Text -> Integer -> Integer -> CodexType
    lookup-type-loop (bindings) (name) (i) (len) =
      if i == len then ErrorTy
      else
        let b = list-at bindings i
        in if b.name == name then b.bound-type
           else lookup-type-loop bindings name (i + 1) len

    peel-fun-param : CodexType -> CodexType
    peel-fun-param (ty) =
      when ty
        if FunTy (p) (r) -> p
        if ForAllTy (id) (body) -> peel-fun-param body
        if _ -> ErrorTy

    peel-fun-return : CodexType -> CodexType
    peel-fun-return (ty) =
      when ty
        if FunTy (p) (r) -> r
        if ForAllTy (id) (body) -> peel-fun-return body
        if _ -> ErrorTy

    strip-forall-ty : CodexType -> CodexType
    strip-forall-ty (ty) =
      when ty
        if ForAllTy (id) (body) -> strip-forall-ty body
        if _ -> ty

Section: Binary Op Lowering

    lower-bin-op : BinaryOp -> CodexType -> IRBinaryOp
    lower-bin-op (op) (ty) =
      when op
        if OpAdd -> IrAddInt
        if OpSub -> IrSubInt
        if OpMul -> IrMulInt
        if OpDiv -> IrDivInt
        if OpPow -> IrPowInt
        if OpEq -> IrEq
        if OpNotEq -> IrNotEq
        if OpLt -> IrLt
        if OpGt -> IrGt
        if OpLtEq -> IrLtEq
        if OpGtEq -> IrGtEq
        if OpDefEq -> IrEq
        if OpAppend -> IrAppendList
        if OpCons -> IrConsList
        if OpAnd -> IrAnd
        if OpOr -> IrOr

Section: Expression Lowering

    lower-expr : AExpr -> CodexType -> IRExpr
    lower-expr (e) (ty) =
      when e
        if ALitExpr (text) (kind) -> lower-literal text kind
        if ANameExpr (name) -> IrName name.value ty
        if AApplyExpr (f) (a) -> lower-apply f a ty
        if ABinaryExpr (l) (op) (r) -> IrBinary (lower-bin-op op ty) (lower-expr l ty) (lower-expr r ty) ty
        if AUnaryExpr (operand) -> IrNegate (lower-expr operand IntegerTy)
        if AIfExpr (c) (t) (e2) -> IrIf (lower-expr c BooleanTy) (lower-expr t ty) (lower-expr e2 ty) ty
        if ALetExpr (binds) (body) -> lower-let binds body ty
        if ALambdaExpr (params) (body) -> lower-lambda params body ty
        if AMatchExpr (scrut) (arms) -> lower-match scrut arms ty
        if AListExpr (elems) -> lower-list elems ty
        if ARecordExpr (name) (fields) -> lower-record name fields ty
        if AFieldAccess (rec) (field) -> IrFieldAccess (lower-expr rec ty) field.value ty
        if ADoExpr (stmts) -> lower-do stmts ty
        if AErrorExpr (msg) -> IrError msg ty

    lower-literal : Text -> LiteralKind -> IRExpr
    lower-literal (text) (kind) =
      when kind
        if IntLit -> IrIntLit (text-to-integer text)
        if NumLit -> IrIntLit (text-to-integer text)
        if TextLit -> IrTextLit text
        if BoolLit -> IrBoolLit (text == "True")

    lower-apply : AExpr -> AExpr -> CodexType -> IRExpr
    lower-apply (f) (a) (ty) =
      IrApply (lower-expr f ty) (lower-expr a ty) ty

    lower-let : List ALetBind -> AExpr -> CodexType -> IRExpr
    lower-let (binds) (body) (ty) =
      if list-length binds == 0 then lower-expr body ty
      else let b = list-at binds 0
        in IrLet b.name.value ty (lower-expr b.value ErrorTy) (lower-let-rest binds body ty 1)

    lower-let-rest : List ALetBind -> AExpr -> CodexType -> Integer -> IRExpr
    lower-let-rest (binds) (body) (ty) (i) =
      if i == list-length binds then lower-expr body ty
      else let b = list-at binds i
        in IrLet b.name.value ty (lower-expr b.value ErrorTy) (lower-let-rest binds body ty (i + 1))

    lower-lambda : List Name -> AExpr -> CodexType -> IRExpr
    lower-lambda (params) (body) (ty) =
      let stripped = strip-forall-ty ty
      in IrLambda (lower-lambda-params params stripped 0) (lower-expr body (get-lambda-return stripped (list-length params))) ty

    lower-lambda-params : List Name -> CodexType -> Integer -> List IRParam
    lower-lambda-params (params) (ty) (i) =
      if i == list-length params then []
      else let p = list-at params i
        in let param-ty = peel-fun-param ty
        in let rest-ty = peel-fun-return ty
        in [IRParam { name = p.value, type-val = param-ty }] ++ lower-lambda-params params rest-ty (i + 1)

    get-lambda-return : CodexType -> Integer -> CodexType
    get-lambda-return (ty) (n) =
      if n == 0 then ty
      else when ty
        if FunTy (p) (r) -> get-lambda-return r (n - 1)
        if _ -> ErrorTy

    lower-match : AExpr -> List AMatchArm -> CodexType -> IRExpr
    lower-match (scrut) (arms) (ty) =
      IrMatch (lower-expr scrut ty) (map-list (lower-arm ty) arms) ty

    lower-arm : CodexType -> AMatchArm -> IRBranch
    lower-arm (ty) (arm) =
      IRBranch { pattern = lower-pattern arm.pattern, body = lower-expr arm.body ty }

    lower-pattern : APat -> IRPat
    lower-pattern (p) =
      when p
        if AVarPat (name) -> IrVarPat name.value ErrorTy
        if ALitPat (text) (kind) -> IrLitPat text ErrorTy
        if ACtorPat (name) (subs) -> IrCtorPat name.value (map-list lower-pattern subs) ErrorTy
        if AWildPat -> IrWildPat

    lower-list : List AExpr -> CodexType -> IRExpr
    lower-list (elems) (ty) =
      let elem-ty = when ty
            if ListTy (e) -> e
            if _ -> ErrorTy
      in IrList (map-list (lower-elem elem-ty) elems) elem-ty

    lower-elem : CodexType -> AExpr -> IRExpr
    lower-elem (ty) (e) = lower-expr e ty

    lower-record : Name -> List AFieldExpr -> CodexType -> IRExpr
    lower-record (name) (fields) (ty) =
      IrRecord name.value (map-list (lower-field-val ty) fields) ty

    lower-field-val : CodexType -> AFieldExpr -> IRFieldVal
    lower-field-val (ty) (f) =
      IRFieldVal { name = f.name.value, value = lower-expr f.value ty }

    lower-do : List ADoStmt -> CodexType -> IRExpr
    lower-do (stmts) (ty) =
      IrDo (map-list (lower-do-stmt ty) stmts) ty

    lower-do-stmt : CodexType -> ADoStmt -> IRDoStmt
    lower-do-stmt (ty) (s) =
      when s
        if ADoBindStmt (name) (val) -> IrDoBind name.value ty (lower-expr val ty)
        if ADoExprStmt (e) -> IrDoExec (lower-expr e ty)

Section: Definition Lowering

    lower-def : ADef -> List TypeBinding -> UnificationState -> IRDef
    lower-def (d) (types) (ust) =
      let raw-type = lookup-type types d.name.value
      in let full-type = deep-resolve ust raw-type
      in let stripped = strip-forall-ty full-type
      in let params = lower-def-params d.params stripped 0
      in let ret-type = get-return-type-n stripped (list-length d.params)
      in IRDef { name = d.name.value, params = params, type-val = full-type, body = lower-expr d.body ret-type }

    lower-def-params : List AParam -> CodexType -> Integer -> List IRParam
    lower-def-params (params) (ty) (i) =
      if i == list-length params then []
      else let p = list-at params i
        in let param-ty = peel-fun-param ty
        in let rest-ty = peel-fun-return ty
        in [IRParam { name = p.name.value, type-val = param-ty }] ++ lower-def-params params rest-ty (i + 1)

    get-return-type-n : CodexType -> Integer -> CodexType
    get-return-type-n (ty) (n) =
      if n == 0 then ty
      else when ty
        if FunTy (p) (r) -> get-return-type-n r (n - 1)
        if _ -> ErrorTy

    lower-module : AModule -> List TypeBinding -> UnificationState -> IRModule
    lower-module (m) (types) (ust) =
      IRModule { name = m.name, defs = lower-defs m.defs types ust 0 }

    lower-defs : List ADef -> List TypeBinding -> UnificationState -> Integer -> List IRDef
    lower-defs (defs) (types) (ust) (i) =
      if i == list-length defs then []
      else [lower-def (list-at defs i) types ust] ++ lower-defs defs types ust (i + 1)
