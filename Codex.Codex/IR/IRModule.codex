Chapter: IR Module

 The intermediate representation sits between the typed AST and code
 emission. Every node carries its resolved type.

Section: IR Expressions

  IRBinaryOp =
   | IrAddInt | IrSubInt | IrMulInt | IrDivInt | IrPowInt
   | IrAddNum | IrSubNum | IrMulNum | IrDivNum
   | IrEq | IrNotEq | IrLt | IrGt | IrLtEq | IrGtEq
   | IrAnd | IrOr
   | IrAppendText | IrAppendList
   | IrConsList

  IRExpr =
   | IrIntLit (Integer)
   | IrNumLit (Integer)
   | IrTextLit (Text)
   | IrBoolLit (Boolean)
   | IrName (Text) (CodexType)
   | IrBinary (IRBinaryOp) (IRExpr) (IRExpr) (CodexType)
   | IrNegate (IRExpr)
   | IrIf (IRExpr) (IRExpr) (IRExpr) (CodexType)
   | IrLet (Text) (CodexType) (IRExpr) (IRExpr)
   | IrApply (IRExpr) (IRExpr) (CodexType)
   | IrLambda (List IRParam) (IRExpr) (CodexType)
   | IrList (List IRExpr) (CodexType)
   | IrMatch (IRExpr) (List IRBranch) (CodexType)
   | IrDo (List IRDoStmt) (CodexType)
   | IrHandle (Text) (IRExpr) (List IRHandleClause) (CodexType)
   | IrRecord (Text) (List IRFieldVal) (CodexType)
   | IrFieldAccess (IRExpr) (Text) (CodexType)
   | IrFork (IRExpr) (CodexType)
   | IrAwait (IRExpr) (CodexType)
   | IrError (Text) (CodexType)

  IRParam = record {
   name : Text,
   type-val : CodexType
  }

  IRBranch = record {
   pattern : IRPat,
   body : IRExpr
  }

  IRPat =
   | IrVarPat (Text) (CodexType)
   | IrLitPat (Text) (CodexType)
   | IrCtorPat (Text) (List IRPat) (CodexType)
   | IrWildPat

  IRDoStmt =
   | IrDoBind (Text) (CodexType) (IRExpr)
   | IrDoExec (IRExpr)

  IRHandleClause = record {
   op-name : Text,
   resume-name : Text,
   body : IRExpr
  }

  IRFieldVal = record {
   name : Text,
   value : IRExpr
  }

Section: IR Definitions

  IRDef = record {
   name : Text,
   params : List IRParam,
   type-val : CodexType,
   body : IRExpr
  }

  IRModule = record {
   name : Name,
   defs : List IRDef
  }

Section: IR Expression Type

  ir-expr-type : IRExpr -> CodexType
  ir-expr-type (e) =
   when e
    if IrIntLit (v) -> IntegerTy
    if IrNumLit (v) -> IntegerTy
    if IrTextLit (v) -> TextTy
    if IrBoolLit (v) -> BooleanTy
    if IrName (n) (t) -> t
    if IrBinary (op) (l) (r) (t) -> t
    if IrNegate (x) -> IntegerTy
    if IrIf (c) (th) (el) (t) -> t
    if IrLet (n) (t) (v) (b) -> ir-expr-type b
    if IrApply (f) (a) (t) -> t
    if IrLambda (ps) (b) (t) -> t
    if IrList (es) (t) -> ListTy t
    if IrMatch (s) (bs) (t) -> t
    if IrDo (ss) (t) -> t
    if IrHandle (eff) (h) (cs) (t) -> t
    if IrRecord (n) (fs) (t) -> t
    if IrFieldAccess (r) (f) (t) -> t
    if IrFork (body) (t) -> t
    if IrAwait (task) (t) -> t
    if IrError (m) (t) -> t
