Chapter: Parser

 The parser transforms a flat token list into a concrete syntax tree.
 It is a recursive descent parser threading state through pure functions.

 Rule: no when-expression may contain another when-expression in a
 non-final branch body, because the Stage 0 parser greedily consumes
 if-branches without checking indentation.

Section: Type Parsing

  parse-type : ParseState -> ParseTypeResult
  parse-type (st) =
   let result = parse-type-atom st
   in unwrap-type-ok result parse-type-continue

  parse-type-continue : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-continue (left) (st) =
   if is-arrow (current-kind st) then let st2 = advance st
     in let right-result = parse-type st2
      in unwrap-type-ok right-result (make-fun-type left)
    else TypeOk left st

  make-fun-type : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  make-fun-type (left) (right) (st) =
   TypeOk (FunType left right) st

  unwrap-type-ok : ParseTypeResult -> (TypeExpr -> ParseState -> ParseTypeResult) -> ParseTypeResult
  unwrap-type-ok (r) (f) =
   when r
    if TypeOk (t) (st) -> f t st

  parse-type-atom : ParseState -> ParseTypeResult
  parse-type-atom (st) =
   if is-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-left-paren (current-kind st) then parse-paren-type (advance st)
   else if is-left-bracket (current-kind st) then parse-effect-type (advance st)
       else let tok = current st
        in TypeOk (NamedType tok) (advance st)

  parse-paren-type : ParseState -> ParseTypeResult
  parse-paren-type (st) =
   let inner = parse-type st
   in unwrap-type-ok inner finish-paren-type

  finish-paren-type : TypeExpr -> ParseState -> ParseTypeResult
  finish-paren-type (t) (st) =
   let st2 = expect RightParen st
   in TypeOk (ParenType t) st2

  parse-effect-type : ParseState -> ParseTypeResult
  parse-effect-type (st) =
   let st2 = skip-effect-contents st
   in parse-type st2

  skip-effect-contents : ParseState -> ParseState
  skip-effect-contents (st) =
   if is-done st then st
   else if is-right-bracket (current-kind st) then advance st
   else skip-effect-contents (advance st)

  parse-type-args : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-args (base-type) (st) =
   if is-done st then TypeOk base-type st
   else if is-type-arg-start (current-kind st) then parse-type-arg-next base-type st
   else TypeOk base-type st

  parse-type-arg-next : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-arg-next (base-type) (st) =
   let arg-result = parse-type-atom st
   in unwrap-type-ok arg-result (continue-type-args base-type)

  continue-type-args : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  continue-type-args (base-type) (arg) (st) =
   parse-type-args (AppType base-type [arg]) st

Section: Pattern Parsing

  parse-pattern : ParseState -> ParsePatResult
  parse-pattern (st) =
   if is-underscore (current-kind st) then PatOk (WildPat (current st)) (advance st)
   else if is-literal (current-kind st) then PatOk (LitPat (current st)) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
       in parse-ctor-pattern-fields tok [] (advance st)
   else if is-ident (current-kind st) then PatOk (VarPat (current st)) (advance st)
       else PatOk (WildPat (current st)) (advance st)

  parse-ctor-pattern-fields : Token -> List Pat -> ParseState -> ParsePatResult
  parse-ctor-pattern-fields (ctor) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
     in let sub = parse-pattern st2
      in unwrap-pat-ok sub (continue-ctor-fields ctor acc)
    else PatOk (CtorPat ctor acc) st

  continue-ctor-fields : Token -> List Pat -> Pat -> ParseState -> ParsePatResult
  continue-ctor-fields (ctor) (acc) (p) (st) =
   let st2 = expect RightParen st
   in parse-ctor-pattern-fields ctor (list-snoc acc p) st2

  unwrap-pat-ok : ParsePatResult -> (Pat -> ParseState -> ParsePatResult) -> ParsePatResult
  unwrap-pat-ok (r) (f) =
   when r
    if PatOk (p) (st) -> f p st

Section: Definition Parsing

  parse-type-annotation : ParseState -> ParseTypeResult
  parse-type-annotation (st) =
   let st2 = advance st
   in let st3 = expect Colon st2
   in parse-type st3

  parse-definition : ParseState -> ParseDefResult
  parse-definition (st) =
   if is-done st then DefNone st
   else if is-ident (current-kind st) then try-parse-def st
   else if is-type-ident (current-kind st) then try-parse-def st
     else DefNone st

  try-parse-def : ParseState -> ParseDefResult
  try-parse-def (st) =
   if is-colon (peek-kind st 1) then let ann-result = parse-type-annotation st
     in unwrap-type-for-def ann-result
    else parse-def-body-with-ann [] st

  unwrap-type-for-def : ParseTypeResult -> ParseDefResult
  unwrap-type-for-def (r) =
   when r
    if TypeOk (ann-type) (st) ->
     let name-tok = Token {
      kind = Identifier,
      text = "",
      offset = 0,
      line = 0,
      column = 0
     }
     in let ann = [TypeAnn {
      name = name-tok,
      type-expr = ann-type
     }]
      in let st2 = skip-newlines st
       in parse-def-body-with-ann ann st2

  parse-def-body-with-ann : List TypeAnn -> ParseState -> ParseDefResult
  parse-def-body-with-ann (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in parse-def-params-then ann name-tok [] st2

  parse-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  parse-def-params-then (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
   in if is-ident (current-kind st2) then let param = current st2
       in let st3 = advance st2
        in let st4 = expect RightParen st3
         in parse-def-params-then ann name-tok (list-snoc acc param) st4
      else finish-def ann name-tok acc st
    else finish-def ann name-tok acc st

  finish-def : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  finish-def (ann) (name-tok) (params) (st) =
   let st2 = expect Equals st
   in let st3 = skip-newlines st2
   in let body-result = parse-expr st3
     in unwrap-def-body body-result ann name-tok params

  unwrap-def-body : ParseExprResult -> List TypeAnn -> Token -> List Token -> ParseDefResult
  unwrap-def-body (r) (ann) (name-tok) (params) =
   when r
    if ExprOk (b) (st) ->
     DefOk (Def {
      name = name-tok,
      params = params,
      ann = ann,
      body = b
     }) st

Section: Type Definition Parsing

  is-paren-type-param : ParseState -> Boolean
  is-paren-type-param (st) =
   if is-left-paren (current-kind st) then let k1 = peek-kind st 1
   in if is-ident k1 then is-right-paren (peek-kind st 2)
      else if is-type-ident k1 then is-right-paren (peek-kind st 2)
      else False
    else False

  is-type-param-pattern : ParseState -> Boolean
  is-type-param-pattern (st) =
   if is-paren-type-param st then True
   else is-ident (current-kind st)

  parse-type-params : ParseState -> List Token -> ParseState
  parse-type-params (st) (acc) =
   if is-paren-type-param st then parse-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then parse-type-params (advance st) (list-snoc acc (current st))
   else st

  collect-type-params : ParseState -> List Token -> List Token
  collect-type-params (st) (acc) =
   if is-paren-type-param st then collect-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then collect-type-params (advance st) (list-snoc acc (current st))
   else acc

  parse-type-def : ParseState -> ParseTypeDefResult
  parse-type-def (st) =
   if is-type-ident (current-kind st) then let name-tok = current st
     in let st2 = advance st
      in let tparams = collect-type-params st2 []
       in let st3 = parse-type-params st2 []
        in if is-equals (current-kind st3) then let st4 = skip-newlines (advance st3)
         in if is-record-keyword (current-kind st4) then parse-record-type name-tok tparams st4
            else if is-pipe (current-kind st4) then parse-variant-type name-tok tparams st4
            else if is-type-ident (current-kind st4) & looks-like-variant st4 then parse-variant-type name-tok tparams st4
            else TypeDefNone st
         else TypeDefNone st
    else TypeDefNone st

  parse-record-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-record-type (name-tok) (tparams) (st) =
   let st2 = advance st
   in let st3 = expect LeftBrace st2
   in let st4 = skip-newlines st3
     in parse-record-fields-loop name-tok tparams [] st4

  parse-record-fields-loop : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-record-fields-loop (name-tok) (tparams) (acc) (st) =
   if is-right-brace (current-kind st) then TypeDefOk (TypeDef {
    name = name-tok,
    type-params = tparams,
    body = RecordBody acc
   }) (advance st)
   else if is-ident (current-kind st) then parse-one-record-field name-tok tparams acc st
     else TypeDefOk (TypeDef {
    name = name-tok,
    type-params = tparams,
    body = RecordBody acc
   }) st

  parse-one-record-field : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-one-record-field (name-tok) (tparams) (acc) (st) =
   let field-name = current st
   in let st2 = advance st
   in let st3 = expect Colon st2
     in let field-type-result = parse-type st3
      in unwrap-record-field-type name-tok tparams acc field-name field-type-result

  unwrap-record-field-type : Token -> List Token -> List RecordFieldDef -> Token -> ParseTypeResult -> ParseTypeDefResult
  unwrap-record-field-type (name-tok) (tparams) (acc) (field-name) (r) =
   when r
    if TypeOk (ft) (st) ->
     let field = RecordFieldDef {
      name = field-name,
      type-expr = ft
     }
     in let st2 = skip-newlines st
      in if is-comma (current-kind st2) then parse-record-fields-loop name-tok tparams (list-snoc acc field) (skip-newlines (advance st2))
         else parse-record-fields-loop name-tok tparams (list-snoc acc field) st2

  looks-like-variant : ParseState -> Boolean
  looks-like-variant (st) =
   looks-like-variant-scan (st.tokens) (st.pos + 1) (list-length (st.tokens))

  looks-like-variant-scan : List Token -> Integer -> Integer -> Boolean
  looks-like-variant-scan (tokens) (i) (len) =
   if i >= len then False
   else let k = (list-at tokens i).kind
   in if is-pipe k then True
      else when k
      if Newline -> False
      if EndOfFile -> False
      if _ -> looks-like-variant-scan tokens (i + 1) len

  parse-variant-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-variant-type (name-tok) (tparams) (st) =
   if is-type-ident (current-kind st) then let ctor-name = current st
     in let st2 = advance st
      in parse-ctor-fields ctor-name [] st2 name-tok tparams []
    else parse-variant-ctors name-tok tparams [] st

  parse-variant-ctors : Token -> List Token -> List VariantCtorDef -> ParseState -> ParseTypeDefResult
  parse-variant-ctors (name-tok) (tparams) (acc) (st) =
   if is-pipe (current-kind st) then let st2 = skip-newlines (advance st)
     in let ctor-name = current st2
      in let st3 = advance st2
       in parse-ctor-fields ctor-name [] st3 name-tok tparams acc
    else TypeDefOk (TypeDef {
     name = name-tok,
     type-params = tparams,
     body = VariantBody acc
    }) st

  parse-ctor-fields : Token -> List TypeExpr -> ParseState -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  parse-ctor-fields (ctor-name) (fields) (st) (name-tok) (tparams) (acc) =
   if is-left-paren (current-kind st) then let field-result = parse-type (advance st)
     in unwrap-ctor-field field-result ctor-name fields name-tok tparams acc
    else let st2 = skip-newlines st
     in let ctor = VariantCtorDef {
      name = ctor-name,
      fields = fields
     }
      in parse-variant-ctors name-tok tparams (list-snoc acc ctor) st2

  unwrap-ctor-field : ParseTypeResult -> Token -> List TypeExpr -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  unwrap-ctor-field (r) (ctor-name) (fields) (name-tok) (tparams) (acc) =
   when r
    if TypeOk (ty) (st) ->
     let st2 = expect RightParen st
      in parse-ctor-fields ctor-name (fields ++ [ty]) st2 name-tok tparams acc

Section: Document Parsing

  parse-document : ParseState -> Document
  parse-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-imports st2 []
   in parse-top-level [] [] [] (imp-result.imports) (imp-result.state)

  parse-imports : ParseState -> List ImportDecl -> ImportParseResult
  parse-imports (st) (acc) =
   if is-import-keyword (current-kind st) then let st2 = advance st
     in let name-tok = current st2
      in let st3 = advance st2
       in if is-left-paren (current-kind st3) then let sel = parse-selected-names (advance st3) []
         in let st4 = skip-newlines (sel.state)
          in parse-imports st4 (list-snoc acc (ImportDecl {
           module-name = name-tok,
           selected-names = sel.names
          }))
        else let st4 = skip-newlines st3
         in parse-imports st4 (list-snoc acc (ImportDecl {
          module-name = name-tok,
          selected-names = []
         }))
    else ImportParseResult {
     imports = acc,
     state = st
    }

  SelectedNamesResult = record { names : List Token, state : ParseState }

  parse-selected-names : ParseState -> List Token -> SelectedNamesResult
  parse-selected-names (st) (acc) =
   if is-ident (current-kind st) then let tok = current st
     in let st2 = advance st
      in if is-comma (current-kind st2) then parse-selected-names (skip-newlines (advance st2)) (list-snoc acc tok)
         else SelectedNamesResult {
          names = list-snoc acc tok,
          state = st2
         }
    else if is-right-paren (current-kind st) then SelectedNamesResult {
     names = acc,
     state = advance st
    }
    else SelectedNamesResult {
     names = acc,
     state = st
    }

  ImportParseResult = record { imports : List ImportDecl, state : ParseState }

  parse-top-level : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
  parse-top-level (defs) (type-defs) (effect-defs) (imports) (st) =
   if is-done st then Document {
    defs = defs,
    type-defs = type-defs,
    effect-defs = effect-defs,
    imports = imports
   }
   else if is-effect-keyword (current-kind st) then parse-top-level-effect defs type-defs effect-defs imports st
   else try-top-level-type-def defs type-defs effect-defs imports st

  parse-top-level-effect : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
  parse-top-level-effect (defs) (type-defs) (effect-defs) (imports) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
     in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
      in let ops = parse-effect-ops st3 []
       in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
        in parse-top-level defs type-defs (effect-defs ++ [ed]) imports (skip-newlines (ops.state))

  EffectOpsResult = record { ops : List EffectOpDef, state : ParseState }

  parse-effect-ops : ParseState -> List EffectOpDef -> EffectOpsResult
  parse-effect-ops (st) (acc) =
   if is-ident (current-kind st) then if is-colon (peek-kind st 1) then let op-tok = current st
      in let st2 = advance (advance st)
       in let type-result = parse-type st2
        in when type-result
         if TypeOk (ty) (st3) ->
          let op = EffectOpDef {
           name = op-tok,
           type-expr = ty
          }
          in parse-effect-ops (skip-newlines st3) (list-snoc acc op)
     else EffectOpsResult {
      ops = acc,
      state = st
     }
    else EffectOpsResult {
     ops = acc,
     state = st
    }

  try-top-level-type-def : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
  try-top-level-type-def (defs) (type-defs) (effect-defs) (imports) (st) =
   let td-result = parse-type-def st
   in when td-result
    if TypeDefOk (td) (st2) ->
     parse-top-level defs (type-defs ++ [td]) effect-defs imports (skip-newlines st2)
    if TypeDefNone (st2) ->
     try-top-level-def defs type-defs effect-defs imports st

  try-top-level-def : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
  try-top-level-def (defs) (type-defs) (effect-defs) (imports) (st) =
   let def-result = parse-definition st
   in when def-result
    if DefOk (d) (st2) ->
     parse-top-level (defs ++ [d]) type-defs effect-defs imports (skip-newlines st2)
    if DefNone (st2) ->
     parse-top-level defs type-defs effect-defs imports (skip-newlines (advance st2))

Section: Header Scanning (Phase 2 streaming)

 Scans the token stream collecting definition headers (name, params,
 type annotation, body token position) without parsing def bodies.
 Type defs and effect defs are fully parsed (they are small).

  scan-document : ParseState -> ScanResult
  scan-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-imports st2 []
   in scan-top-level [] [] [] (imp-result.imports) (imp-result.state)

  scan-top-level : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
  scan-top-level (headers) (type-defs) (effect-defs) (imports) (st) =
   if is-done st then ScanResult {
    type-defs = type-defs,
    effect-defs = effect-defs,
    def-headers = headers,
    imports = imports
   }
   else if is-effect-keyword (current-kind st) then scan-top-level-effect headers type-defs effect-defs imports st
   else try-scan-type-def headers type-defs effect-defs imports st

  scan-top-level-effect : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
  scan-top-level-effect (headers) (type-defs) (effect-defs) (imports) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
     in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
      in let ops = parse-effect-ops st3 []
       in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
        in scan-top-level headers type-defs (effect-defs ++ [ed]) imports (skip-newlines (ops.state))

  try-scan-type-def : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
  try-scan-type-def (headers) (type-defs) (effect-defs) (imports) (st) =
   let td-result = parse-type-def st
   in when td-result
    if TypeDefOk (td) (st2) ->
     scan-top-level headers (type-defs ++ [td]) effect-defs imports (skip-newlines st2)
    if TypeDefNone (st2) ->
     try-scan-def-header headers type-defs effect-defs imports st

  try-scan-def-header : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
  try-scan-def-header (headers) (type-defs) (effect-defs) (imports) (st) =
   let hdr-result = scan-definition st
   in when hdr-result
    if DefHeaderOk (hdr) (st2) ->
     scan-top-level (headers ++ [hdr]) type-defs effect-defs imports (skip-newlines st2)
    if DefHeaderNone (st2) ->
     scan-top-level headers type-defs effect-defs imports (skip-newlines (advance st2))

  scan-definition : ParseState -> ScanDefResult
  scan-definition (st) =
   if is-done st then DefHeaderNone st
   else if is-ident (current-kind st) then try-scan-def st
   else if is-type-ident (current-kind st) then try-scan-def st
     else DefHeaderNone st

  try-scan-def : ParseState -> ScanDefResult
  try-scan-def (st) =
   if is-colon (peek-kind st 1) then let ann-result = parse-type-annotation st
     in unwrap-type-for-scan ann-result
    else scan-def-body-with-ann [] st

  unwrap-type-for-scan : ParseTypeResult -> ScanDefResult
  unwrap-type-for-scan (r) =
   when r
    if TypeOk (ann-type) (st) ->
     let name-tok = Token {
      kind = Identifier,
      text = "",
      offset = 0,
      line = 0,
      column = 0
     }
     in let ann = [TypeAnn {
      name = name-tok,
      type-expr = ann-type
     }]
      in let st2 = skip-newlines st
       in scan-def-body-with-ann ann st2

  scan-def-body-with-ann : List TypeAnn -> ParseState -> ScanDefResult
  scan-def-body-with-ann (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in scan-def-params-then ann name-tok [] st2

  scan-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  scan-def-params-then (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
   in if is-ident (current-kind st2) then let param = current st2
       in let st3 = advance st2
        in let st4 = expect RightParen st3
         in scan-def-params-then ann name-tok (list-snoc acc param) st4
      else finish-def-scan ann name-tok acc st
    else finish-def-scan ann name-tok acc st

  finish-def-scan : List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  finish-def-scan (ann) (name-tok) (params) (st) =
   let st2 = expect Equals st
   in let st3 = skip-newlines st2
   in let body-pos = st3.pos
     in let st4 = skip-body-tokens st3 (name-tok.column)
      in DefHeaderOk (DefHeader {
       name = name-tok,
       params = params,
       ann = ann,
       body-pos = body-pos
      }) st4

  skip-body-tokens : ParseState -> Integer -> ParseState
  skip-body-tokens (st) (name-col) =
   if is-done st then st
   else let tok = current st
   in when tok.kind
     if Newline -> skip-body-tokens (advance st) name-col
     if Indent -> skip-body-tokens (advance st) name-col
     if Dedent -> skip-body-tokens (advance st) name-col
     if _ -> if tok.column <= name-col then st
      else skip-body-tokens (advance st) name-col
