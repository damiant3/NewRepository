Chapter: Parser

 The parser transforms a flat token list into a concrete syntax tree.

  cites Foreword chapter Maybe

Section: Type Parsing
  parse-type : ParseState -> ParseTypeResult
  parse-type (st) =
   let result = parse-type-atom st
   in unwrap-type-ok result parse-type-continue

  parse-type-continue : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-continue (left) (st) =
   if is-arrow (current-kind st) then let st2 = advance st
     in let right-result = parse-type st2
     in unwrap-type-ok right-result (make-fun-type left)
    else TypeOk left st

  make-fun-type : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  make-fun-type (left) (right) (st) =
   TypeOk (FunType left right) st

  unwrap-type-ok : ParseTypeResult -> (TypeExpr -> ParseState -> ParseTypeResult) -> ParseTypeResult
  unwrap-type-ok (r) (f) =
   when r
    is TypeOk (t) (st) -> f t st

  parse-type-atom : ParseState -> ParseTypeResult
  parse-type-atom (st) =
   if is-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-left-paren (current-kind st) then parse-paren-type (advance st)
   else if is-left-bracket (current-kind st) then parse-effect-type (advance st)
   else let tok = current st
   in TypeOk (NamedType tok) (advance st)

  parse-paren-type : ParseState -> ParseTypeResult
  parse-paren-type (st) =
   let inner = parse-type st
   in unwrap-type-ok inner finish-paren-type

  finish-paren-type : TypeExpr -> ParseState -> ParseTypeResult
  finish-paren-type (t) (st) =
   let st2 = expect RightParen st
   in TypeOk (ParenType t) st2

  parse-effect-type : ParseState -> ParseTypeResult
  parse-effect-type (st) =
   let effs = parse-effect-names st []
   in let ret = parse-type (effs.state)
   in unwrap-type-ok ret (finish-effect-type (effs.names))

  finish-effect-type : List Token -> TypeExpr -> ParseState -> ParseTypeResult
  finish-effect-type (effs) (ret) (st) =
   TypeOk (EffectTypeExpr effs ret) st

  EffectNamesResult = record {
   names : List Token,
   state : ParseState
  }

  parse-effect-names : ParseState -> List Token -> EffectNamesResult
  parse-effect-names (st) (acc) =
   if is-done st then EffectNamesResult { names = acc, state = st }
   else if is-right-bracket (current-kind st) then EffectNamesResult { names = acc, state = advance st }
   else if is-comma (current-kind st) then parse-effect-names (advance st) acc
   else if is-ident (current-kind st) | is-type-ident (current-kind st) then
    let tok = current st
    in parse-effect-names (advance st) (list-snoc acc tok)
   else parse-effect-names (advance st) acc

  parse-type-args : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-args (base-type) (st) =
   if is-done st then TypeOk base-type st
   else if is-type-arg-start (current-kind st) then parse-type-arg-next base-type st
   else TypeOk base-type st

  parse-type-arg-next : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-arg-next (base-type) (st) =
   let arg-result = parse-type-atom st
   in unwrap-type-ok arg-result (continue-type-args base-type)

  continue-type-args : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  continue-type-args (base-type) (arg) (st) =
   parse-type-args (AppType base-type [arg]) st

Section: Pattern Parsing
  parse-pattern : ParseState -> ParsePatResult
  parse-pattern (st) =
   if is-wildcard-pat (current-kind st) then PatOk (WildPat (current st)) (advance st)
   else if is-literal (current-kind st) then PatOk (LitPat (current st)) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
       in parse-ctor-pattern-fields tok [] (advance st)
   else if is-ident (current-kind st) then PatOk (VarPat (current st)) (advance st)
       else PatOk (WildPat (current st)) (advance st)

  parse-ctor-pattern-fields : Token -> List Pat -> ParseState -> ParsePatResult
  parse-ctor-pattern-fields (ctor) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
     in let sub = parse-pattern st2
     in unwrap-pat-ok sub (continue-ctor-fields ctor acc)
    else PatOk (CtorPat ctor acc) st

  continue-ctor-fields : Token -> List Pat -> Pat -> ParseState -> ParsePatResult
  continue-ctor-fields (ctor) (acc) (p) (st) =
   let st2 = expect RightParen st
   in parse-ctor-pattern-fields ctor (list-snoc acc p) st2

  unwrap-pat-ok : ParsePatResult -> (Pat -> ParseState -> ParsePatResult) -> ParsePatResult
  unwrap-pat-ok (r) (f) =
   when r
    is PatOk (p) (st) -> f p st

Section: Definition Parsing
  parse-type-annotation : ParseState -> ParseTypeResult
  parse-type-annotation (st) =
   let st2 = advance st
   in let st3 = expect Colon st2
   in parse-type st3

  parse-definition : ParseState -> ParseDefResult
  parse-definition (st) =
   if is-done st then ParseDefResult { maybe-def = None, state = st }
   else if is-ident (current-kind st) then try-parse-def st
   else if is-type-ident (current-kind st) then try-parse-def st
     else ParseDefResult { maybe-def = None, state = st }

  try-parse-def : ParseState -> ParseDefResult
  try-parse-def (st) =
   if is-colon (peek-kind st 1) then let first-name = current st
     in let ann-result = parse-type-annotation st
     in unwrap-type-for-def first-name ann-result
    else parse-def-body-with-ann [] st

  unwrap-type-for-def : Token -> ParseTypeResult -> ParseDefResult
  unwrap-type-for-def (first-name) (r) =
   when r
    is TypeOk (ann-type) (st) ->
     if is-equals (current-kind st) then
      let ann = [TypeAnn {
       name = first-name,
       type-expr = ann-type
      }]
      in let st2 = advance st
      in let st3 = skip-newlines st2
      in let body-result = parse-expr-col st3 (first-name.column)
      in unwrap-def-body body-result ann first-name []
     else
      let name-tok = Token {
       kind = Identifier,
       text = "",
       offset = 0,
       line = 0,
       column = 0,
       file-id = 0
      }
      in let ann = [TypeAnn {
       name = name-tok,
       type-expr = ann-type
      }]
      in let st2 = skip-newlines st
      in parse-def-body-with-ann ann st2

  parse-def-body-with-ann : List TypeAnn -> ParseState -> ParseDefResult
  parse-def-body-with-ann (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in parse-def-params-then ann name-tok [] st2

  parse-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  parse-def-params-then (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then parse-def-params-after-lparen ann name-tok acc (advance st)
   else finish-def ann name-tok acc st

  parse-def-params-after-lparen : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  parse-def-params-after-lparen (ann) (name-tok) (acc) (st) =
   if is-ident (current-kind st) then let param = current st
     in let st2 = expect RightParen (advance st)
     in parse-def-params-then ann name-tok (list-snoc acc param) st2
    else if is-reserved-keyword (current-kind st) then
     let st2 = report-reserved-keyword "a parameter name" st
     in let st3 = expect RightParen (advance st2)
     in parse-def-params-then ann name-tok acc st3
      else finish-def ann name-tok acc st

  finish-def : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  finish-def (ann) (name-tok) (params) (st) =
   if is-equals (current-kind st) then
    let st2 = advance st
    in let st3 = skip-newlines st2
    in let body-result = parse-expr-col st3 (name-tok.column)
    in unwrap-def-body body-result ann name-tok params
   else let tok = current st
    in let err-st = expect Equals st
    in let st2 = skip-body-tokens err-st (name-tok.column)
    in ParseDefResult {
     maybe-def = Just (Def {
      name = name-tok,
      params = params,
      ann = ann,
      body = ErrExpr tok,
      chapter-slug = ""
     }),
     state = st2
    }

  unwrap-def-body : ParseExprResult -> List TypeAnn -> Token -> List Token -> ParseDefResult
  unwrap-def-body (r) (ann) (name-tok) (params) =
   when r
    is ExprOk (b) (st) ->
     ParseDefResult {
      maybe-def = Just (Def {
       name = name-tok,
       params = params,
       ann = ann,
       body = b,
       chapter-slug = ""
      }),
      state = st
     }

Section: Type Definition Parsing
  is-paren-type-param : ParseState -> Boolean
  is-paren-type-param (st) =
   if is-left-paren (current-kind st) then let k1 = peek-kind st 1
   in if is-ident k1 then is-right-paren (peek-kind st 2)
      else if is-type-ident k1 then is-right-paren (peek-kind st 2)
      else False
    else False

  is-type-param-pattern : ParseState -> Boolean
  is-type-param-pattern (st) =
   if is-paren-type-param st then True
   else is-ident (current-kind st)

  parse-type-params : ParseState -> List Token -> ParseState
  parse-type-params (st) (acc) =
   if is-paren-type-param st then parse-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then parse-type-params (advance st) (list-snoc acc (current st))
   else st

  collect-type-params : ParseState -> List Token -> List Token
  collect-type-params (st) (acc) =
   if is-paren-type-param st then collect-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then collect-type-params (advance st) (list-snoc acc (current st))
   else acc

  parse-type-def : ParseState -> ParseTypeDefResult
  parse-type-def (st) =
   if is-type-ident (current-kind st) then let name-tok = current st
     in let st2 = advance st
     in let tparams = collect-type-params st2 []
     in let st3 = parse-type-params st2 []
     in if is-equals (current-kind st3) then let st4 = skip-newlines (advance st3)
     in if is-record-keyword (current-kind st4) then parse-record-type name-tok tparams st4
            else if is-pipe (current-kind st4) then parse-variant-type name-tok tparams st4
            else if is-type-ident (current-kind st4) & looks-like-variant st4 then parse-variant-type name-tok tparams st4
            else ParseTypeDefResult { maybe-type-def = None, state = st }
         else ParseTypeDefResult { maybe-type-def = None, state = st }
    else ParseTypeDefResult { maybe-type-def = None, state = st }

  parse-record-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-record-type (name-tok) (tparams) (st) =
   let st2 = advance st
   in let st3 = expect LeftBrace st2
   in let st4 = skip-newlines st3
   in parse-record-fields-loop name-tok tparams [] st4

  parse-record-fields-loop : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-record-fields-loop (name-tok) (tparams) (acc) (st) =
   if is-right-brace (current-kind st) then ParseTypeDefResult {
    maybe-type-def = Just (TypeDef {
     name = name-tok,
     type-params = tparams,
     body = RecordBody acc
    }),
    state = advance st
   }
   else if is-ident-like (current-kind st) then parse-one-record-field name-tok tparams acc st
   else ParseTypeDefResult {
    maybe-type-def = Just (TypeDef {
     name = name-tok,
     type-params = tparams,
     body = RecordBody acc
    }),
    state = st
   }

  parse-one-record-field : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-one-record-field (name-tok) (tparams) (acc) (st) =
   let field-name = current st
   in let st2 = advance st
   in let st3 = expect Colon st2
   in let field-type-result = parse-type st3
   in unwrap-record-field-type name-tok tparams acc field-name field-type-result

  unwrap-record-field-type : Token -> List Token -> List RecordFieldDef -> Token -> ParseTypeResult -> ParseTypeDefResult
  unwrap-record-field-type (name-tok) (tparams) (acc) (field-name) (r) =
   when r
    is TypeOk (ft) (st) ->
     let field = RecordFieldDef {
      name = field-name,
      type-expr = ft
     }
     in let st2 = skip-newlines st
     in if is-comma (current-kind st2) then parse-record-fields-loop name-tok tparams (list-snoc acc field) (skip-newlines (advance st2))
         else parse-record-fields-loop name-tok tparams (list-snoc acc field) st2

  looks-like-variant : ParseState -> Boolean
  looks-like-variant (st) =
   looks-like-variant-scan (st.tokens) (st.pos + 1) (list-length (st.tokens))

  looks-like-variant-scan : List Token -> Integer -> Integer -> Boolean
  looks-like-variant-scan (tokens) (i) (len) =
   if i >= len then False
   else let k = (list-at tokens i).kind
   in if is-pipe k then True
      else when k
      is Newline -> False
      is EndOfFile -> False
      is otherwise -> looks-like-variant-scan tokens (i + 1) len

  parse-variant-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-variant-type (name-tok) (tparams) (st) =
   if is-type-ident (current-kind st) then let ctor-name = current st
     in let st2 = advance st
     in parse-ctor-fields ctor-name [] st2 name-tok tparams []
    else parse-variant-ctors name-tok tparams [] st

  parse-variant-ctors : Token -> List Token -> List VariantCtorDef -> ParseState -> ParseTypeDefResult
  parse-variant-ctors (name-tok) (tparams) (acc) (st) =
   if is-pipe (current-kind st) then let st2 = skip-newlines (advance st)
     in let ctor-name = current st2
     in let st3 = advance st2
     in parse-ctor-fields ctor-name [] st3 name-tok tparams acc
    else ParseTypeDefResult {
     maybe-type-def = Just (TypeDef {
      name = name-tok,
      type-params = tparams,
      body = VariantBody acc
     }),
     state = st
    }

  parse-ctor-fields : Token -> List TypeExpr -> ParseState -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  parse-ctor-fields (ctor-name) (fields) (st) (name-tok) (tparams) (acc) =
   if is-left-paren (current-kind st) then let field-result = parse-type (advance st)
     in unwrap-ctor-field field-result ctor-name fields name-tok tparams acc
    else let st2 = skip-newlines st
    in let ctor = VariantCtorDef {
      name = ctor-name,
      fields = fields
     }
    in parse-variant-ctors name-tok tparams (list-snoc acc ctor) st2

  unwrap-ctor-field : ParseTypeResult -> Token -> List TypeExpr -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  unwrap-ctor-field (r) (ctor-name) (fields) (name-tok) (tparams) (acc) =
   when r
    is TypeOk (ty) (st) ->
     let st2 = expect RightParen st
      in parse-ctor-fields ctor-name (fields ++ [ty]) st2 name-tok tparams acc

Section: Document Parsing
  parse-document : ParseState -> Document
  parse-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-citations st2 "" []
   in parse-top-level [] [] [] (imp-result.imports) "" [] (imp-result.state)

  CiteTitleResult = record { title : Text, state : ParseState }

  collect-cite-title : ParseState -> Text -> CiteTitleResult
  collect-cite-title (st) (acc) =
   if is-done st then CiteTitleResult { title = acc, state = st }
    else when current-kind st
     is Newline -> CiteTitleResult { title = acc, state = st }
     is LeftParen -> CiteTitleResult { title = acc, state = st }
     is otherwise -> let tok = current st
      in collect-cite-title (advance st) (join-title-parts acc (tok.text))

  parse-citations : ParseState -> Text -> List CitesDecl -> ImportParseResult
  parse-citations (st) (citing) (acc) =
   if is-cites-keyword (current-kind st) then let st2 = advance st
     in let quire-tok = current st2
     in let st3 = advance st2
     in let st4 = advance st3
     in let title-result = collect-cite-title st4 ""
     in let st5 = title-result.state
     in if is-left-paren (current-kind st5) then let sel = parse-selected-names (advance st5) []
     in let st6 = skip-newlines (sel.state)
     in parse-citations st6 citing (list-snoc acc (CitesDecl {
           quire = quire-tok,
           chapter-name = title-result.title,
           selected-names = sel.names,
           citing-chapter = citing
          }))
     else let st6 = skip-newlines st5
     in parse-citations st6 citing (list-snoc acc (CitesDecl {
          quire = quire-tok,
          chapter-name = title-result.title,
          selected-names = [],
          citing-chapter = citing
         }))
    else ImportParseResult {
     imports = acc,
     state = st
    }

  SelectedNamesResult = record { names : List Token, state : ParseState }

  parse-selected-names : ParseState -> List Token -> SelectedNamesResult
  parse-selected-names (st) (acc) =
   if is-ident (current-kind st) then let tok = current st
     in let st2 = advance st
     in if is-comma (current-kind st2) then parse-selected-names (skip-newlines (advance st2)) (list-snoc acc tok)
         else SelectedNamesResult {
          names = list-snoc acc tok,
          state = st2
         }
    else if is-right-paren (current-kind st) then SelectedNamesResult {
     names = acc,
     state = advance st
    }
    else SelectedNamesResult {
     names = acc,
     state = st
    }

  ImportParseResult = record { imports : List CitesDecl, state : ParseState }

  is-chapter-header : ParseState -> Boolean
  is-chapter-header (st) =
   if is-type-ident (current-kind st) then if (current st).text == "Chapter" then is-colon (peek-kind st 1)
      else False
    else False

  is-section-header : ParseState -> Boolean
  is-section-header (st) =
   if is-type-ident (current-kind st) then if (current st).text == "Section" then is-colon (peek-kind st 1)
      else False
    else False

  is-page-marker : ParseState -> Boolean
  is-page-marker (st) =
   if is-type-ident (current-kind st) then (current st).text == "Page"
    else False

  extract-header-title : ParseState -> Text
  extract-header-title (st) =
   let st2 = advance (advance st)
   in collect-title-tokens st2 ""

  join-title-parts : Text -> Text -> Text
  join-title-parts (acc) (next) =
   if text-length acc == 0 then next
    else if text-length next == 0 then acc
    else let prev-last = char-code-at acc (text-length acc - 1)
     in let next-first = char-code-at next 0
     in if (is-letter-code prev-last | is-digit-code prev-last) & (is-letter-code next-first | is-digit-code next-first)
        then acc ++ " " ++ next
        else acc ++ next

  collect-title-tokens : ParseState -> Text -> Text
  collect-title-tokens (st) (acc) =
   if is-done st then acc
   else when current-kind st
    is Newline -> acc
    is otherwise -> let tok = current st
     in collect-title-tokens (advance st) (join-title-parts acc (tok.text))

  is-prose-line : ParseState -> Boolean
  is-prose-line (st) = (current st).column == 2

  skip-prose-lines : ParseState -> ParseState
  skip-prose-lines (st) =
   let st2 = skip-newlines st
   in if is-done st2 then st2
      else if is-prose-line st2 then skip-prose-lines (skip-to-next-line st2)
      else st2

  skip-to-next-line : ParseState -> ParseState
  skip-to-next-line (st) =
   if is-done st then st
   else when current-kind st
    is Newline -> advance st
    is otherwise -> skip-to-next-line (advance st)

  parse-top-level : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  parse-top-level (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   if is-done st then Document {
    defs = defs,
    type-defs = type-defs,
    effect-defs = effect-defs,
    citations = imports,
    chapter-title = ch-title,
    section-titles = sec-titles,
    parse-bag = st.bag
   }
   else if is-chapter-header st then let title = extract-header-title st
     in parse-top-level defs type-defs effect-defs imports title sec-titles (skip-prose-lines (skip-to-next-line st))
   else if is-section-header st then let title = extract-header-title st
     in parse-top-level defs type-defs effect-defs imports ch-title (sec-titles ++ [title]) (skip-prose-lines (skip-to-next-line st))
   else if is-page-marker st then parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-to-next-line st)
   else if is-cites-keyword (current-kind st) then let cite-result = parse-citations st ch-title []
     in parse-top-level defs type-defs effect-defs (imports ++ cite-result.imports) ch-title sec-titles (cite-result.state)
   else if is-effect-keyword (current-kind st) then parse-top-level-effect defs type-defs effect-defs imports ch-title sec-titles st
   else if is-prose-line st then parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-prose-lines st)
   else try-top-level-type-def defs type-defs effect-defs imports ch-title sec-titles st

  parse-top-level-effect : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  parse-top-level-effect (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
   in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
   in let ops = parse-effect-ops st3 []
   in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
   in parse-top-level defs type-defs (effect-defs ++ [ed]) imports ch-title sec-titles (skip-newlines (ops.state))

  EffectOpsResult = record { ops : List EffectOpDef, state : ParseState }

  parse-effect-ops : ParseState -> List EffectOpDef -> EffectOpsResult
  parse-effect-ops (st) (acc) =
   if is-ident (current-kind st) then if is-colon (peek-kind st 1) then let op-tok = current st
      in let st2 = advance (advance st)
      in let type-result = parse-type st2
      in when type-result
         is TypeOk (ty) (st3) ->
          let op = EffectOpDef {
           name = op-tok,
           type-expr = ty
          }
      in parse-effect-ops (skip-newlines st3) (list-snoc acc op)
     else EffectOpsResult {
      ops = acc,
      state = st
     }
    else EffectOpsResult {
     ops = acc,
     state = st
    }

  try-top-level-type-def : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  try-top-level-type-def (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let td-result = parse-type-def st
   in let st2 = td-result.state
   in when td-result.maybe-type-def
    is Just (td) ->
     parse-top-level defs (type-defs ++ [td]) effect-defs imports ch-title sec-titles (skip-newlines st2)
    is None ->
     try-top-level-def defs type-defs effect-defs imports ch-title sec-titles st

  try-top-level-def : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  try-top-level-def (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let def-result = parse-definition st
   in let st2 = def-result.state
   in when def-result.maybe-def
    is Just (d) ->
     let tagged = Def {
      name = d.name,
      params = d.params,
      ann = d.ann,
      body = d.body,
      chapter-slug = ch-title
     }
     in parse-top-level (defs ++ [tagged]) type-defs effect-defs imports ch-title sec-titles (skip-newlines st2)
    is None ->
     parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-newlines (advance st2))

Section: Header Scanning (streaming)
  scan-document : ParseState -> ScanResult
  scan-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-citations st2 "" []
   in scan-top-level [] [] [] (imp-result.imports) "" "" [] (imp-result.state)

  scan-top-level : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  scan-top-level (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   if is-done st then ScanResult {
    type-defs = type-defs,
    effect-defs = effect-defs,
    def-headers = headers,
    citations = imports,
    chapter-title = ch-title,
    section-titles = sec-titles
   }
   else if is-chapter-header st then let title = extract-header-title st
     in scan-top-level headers type-defs effect-defs imports title title sec-titles (skip-prose-lines (skip-to-next-line st))
   else if is-section-header st then let title = extract-header-title st
     in scan-top-level headers type-defs effect-defs imports cur-chap ch-title (sec-titles ++ [title]) (skip-prose-lines (skip-to-next-line st))
   else if is-page-marker st then scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-to-next-line st)
   else if is-cites-keyword (current-kind st) then let cite-result = parse-citations st cur-chap []
     in scan-top-level headers type-defs effect-defs (imports ++ cite-result.imports) cur-chap ch-title sec-titles (cite-result.state)
   else if is-effect-keyword (current-kind st) then scan-top-level-effect headers type-defs effect-defs imports cur-chap ch-title sec-titles st
   else if is-prose-line st then scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-prose-lines st)
   else try-scan-type-def headers type-defs effect-defs imports cur-chap ch-title sec-titles st

  scan-top-level-effect : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  scan-top-level-effect (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
   in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
   in let ops = parse-effect-ops st3 []
   in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
   in scan-top-level headers type-defs (effect-defs ++ [ed]) imports cur-chap ch-title sec-titles (skip-newlines (ops.state))

  try-scan-type-def : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  try-scan-type-def (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let td-result = parse-type-def st
   in let st2 = td-result.state
   in when td-result.maybe-type-def
    is Just (td) ->
     scan-top-level headers (type-defs ++ [td]) effect-defs imports cur-chap ch-title sec-titles (skip-newlines st2)
    is None ->
     try-scan-def-header headers type-defs effect-defs imports cur-chap ch-title sec-titles st

  try-scan-def-header : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  try-scan-def-header (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let hdr-result = scan-definition cur-chap st
   in let st2 = hdr-result.state
   in when hdr-result.maybe-header
    is Just (hdr) ->
     scan-top-level (headers ++ [hdr]) type-defs effect-defs imports cur-chap ch-title sec-titles (skip-newlines st2)
    is None ->
     scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-newlines (advance st2))

  scan-definition : Text -> ParseState -> ScanDefResult
  scan-definition (cur-chap) (st) =
   if is-done st then ScanDefResult { maybe-header = None, state = st }
   else if is-ident (current-kind st) then try-scan-def cur-chap st
   else if is-type-ident (current-kind st) then try-scan-def cur-chap st
     else ScanDefResult { maybe-header = None, state = st }

  try-scan-def : Text -> ParseState -> ScanDefResult
  try-scan-def (cur-chap) (st) =
   if is-colon (peek-kind st 1) then let first-name = current st
     in let ann-result = parse-type-annotation st
     in unwrap-type-for-scan cur-chap first-name ann-result
    else scan-def-body-with-ann cur-chap [] st

  unwrap-type-for-scan : Text -> Token -> ParseTypeResult -> ScanDefResult
  unwrap-type-for-scan (cur-chap) (first-name) (r) =
   when r
    is TypeOk (ann-type) (st) ->
     if is-equals (current-kind st) then
      let ann = [TypeAnn {
       name = first-name,
       type-expr = ann-type
      }]
      in let st2 = advance st
      in let st3 = skip-newlines st2
      in let body-pos = st3.pos
      in let st4 = skip-body-tokens st3 (first-name.column)
      in ScanDefResult {
          maybe-header = Just (DefHeader {
           name = first-name,
           params = [],
           ann = ann,
           body-pos = body-pos,
           chapter-slug = cur-chap
          }),
          state = st4
         }
     else
      let name-tok = Token {
       kind = Identifier,
       text = "",
       offset = 0,
       line = 0,
       column = 0,
       file-id = 0
      }
      in let ann = [TypeAnn {
       name = name-tok,
       type-expr = ann-type
      }]
      in let st2 = skip-newlines st
      in scan-def-body-with-ann cur-chap ann st2

  scan-def-body-with-ann : Text -> List TypeAnn -> ParseState -> ScanDefResult
  scan-def-body-with-ann (cur-chap) (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in scan-def-params-then cur-chap ann name-tok [] st2

  scan-def-params-then : Text -> List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  scan-def-params-then (cur-chap) (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
   in if is-ident (current-kind st2) then let param = current st2
   in let st3 = advance st2
   in let st4 = expect RightParen st3
   in scan-def-params-then cur-chap ann name-tok (list-snoc acc param) st4
      else finish-def-scan cur-chap ann name-tok acc st
    else finish-def-scan cur-chap ann name-tok acc st

  finish-def-scan : Text -> List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  finish-def-scan (cur-chap) (ann) (name-tok) (params) (st) =
   if is-equals (current-kind st) == False then ScanDefResult { maybe-header = None, state = st }
   else let st2 = advance st
   in let st3 = skip-newlines st2
   in let body-pos = st3.pos
   in let st4 = skip-body-tokens st3 (name-tok.column)
   in ScanDefResult {
       maybe-header = Just (DefHeader {
        name = name-tok,
        params = params,
        ann = ann,
        body-pos = body-pos,
        chapter-slug = cur-chap
       }),
       state = st4
      }

  skip-body-tokens : ParseState -> Integer -> ParseState
  skip-body-tokens (st) (name-col) =
   if is-done st then st
   else let tok = current st
   in when tok.kind
     is Newline -> skip-body-tokens (advance st) name-col
     is Indent -> skip-body-tokens (advance st) name-col
     is Dedent -> skip-body-tokens (advance st) name-col
     is otherwise -> if tok.column <= name-col then st
      else skip-body-tokens (advance st) name-col

