Chapter: Lexer

 The lexer converts source text into a flat list of tokens. It operates
 as a series of pure functions threading state through. The input is
 well-formed Codex source: UTF-8, newline-delimited, space-indented.

 Performance: all character inspection uses char-code-at (returns Integer)
 to avoid per-character string allocation. Character constants are
 integer codes compared with == which compiles to a single CPU compare.

Section: Character Code Constants

  cc-newline : Integer
  cc-newline = 10

  cc-carriage-return : Integer
  cc-carriage-return = 13

  cc-space : Integer
  cc-space = 32

  cc-double-quote : Integer
  cc-double-quote = 34

  cc-ampersand : Integer
  cc-ampersand = 38

  cc-left-paren : Integer
  cc-left-paren = 40

  cc-right-paren : Integer
  cc-right-paren = 41

  cc-star : Integer
  cc-star = 42

  cc-plus : Integer
  cc-plus = 43

  cc-comma : Integer
  cc-comma = 44

  cc-minus : Integer
  cc-minus = 45

  cc-dot : Integer
  cc-dot = 46

  cc-slash : Integer
  cc-slash = 47

  cc-zero : Integer
  cc-zero = 48

  cc-nine : Integer
  cc-nine = 57

  cc-colon : Integer
  cc-colon = 58

  cc-less : Integer
  cc-less = 60

  cc-equals : Integer
  cc-equals = 61

  cc-greater : Integer
  cc-greater = 62

  cc-upper-a : Integer
  cc-upper-a = 65

  cc-upper-z : Integer
  cc-upper-z = 90

  cc-left-bracket : Integer
  cc-left-bracket = 91

  cc-backslash : Integer
  cc-backslash = 92

  cc-right-bracket : Integer
  cc-right-bracket = 93

  cc-caret : Integer
  cc-caret = 94

  cc-underscore : Integer
  cc-underscore = 95

  cc-lower-a : Integer
  cc-lower-a = 97

  cc-lower-n : Integer
  cc-lower-n = 110

  cc-lower-r : Integer
  cc-lower-r = 114

  cc-lower-t : Integer
  cc-lower-t = 116

  cc-lower-z : Integer
  cc-lower-z = 122

  cc-left-brace : Integer
  cc-left-brace = 123

  cc-pipe : Integer
  cc-pipe = 124

  cc-right-brace : Integer
  cc-right-brace = 125

Section: Character Classification (Integer)

  is-letter-code : Integer -> Boolean
  is-letter-code (c) =
   if c >= cc-upper-a
    then if c <= cc-upper-z then True
     else if c >= cc-lower-a
      then c <= cc-lower-z
      else False
    else False

  is-digit-code : Integer -> Boolean
  is-digit-code (c) =
   if c >= cc-zero then c <= cc-nine else False

Section: Lexer State

  LexState = record {
   source : Text,
   offset : Integer,
   line : Integer,
   column : Integer
  }

  make-lex-state : Text -> LexState
  make-lex-state (src) = LexState { source = src, offset = 0, line = 1, column = 1 }

  is-at-end : LexState -> Boolean
  is-at-end (st) = st.offset >= text-length st.source

  peek-code : LexState -> Integer
  peek-code (st) =
   if is-at-end st
    then 0
    else char-code-at st.source st.offset

  advance-char : LexState -> LexState
  advance-char (st) =
   if peek-code st == cc-newline
    then LexState {
     source = st.source,
     offset = st.offset + 1,
     line = st.line + 1,
     column = 1
    }
    else LexState {
     source = st.source,
     offset = st.offset + 1,
     line = st.line,
     column = st.column + 1
    }

Section: Whitespace

  skip-spaces : LexState -> LexState
  skip-spaces (st) =
   if is-at-end st
    then st
    else let c = peek-code st
     in if c == cc-space
      then skip-spaces (advance-char st)
      else if c == cc-carriage-return
       then skip-spaces (advance-char st)
       else st

Section: Character Scanning

  scan-ident-rest : LexState -> LexState
  scan-ident-rest (st) =
   if is-at-end st
    then st
    else let c = peek-code st
     in if is-letter-code c
      then scan-ident-rest (advance-char st)
      else if is-digit-code c
       then scan-ident-rest (advance-char st)
       else if c == cc-underscore
        then scan-ident-rest (advance-char st)
        else if c == cc-minus
         then let next = advance-char st
          in if is-at-end next
           then st
           else if is-letter-code (peek-code next)
            then scan-ident-rest next
            else st
         else st

  scan-digits : LexState -> LexState
  scan-digits (st) =
   if is-at-end st
    then st
    else let c = peek-code st
     in if is-digit-code c
      then scan-digits (advance-char st)
      else if c == cc-underscore
       then scan-digits (advance-char st)
       else st

  scan-string-body : LexState -> LexState
  scan-string-body (st) =
   if is-at-end st
    then st
    else let c = peek-code st
     in if c == cc-double-quote
      then advance-char st
      else if c == cc-newline
       then st
       else if c == cc-backslash
        then scan-string-body (advance-char (advance-char st))
        else scan-string-body (advance-char st)

  process-escapes : Text -> Integer -> Integer -> Text -> Text
  process-escapes (s) (i) (len) (acc) =
   if i >= len then acc
   else let c = char-code-at s i
    in if c == cc-backslash
     then if i + 1 < len
      then let nc = char-code-at s (i + 1)
       in if nc == cc-lower-n then process-escapes s (i + 2) len (acc ++ code-to-char 10)
       else if nc == cc-lower-t then process-escapes s (i + 2) len (acc ++ code-to-char 9)
       else if nc == cc-lower-r then process-escapes s (i + 2) len (acc ++ code-to-char 13)
       else if nc == cc-backslash then process-escapes s (i + 2) len (acc ++ "\\")
       else if nc == cc-double-quote then process-escapes s (i + 2) len (acc ++ "\"")
       else process-escapes s (i + 2) len (acc ++ char-at s (i + 1))
      else acc ++ char-at s i
     else process-escapes s (i + 1) len (acc ++ char-at s i)

Section: Keyword Classification

  classify-word : Text -> TokenKind
  classify-word (w) =
   if w == "let" then LetKeyword
   else if w == "in" then InKeyword
   else if w == "if" then IfKeyword
   else if w == "then" then ThenKeyword
   else if w == "else" then ElseKeyword
   else if w == "when" then WhenKeyword
   else if w == "where" then WhereKeyword
   else if w == "do" then DoKeyword
   else if w == "record" then RecordKeyword
   else if w == "import" then ImportKeyword
   else if w == "export" then ExportKeyword
   else if w == "claim" then ClaimKeyword
   else if w == "proof" then ProofKeyword
   else if w == "forall" then ForAllKeyword
   else if w == "exists" then ThereExistsKeyword
   else if w == "linear" then LinearKeyword
   else if w == "effect" then EffectKeyword
   else if w == "with" then WithKeyword
   else if w == "True" then TrueKeyword
   else if w == "False" then FalseKeyword
   else let first-code = char-code-at w 0
    in if first-code >= cc-upper-a
     then if first-code <= cc-upper-z
      then TypeIdentifier
      else Identifier
     else Identifier

Section: Single Token Scanning

  LexResult =
   | LexToken (Token) (LexState)
   | LexEnd

  make-token : TokenKind -> Text -> LexState -> Token
  make-token (kind) (text) (st) =
   Token {
    kind = kind,
    text = text,
    offset = st.offset,
    line = st.line,
    column = st.column
   }

  extract-text : LexState -> Integer -> LexState -> Text
  extract-text (st) (start) (end-st) =
   substring st.source start (end-st.offset - start)

  scan-token : LexState -> LexResult
  scan-token (st) =
   let s = skip-spaces st
   in if is-at-end s
    then LexEnd
    else let c = peek-code s
     in if c == cc-newline
      then LexToken (make-token Newline "\n" s) (advance-char s)
      else if c == cc-double-quote
       then let start = s.offset + 1
        in let after = scan-string-body (advance-char s)
         in let text-len = after.offset - start - 1
          in let raw = substring s.source start text-len
           in LexToken (make-token TextLiteral (process-escapes raw 0 (text-length raw) "") s) after
       else if is-letter-code c
        then let start = s.offset
         in let after = scan-ident-rest (advance-char s)
          in let word = extract-text s start after
           in LexToken (make-token (classify-word word) word s) after
        else if c == cc-underscore
         then let start = s.offset
          in let after = scan-ident-rest (advance-char s)
           in let word = extract-text s start after
            in if text-length word == 1
             then LexToken (make-token Underscore "_" s) after
             else LexToken (make-token (classify-word word) word s) after
         else if is-digit-code c
          then let start = s.offset
           in let after = scan-digits (advance-char s)
            in if is-at-end after
             then LexToken (make-token IntegerLiteral (extract-text s start after) s) after
             else if peek-code after == cc-dot
              then let after2 = scan-digits (advance-char after)
               in LexToken (make-token NumberLiteral (extract-text s start after2) s) after2
              else LexToken (make-token IntegerLiteral (extract-text s start after) s) after
          else scan-operator s

  scan-operator : LexState -> LexResult
  scan-operator (s) =
   let c = peek-code s
   in let next = advance-char s
    in if c == cc-left-paren
     then LexToken (make-token LeftParen "(" s) next
     else if c == cc-right-paren
      then LexToken (make-token RightParen ")" s) next
      else if c == cc-left-bracket
       then LexToken (make-token LeftBracket "[" s) next
       else if c == cc-right-bracket
        then LexToken (make-token RightBracket "]" s) next
        else if c == cc-left-brace
         then LexToken (make-token LeftBrace "{" s) next
         else if c == cc-right-brace
          then LexToken (make-token RightBrace "}" s) next
          else if c == cc-comma
           then LexToken (make-token Comma "," s) next
           else if c == cc-dot
            then LexToken (make-token Dot "." s) next
            else if c == cc-caret
             then LexToken (make-token Caret "^" s) next
             else if c == cc-ampersand
              then LexToken (make-token Ampersand "&" s) next
              else scan-multi-char-operator s

  scan-multi-char-operator : LexState -> LexResult
  scan-multi-char-operator (s) =
   let c = peek-code s
   in let next = advance-char s
    in let nc = if is-at-end next then 0 else peek-code next
     in if c == cc-plus
      then if nc == cc-plus
       then LexToken (make-token PlusPlus "++" s) (advance-char next)
       else LexToken (make-token Plus "+" s) next
      else if c == cc-minus
       then if nc == cc-greater
        then LexToken (make-token Arrow "->" s) (advance-char next)
        else LexToken (make-token Minus "-" s) next
       else if c == cc-star
        then LexToken (make-token Star "*" s) next
        else if c == cc-slash
         then if nc == cc-equals
          then LexToken (make-token NotEquals "/=" s) (advance-char next)
          else LexToken (make-token Slash "/" s) next
         else if c == cc-equals
          then if nc == cc-equals
           then let next2 = advance-char next
            in let nc2 = if is-at-end next2 then 0 else peek-code next2
             in if nc2 == cc-equals
              then LexToken (make-token TripleEquals "===" s) (advance-char next2)
              else LexToken (make-token DoubleEquals "==" s) next2
           else LexToken (make-token Equals "=" s) next
          else if c == cc-colon
           then if nc == cc-colon
            then LexToken (make-token ColonColon "::" s) (advance-char next)
            else LexToken (make-token Colon ":" s) next
           else if c == cc-pipe
            then if nc == cc-minus
             then LexToken (make-token Turnstile "|-" s) (advance-char next)
             else LexToken (make-token Pipe "|" s) next
            else if c == cc-less
             then if nc == cc-equals
              then LexToken (make-token LessOrEqual "<=" s) (advance-char next)
              else if nc == cc-minus
               then LexToken (make-token LeftArrow "<-" s) (advance-char next)
               else LexToken (make-token LessThan "<" s) next
             else if c == cc-greater
              then if nc == cc-equals
               then LexToken (make-token GreaterOrEqual ">=" s) (advance-char next)
               else LexToken (make-token GreaterThan ">" s) next
              else LexToken (make-token ErrorToken (char-at s.source s.offset) s) next

Section: Tokenize All

 Collect all tokens from source into a list.

  tokenize-loop : LexState -> List Token -> List Token
  tokenize-loop (st) (acc) =
   when scan-token st
    if LexToken (tok) (next) ->
     if tok.kind == EndOfFile
      then acc ++ [tok]
      else tokenize-loop next (acc ++ [tok])
    if LexEnd ->
     acc ++ [make-token EndOfFile "" st]

  tokenize : Text -> List Token
  tokenize (src) = tokenize-loop (make-lex-state src) []
