Chapter: Syntax Nodes

 The concrete syntax tree represents the structure of a parsed Codex
 source file. Each node carries position information for diagnostics.

Section: Expressions
  Expr =
   | LitExpr (Token)
   | NameExpr (Token)
   | AppExpr (Expr) (Expr)
   | BinExpr (Expr) (Token) (Expr)
   | UnaryExpr (Token) (Expr)
   | IfExpr (Expr) (Expr) (Expr)
   | LetExpr (List LetBind) (Expr)
   | MatchExpr (Expr) (List MatchArm)
   | ListExpr (List Expr)
   | RecordExpr (Token) (List RecordFieldExpr)
   | FieldExpr (Expr) (Token)
   | ParenExpr (Expr)
   | DoExpr (List DoStmt)
   | HandleExpr (Token) (Expr) (List HandleClause)
   | LambdaExpr (List Token) (Expr)
   | ErrExpr (Token)

  LetBind = record {
   name : Token,
   value : Expr
  }

  MatchArm = record {
   pattern : Pat,
   body : Expr
  }

  RecordFieldExpr = record {
   name : Token,
   value : Expr
  }

  DoStmt =
   | DoBindStmt (Token) (Expr)
   | DoExprStmt (Expr)

  HandleClause = record {
   op-name : Token,
   resume-name : Token,
   body : Expr
  }

Section: Patterns
  Pat =
   | VarPat (Token)
   | LitPat (Token)
   | CtorPat (Token) (List Pat)
   | WildPat (Token)

Section: Types
  TypeExpr =
   | NamedType (Token)
   | FunType (TypeExpr) (TypeExpr)
   | AppType (TypeExpr) (List TypeExpr)
   | ParenType (TypeExpr)
   | ListType (TypeExpr)
   | LinearTypeExpr (TypeExpr)
   | EffectTypeExpr (List Token) (TypeExpr)

Section: Definitions
  TypeAnn = record {
   name : Token,
   type-expr : TypeExpr
  }

  Def = record {
   name : Token,
   params : List Token,
   ann : List TypeAnn,
   body : Expr,
   chapter-slug : Text
  }

  RecordFieldDef = record {
   name : Token,
   type-expr : TypeExpr
  }

  VariantCtorDef = record {
   name : Token,
   fields : List TypeExpr
  }

  EffectOpDef = record {
   name : Token,
   type-expr : TypeExpr
  }

  EffectDef = record {
   name : Token,
   ops : List EffectOpDef
  }

  TypeBody =
   | RecordBody (List RecordFieldDef)
   | VariantBody (List VariantCtorDef)

  TypeDef = record {
   name : Token,
   type-params : List Token,
   body : TypeBody
  }

Section: Document
  CitesDecl = record {
   chapter-name : Token,
   selected-names : List Token
  }

  Document = record {
   defs : List Def,
   type-defs : List TypeDef,
   effect-defs : List EffectDef,
   citations : List CitesDecl,
   chapter-title : Text,
   section-titles : List Text
  }

Section: Definition Headers (for streaming)
  DefHeader = record {
   name : Token,
   params : List Token,
   ann : List TypeAnn,
   body-pos : Integer,
   chapter-slug : Text
  }

  ScanDefResult =
   | DefHeaderOk (DefHeader) (ParseState)
   | DefHeaderNone (ParseState)

  ScanResult = record {
   type-defs : List TypeDef,
   effect-defs : List EffectDef,
   def-headers : List DefHeader,
   citations : List CitesDecl,
   chapter-title : Text,
   section-titles : List Text
  }

