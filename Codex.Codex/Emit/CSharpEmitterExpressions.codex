Chapter: CSharp Emitter

 Expression emission: identifiers, arity, apply chains, dispatch.

Section: Identifier Helpers

  cs-keywords : List Text
  cs-keywords =
   let unsorted = ["abstract", "as", "base", "bool", "break",
    "case", "catch", "class", "continue", "decimal",
    "default", "delegate", "do", "double", "else",
    "event", "false", "finally", "for", "if",
    "in", "int", "internal", "is", "long",
    "namespace", "new", "null", "object", "out",
    "override", "params", "private", "protected", "public",
    "ref", "return", "sealed", "static", "string",
    "switch", "this", "throw", "true", "try",
    "typeof", "using", "virtual", "void", "while"]
   in sort-text-list unsorted

  is-cs-keyword : Text -> Boolean
  is-cs-keyword (n) = text-set-has cs-keywords n

  sanitize : Text -> Text
  sanitize (name) =
   let s = text-replace name "-" "_"
   in if is-cs-keyword s then "@" ++ s
      else if is-cs-member-name s then s ++ "_"
              else s

  cs-member-names : List Text
  cs-member-names =
   let unsorted = ["Equals", "GetHashCode", "GetType", "MemberwiseClone", "ToString"]
   in sort-text-list unsorted

  is-cs-member-name : Text -> Boolean
  is-cs-member-name (n) = text-set-has cs-member-names n

  cs-type : CodexType -> Text
  cs-type (ty) =
   when ty
    if IntegerTy -> "long"
    if NumberTy -> "decimal"
    if TextTy -> "string"
    if BooleanTy -> "bool"
    if CharTy -> "long"
    if VoidTy -> "void"
    if NothingTy -> "object"
    if ErrorTy -> "object"
    if FunTy (p) (r) -> "Func<" ++ cs-type p ++ ", " ++ cs-type r ++ ">"
    if ListTy (elem) -> "List<" ++ cs-type elem ++ ">"
    if TypeVar (id) -> "T" ++ integer-to-text id
    if ForAllTy (id) (body) -> cs-type body
    if SumTy (name) (ctors) -> sanitize (name.value)
    if RecordTy (name) (fields) -> sanitize (name.value)
    if ConstructedTy (name) (args) -> if list-length args == 0 then sanitize (name.value)
                                     else sanitize (name.value) ++ "<" ++ emit-cs-type-args args 0 ++ ">"
    if EffectfulTy (effects) (ret) -> cs-type ret

  emit-cs-type-args : List CodexType -> Integer -> Text
  emit-cs-type-args (args) (i) =
   if i == list-length args then ""
   else let t = cs-type (list-at args i)
   in if i == list-length args - 1 then t
      else t ++ ", " ++ emit-cs-type-args args (i + 1)

Section: Arity Map

  ArityEntry = record {
   name : Text,
   arity : Integer
  }

  build-arity-map : List IRDef -> Integer -> List ArityEntry -> List ArityEntry
  build-arity-map (defs) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in build-arity-map defs (i + 1) (list-snoc acc (ArityEntry {
    name = d.name,
    arity = list-length (d.params)
   }))

  build-arity-map-from-ast : List ADef -> Integer -> List ArityEntry -> List ArityEntry
  build-arity-map-from-ast (defs) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in build-arity-map-from-ast defs (i + 1) (list-snoc acc (ArityEntry {
    name = d.name.value,
    arity = list-length (d.params)
   }))

  lookup-arity : List ArityEntry -> Text -> Integer
  lookup-arity (entries) (name) =
   lookup-arity-loop entries name 0 (list-length entries)

  lookup-arity-loop : List ArityEntry -> Text -> Integer -> Integer -> Integer
  lookup-arity-loop (entries) (name) (i) (len) =
   if i == len then 0 - 1
   else let e = list-at entries i
   in if e.name == name then e.arity
      else lookup-arity-loop entries name (i + 1) len

Section: Apply Chain

  ApplyChain = record {
   root : IRExpr,
   args : List IRExpr
  }

  collect-apply-chain : IRExpr -> List IRExpr -> ApplyChain
  collect-apply-chain (e) (acc) =
   when e
    if IrApply (f) (a) (ty) -> collect-apply-chain f ([a] ++ acc)
    if _ -> ApplyChain {
     root = e,
     args = acc
    }

  is-upper-letter : Char -> Boolean
  is-upper-letter (c) =
   let code = char-code c
   in code >= char-code 'E' & code <= char-code 'Z'

  emit-apply-args : List IRExpr -> List ArityEntry -> Integer -> Text
  emit-apply-args (args) (arities) (i) =
   if i == list-length args then ""
   else if i == list-length args - 1 then emit-expr (list-at args i) arities
        else emit-expr (list-at args i) arities ++ ", " ++ emit-apply-args args arities (i + 1)

  emit-partial-params : Integer -> Integer -> Text
  emit-partial-params (i) (count) =
   if i == count then ""
   else if i == count - 1 then "_p" ++ integer-to-text i ++ "_"
        else "_p" ++ integer-to-text i ++ "_" ++ ", " ++ emit-partial-params (i + 1) count

  emit-partial-wrappers : Integer -> Integer -> Text
  emit-partial-wrappers (i) (count) =
   if i == count then ""
   else "(_p" ++ integer-to-text i ++ "_) => " ++ emit-partial-wrappers (i + 1) count

  is-builtin-name : Text -> Boolean
  is-builtin-name (n) =
   if n == "show" then True
   else if n == "negate" then True
   else if n == "print-line" then True
   else if n == "text-length" then True
   else if n == "is-letter" then True
   else if n == "is-digit" then True
   else if n == "is-whitespace" then True
   else if n == "text-to-integer" then True
   else if n == "integer-to-text" then True
   else if n == "char-code" then True
   else if n == "char-code-at" then True
   else if n == "code-to-char" then True
   else if n == "char-to-text" then True
   else if n == "list-length" then True
   else if n == "char-at" then True
   else if n == "substring" then True
   else if n == "list-at" then True
   else if n == "list-insert-at" then True
   else if n == "list-snoc" then True
   else if n == "list-contains" then True
   else if n == "text-compare" then True
   else if n == "text-replace" then True
   else if n == "open-file" then True
   else if n == "read-all" then True
   else if n == "close-file" then True
   else if n == "read-line" then True
   else if n == "read-file" then True
   else if n == "write-file" then True
   else if n == "write-binary" then True
   else if n == "file-exists" then True
   else if n == "list-files" then True
   else if n == "text-concat-list" then True
   else if n == "text-split" then True
   else if n == "text-contains" then True
   else if n == "text-starts-with" then True
   else if n == "get-args" then True
   else if n == "get-env" then True
   else if n == "current-dir" then True
   else if n == "run-process" then True
   else if n == "fork" then True
   else if n == "await" then True
   else if n == "par" then True
   else if n == "race" then True
   else False

  emit-builtin : Text -> List IRExpr -> List ArityEntry -> Text
  emit-builtin (n) (args) (arities) =
   if n == "show" then emit-builtin-show args arities
   else if n == "negate" then "(-" ++ emit-expr (list-at args 0) arities ++ ")"
   else if n == "print-line" then emit-builtin-print-line args arities
   else if n == "text-length" then "((long)" ++ emit-expr (list-at args 0) arities ++ ".Length)"
   else if n == "is-letter" then emit-builtin-is-letter args arities
   else if n == "is-digit" then emit-builtin-is-digit args arities
   else if n == "is-whitespace" then "(" ++ emit-expr (list-at args 0) arities ++ " <= 2L)"
   else if n == "text-to-integer" then emit-builtin-text-to-integer args arities
   else if n == "integer-to-text" then emit-builtin-integer-to-text args arities
   else if n == "char-code" then emit-expr (list-at args 0) arities
   else if n == "char-code-at" then emit-builtin-char-code-at args arities
   else if n == "code-to-char" then emit-expr (list-at args 0) arities
   else if n == "char-to-text" then "((char)" ++ emit-expr (list-at args 0) arities ++ ").ToString()"
   else if n == "list-length" then "((long)" ++ emit-expr (list-at args 0) arities ++ ".Count)"
   else if n == "char-at" then emit-builtin-char-at args arities
   else if n == "substring" then emit-builtin-substring args arities
   else if n == "list-at" then emit-builtin-list-at args arities
   else if n == "list-insert-at" then emit-builtin-list-insert-at args arities
   else if n == "list-snoc" then emit-builtin-list-snoc args arities
   else if n == "list-contains" then emit-expr (list-at args 0) arities ++ ".Contains(" ++ emit-expr (list-at args 1) arities ++ ")"
   else if n == "text-compare" then emit-builtin-text-compare args arities
   else if n == "text-replace" then emit-builtin-text-replace args arities
   else if n == "open-file" then "File.OpenRead(" ++ emit-expr (list-at args 0) arities ++ ")"
   else if n == "read-all" then emit-builtin-read-all args arities
   else if n == "close-file" then emit-expr (list-at args 0) arities ++ ".Dispose()"
   else if n == "read-line" then "_Cce.FromUnicode(Console.ReadLine() ?? \"\")"
   else if n == "read-file" then emit-builtin-read-file args arities
   else if n == "write-file" then emit-builtin-write-file args arities
   else if n == "write-binary" then "((Func<object>)(() => { var _bl = (List<long>)" ++ emit-expr (list-at args 0) arities ++ "; using var _s = Console.OpenStandardOutput(); foreach (var _b in _bl) _s.WriteByte((byte)_b); _s.Flush(); return null; }))()"
   else if n == "file-exists" then emit-builtin-file-exists args arities
   else if n == "list-files" then emit-builtin-list-files args arities
   else if n == "text-concat-list" then "string.Concat(" ++ emit-expr (list-at args 0) arities ++ ")"
   else if n == "text-split" then emit-builtin-text-split args arities
   else if n == "text-contains" then emit-builtin-text-contains args arities
   else if n == "text-starts-with" then emit-builtin-text-starts-with args arities
   else if n == "get-args" then "Environment.GetCommandLineArgs().Select(_Cce.FromUnicode).ToList()"
   else if n == "get-env" then emit-builtin-get-env args arities
   else if n == "run-process" then emit-builtin-run-process args arities
   else if n == "current-dir" then "_Cce.FromUnicode(Directory.GetCurrentDirectory())"
   else if n == "fork" then "Task.Run(() => (" ++ emit-expr (list-at args 0) arities ++ ")(null))"
   else if n == "await" then "(" ++ emit-expr (list-at args 0) arities ++ ").Result"
   else if n == "par" then emit-builtin-par args arities
   else if n == "race" then emit-builtin-race args arities
   else ""

  emit-builtin-show : List IRExpr -> List ArityEntry -> Text
  emit-builtin-show (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(Convert.ToString(" ++ a0 ++ "))"

  emit-builtin-print-line : List IRExpr -> List ArityEntry -> Text
  emit-builtin-print-line (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "((Func<object>)(() => { Console.WriteLine(_Cce.ToUnicode(" ++ a0 ++ ")); return null; }))()"

  emit-builtin-is-letter : List IRExpr -> List ArityEntry -> Text
  emit-builtin-is-letter (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "(" ++ a0 ++ " >= 13L && " ++ a0 ++ " <= 64L)"

  emit-builtin-is-digit : List IRExpr -> List ArityEntry -> Text
  emit-builtin-is-digit (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "(" ++ a0 ++ " >= 3L && " ++ a0 ++ " <= 12L)"

  emit-builtin-text-to-integer : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-to-integer (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "long.Parse(_Cce.ToUnicode(" ++ a0 ++ "))"

  emit-builtin-integer-to-text : List IRExpr -> List ArityEntry -> Text
  emit-builtin-integer-to-text (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(" ++ a0 ++ ".ToString())"

  emit-builtin-char-code-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-char-code-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((long)" ++ a0 ++ "[(int)" ++ a1 ++ "])"

  emit-builtin-char-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-char-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((long)" ++ a0 ++ "[(int)" ++ a1 ++ "])"

  emit-builtin-substring : List IRExpr -> List ArityEntry -> Text
  emit-builtin-substring (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in a0 ++ ".Substring((int)" ++ a1 ++ ", (int)" ++ a2 ++ ")"

  emit-builtin-list-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ "[(int)" ++ a1 ++ "]"

  emit-builtin-list-insert-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-insert-at (args) (arities) =
   let elem-ty = when ir-expr-type (list-at args 0)
    if ListTy (et) -> et
    if _ -> ErrorTy
   in let ty = cs-type elem-ty
   in let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in "((Func<List<" ++ ty ++ ">>)(() => { var _l = new List<" ++ ty ++ ">(" ++ a0 ++ "); _l.Insert((int)" ++ a1 ++ ", " ++ a2 ++ "); return _l; }))()"

  emit-builtin-list-snoc : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-snoc (args) (arities) =
   let elem-ty = when ir-expr-type (list-at args 0)
    if ListTy (et) -> et
    if _ -> ErrorTy
   in let ty = cs-type elem-ty
   in let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((Func<List<" ++ ty ++ ">>)(() => { var _l = " ++ a0 ++ "; _l.Add(" ++ a1 ++ "); return _l; }))()"

  emit-builtin-text-compare : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-compare (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "(long)string.CompareOrdinal(" ++ a0 ++ ", " ++ a1 ++ ")"

  emit-builtin-text-replace : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-replace (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in a0 ++ ".Replace(" ++ a1 ++ ", " ++ a2 ++ ")"

  emit-builtin-read-all : List IRExpr -> List ArityEntry -> Text
  emit-builtin-read-all (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "new System.IO.StreamReader(" ++ a0 ++ ").ReadToEnd()"

  emit-builtin-read-file : List IRExpr -> List ArityEntry -> Text
  emit-builtin-read-file (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(File.ReadAllText(_Cce.ToUnicode(" ++ a0 ++ ")))"

  emit-builtin-write-file : List IRExpr -> List ArityEntry -> Text
  emit-builtin-write-file (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "File.WriteAllText(_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ "))"

  emit-builtin-file-exists : List IRExpr -> List ArityEntry -> Text
  emit-builtin-file-exists (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "File.Exists(_Cce.ToUnicode(" ++ a0 ++ "))"

  emit-builtin-list-files : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-files (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "Directory.GetFiles(_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ ")).Select(_Cce.FromUnicode).ToList()"

  emit-builtin-text-split : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-split (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "new List<string>(" ++ a0 ++ ".Split(" ++ a1 ++ "))"

  emit-builtin-text-contains : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-contains (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ ".Contains(" ++ a1 ++ ")"

  emit-builtin-text-starts-with : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-starts-with (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ ".StartsWith(" ++ a1 ++ ")"

  emit-builtin-get-env : List IRExpr -> List ArityEntry -> Text
  emit-builtin-get-env (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(Environment.GetEnvironmentVariable(_Cce.ToUnicode(" ++ a0 ++ ")) ?? \"\")"

  emit-builtin-run-process : List IRExpr -> List ArityEntry -> Text
  emit-builtin-run-process (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "_Cce.FromUnicode(((Func<string>)(() => {"
   ++ " var _psi = new System.Diagnostics.ProcessStartInfo("
   ++ "_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ "))"
   ++ " { RedirectStandardOutput = true, UseShellExecute = false };"
   ++ " var _p = System.Diagnostics.Process.Start(_psi)!;"
   ++ " var _o = _p.StandardOutput.ReadToEnd();"
   ++ " _p.WaitForExit(); return _o; }))()"

  emit-builtin-par : List IRExpr -> List ArityEntry -> Text
  emit-builtin-par (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "Task.WhenAll(" ++ a1 ++ ".Select(_x_ => Task.Run(() => (" ++ a0 ++ ")(_x_)))).Result.ToList()"

  emit-builtin-race : List IRExpr -> List ArityEntry -> Text
  emit-builtin-race (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "Task.WhenAny(" ++ a0 ++ ".Select(_t_ => Task.Run(() => _t_(null)))).Result.Result"

  emit-apply : IRExpr -> List ArityEntry -> Text
  emit-apply (e) (arities) =
   let chain = collect-apply-chain e []
   in let root = chain.root
   in let args = chain.args
   in when root
      if IrName (n) (ty) ->
       if is-builtin-name n then emit-builtin n args arities
       else if text-length n > 0 & is-upper-letter (char-at n 0) then let result-ty = ir-expr-type e
   in let ctor-type-args = extract-ctor-type-args result-ty
   in "new " ++ sanitize n ++ ctor-type-args ++ "(" ++ emit-apply-args args arities 0 ++ ")"
   else let ar = lookup-arity arities n
   in if ar > 1 & list-length args == ar then sanitize n ++ "(" ++ emit-apply-args args arities 0 ++ ")"
            else if ar > 1 & list-length args < ar then let remaining = ar - list-length args
   in emit-partial-wrappers 0 remaining ++ sanitize n ++ "(" ++ emit-apply-args args arities 0 ++ ", " ++ emit-partial-params 0 remaining ++ ")"
           else emit-expr-curried e arities
      if _ -> emit-expr-curried e arities

  emit-expr-curried : IRExpr -> List ArityEntry -> Text
  emit-expr-curried (e) (arities) =
   when e
    if IrApply (f) (a) (ty) -> emit-expr f arities ++ "(" ++ emit-expr a arities ++ ")"
    if _ -> emit-expr e arities

Section: Expression Emission

  emit-expr : IRExpr -> List ArityEntry -> Text
  emit-expr (e) (arities) =
   when e
    if IrIntLit (n) -> integer-to-text n ++ "L"
    if IrNumLit (n) -> integer-to-text n
    if IrTextLit (s) -> "\"" ++ escape-text s ++ "\""
    if IrBoolLit (b) -> if b then "true" else "false"
    if IrCharLit (n) -> integer-to-text n
    if IrName (n) (ty) -> if n == "read-line" then "_Cce.FromUnicode(Console.ReadLine() ?? \"\")" else if n == "get-args" then "Environment.GetCommandLineArgs().Select(_Cce.FromUnicode).ToList()" else if n == "current-dir" then "_Cce.FromUnicode(Directory.GetCurrentDirectory())" else if text-length n > 0 & is-upper-letter (char-at n 0) then "new " ++ sanitize n ++ "()" else if lookup-arity arities n == 0 then sanitize n ++ "()" else let ar = lookup-arity arities n in if ar >= 2 then emit-partial-wrappers 0 ar ++ sanitize n ++ "(" ++ emit-partial-params 0 ar ++ ")" else sanitize n
    if IrBinary (op) (l) (r) (ty) -> emit-binary op l r ty arities
    if IrNegate (operand) -> "(-" ++ emit-expr operand arities ++ ")"
    if IrIf (c) (t) (el) (ty) -> "(" ++ emit-expr c arities ++ " ? " ++ emit-expr t arities ++ " : " ++ emit-expr el arities ++ ")"
    if IrLet (name) (ty) (val) (body) -> emit-let name ty val body arities
    if IrApply (f) (a) (ty) -> emit-apply e arities
    if IrLambda (params) (body) (ty) -> emit-lambda params body arities
    if IrList (elems) (ty) -> emit-list elems ty arities
    if IrMatch (scrut) (branches) (ty) -> emit-match scrut branches ty arities
    if IrDo (stmts) (ty) -> emit-do stmts ty arities
    if IrHandle (eff) (body) (clauses) (ty) -> emit-handle eff body clauses ty arities
    if IrRecord (name) (fields) (ty) -> emit-record name fields arities
    if IrFieldAccess (rec) (field) (ty) -> emit-expr rec arities ++ "." ++ sanitize field
    if IrFork (body) (ty) -> "Task.Run(() => (" ++ emit-expr body arities ++ ")(null))"
    if IrAwait (task) (ty) -> "(" ++ emit-expr task arities ++ ").Result"
    if IrError (msg) (ty) -> "/* error: " ++ msg ++ " */ default"

  hex-digit : Integer -> Text
  hex-digit (n) =
   if n == 0 then "0"
   else if n == 1 then "1"
   else if n == 2 then "2"
   else if n == 3 then "3"
   else if n == 4 then "4"
   else if n == 5 then "5"
   else if n == 6 then "6"
   else if n == 7 then "7"
   else if n == 8 then "8"
   else if n == 9 then "9"
   else if n == 10 then "A"
   else if n == 11 then "B"
   else if n == 12 then "C"
   else if n == 13 then "D"
   else if n == 14 then "E"
   else if n == 15 then "F"
   else "?"

  hex4 : Integer -> Text
  hex4 (n) =
   "00" ++ hex-digit (n / 16) ++ hex-digit (n - n / 16 * 16)

  escape-cce-char : Integer -> Text
  escape-cce-char (c) =
   "\\u" ++ hex4 c

  escape-text-loop : Text -> Integer -> Integer -> List Text -> List Text
  escape-text-loop (s) (i) (len) (acc) =
   if i == len then acc
   else escape-text-loop s (i + 1) len (list-snoc acc (escape-cce-char (char-code (char-at s i))))

  escape-text : Text -> Text
  escape-text (s) =
   text-concat-list (escape-text-loop s 0 (text-length s) [])

  emit-bin-op : IRBinaryOp -> Text
  emit-bin-op (op) =
   when op
    if IrAddInt -> "+"
    if IrSubInt -> "-"

    if IrMulInt -> "*"
    if IrDivInt -> "/"
    if IrPowInt -> "^"
    if IrAddNum -> "+"

    if IrSubNum -> "-"
    if IrMulNum -> "*"
    if IrDivNum -> "/"
    if IrEq -> "=="
    if IrNotEq -> "!="
    if IrLt -> "<"
    if IrGt -> ">"

    if IrLtEq -> "<="
    if IrGtEq -> ">="

    if IrAnd -> "&&"
    if IrOr -> "||"
    if IrAppendText -> "+"
    if IrAppendList -> "+"
    if IrConsList -> "+"

  emit-binary : IRBinaryOp -> IRExpr -> IRExpr -> CodexType -> List ArityEntry -> Text
  emit-binary (op) (l) (r) (ty) (arities) =
   when op
    if IrAppendList -> "Enumerable.Concat(" ++ emit-expr l arities ++ ", " ++ emit-expr r arities ++ ").ToList()"
    if IrConsList -> "new List<" ++ cs-type (ir-expr-type l) ++ "> { " ++ emit-expr l arities ++ " }.Concat(" ++ emit-expr r arities ++ ").ToList()"
    if _ -> "(" ++ emit-expr l arities ++ " " ++ emit-bin-op op ++ " " ++ emit-expr r arities ++ ")"

  emit-let : Text -> CodexType -> IRExpr -> IRExpr -> List ArityEntry -> Text
  emit-let (name) (ty) (val) (body) (arities) =
   "((Func<" ++ cs-type ty ++ ", " ++ cs-type (ir-expr-type body) ++ ">)((" ++ sanitize name ++ ") => " ++ emit-expr body arities ++ "))(" ++ emit-expr val arities ++ ")"

  emit-lambda : List IRParam -> IRExpr -> List ArityEntry -> Text
  emit-lambda (params) (body) (arities) =
   if list-length params == 0 then "(() => " ++ emit-expr body arities ++ ")"
   else if list-length params == 1 then let p = list-at params 0
     in "((" ++ cs-type (p.type-val) ++ " " ++ sanitize (p.name) ++ ") => " ++ emit-expr body arities ++ ")"
    else "(() => " ++ emit-expr body arities ++ ")"

  emit-list : List IRExpr -> CodexType -> List ArityEntry -> Text
  emit-list (elems) (ty) (arities) =
   if list-length elems == 0 then "new List<" ++ cs-type ty ++ ">()"
   else "new List<" ++ cs-type ty ++ "> { " ++ emit-list-elems elems 0 arities ++ " }"

  emit-list-elems : List IRExpr -> Integer -> List ArityEntry -> Text
  emit-list-elems (elems) (i) (arities) =
   if i == list-length elems then ""
   else if i == list-length elems - 1 then emit-expr (list-at elems i) arities
   else emit-expr (list-at elems i) arities ++ ", " ++ emit-list-elems elems (i + 1) arities

  emit-match : IRExpr -> List IRBranch -> CodexType -> List ArityEntry -> Text
  emit-match (scrut) (branches) (ty) (arities) =
   let arms = emit-match-arms branches 0 arities
   in let needs-wild = if has-any-catch-all branches 0 then False else True
   in emit-expr scrut arities ++ " switch { " ++ arms ++ (if needs-wild then "_ => throw new InvalidOperationException(\"Non-exhaustive match\"), " else "") ++ "}"

  emit-match-arms : List IRBranch -> Integer -> List ArityEntry -> Text
  emit-match-arms (branches) (i) (arities) =
   if i == list-length branches then ""
   else let arm = list-at branches i
   in let this-arm = emit-pattern (arm.pattern) ++ " => " ++ emit-expr (arm.body) arities ++ ", "
   in if is-catch-all (arm.pattern) then this-arm
        else this-arm ++ emit-match-arms branches (i + 1) arities

  is-catch-all : IRPat -> Boolean
  is-catch-all (p) =
   when p
    if IrWildPat -> True
    if IrVarPat (name) (ty) -> True
    if _ -> False

  has-any-catch-all : List IRBranch -> Integer -> Boolean
  has-any-catch-all (branches) (i) =
   if i == list-length branches then False
   else let b = list-at branches i
   in if is-catch-all (b.pattern) then True
      else has-any-catch-all branches (i + 1)
  emit-pattern : IRPat -> Text
  emit-pattern (p) =
   when p
    if IrVarPat (name) (ty) -> cs-type ty ++ " " ++ sanitize name
    if IrLitPat (text) (ty) -> text
    if IrCtorPat (name) (subs) (ty) ->
     if list-length subs == 0 then sanitize name ++ " { }"
      else sanitize name ++ "(" ++ emit-sub-patterns subs 0 ++ ")"
    if IrWildPat -> "_"

  emit-sub-patterns : List IRPat -> Integer -> Text
  emit-sub-patterns (subs) (i) =
   if i == list-length subs then ""
   else let sub = list-at subs i
   in emit-sub-pattern sub ++ (if i < list-length subs - 1 then ", " else "") ++ emit-sub-patterns subs (i + 1)

  emit-sub-pattern : IRPat -> Text
  emit-sub-pattern (p) =
   when p
    if IrVarPat (name) (ty) -> "var " ++ sanitize name
    if IrCtorPat (name) (subs) (ty) -> emit-pattern p
    if IrWildPat -> "_"
    if IrLitPat (text) (ty) -> text

  emit-do : List IRDoStmt -> CodexType -> List ArityEntry -> Text
  emit-do (stmts) (ty) (arities) =
   let ret-type = cs-type ty
   in let len = list-length stmts
   in when ty
    if VoidTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    if NothingTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    if ErrorTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    if _ -> if len == 0 then "((Func<" ++ ret-type ++ ">)(() => { return null; }))()"
    else "((Func<" ++ ret-type ++ ">)(() => { " ++ emit-do-stmts stmts 0 len True arities ++ " }))()"

  emit-do-stmts : List IRDoStmt -> Integer -> Integer -> Boolean -> List ArityEntry -> Text
  emit-do-stmts (stmts) (i) (len) (needs-return) (arities) =
   if i == len then ""
   else let s = list-at stmts i
   in let is-last = i == len - 1
   in let use-return = if is-last then needs-return else False
   in emit-do-stmt s use-return arities ++ " " ++ emit-do-stmts stmts (i + 1) len needs-return arities

  emit-do-stmt : IRDoStmt -> Boolean -> List ArityEntry -> Text
  emit-do-stmt (s) (use-return) (arities) =
   when s
    if IrDoBind (name) (ty) (val) -> "var " ++ sanitize name ++ " = " ++ emit-expr val arities ++ ";"
    if IrDoExec (e) ->
     if use-return then "return " ++ emit-expr e arities ++ ";"
     else emit-expr e arities ++ ";"

  emit-record : Text -> List IRFieldVal -> List ArityEntry -> Text
  emit-record (name) (fields) (arities) =
   "new " ++ sanitize name ++ "(" ++ emit-record-fields fields 0 arities ++ ")"

  emit-record-fields : List IRFieldVal -> Integer -> List ArityEntry -> Text
  emit-record-fields (fields) (i) (arities) =
   if i == list-length fields then ""
   else let f = list-at fields i
   in sanitize (f.name) ++ ": " ++ emit-expr (f.value) arities ++ (if i < list-length fields - 1 then ", " else "") ++ emit-record-fields fields (i + 1) arities

  emit-handle : Text -> IRExpr -> List IRHandleClause -> CodexType -> List ArityEntry -> Text
  emit-handle (eff) (body) (clauses) (ty) (arities) =
   let ret-type = cs-type ty
   in "((Func<" ++ ret-type ++ ">)(() => { " ++ emit-handle-clauses clauses ret-type arities ++ "return " ++ emit-expr body arities ++ "; }))()"

  emit-handle-clauses : List IRHandleClause -> Text -> List ArityEntry -> Text
  emit-handle-clauses (clauses) (ret-type) (arities) =
   emit-handle-clauses-loop clauses 0 ret-type arities

  emit-handle-clauses-loop : List IRHandleClause -> Integer -> Text -> List ArityEntry -> Text
  emit-handle-clauses-loop (clauses) (i) (ret-type) (arities) =
   if i == list-length clauses then ""
   else let c = list-at clauses i
   in "Func<Func<" ++ ret-type ++ ", " ++ ret-type ++ ">, " ++ ret-type ++ "> _handle_" ++ sanitize (c.op-name) ++ "_ = (" ++ sanitize (c.resume-name) ++ ") => { return " ++ emit-expr (c.body) arities ++ "; }; " ++ emit-handle-clauses-loop clauses (i + 1) ret-type arities

