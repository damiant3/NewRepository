Chapter: CSharp Emitter

 Expression emission: identifiers, arity, apply chains, dispatch.

Section: Identifier Helpers

  cs-keywords : List Text
  cs-keywords =
   let unsorted = ["abstract", "as", "base", "bool", "break",
    "case", "catch", "class", "continue", "decimal",
    "default", "delegate", "do", "double", "else",
    "event", "false", "finally", "for", "if",
    "in", "int", "internal", "is", "long",
    "namespace", "new", "null", "object", "out",
    "override", "params", "private", "protected", "public",
    "ref", "return", "sealed", "static", "string",
    "switch", "this", "throw", "true", "try",
    "typeof", "using", "virtual", "void", "while"]
   in sort-text-list unsorted

  is-cs-keyword : Text -> Boolean
  is-cs-keyword (n) = text-set-has cs-keywords n

  sanitize : Text -> Text
  sanitize (name) =
   let s = text-replace name "-" "_"
   in if is-cs-keyword s then "@" ++ s
      else if is-cs-member-name s then s ++ "_"
              else s

  cs-member-names : List Text
  cs-member-names =
   let unsorted = ["Equals", "GetHashCode", "GetType", "MemberwiseClone", "ToString"]
   in sort-text-list unsorted

  is-cs-member-name : Text -> Boolean
  is-cs-member-name (n) = text-set-has cs-member-names n

  cs-type : CodexType -> Text
  cs-type (ty) =
   when ty
    is IntegerTy -> "long"
    is NumberTy -> "double"
    is TextTy -> "string"
    is BooleanTy -> "bool"
    is CharTy -> "long"
    is VoidTy -> "void"
    is NothingTy -> "object"
    is ErrorTy -> "object"
    is FunTy (p) (r) -> "Func<" ++ cs-type p ++ ", " ++ cs-type r ++ ">"
    is ListTy (elem) -> "List<" ++ cs-type elem ++ ">"
    is LinkedListTy (elem) -> "List<" ++ cs-type elem ++ ">"
    is TypeVar (id) -> "T" ++ integer-to-text id
    is ForAllTy (id) (body) -> cs-type body
    is SumTy (name) (ctors) -> sanitize (name.value)
    is RecordTy (name) (fields) -> sanitize (name.value)
    is ConstructedTy (name) (args) -> if list-length args == 0 then sanitize (name.value)
                                     else sanitize (name.value) ++ "<" ++ emit-cs-type-args args 0 ++ ">"
    is EffectfulTy (effects) (ret) -> cs-type ret

  emit-cs-type-args : List CodexType -> Integer -> Text
  emit-cs-type-args (args) (i) =
   if i == list-length args then ""
   else let t = cs-type (list-at args i)
   in if i == list-length args - 1 then t
      else t ++ ", " ++ emit-cs-type-args args (i + 1)

Section: Arity Map

  ArityEntry = record {
   name : Text,
   arity : Integer
  }

  build-arity-map : List IRDef -> Integer -> List ArityEntry -> List ArityEntry
  build-arity-map (defs) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in build-arity-map defs (i + 1) (list-snoc acc (ArityEntry {
    name = d.name,
    arity = list-length (d.params)
   }))

  build-arity-map-from-ast : List ADef -> Integer -> List ArityEntry -> List ArityEntry
  build-arity-map-from-ast (defs) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in build-arity-map-from-ast defs (i + 1) (list-snoc acc (ArityEntry {
    name = d.name.value,
    arity = list-length (d.params)
   }))

  lookup-arity : List ArityEntry -> Text -> Integer
  lookup-arity (entries) (name) =
   lookup-arity-loop entries name 0 (list-length entries)

  lookup-arity-loop : List ArityEntry -> Text -> Integer -> Integer -> Integer
  lookup-arity-loop (entries) (name) (i) (len) =
   if i == len then -1
   else let e = list-at entries i
   in if e.name == name then e.arity
      else lookup-arity-loop entries name (i + 1) len

Section: Apply Chain

  ApplyChain = record {
   root : IRExpr,
   args : List IRExpr
  }

  collect-apply-chain : IRExpr -> List IRExpr -> ApplyChain
  collect-apply-chain (e) (acc) =
   when e
    is IrApply (f) (a) (ty) (sp) -> collect-apply-chain f ([a] ++ acc)
    is otherwise -> ApplyChain {
     root = e,
     args = acc
    }

  is-upper-letter : Char -> Boolean
  is-upper-letter (c) =
   let code = char-code c
   in code >= char-code 'E' & code <= char-code 'Z'

  emit-apply-args : List IRExpr -> List ArityEntry -> Integer -> Text
  emit-apply-args (args) (arities) (i) =
   if i == list-length args then ""
   else if i == list-length args - 1 then emit-expr (list-at args i) arities
        else emit-expr (list-at args i) arities ++ ", " ++ emit-apply-args args arities (i + 1)

  emit-partial-params : Integer -> Integer -> Text
  emit-partial-params (i) (count) =
   if i == count then ""
   else if i == count - 1 then "_p" ++ integer-to-text i ++ "_"
        else "_p" ++ integer-to-text i ++ "_" ++ ", " ++ emit-partial-params (i + 1) count

  emit-partial-wrappers : Integer -> Integer -> Text
  emit-partial-wrappers (i) (count) =
   if i == count then ""
   else "(_p" ++ integer-to-text i ++ "_) => " ++ emit-partial-wrappers (i + 1) count

  BuiltinEmitter = record {
   name : Text,
   emit : List IRExpr -> List ArityEntry -> CodexType -> Text
  }

  bsearch-emitter-pos : List BuiltinEmitter -> Text -> Integer -> Integer -> Integer
  bsearch-emitter-pos (entries) (name) (lo) (hi) =
   if lo >= hi then lo
   else let mid = lo + (hi - lo) / 2
   in let mid-name = (list-at entries mid).name
   in if text-compare name mid-name <= 0 then bsearch-emitter-pos entries name lo mid
      else bsearch-emitter-pos entries name (mid + 1) hi

  sorted-insert-emitter : List BuiltinEmitter -> BuiltinEmitter -> List BuiltinEmitter
  sorted-insert-emitter (xs) (e) =
   let len = list-length xs
   in let pos = bsearch-emitter-pos xs (e.name) 0 len
   in list-insert-at xs pos e

  sort-emitters : List BuiltinEmitter -> List BuiltinEmitter
  sort-emitters (xs) = fold-list sorted-insert-emitter [] xs

  builtin-emitters : List BuiltinEmitter = sort-emitters [
   BuiltinEmitter { name = "show", emit = \args -> \arities -> \ty -> emit-builtin-show args arities },
   BuiltinEmitter { name = "negate", emit = \args -> \arities -> \ty -> "(-" ++ emit-expr (list-at args 0) arities ++ ")" },
   BuiltinEmitter { name = "print-line", emit = \args -> \arities -> \ty -> emit-builtin-print-line args arities },
   BuiltinEmitter { name = "text-length", emit = \args -> \arities -> \ty -> "((long)" ++ emit-expr (list-at args 0) arities ++ ".Length)" },
   BuiltinEmitter { name = "is-letter", emit = \args -> \arities -> \ty -> emit-builtin-is-letter args arities },
   BuiltinEmitter { name = "is-digit", emit = \args -> \arities -> \ty -> emit-builtin-is-digit args arities },
   BuiltinEmitter { name = "is-whitespace", emit = \args -> \arities -> \ty -> "(" ++ emit-expr (list-at args 0) arities ++ " <= 2L)" },
   BuiltinEmitter { name = "text-to-integer", emit = \args -> \arities -> \ty -> emit-builtin-text-to-integer args arities },
   BuiltinEmitter { name = "text-to-double-bits", emit = \args -> \arities -> \ty -> emit-builtin-text-to-double-bits args arities },
   BuiltinEmitter { name = "integer-to-text", emit = \args -> \arities -> \ty -> emit-builtin-integer-to-text args arities },
   BuiltinEmitter { name = "char-code", emit = \args -> \arities -> \ty -> emit-expr (list-at args 0) arities },
   BuiltinEmitter { name = "char-code-at", emit = \args -> \arities -> \ty -> emit-builtin-char-code-at args arities },
   BuiltinEmitter { name = "code-to-char", emit = \args -> \arities -> \ty -> emit-expr (list-at args 0) arities },
   BuiltinEmitter { name = "char-to-text", emit = \args -> \arities -> \ty -> "((char)" ++ emit-expr (list-at args 0) arities ++ ").ToString()" },
   BuiltinEmitter { name = "list-length", emit = \args -> \arities -> \ty -> "((long)" ++ emit-expr (list-at args 0) arities ++ ".Count)" },
   BuiltinEmitter { name = "char-at", emit = \args -> \arities -> \ty -> emit-builtin-char-at args arities },
   BuiltinEmitter { name = "substring", emit = \args -> \arities -> \ty -> emit-builtin-substring args arities },
   BuiltinEmitter { name = "list-at", emit = \args -> \arities -> \ty -> emit-builtin-list-at args arities },
   BuiltinEmitter { name = "list-insert-at", emit = \args -> \arities -> \ty -> emit-builtin-list-insert-at args arities },
   BuiltinEmitter { name = "list-set-at", emit = \args -> \arities -> \ty -> emit-builtin-list-set-at args arities },
   BuiltinEmitter { name = "list-snoc", emit = \args -> \arities -> \ty -> emit-builtin-list-snoc args arities },
   BuiltinEmitter { name = "list-contains", emit = \args -> \arities -> \ty -> emit-expr (list-at args 0) arities ++ ".Contains(" ++ emit-expr (list-at args 1) arities ++ ")" },
   BuiltinEmitter { name = "text-compare", emit = \args -> \arities -> \ty -> emit-builtin-text-compare args arities },
   BuiltinEmitter { name = "text-replace", emit = \args -> \arities -> \ty -> emit-builtin-text-replace args arities },
   BuiltinEmitter { name = "open-file", emit = \args -> \arities -> \ty -> "File.OpenRead(" ++ emit-expr (list-at args 0) arities ++ ")" },
   BuiltinEmitter { name = "read-all", emit = \args -> \arities -> \ty -> emit-builtin-read-all args arities },
   BuiltinEmitter { name = "close-file", emit = \args -> \arities -> \ty -> emit-expr (list-at args 0) arities ++ ".Dispose()" },
   BuiltinEmitter { name = "read-line", emit = \args -> \arities -> \ty -> "_Cce.FromUnicode(Console.ReadLine() ?? \"\")" },
   BuiltinEmitter { name = "read-file", emit = \args -> \arities -> \ty -> emit-builtin-read-file args arities },
   BuiltinEmitter { name = "write-file", emit = \args -> \arities -> \ty -> emit-builtin-write-file args arities },
   BuiltinEmitter { name = "write-binary", emit = \args -> \arities -> \ty -> "((Func<object>)(() => { var _bl = (List<long>)" ++ emit-expr (list-at args 0) arities ++ "; using var _s = Console.OpenStandardOutput(); foreach (var _b in _bl) _s.WriteByte((byte)_b); _s.Flush(); return null; }))()" },
   BuiltinEmitter { name = "file-exists", emit = \args -> \arities -> \ty -> emit-builtin-file-exists args arities },
   BuiltinEmitter { name = "list-files", emit = \args -> \arities -> \ty -> emit-builtin-list-files args arities },
   BuiltinEmitter { name = "text-concat-list", emit = \args -> \arities -> \ty -> "string.Concat(" ++ emit-expr (list-at args 0) arities ++ ")" },
   BuiltinEmitter { name = "text-split", emit = \args -> \arities -> \ty -> emit-builtin-text-split args arities },
   BuiltinEmitter { name = "text-contains", emit = \args -> \arities -> \ty -> emit-builtin-text-contains args arities },
   BuiltinEmitter { name = "text-starts-with", emit = \args -> \arities -> \ty -> emit-builtin-text-starts-with args arities },
   BuiltinEmitter { name = "get-args", emit = \args -> \arities -> \ty -> "Environment.GetCommandLineArgs().Select(_Cce.FromUnicode).ToList()" },
   BuiltinEmitter { name = "get-env", emit = \args -> \arities -> \ty -> emit-builtin-get-env args arities },
   BuiltinEmitter { name = "current-dir", emit = \args -> \arities -> \ty -> "_Cce.FromUnicode(Directory.GetCurrentDirectory())" },
   BuiltinEmitter { name = "run-process", emit = \args -> \arities -> \ty -> emit-builtin-run-process args arities },
   BuiltinEmitter { name = "fork", emit = \args -> \arities -> \ty -> "Task.Run(() => (" ++ emit-expr (list-at args 0) arities ++ ")(null))" },
   BuiltinEmitter { name = "await", emit = \args -> \arities -> \ty -> "(" ++ emit-expr (list-at args 0) arities ++ ").Result" },
   BuiltinEmitter { name = "par", emit = \args -> \arities -> \ty -> emit-builtin-par args arities },
   BuiltinEmitter { name = "race", emit = \args -> \arities -> \ty -> emit-builtin-race args arities },
   BuiltinEmitter { name = "record-set", emit = \args -> \arities -> \ty -> emit-builtin-record-set args arities },
   BuiltinEmitter { name = "linked-list-empty", emit = \args -> \arities -> \ty -> let et = when ty is LinkedListTy (elem) -> cs-type elem is otherwise -> "object" in "new List<" ++ et ++ ">()" },
   BuiltinEmitter { name = "linked-list-push", emit = \args -> \arities -> \ty -> let et = when ty is LinkedListTy (elem) -> cs-type elem is otherwise -> "object" in "((Func<List<" ++ et ++ ">, " ++ et ++ ", List<" ++ et ++ ">>)((_ll, _v) => { _ll.Add(_v); return _ll; }))(" ++ emit-expr (list-at args 0) arities ++ ", " ++ emit-expr (list-at args 1) arities ++ ")" },
   BuiltinEmitter { name = "linked-list-to-list", emit = \args -> \arities -> \ty -> emit-expr (list-at args 0) arities },
   BuiltinEmitter { name = "heap-save", emit = \args -> \arities -> \ty -> "_Buf.heap_save()" },
   BuiltinEmitter { name = "heap-restore", emit = \args -> \arities -> \ty -> emit-buf-call-1 "heap-restore" args arities },
   BuiltinEmitter { name = "heap-advance", emit = \args -> \arities -> \ty -> emit-buf-call-1 "heap-advance" args arities },
   BuiltinEmitter { name = "list-with-capacity", emit = \args -> \arities -> \ty -> emit-buf-call-1 "list-with-capacity" args arities },
   BuiltinEmitter { name = "buf-write-byte", emit = \args -> \arities -> \ty -> emit-buf-call-3 "buf-write-byte" args arities },
   BuiltinEmitter { name = "buf-write-bytes", emit = \args -> \arities -> \ty -> emit-buf-call-3 "buf-write-bytes" args arities },
   BuiltinEmitter { name = "buf-read-bytes", emit = \args -> \arities -> \ty -> emit-buf-call-3 "buf-read-bytes" args arities },
   BuiltinEmitter { name = "bit-and", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-and" args arities },
   BuiltinEmitter { name = "bit-or", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-or" args arities },
   BuiltinEmitter { name = "bit-xor", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-xor" args arities },
   BuiltinEmitter { name = "bit-shl", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-shl" args arities },
   BuiltinEmitter { name = "bit-shr", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-shr" args arities },
   BuiltinEmitter { name = "bit-not", emit = \args -> \arities -> \ty -> emit-bit-builtin "bit-not" args arities }
  ]

  is-builtin-name : Text -> Boolean
  is-builtin-name (n) =
   let len = list-length builtin-emitters
   in let pos = bsearch-emitter-pos builtin-emitters n 0 len
   in if pos >= len then False
      else (list-at builtin-emitters pos).name == n

  emit-builtin : Text -> List IRExpr -> List ArityEntry -> CodexType -> Text
  emit-builtin (n) (args) (arities) (result-ty) =
   let len = list-length builtin-emitters
   in let pos = bsearch-emitter-pos builtin-emitters n 0 len
   in if pos >= len then ""
      else let entry = list-at builtin-emitters pos
      in if entry.name == n then entry.emit args arities result-ty
         else ""

  cs-name-for : Text -> Text
  cs-name-for (n) = text-replace n "-" "_"

  emit-buf-call-1 : Text -> List IRExpr -> List ArityEntry -> Text
  emit-buf-call-1 (n) (args) (arities) =
   "_Buf." ++ cs-name-for n ++ "(" ++ emit-expr (list-at args 0) arities ++ ")"

  emit-buf-call-3 : Text -> List IRExpr -> List ArityEntry -> Text
  emit-buf-call-3 (n) (args) (arities) =
   "_Buf." ++ cs-name-for n ++ "("
    ++ emit-expr (list-at args 0) arities ++ ", "
    ++ emit-expr (list-at args 1) arities ++ ", "
    ++ emit-expr (list-at args 2) arities ++ ")"

  bit-op-symbol : Text -> Text
  bit-op-symbol (n) =
   if n == "bit-and" then " & "
   else if n == "bit-or" then " | "
   else if n == "bit-xor" then " ^ "
   else if n == "bit-shl" then " << (int)"
   else if n == "bit-shr" then " >> (int)"
   else ""

  emit-bit-builtin : Text -> List IRExpr -> List ArityEntry -> Text
  emit-bit-builtin (n) (args) (arities) =
   if n == "bit-not" then "(~" ++ emit-expr (list-at args 0) arities ++ ")"
   else "(" ++ emit-expr (list-at args 0) arities ++ bit-op-symbol n ++ emit-expr (list-at args 1) arities ++ ")"

  emit-builtin-record-set : List IRExpr -> List ArityEntry -> Text
  emit-builtin-record-set (args) (arities) =
   let field-name = when (list-at args 1)
    is IrTextLit (s) (sp) -> s
    is otherwise -> ""
   in "(" ++ emit-expr (list-at args 0) arities ++ " with { " ++ sanitize field-name ++ " = " ++ emit-expr (list-at args 2) arities ++ " })"

  emit-builtin-show : List IRExpr -> List ArityEntry -> Text
  emit-builtin-show (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(Convert.ToString(" ++ a0 ++ "))"

  emit-builtin-print-line : List IRExpr -> List ArityEntry -> Text
  emit-builtin-print-line (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "((Func<object>)(() => { Console.WriteLine(_Cce.ToUnicode(" ++ a0 ++ ")); return null; }))()"

  emit-builtin-is-letter : List IRExpr -> List ArityEntry -> Text
  emit-builtin-is-letter (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "(" ++ a0 ++ " >= 13L && " ++ a0 ++ " <= 64L)"

  emit-builtin-is-digit : List IRExpr -> List ArityEntry -> Text
  emit-builtin-is-digit (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "(" ++ a0 ++ " >= 3L && " ++ a0 ++ " <= 12L)"

  emit-builtin-text-to-integer : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-to-integer (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "long.Parse(_Cce.ToUnicode(" ++ a0 ++ "))"

  emit-builtin-text-to-double-bits : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-to-double-bits (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "BitConverter.DoubleToInt64Bits(double.Parse(_Cce.ToUnicode(" ++ a0 ++ "), System.Globalization.CultureInfo.InvariantCulture))"

  emit-builtin-integer-to-text : List IRExpr -> List ArityEntry -> Text
  emit-builtin-integer-to-text (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(" ++ a0 ++ ".ToString())"

  emit-builtin-char-code-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-char-code-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((long)" ++ a0 ++ "[(int)" ++ a1 ++ "])"

  emit-builtin-char-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-char-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((long)" ++ a0 ++ "[(int)" ++ a1 ++ "])"

  emit-builtin-substring : List IRExpr -> List ArityEntry -> Text
  emit-builtin-substring (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in a0 ++ ".Substring((int)" ++ a1 ++ ", (int)" ++ a2 ++ ")"

  emit-builtin-list-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-at (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ "[(int)" ++ a1 ++ "]"

  emit-builtin-list-insert-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-insert-at (args) (arities) =
   let elem-ty = when ir-expr-type (list-at args 0)
    is ListTy (et) -> et
    is otherwise -> ErrorTy
   in let ty = cs-type elem-ty
   in let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in "((Func<List<" ++ ty ++ ">>)(() => { var _l = new List<" ++ ty ++ ">(" ++ a0 ++ "); _l.Insert((int)" ++ a1 ++ ", " ++ a2 ++ "); return _l; }))()"

  emit-builtin-list-set-at : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-set-at (args) (arities) =
   let elem-ty = when ir-expr-type (list-at args 0)
    is ListTy (et) -> et
    is otherwise -> ErrorTy
   in let ty = cs-type elem-ty
   in let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in "((Func<List<" ++ ty ++ ">>)(() => { var _l = " ++ a0 ++ "; _l[(int)" ++ a1 ++ "] = " ++ a2 ++ "; return _l; }))()"

  emit-builtin-list-snoc : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-snoc (args) (arities) =
   let elem-ty = when ir-expr-type (list-at args 0)
    is ListTy (et) -> et
    is otherwise -> ErrorTy
   in let ty = cs-type elem-ty
   in let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "((Func<List<" ++ ty ++ ">>)(() => { var _l = " ++ a0 ++ "; _l.Add(" ++ a1 ++ "); return _l; }))()"

  emit-builtin-text-compare : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-compare (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "(long)string.CompareOrdinal(" ++ a0 ++ ", " ++ a1 ++ ")"

  emit-builtin-text-replace : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-replace (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in let a2 = emit-expr (list-at args 2) arities
   in a0 ++ ".Replace(" ++ a1 ++ ", " ++ a2 ++ ")"

  emit-builtin-read-all : List IRExpr -> List ArityEntry -> Text
  emit-builtin-read-all (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "new System.IO.StreamReader(" ++ a0 ++ ").ReadToEnd()"

  emit-builtin-read-file : List IRExpr -> List ArityEntry -> Text
  emit-builtin-read-file (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(File.ReadAllText(_Cce.ToUnicode(" ++ a0 ++ ")))"

  emit-builtin-write-file : List IRExpr -> List ArityEntry -> Text
  emit-builtin-write-file (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "File.WriteAllText(_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ "))"

  emit-builtin-file-exists : List IRExpr -> List ArityEntry -> Text
  emit-builtin-file-exists (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "File.Exists(_Cce.ToUnicode(" ++ a0 ++ "))"

  emit-builtin-list-files : List IRExpr -> List ArityEntry -> Text
  emit-builtin-list-files (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "Directory.GetFiles(_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ ")).Select(_Cce.FromUnicode).ToList()"

  emit-builtin-text-split : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-split (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "new List<string>(" ++ a0 ++ ".Split(" ++ a1 ++ "))"

  emit-builtin-text-contains : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-contains (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ ".Contains(" ++ a1 ++ ")"

  emit-builtin-text-starts-with : List IRExpr -> List ArityEntry -> Text
  emit-builtin-text-starts-with (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in a0 ++ ".StartsWith(" ++ a1 ++ ")"

  emit-builtin-get-env : List IRExpr -> List ArityEntry -> Text
  emit-builtin-get-env (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "_Cce.FromUnicode(Environment.GetEnvironmentVariable(_Cce.ToUnicode(" ++ a0 ++ ")) ?? \"\")"

  emit-builtin-run-process : List IRExpr -> List ArityEntry -> Text
  emit-builtin-run-process (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "_Cce.FromUnicode(((Func<string>)(() => {"
   ++ " var _psi = new System.Diagnostics.ProcessStartInfo("
   ++ "_Cce.ToUnicode(" ++ a0 ++ "), _Cce.ToUnicode(" ++ a1 ++ "))"
   ++ " { RedirectStandardOutput = true, UseShellExecute = false };"
   ++ " var _p = System.Diagnostics.Process.Start(_psi)!;"
   ++ " var _o = _p.StandardOutput.ReadToEnd();"
   ++ " _p.WaitForExit(); return _o; }))()"

  emit-builtin-par : List IRExpr -> List ArityEntry -> Text
  emit-builtin-par (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in let a1 = emit-expr (list-at args 1) arities
   in "Task.WhenAll(" ++ a1 ++ ".Select(_x_ => Task.Run(() => (" ++ a0 ++ ")(_x_)))).Result.ToList()"

  emit-builtin-race : List IRExpr -> List ArityEntry -> Text
  emit-builtin-race (args) (arities) =
   let a0 = emit-expr (list-at args 0) arities
   in "Task.WhenAny(" ++ a0 ++ ".Select(_t_ => Task.Run(() => _t_(null)))).Result.Result"

  emit-apply : IRExpr -> List ArityEntry -> Text
  emit-apply (e) (arities) =
   let chain = collect-apply-chain e []
   in let root = chain.root
   in let args = chain.args
   in when root
      is IrName (n) (ty) (sp) ->
       if is-builtin-name n then emit-builtin n args arities (ir-expr-type e)
       else if text-length n > 0 & is-upper-letter (char-at n 0) then let result-ty = ir-expr-type e
   in let ctor-type-args = extract-ctor-type-args result-ty
   in "new " ++ sanitize n ++ ctor-type-args ++ "(" ++ emit-apply-args args arities 0 ++ ")"
   else let ar = lookup-arity arities n
   in if ar > 1 & list-length args == ar then sanitize n ++ "(" ++ emit-apply-args args arities 0 ++ ")"
            else if ar > 1 & list-length args < ar then let remaining = ar - list-length args
   in emit-partial-wrappers 0 remaining ++ sanitize n ++ "(" ++ emit-apply-args args arities 0 ++ ", " ++ emit-partial-params 0 remaining ++ ")"
           else emit-expr-curried e arities
      is otherwise -> emit-expr-curried e arities

  emit-expr-curried : IRExpr -> List ArityEntry -> Text
  emit-expr-curried (e) (arities) =
   when e
    is IrApply (f) (a) (ty) (sp) -> emit-expr f arities ++ "(" ++ emit-expr a arities ++ ")"
    is otherwise -> emit-expr e arities

Section: Expression Emission

  emit-expr : IRExpr -> List ArityEntry -> Text
  emit-expr (e) (arities) =
   when e
    is IrIntLit (n) (sp) -> integer-to-text n ++ "L"
    is IrNumLit (n) (sp) -> "BitConverter.Int64BitsToDouble(" ++ integer-to-text n ++ "L)"
    is IrTextLit (s) (sp) -> "\"" ++ escape-text s ++ "\""
    is IrBoolLit (b) (sp) -> if b then "true" else "false"
    is IrCharLit (n) (sp) -> integer-to-text n
    is IrName (n) (ty) (sp) -> if n == "read-line" then "_Cce.FromUnicode(Console.ReadLine() ?? \"\")" else if n == "get-args" then "Environment.GetCommandLineArgs().Select(_Cce.FromUnicode).ToList()" else if n == "current-dir" then "_Cce.FromUnicode(Directory.GetCurrentDirectory())" else if n == "heap-save" then "_Buf.heap_save()" else if n == "heap-restore" then "new Func<object, long>(_p => _Buf.heap_restore(_p))" else if n == "heap-advance" then "new Func<object, long>(_n => _Buf.heap_advance(_n))" else if n == "list-with-capacity" then "new Func<object, List<long>>(_c => _Buf.list_with_capacity(_c))" else if n == "buf-write-byte" then "new Func<object, Func<object, Func<object, long>>>(_b => _o => _v => _Buf.buf_write_byte(_b, _o, _v))" else if n == "buf-write-bytes" then "new Func<object, Func<object, Func<object, long>>>(_b => _o => _vs => _Buf.buf_write_bytes(_b, _o, _vs))" else if n == "buf-read-bytes" then "new Func<object, Func<object, Func<object, List<long>>>>(_b => _o => _n => _Buf.buf_read_bytes(_b, _o, _n))" else if text-length n > 0 & is-upper-letter (char-at n 0) then "new " ++ sanitize n ++ "()" else if lookup-arity arities n == 0 then sanitize n ++ "()" else let ar = lookup-arity arities n in if ar >= 2 then emit-partial-wrappers 0 ar ++ sanitize n ++ "(" ++ emit-partial-params 0 ar ++ ")" else sanitize n
    is IrBinary (op) (l) (r) (ty) (sp) -> emit-binary op l r ty arities
    is IrNegate (operand) (sp) -> "(-" ++ emit-expr operand arities ++ ")"
    is IrIf (c) (t) (el) (ty) (sp) -> "(" ++ emit-expr c arities ++ " ? " ++ emit-expr t arities ++ " : " ++ emit-expr el arities ++ ")"
    is IrLet (name) (ty) (val) (body) (sp) -> emit-let name ty val body arities
    is IrApply (f) (a) (ty) (sp) -> emit-apply e arities
    is IrLambda (params) (body) (ty) (sp) -> emit-lambda params body arities
    is IrList (elems) (ty) (sp) -> emit-list elems ty arities
    is IrMatch (scrut) (branches) (ty) (sp) -> emit-match scrut branches ty arities
    is IrDo (stmts) (ty) (sp) -> emit-do stmts ty arities
    is IrHandle (eff) (body) (clauses) (ty) (sp) -> emit-handle eff body clauses ty arities
    is IrRecord (name) (fields) (ty) (sp) -> emit-record name fields arities
    is IrFieldAccess (rec) (field) (ty) (sp) -> emit-expr rec arities ++ "." ++ sanitize field
    is IrFork (body) (ty) (sp) -> "Task.Run(() => (" ++ emit-expr body arities ++ ")(null))"
    is IrAwait (task) (ty) (sp) -> "(" ++ emit-expr task arities ++ ").Result"
    is IrError (msg) (ty) (sp) -> "/* error: " ++ msg ++ " */ default"

  hex-digit : Integer -> Text
  hex-digit (n) =
   if n == 0 then "0"
   else if n == 1 then "1"
   else if n == 2 then "2"
   else if n == 3 then "3"
   else if n == 4 then "4"
   else if n == 5 then "5"
   else if n == 6 then "6"
   else if n == 7 then "7"
   else if n == 8 then "8"
   else if n == 9 then "9"
   else if n == 10 then "A"
   else if n == 11 then "B"
   else if n == 12 then "C"
   else if n == 13 then "D"
   else if n == 14 then "E"
   else if n == 15 then "F"
   else "?"

  hex4 : Integer -> Text
  hex4 (n) =
   "00" ++ hex-digit (n / 16) ++ hex-digit (n - n / 16 * 16)

  escape-cce-char : Integer -> Text
  escape-cce-char (c) =
   "\\u" ++ hex4 c

  escape-text-loop : Text -> Integer -> Integer -> List Text -> List Text
  escape-text-loop (s) (i) (len) (acc) =
   if i == len then acc
   else escape-text-loop s (i + 1) len (list-snoc acc (escape-cce-char (char-code (char-at s i))))

  escape-text : Text -> Text
  escape-text (s) =
   text-concat-list (escape-text-loop s 0 (text-length s) [])

  emit-bin-op : IRBinaryOp -> Text
  emit-bin-op (op) =
   when op
    is IrAddInt -> "+"
    is IrSubInt -> "-"

    is IrMulInt -> "*"
    is IrDivInt -> "/"
    is IrPowInt -> "^"
    is IrAddNum -> "+"

    is IrSubNum -> "-"
    is IrMulNum -> "*"
    is IrDivNum -> "/"
    is IrEq -> "=="
    is IrNotEq -> "!="
    is IrLt -> "<"
    is IrGt -> ">"

    is IrLtEq -> "<="
    is IrGtEq -> ">="

    is IrAnd -> "&&"
    is IrOr -> "||"
    is IrAppendText -> "+"
    is IrAppendList -> "+"
    is IrConsList -> "+"

  emit-binary : IRBinaryOp -> IRExpr -> IRExpr -> CodexType -> List ArityEntry -> Text
  emit-binary (op) (l) (r) (ty) (arities) =
   when op
    is IrAppendList -> "Enumerable.Concat(" ++ emit-expr l arities ++ ", " ++ emit-expr r arities ++ ").ToList()"
    is IrConsList -> "new List<" ++ cs-type (ir-expr-type l) ++ "> { " ++ emit-expr l arities ++ " }.Concat(" ++ emit-expr r arities ++ ").ToList()"
    is otherwise -> "(" ++ emit-expr l arities ++ " " ++ emit-bin-op op ++ " " ++ emit-expr r arities ++ ")"

  cs-type-or-dynamic : CodexType -> Text
  cs-type-or-dynamic (ty) =
   let t = cs-type ty
   in if t == "object" then "dynamic" else t

  emit-let : Text -> CodexType -> IRExpr -> IRExpr -> List ArityEntry -> Text
  emit-let (name) (ty) (val) (body) (arities) =
   "((Func<" ++ cs-type-or-dynamic ty ++ ", " ++ cs-type (ir-expr-type body) ++ ">)((" ++ sanitize name ++ ") => " ++ emit-expr body arities ++ "))(" ++ emit-expr val arities ++ ")"

  emit-lambda : List IRParam -> IRExpr -> List ArityEntry -> Text
  emit-lambda (params) (body) (arities) =
   if list-length params == 0 then "(() => " ++ emit-expr body arities ++ ")"
   else "(" ++ emit-lambda-params params 0 (list-length params) ++ emit-expr body arities ++ ")"

  emit-lambda-params : List IRParam -> Integer -> Integer -> Text
  emit-lambda-params (params) (i) (len) =
   if i == len then ""
   else let p = list-at params i
    in "(" ++ cs-type (p.type-val) ++ " " ++ sanitize (p.name) ++ ") => " ++ emit-lambda-params params (i + 1) len

  emit-list : List IRExpr -> CodexType -> List ArityEntry -> Text
  emit-list (elems) (ty) (arities) =
   if list-length elems == 0 then "new List<" ++ cs-type ty ++ ">()"
   else "new List<" ++ cs-type ty ++ "> { " ++ emit-list-elems elems 0 arities ++ " }"

  emit-list-elems : List IRExpr -> Integer -> List ArityEntry -> Text
  emit-list-elems (elems) (i) (arities) =
   if i == list-length elems then ""
   else if i == list-length elems - 1 then emit-expr (list-at elems i) arities
   else emit-expr (list-at elems i) arities ++ ", " ++ emit-list-elems elems (i + 1) arities

  emit-match : IRExpr -> List IRBranch -> CodexType -> List ArityEntry -> Text
  emit-match (scrut) (branches) (ty) (arities) =
   let result-cast = "(" ++ cs-type ty ++ ")"
   in let arms = emit-match-arms branches 0 arities result-cast
   in let needs-wild = if has-any-catch-all branches 0 then False else True
   in emit-expr scrut arities ++ " switch { " ++ arms ++ (if needs-wild then "_ => throw new InvalidOperationException(\"Non-exhaustive match\"), " else "") ++ "}"

  emit-match-arms : List IRBranch -> Integer -> List ArityEntry -> Text -> Text
  emit-match-arms (branches) (i) (arities) (result-cast) =
   if i == list-length branches then ""
   else let arm = list-at branches i
   in let this-arm = emit-pattern (arm.pattern) ++ " => " ++ result-cast ++ "(" ++ emit-expr (arm.body) arities ++ "), "
   in if is-catch-all (arm.pattern) then this-arm
        else this-arm ++ emit-match-arms branches (i + 1) arities result-cast

  is-catch-all : IRPat -> Boolean
  is-catch-all (p) =
   when p
    is IrWildPat (sp) -> True
    is IrVarPat (name) (ty) (sp) -> True
    is otherwise -> False

  has-any-catch-all : List IRBranch -> Integer -> Boolean
  has-any-catch-all (branches) (i) =
   if i == list-length branches then False
   else let b = list-at branches i
   in if is-catch-all (b.pattern) then True
      else has-any-catch-all branches (i + 1)
  emit-pattern : IRPat -> Text
  emit-pattern (p) =
   when p
    is IrVarPat (name) (ty) (sp) -> cs-type ty ++ " " ++ sanitize name
    is IrLitPat (text) (ty) (sp) -> text
    is IrCtorPat (name) (subs) (ty) (sp) ->
     if list-length subs == 0 then sanitize name ++ " { }"
      else sanitize name ++ "(" ++ emit-sub-patterns subs 0 ++ ")"
    is IrWildPat (sp) -> "_"

  emit-sub-patterns : List IRPat -> Integer -> Text
  emit-sub-patterns (subs) (i) =
   if i == list-length subs then ""
   else let sub = list-at subs i
   in emit-sub-pattern sub ++ (if i < list-length subs - 1 then ", " else "") ++ emit-sub-patterns subs (i + 1)

  emit-sub-pattern : IRPat -> Text
  emit-sub-pattern (p) =
   when p
    is IrVarPat (name) (ty) (sp) -> "var " ++ sanitize name
    is IrCtorPat (name) (subs) (ty) (sp) -> emit-pattern p
    is IrWildPat (sp) -> "_"
    is IrLitPat (text) (ty) (sp) -> text

  emit-do : List IRDoStmt -> CodexType -> List ArityEntry -> Text
  emit-do (stmts) (ty) (arities) =
   let actual-ty = when ty
    is EffectfulTy (effs) (ret) -> ret
    is otherwise -> ty
   in let ret-type = cs-type actual-ty
   in let len = list-length stmts
   in when actual-ty
    is VoidTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    is NothingTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    is ErrorTy -> "((Func<object>)(() => { " ++ emit-do-stmts stmts 0 len False arities ++ " return null; }))()"
    is otherwise -> if len == 0 then "((Func<" ++ ret-type ++ ">)(() => { return null; }))()"
    else "((Func<" ++ ret-type ++ ">)(() => { " ++ emit-do-stmts stmts 0 len True arities ++ " }))()"

  emit-do-stmts : List IRDoStmt -> Integer -> Integer -> Boolean -> List ArityEntry -> Text
  emit-do-stmts (stmts) (i) (len) (needs-return) (arities) =
   if i == len then ""
   else let s = list-at stmts i
   in let is-last = i == len - 1
   in let use-return = if is-last then needs-return else False
   in emit-do-stmt s use-return arities ++ " " ++ emit-do-stmts stmts (i + 1) len needs-return arities

  emit-do-stmt : IRDoStmt -> Boolean -> List ArityEntry -> Text
  emit-do-stmt (s) (use-return) (arities) =
   when s
    is IrDoBind (name) (ty) (val) (sp) -> "var " ++ sanitize name ++ " = " ++ emit-expr val arities ++ ";"
    is IrDoExec (e) (sp) ->
     if use-return then "return " ++ emit-expr e arities ++ ";"
     else emit-expr e arities ++ ";"

  emit-record : Text -> List IRFieldVal -> List ArityEntry -> Text
  emit-record (name) (fields) (arities) =
   "new " ++ sanitize name ++ "(" ++ emit-record-fields fields 0 arities ++ ")"

  emit-record-fields : List IRFieldVal -> Integer -> List ArityEntry -> Text
  emit-record-fields (fields) (i) (arities) =
   if i == list-length fields then ""
   else let f = list-at fields i
   in sanitize (f.name) ++ ": " ++ emit-expr (f.value) arities ++ (if i < list-length fields - 1 then ", " else "") ++ emit-record-fields fields (i + 1) arities

  emit-handle : Text -> IRExpr -> List IRHandleClause -> CodexType -> List ArityEntry -> Text
  emit-handle (eff) (body) (clauses) (ty) (arities) =
   let ret-type = cs-type ty
   in "((Func<" ++ ret-type ++ ">)(() => { " ++ emit-handle-clauses clauses ret-type arities ++ "return " ++ emit-expr body arities ++ "; }))()"

  emit-handle-clauses : List IRHandleClause -> Text -> List ArityEntry -> Text
  emit-handle-clauses (clauses) (ret-type) (arities) =
   emit-handle-clauses-loop clauses 0 ret-type arities

  emit-handle-clauses-loop : List IRHandleClause -> Integer -> Text -> List ArityEntry -> Text
  emit-handle-clauses-loop (clauses) (i) (ret-type) (arities) =
   if i == list-length clauses then ""
   else let c = list-at clauses i
   in "Func<Func<" ++ ret-type ++ ", " ++ ret-type ++ ">, " ++ ret-type ++ "> _handle_" ++ sanitize (c.op-name) ++ "_ = (" ++ sanitize (c.resume-name) ++ ") => { return " ++ emit-expr (c.body) arities ++ "; }; " ++ emit-handle-clauses-loop clauses (i + 1) ret-type arities

