Chapter: X86-64 Code Generator

 State records, constants, rodata tables, register allocation, and
 byte-patching helpers used throughout the x86-64 code generator.

Section: Record Types
  FuncOffset = record {
   name : Text,
   offset : Integer
  }

  CallPatch = record {
   patch-offset : Integer,
   target : Text
  }

  LocalBinding = record {
   name : Text,
   slot : Integer
  }

  FuncAddrFixup = record {
   patch-offset : Integer,
   target : Text
  }

  RodataFixup = record {
   patch-offset : Integer,
   rodata-offset : Integer
  }

  TcoState = record {
   active : Boolean,
   in-tail-pos : Boolean,
   loop-top : Integer,
   param-locals : List Integer,
   temp-locals : List Integer,
   current-func : Text,
   saved-next-local : Integer,
   saved-next-temp : Integer
  }

  CodegenState = record {
   text-buf-addr : Integer,
   text-len : Integer,
   rodata-buf-addr : Integer,
   rodata-len : Integer,
   func-offsets : List FuncOffset,
   call-patches : List CallPatch,
   func-addr-fixups : List FuncAddrFixup,
   rodata-fixups : List RodataFixup,
   deferred-patches : List PatchEntry,
   locals : List LocalBinding,
   next-temp : Integer,
   next-local : Integer,
   spill-count : Integer,
   load-local-toggle : Integer,
   tco : TcoState,
   type-defs : List TypeBinding,
   stack-overflow-checks : List Integer,
   bag : DiagnosticBag
  }

  EmitResult = record {
   state : CodegenState,
   reg : Integer
  }

  TrampolineResult = record {
   bytes : List Integer,
   far-jump-patch-pos : Integer
  }

  EmitChapterResult = record {
   bytes : List Integer,
   bag : DiagnosticBag
  }

  FlatApply = record {
   func-name : Text,
   args : List IRExpr
  }

  SavedArgs = record {
   state : CodegenState,
   locals : List Integer
  }

  FieldLocal = record {
   name : Text,
   slot : Integer
  }

  EvalFieldsResult = record {
   state : CodegenState,
   field-locals : List FieldLocal
  }

  MatchBranchState = record {
   cg-state : CodegenState,
   end-patches : List Integer
  }

Section: Constants
  default-tco-state : TcoState
  default-tco-state =
   TcoState {
    active = False,
    in-tail-pos = False,
    loop-top = 0,
    param-locals = [],
    temp-locals = [],
    current-func = "",
    saved-next-local = 0,
    saved-next-temp = 0
  }

  temp-regs : List Integer
  temp-regs =
   [0, 1, 2, 6, 7, 11]

  local-regs : List Integer
  local-regs =
   [3, 12, 13, 14]

  spill-base : Integer
  spill-base =
   32

  bare-metal-load-addr : Integer
  bare-metal-load-addr =
   1048576

  bare-metal-stack-top : Integer
  bare-metal-stack-top =
   1073741824

