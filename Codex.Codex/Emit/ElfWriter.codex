Chapter: ELF Writer

 Produces ELF executables as byte lists. Two variants serve different
 targets: a 32-bit ELF with PVH note boots bare metal under QEMU, and
 a 64-bit ELF runs natively on Linux. Both are pure functions — byte
 lists in, complete ELF byte list out.

 The 32-bit bare-metal variant is the primary output for the Second
 Bootstrap. QEMU reads the PVH note and enters in 32-bit protected
 mode. The codegen's trampoline then transitions to long mode. A single
 PT_LOAD segment maps text and rodata at the 1 MB physical address,
 with extra memsz for the two-space heap.

 The 64-bit Linux variant maps text and rodata as separate PT_LOAD
 segments at the standard 0x400000 base. Text is mapped from file
 offset zero so the ELF and program headers share the page. Rodata
 is page-aligned and writable because the escape-copy subsystem stores
 the result-space base pointer there.

 Ported from ElfWriter32.cs and ElfWriterX86_64.cs. Uses write-i32,
 write-i64, write-bytes, and friends from X86_64Encoder.codex.

Section: ELF Format Constants

  elf-magic : List Integer
  elf-magic =
   [127, 69, 76, 70]

  elf-class-32 : Integer
  elf-class-32 =
   1

  elf-class-64 : Integer
  elf-class-64 =
   2

  elf-data-lsb : Integer
  elf-data-lsb =
   1

  elf-version-current : Integer
  elf-version-current =
   1

  elf-type-exec : Integer
  elf-type-exec =
   2

  elf-machine-386 : Integer
  elf-machine-386 =
   3

  elf-machine-x86-64 : Integer
  elf-machine-x86-64 =
   62

  pt-load : Integer
  pt-load =
   1

  pt-note : Integer
  pt-note =
   4

  pf-r : Integer
  pf-r =
   4

  pf-w : Integer
  pf-w =
   2

  pf-x : Integer
  pf-x =
   1

  pf-rwx : Integer
  pf-rwx =
   7

  pf-rw : Integer
  pf-rw =
   6

  xen-elfnote-phys32-entry : Integer
  xen-elfnote-phys32-entry =
   18

  xen-name : List Integer
  xen-name =
   [88, 101, 110, 0]

Section: Layout Constants

  elf-bare-metal-load-addr : Integer
  elf-bare-metal-load-addr =
   1048576

  elf-bare-metal-heap-size : Integer
  elf-bare-metal-heap-size =
   2097152

  elf-linux-base-addr : Integer
  elf-linux-base-addr =
   4194304

  elf-page-size : Integer
  elf-page-size =
   4096

  elf32-header-size : Integer
  elf32-header-size =
   52

  elf32-phdr-size : Integer
  elf32-phdr-size =
   32

  elf64-header-size : Integer
  elf64-header-size =
   64

  elf64-phdr-size : Integer
  elf64-phdr-size =
   56

Section: Helpers

  elf-align : Integer -> Integer -> Integer
  elf-align (v) (a) =
   let r = int-mod v a
   in if r == 0 then v else v + a - r

  write-i16 : Integer -> List Integer
  write-i16 (v) =
   write-bytes v 2

  pad-zeros : Integer -> List Integer
  pad-zeros (n) =
   pad-zeros-acc n []

  pad-zeros-acc : Integer -> List Integer -> List Integer
  pad-zeros-acc (n) (acc) =
   if n <= 0 then acc
   else pad-zeros-acc (n - 1) (list-snoc acc 0)

Section: ELF Identification

  elf-ident-32 : List Integer
  elf-ident-32 =
   elf-magic ++ [elf-class-32, elf-data-lsb, elf-version-current]
   ++ pad-zeros 9

  elf-ident-64 : List Integer
  elf-ident-64 =
   elf-magic ++ [elf-class-64, elf-data-lsb, elf-version-current]
   ++ pad-zeros 9

Section: 32-bit ELF Header

  elf32-header-bytes : Integer -> Integer -> Integer -> List Integer
  elf32-header-bytes (entry) (phoff) (phnum) =
   elf-ident-32
   ++ write-i16 elf-type-exec
   ++ write-i16 elf-machine-386
   ++ write-i32 elf-version-current
   ++ write-i32 entry
   ++ write-i32 phoff
   ++ write-i32 0
   ++ write-i32 0
   ++ write-i16 elf32-header-size
   ++ write-i16 elf32-phdr-size
   ++ write-i16 phnum
   ++ write-i16 0
   ++ write-i16 0
   ++ write-i16 0

Section: 32-bit Program Header

  phdr-32 : Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> List Integer
  phdr-32 (ptype) (offset) (vaddr) (paddr) (filesz) (memsz) (flags) (palign) =
   write-i32 ptype
   ++ write-i32 offset
   ++ write-i32 vaddr
   ++ write-i32 paddr
   ++ write-i32 filesz
   ++ write-i32 memsz
   ++ write-i32 flags
   ++ write-i32 palign

Section: PVH Note

  pvh-note : Integer -> List Integer
  pvh-note (entry-addr) =
   write-i32 4
   ++ write-i32 4
   ++ write-i32 xen-elfnote-phys32-entry
   ++ xen-name
   ++ write-i32 entry-addr

Section: 32-bit Bare-Metal ELF

  build-elf-32-bare : List Integer -> List Integer -> Integer -> List Integer
  build-elf-32-bare (text) (rodata) (entry-offset) =
   let load-addr = elf-bare-metal-load-addr
   in let headers-end = elf32-header-size + elf32-phdr-size * 2
   in let note-offset = elf-align headers-end 4
   in let text-start = elf-align (note-offset + 20) 16
   in let text-end = text-start + list-length text
   in let rodata-start = elf-align text-end 8
   in let file-size = rodata-start + list-length rodata
   in let entry = load-addr + entry-offset
   in let seg-filesz = file-size - text-start
   in let seg-memsz = seg-filesz + elf-bare-metal-heap-size
   in elf32-header-bytes entry elf32-header-size 2
   ++ phdr-32 pt-load text-start load-addr load-addr seg-filesz seg-memsz pf-rwx elf-page-size
   ++ phdr-32 pt-note note-offset 0 0 20 20 pf-r 4
   ++ pad-zeros (note-offset - headers-end)
   ++ pvh-note entry
   ++ pad-zeros (text-start - note-offset - 20)
   ++ text
   ++ pad-zeros (rodata-start - text-end)
   ++ rodata

Section: 64-bit ELF Header

  elf64-header-bytes : Integer -> Integer -> Integer -> List Integer
  elf64-header-bytes (entry) (phoff) (phnum) =
   elf-ident-64
   ++ write-i16 elf-type-exec
   ++ write-i16 elf-machine-x86-64
   ++ write-i32 elf-version-current
   ++ write-i64 entry
   ++ write-i64 phoff
   ++ write-i64 0
   ++ write-i32 0
   ++ write-i16 elf64-header-size
   ++ write-i16 elf64-phdr-size
   ++ write-i16 phnum
   ++ write-i16 0
   ++ write-i16 0
   ++ write-i16 0

Section: 64-bit Program Header

  phdr-64 : Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> Integer -> List Integer
  phdr-64 (ptype) (flags) (offset) (vaddr) (paddr) (filesz) (memsz) (palign) =
   write-i32 ptype
   ++ write-i32 flags
   ++ write-i64 offset
   ++ write-i64 vaddr
   ++ write-i64 paddr
   ++ write-i64 filesz
   ++ write-i64 memsz
   ++ write-i64 palign

Section: 64-bit Linux User-Mode ELF

  build-elf-64-linux : List Integer -> List Integer -> Integer -> List Integer
  build-elf-64-linux (text) (rodata) (entry-offset) =
   let base-addr = elf-linux-base-addr
   in let headers-size = elf64-header-size + elf64-phdr-size * 2
   in let text-file-offset = elf-align headers-size 16
   in let text-vaddr = base-addr + text-file-offset
   in let entry-point = text-vaddr + entry-offset
   in let text-size = list-length text
   in let text-region-end = text-file-offset + text-size
   in let rodata-file-offset = elf-align text-region-end elf-page-size
   in let rodata-vaddr = base-addr + rodata-file-offset
   in let rodata-size = list-length rodata
   in elf64-header-bytes entry-point elf64-header-size 2
   ++ phdr-64 pt-load pf-rwx 0 base-addr base-addr text-region-end text-region-end elf-page-size
   ++ phdr-64 pt-load pf-rw rodata-file-offset rodata-vaddr rodata-vaddr rodata-size rodata-size elf-page-size
   ++ pad-zeros (text-file-offset - headers-size)
   ++ text
   ++ pad-zeros (rodata-file-offset - text-region-end)
   ++ rodata

Section: Codegen Helpers

  compute-text-file-offset-64 : Integer
  compute-text-file-offset-64 =
   elf-align (elf64-header-size + elf64-phdr-size * 2) 16

  compute-rodata-vaddr-64 : Integer -> Integer
  compute-rodata-vaddr-64 (text-size) =
   let text-file-offset = compute-text-file-offset-64
   in let rodata-file-offset = elf-align (text-file-offset + text-size) elf-page-size
   in elf-linux-base-addr + rodata-file-offset

  compute-text-vaddr-64 : Integer
  compute-text-vaddr-64 = elf-linux-base-addr + compute-text-file-offset-64

  compute-rodata-vaddr-bare : Integer -> Integer
  compute-rodata-vaddr-bare (text-size) =
   elf-bare-metal-load-addr + elf-align text-size 8

  compute-text-start-32 : Integer
  compute-text-start-32 =
   let headers-end = elf32-header-size + elf32-phdr-size * 2
   in let note-offset = elf-align headers-end 4
   in elf-align (note-offset + 20) 16
