Chapter: String Escape Smoke Tests

 Systematic tests for bare-metal string escape behavior.
 Each definition is a text literal with known escape content.
 Compare stage0 vs stage1 to find which patterns break.

Section: Single Newline Position

  t-nl-start : Text
  t-nl-start = "\nhello"

  t-nl-mid : Text
  t-nl-mid = "hel\nlo"

  t-nl-end : Text
  t-nl-end = "hello\n"

Section: Two Newlines

  t-nl-two-adjacent : Text
  t-nl-two-adjacent = "\n\n"

  t-nl-two-spaced : Text
  t-nl-two-spaced = "aaa\nbbb\nccc"

  t-nl-two-short : Text
  t-nl-two-short = "a\nb\n"

  t-nl-two-start : Text
  t-nl-two-start = "\n\nhello"

  t-nl-two-end : Text
  t-nl-two-end = "hello\n\n"

Section: Three Or More Newlines

  t-nl-three : Text
  t-nl-three = "a\nb\nc\nd"

  t-nl-four : Text
  t-nl-four = "a\nb\nc\nd\ne"

  t-nl-five : Text
  t-nl-five = "\n\n\n\n\n"

Section: Newline After Specific Characters

  t-nl-after-space : Text
  t-nl-after-space = " \nok"

  t-nl-after-letter : Text
  t-nl-after-letter = "x\nok"

  t-nl-after-digit : Text
  t-nl-after-digit = "9\nok"

  t-nl-after-brace : Text
  t-nl-after-brace = "{\nok"

  t-nl-after-close-brace : Text
  t-nl-after-close-brace = "}\nok"

  t-nl-after-paren : Text
  t-nl-after-paren = ")\nok"

  t-nl-after-comma : Text
  t-nl-after-comma = ",\nok"

  t-nl-after-semicolon : Text
  t-nl-after-semicolon = ";\nok"

  t-nl-after-backslash : Text
  t-nl-after-backslash = "\\\nok"

  t-nl-after-quote : Text
  t-nl-after-quote = "\"\nok"

Section: Double Quote Escaping

  t-dq-single : Text
  t-dq-single = "\""

  t-dq-two : Text
  t-dq-two = "\"\""

  t-dq-three : Text
  t-dq-three = "\"\"\""

  t-dq-in-text : Text
  t-dq-in-text = "say \"hello\" world"

  t-dq-at-start : Text
  t-dq-at-start = "\"hello"

  t-dq-at-end : Text
  t-dq-at-end = "hello\""

Section: Backslash Escaping

  t-bs-single : Text
  t-bs-single = "\\"

  t-bs-two : Text
  t-bs-two = "\\\\"

  t-bs-in-text : Text
  t-bs-in-text = "a\\b\\c"

Section: Mixed Escapes

  t-mix-bs-nl : Text
  t-mix-bs-nl = "\\\n"

  t-mix-nl-bs : Text
  t-mix-nl-bs = "\n\\"

  t-mix-dq-nl : Text
  t-mix-dq-nl = "\"\n"

  t-mix-nl-dq : Text
  t-mix-nl-dq = "\n\""

  t-mix-all : Text
  t-mix-all = "\\\"\n"

  t-mix-all-rev : Text
  t-mix-all-rev = "\n\"\\"

  t-mix-dq-nl-dq : Text
  t-mix-dq-nl-dq = "\"\n\""

  t-mix-repeat : Text
  t-mix-repeat = "\\\"\n\\\"\n"

Section: Longer Strings With Newlines

  t-real-braces : Text
  t-real-braces = ")\n    {\n"

  t-real-while : Text
  t-real-while = ")\n    {\n        while (true)\n        {\n"

  t-real-closing : Text
  t-real-closing = "        }\n    }\n"

  t-real-using : Text
  t-real-using = "using System;\nusing System.IO;\n"

  t-real-multiline : Text
  t-real-multiline = "    public static\n    {\n        while (true)\n        {\n            return\n        }\n    }\n"

Section: Fuzz Around Newlines

  t-fuzz-a : Text
  t-fuzz-a = "abcdef\nghijkl"

  t-fuzz-b : Text
  t-fuzz-b = "123456\n789012"

  t-fuzz-c : Text
  t-fuzz-c = "+-=*/<>\n[]{}()"

  t-fuzz-d : Text
  t-fuzz-d = "abc\ndef\nghi\njkl\nmno"

  t-fuzz-e : Text
  t-fuzz-e = "aaa\n.\n,\n!\n?\naaa"

  t-fuzz-f : Text
  t-fuzz-f = "ABCDEFGHIJ\nKLMNOPQRST"

  t-fuzz-g : Text
  t-fuzz-g = "the quick brown\nfox jumps over\nthe lazy dog"

  t-fuzz-h : Text
  t-fuzz-h = "0123456789\n0123456789\n0123456789"

  t-fuzz-i : Text
  t-fuzz-i = "({[<\n>]})"

  t-fuzz-j : Text
  t-fuzz-j = "++==--**\n//@@##&&"

Section: String Length With One Newline

  t-len1 : Text
  t-len1 = "\n"

  t-len3 : Text
  t-len3 = "a\nb"

  t-len7 : Text
  t-len7 = "abc\ndef"

  t-len8 : Text
  t-len8 = "abcd\nefg"

  t-len9 : Text
  t-len9 = "abcd\nefgh"

  t-len15 : Text
  t-len15 = "abcdefg\nhijklmn"

  t-len16 : Text
  t-len16 = "abcdefgh\nijklmno"

  t-len17 : Text
  t-len17 = "abcdefgh\nijklmnop"

  t-len31 : Text
  t-len31 = "abcdefghijklmno\npqrstuvwxyz0123"

  t-len32 : Text
  t-len32 = "abcdefghijklmnop\nqrstuvwxyz01234"

Section: Alignment Boundary Tests

  t-align-nl-at-7 : Text
  t-align-nl-at-7 = "0123456\nrest"

  t-align-nl-at-8 : Text
  t-align-nl-at-8 = "01234567\nrest"

  t-align-nl-at-9 : Text
  t-align-nl-at-9 = "012345678\nrest"

