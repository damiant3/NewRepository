  t-align-nl-at-15 = "0123456789abcde\nrest"

  t-align-nl-at-16 : Text
  t-align-nl-at-16 = "0123456789abcdef\nrest"

  t-align-nl-at-17 : Text
  t-align-nl-at-17 = "0123456789abcdefg\nrest"

