Chapter: X86-64 Code Generator

 List runtime helpers emitted into every x86-64-bare binary: cons,
 append, snoc, insert-at, set-at, contains, and concat-many.

Section: __list_contains
  emit-list-contains : CodegenState -> CodegenState
  emit-list-contains (st) =
    let st0 = record-func-offset st "__list_contains"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rdi 0)
   in let st2 = st-append-text st1 (li reg-r11 0)
   in let loop-top = st2.text-len
   in let st3 = st-append-text st2 (cmp-rr reg-r11 reg-rcx)
   in let not-found-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ge 0)
   in let st5 = st-append-text st4 (mov-rr reg-rax reg-r11)
   in let st6 = st-append-text st5 (shl-ri reg-rax 3)
   in let st7 = st-append-text st6 (add-rr reg-rax reg-rdi)
   in let st8 = st-append-text st7 (mov-load reg-rax reg-rax 8)
   in let st9 = st-append-text st8 (cmp-rr reg-rax reg-rsi)
   in let found-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-e 0)
   in let st11 = st-append-text st10 (add-ri reg-r11 1)
   in let st12 = st-append-text st11 (jmp (loop-top - (st11.text-len + 5)))
   in let st13 = patch-jcc-at st12 found-pos (st12.text-len)
   in let st14 = st-append-text st13 (li reg-rax 1)
   in let st15 = st-append-text st14 x86-ret
   in let st16 = patch-jcc-at st15 not-found-pos (st15.text-len)
   in let st17 = st-append-text st16 (li reg-rax 0)
   in st-append-text st17 x86-ret

Section: __list_cons
  emit-list-cons-alloc : CodegenState -> CodegenState
  emit-list-cons-alloc (st) =
    let st0 = record-func-offset st "__list_cons"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rsi 0)
   in let st2 = st-append-text st1 (mov-rr reg-rdx reg-rcx)
   in let st3 = st-append-text st2 (add-ri reg-rdx 1)
   in let st4 = st-append-text st3 (mov-rr reg-r11 reg-rdx)
   in let st5 = st-append-text st4 (shl-ri reg-r11 1)
   in let st6 = st-append-text st5 (cmp-ri reg-r11 4)
   in let cap-ok-pos = st6.text-len
   in let st7 = st-append-text st6 (jcc cc-ge 0)
   in let st8 = st-append-text st7 (li reg-r11 4)
   in let st9 = patch-jcc-at st8 cap-ok-pos (st8.text-len)
   in let st10 = st-append-text st9 (mov-store reg-r10 reg-r11 0)
   in let st11 = st-append-text st10 (add-ri reg-r10 8)
   in let st12 = st-append-text st11 (mov-rr reg-rax reg-r10)
   in let st13 = st-append-text st12 (add-ri reg-r11 1)
   in let st14 = st-append-text st13 (shl-ri reg-r11 3)
   in let st15 = st-append-text st14 (add-rr reg-r10 reg-r11)
   in let st16 = st-append-text st15 (mov-store reg-rax reg-rdx 0)
   in st-append-text st16 (mov-store reg-rax reg-rdi 8)

  emit-list-cons-copy : CodegenState -> CodegenState
  emit-list-cons-copy (st) =
    let st0 = st-append-text st (shl-ri reg-rcx 3)
   in let st1 = st-append-text st0 (li reg-r11 0)
   in let loop-top = st1.text-len
   in let st2 = st-append-text st1 (cmp-rr reg-r11 reg-rcx)
   in let exit-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ge 0)
   in let st4 = st-append-text st3 (mov-rr reg-rdx reg-rsi)
   in let st5 = st-append-text st4 (add-rr reg-rdx reg-r11)
   in let st6 = st-append-text st5 (mov-load reg-rdx reg-rdx 8)
   in let st7 = st-append-text st6 (mov-rr reg-rdi reg-rax)
   in let st8 = st-append-text st7 (add-rr reg-rdi reg-r11)
   in let st9 = st-append-text st8 (mov-store reg-rdi reg-rdx 16)
   in let st10 = st-append-text st9 (add-ri reg-r11 8)
   in let st11 = st-append-text st10 (jmp (loop-top - (st10.text-len + 5)))
   in let st12 = patch-jcc-at st11 exit-pos (st11.text-len)
   in st-append-text st12 x86-ret

  emit-list-cons : CodegenState -> CodegenState
  emit-list-cons (st) =
    let st0 = emit-list-cons-alloc st
   in emit-list-cons-copy st0

Section: __list_append
  emit-list-append-prologue : CodegenState -> HelpResult1
  emit-list-append-prologue (st) =
    let st0 = record-func-offset st "__list_append"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rdi 0)
   in let st2 = st-append-text st1 (mov-load reg-rdx reg-rsi 0)
   in let st3 = st-append-text st2 (mov-load reg-r11 reg-rdi (0 - 8))
   in let st4 = st-append-text st3 (mov-rr reg-rax reg-r11)
   in let st5 = st-append-text st4 (sub-rr reg-rax reg-rcx)
   in let st6 = st-append-text st5 (cmp-rr reg-rax reg-rdx)
   in let p2-pos = st6.text-len
   in let st7 = st-append-text st6 (jcc cc-l 0)
   in HelpResult1 { cg = st7, p1 = p2-pos }

  emit-list-append-path1 : CodegenState -> CodegenState
  emit-list-append-path1 (st) =
    let st0 = st-append-text st (mov-rr reg-rax reg-rcx)
   in let st1 = st-append-text st0 (shl-ri reg-rax 3)
   in let st2 = st-append-text st1 (add-rr reg-rax reg-rdi)
   in let st3 = st-append-text st2 (mov-rr reg-r11 reg-rsi)
   in let st4 = st-append-text st3 (cmp-ri reg-rdx 0)
   in let skip-pos = st4.text-len
   in let st5 = st-append-text st4 (jcc cc-e 0)
   in let loop-pos = st5.text-len
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-r11 8)
   in let st7 = st-append-text st6 (mov-store reg-rax reg-rcx 8)
   in let st8 = st-append-text st7 (add-ri reg-rax 8)
   in let st9 = st-append-text st8 (add-ri reg-r11 8)
   in let st10 = st-append-text st9 (sub-ri reg-rdx 1)
   in let st11 = st-append-text st10 (jcc cc-ne (loop-pos - (st10.text-len + 6)))
   in let st12 = patch-jcc-at st11 skip-pos (st11.text-len)
   in let st13 = st-append-text st12 (mov-load reg-rcx reg-rdi 0)
   in let st14 = st-append-text st13 (mov-load reg-rdx reg-rsi 0)
   in let st15 = st-append-text st14 (add-rr reg-rcx reg-rdx)
   in let st16 = st-append-text st15 (mov-store reg-rdi reg-rcx 0)
   in let st17 = st-append-text st16 (mov-rr reg-rax reg-rdi)
   in st-append-text st17 x86-ret

  emit-list-append-path2-alloc : CodegenState -> Integer -> CodegenState
  emit-list-append-path2-alloc (st) (p2-pos) =
    let st0 = patch-jcc-at st p2-pos (st.text-len)
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (mov-rr reg-rbx reg-rdi)
   in let st5 = st-append-text st4 (mov-rr reg-r12 reg-rsi)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rbx 0)
   in let st7 = st-append-text st6 (mov-load reg-rdx reg-r12 0)
   in let st8 = st-append-text st7 (mov-rr reg-r13 reg-rcx)
   in let st9 = st-append-text st8 (add-rr reg-r13 reg-rdx)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-r13)
   in let st11 = st-append-text st10 (shl-ri reg-rax 1)
   in let st12 = st-append-text st11 (cmp-ri reg-rax 4)
   in let cap-ok-pos = st12.text-len
   in let st13 = st-append-text st12 (jcc cc-ge 0)
   in let st14 = st-append-text st13 (li reg-rax 4)
   in let st15 = patch-jcc-at st14 cap-ok-pos (st14.text-len)
   in let st16 = st-append-text st15 (mov-store reg-r10 reg-rax 0)
   in let st17 = st-append-text st16 (add-ri reg-r10 8)
   in let st18 = st-append-text st17 (mov-rr reg-rsi reg-r10)
   in let st19 = st-append-text st18 (mov-rr reg-r11 reg-rax)
   in let st20 = st-append-text st19 (add-ri reg-r11 1)
   in let st21 = st-append-text st20 (shl-ri reg-r11 3)
   in let st22 = st-append-text st21 (add-rr reg-r10 reg-r11)
   in st-append-text st22 (mov-store reg-rsi reg-r13 0)

  emit-list-append-path2-copy-a : CodegenState -> CodegenState
  emit-list-append-path2-copy-a (st) =
    let st0 = st-append-text st (mov-rr reg-rax reg-rbx)
   in let st1 = st-append-text st0 (mov-rr reg-rdi reg-rsi)
   in let st2 = st-append-text st1 (cmp-ri reg-rcx 0)
   in let skip-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-e 0)
   in let loop-pos = st3.text-len
   in let st4 = st-append-text st3 (mov-load reg-r11 reg-rax 8)
   in let st5 = st-append-text st4 (mov-store reg-rdi reg-r11 8)
   in let st6 = st-append-text st5 (add-ri reg-rax 8)
   in let st7 = st-append-text st6 (add-ri reg-rdi 8)
   in let st8 = st-append-text st7 (sub-ri reg-rcx 1)
   in let st9 = st-append-text st8 (jcc cc-ne (loop-pos - (st8.text-len + 6)))
   in patch-jcc-at st9 skip-pos (st9.text-len)

  emit-list-append-path2-copy-b : CodegenState -> CodegenState
  emit-list-append-path2-copy-b (st) =
    let st0 = st-append-text st (mov-rr reg-rax reg-r12)
   in let st1 = st-append-text st0 (cmp-ri reg-rdx 0)
   in let skip-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let loop-pos = st2.text-len
   in let st3 = st-append-text st2 (mov-load reg-r11 reg-rax 8)
   in let st4 = st-append-text st3 (mov-store reg-rdi reg-r11 8)
   in let st5 = st-append-text st4 (add-ri reg-rax 8)
   in let st6 = st-append-text st5 (add-ri reg-rdi 8)
   in let st7 = st-append-text st6 (sub-ri reg-rdx 1)
   in let st8 = st-append-text st7 (jcc cc-ne (loop-pos - (st7.text-len + 6)))
   in let st9 = patch-jcc-at st8 skip-pos (st8.text-len)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-rsi)
   in let st11 = st-append-text st10 (pop-r reg-r13)
   in let st12 = st-append-text st11 (pop-r reg-r12)
   in let st13 = st-append-text st12 (pop-r reg-rbx)
   in st-append-text st13 x86-ret

  emit-list-append : CodegenState -> CodegenState
  emit-list-append (st) =
    let h = emit-list-append-prologue st
   in let st1 = emit-list-append-path1 (h.cg)
   in let st2 = emit-list-append-path2-alloc st1 (h.p1)
   in let st3 = emit-list-append-path2-copy-a st2
   in emit-list-append-path2-copy-b st3

Section: __list_snoc
  emit-list-snoc-path1 : CodegenState -> HelpResult1
  emit-list-snoc-path1 (st) =
    let st0 = record-func-offset st "__list_snoc"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rdi 0)
   in let st2 = st-append-text st1 (mov-load reg-rdx reg-rdi (0 - 8))
   in let st3 = st-append-text st2 (cmp-rr reg-rcx reg-rdx)
   in let path2-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ge 0)
   in let st5 = st-append-text st4 (mov-rr reg-rax reg-rcx)
   in let st6 = st-append-text st5 (shl-ri reg-rax 3)
   in let st7 = st-append-text st6 (add-rr reg-rax reg-rdi)
   in let st8 = st-append-text st7 (mov-store reg-rax reg-rsi 8)
   in let st9 = st-append-text st8 (add-ri reg-rcx 1)
   in let st10 = st-append-text st9 (mov-store reg-rdi reg-rcx 0)
   in let st11 = st-append-text st10 (mov-rr reg-rax reg-rdi)
   in let st12 = st-append-text st11 x86-ret
   in HelpResult1 {
    cg = st12,
    p1 = path2-pos
   }

  emit-list-snoc-path2 : CodegenState -> Integer -> HelpResult1
  emit-list-snoc-path2 (st) (path2-pos) =
    let st0 = patch-jcc-at st path2-pos (st.text-len)
   in let st1 = st-append-text st0 (mov-rr reg-rax reg-rdx)
   in let st2 = st-append-text st1 (add-ri reg-rax 1)
   in let st3 = st-append-text st2 (shl-ri reg-rax 3)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-rdi)
   in let st5 = st-append-text st4 (cmp-rr reg-rax reg-r10)
   in let path3-pos = st5.text-len
   in let st6 = st-append-text st5 (jcc cc-ne 0)
   in let st7 = st-append-text st6 (mov-rr reg-rax reg-rdx)
   in let st8 = st-append-text st7 (shl-ri reg-rax 1)
   in let st9 = st-append-text st8 (cmp-ri reg-rax 4)
   in let cap-ok-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-ge 0)
   in let st11 = st-append-text st10 (li reg-rax 4)
   in let st12 = patch-jcc-at st11 cap-ok-pos (st11.text-len)
   in let st13 = st-append-text st12 (mov-store reg-rdi reg-rax (0 - 8))
   in let st14 = st-append-text st13 (sub-rr reg-rax reg-rdx)
   in let st15 = st-append-text st14 (shl-ri reg-rax 3)
   in let st16 = st-append-text st15 (add-rr reg-r10 reg-rax)
   in let st17 = st-append-text st16 (mov-rr reg-rax reg-rcx)
   in let st18 = st-append-text st17 (shl-ri reg-rax 3)
   in HelpResult1 {
    cg = st18,
    p1 = path3-pos
   }

  emit-list-snoc-path2-store : CodegenState -> CodegenState
  emit-list-snoc-path2-store (st) =
    let st0 = st-append-text st (add-rr reg-rax reg-rdi)
   in let st1 = st-append-text st0 (mov-store reg-rax reg-rsi 8)
   in let st2 = st-append-text st1 (add-ri reg-rcx 1)
   in let st3 = st-append-text st2 (mov-store reg-rdi reg-rcx 0)
   in let st4 = st-append-text st3 (mov-rr reg-rax reg-rdi)
   in st-append-text st4 x86-ret

  emit-list-snoc-path3-alloc : CodegenState -> Integer -> CodegenState
  emit-list-snoc-path3-alloc (st) (path3-pos) =
    let st0 = patch-jcc-at st path3-pos (st.text-len)
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (mov-rr reg-rbx reg-rdi)
   in let st5 = st-append-text st4 (mov-rr reg-r12 reg-rsi)
   in let st6 = st-append-text st5 (mov-rr reg-r13 reg-rcx)
   in let st7 = st-append-text st6 (shl-ri reg-r13 1)
   in let st8 = st-append-text st7 (cmp-ri reg-r13 4)
   in let cap-ok2-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ge 0)
   in let st10 = st-append-text st9 (li reg-r13 4)
   in let st11 = patch-jcc-at st10 cap-ok2-pos (st10.text-len)
   in let st12 = st-append-text st11 (mov-store reg-r10 reg-r13 0)
   in let st13 = st-append-text st12 (add-ri reg-r10 8)
   in let st14 = st-append-text st13 (mov-rr reg-rax reg-r10)
   in let st15 = st-append-text st14 (mov-rr reg-rdx reg-r13)
   in let st16 = st-append-text st15 (add-ri reg-rdx 1)
   in let st17 = st-append-text st16 (shl-ri reg-rdx 3)
   in st-append-text st17 (add-rr reg-r10 reg-rdx)

  emit-list-snoc-path3-copy : CodegenState -> CodegenState
  emit-list-snoc-path3-copy (st) =
    let st0 = st-append-text st (mov-load reg-rcx reg-rbx 0)
   in let st1 = st-append-text st0 (mov-rr reg-rdx reg-rcx)
   in let st2 = st-append-text st1 (add-ri reg-rdx 1)
   in let st3 = st-append-text st2 (mov-store reg-rax reg-rdx 0)
   in let st4 = st-append-text st3 (li reg-r11 0)
   in let copy-loop = st4.text-len
   in let st5 = st-append-text st4 (cmp-rr reg-r11 reg-rcx)
   in let copy-done-pos = st5.text-len
   in let st6 = st-append-text st5 (jcc cc-ge 0)
   in let st7 = st-append-text st6 (mov-rr reg-rdx reg-r11)
   in let st8 = st-append-text st7 (shl-ri reg-rdx 3)
   in let st9 = st-append-text st8 (mov-rr reg-rsi reg-rbx)
   in let st10 = st-append-text st9 (add-rr reg-rsi reg-rdx)
   in let st11 = st-append-text st10 (mov-load reg-rsi reg-rsi 8)
   in let st12 = st-append-text st11 (mov-rr reg-rdi reg-rax)
   in let st13 = st-append-text st12 (add-rr reg-rdi reg-rdx)
   in let st14 = st-append-text st13 (mov-store reg-rdi reg-rsi 8)
   in let st15 = st-append-text st14 (add-ri reg-r11 1)
   in let st16 = st-append-text st15 (jmp (copy-loop - (st15.text-len + 5)))
   in patch-jcc-at st16 copy-done-pos (st16.text-len)

  emit-list-snoc-path3-finish : CodegenState -> CodegenState
  emit-list-snoc-path3-finish (st) =
    let st0 = st-append-text st (mov-rr reg-rdx reg-rcx)
   in let st1 = st-append-text st0 (shl-ri reg-rdx 3)
   in let st2 = st-append-text st1 (mov-rr reg-rdi reg-rax)
   in let st3 = st-append-text st2 (add-rr reg-rdi reg-rdx)
   in let st4 = st-append-text st3 (mov-store reg-rdi reg-r12 8)
   in let st5 = st-append-text st4 (pop-r reg-r13)
   in let st6 = st-append-text st5 (pop-r reg-r12)
   in let st7 = st-append-text st6 (pop-r reg-rbx)
   in st-append-text st7 x86-ret

  emit-list-snoc : CodegenState -> CodegenState
  emit-list-snoc (st) =
    let p1 = emit-list-snoc-path1 st
   in let p2 = emit-list-snoc-path2 (p1.cg) (p1.p1)
   in let st0 = emit-list-snoc-path2-store (p2.cg)
   in let st1 = emit-list-snoc-path3-alloc st0 (p2.p1)
   in let st2 = emit-list-snoc-path3-copy st1
   in emit-list-snoc-path3-finish st2

Section: __list_insert_at
  emit-list-insert-at-prologue : CodegenState -> HelpResult2
  emit-list-insert-at-prologue (st) =
    let st0 = record-func-offset st "__list_insert_at"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (push-r reg-r14)
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-rdi)
   in let st6 = st-append-text st5 (mov-rr reg-r12 reg-rsi)
   in let st7 = st-append-text st6 (mov-rr reg-r13 reg-rdx)
   in let st8 = st-append-text st7 (mov-load reg-r14 reg-rbx 0)
   in let st9 = st-append-text st8 (mov-load reg-rcx reg-rbx (0 - 8))
   in let st10 = st-append-text st9 (cmp-rr reg-r14 reg-rcx)
   in let in-place-pos = st10.text-len
   in let st11 = st-append-text st10 (jcc cc-l 0)
   in let st12 = st-append-text st11 (mov-rr reg-rax reg-rcx)
   in let st13 = st-append-text st12 (add-ri reg-rax 1)
   in let st14 = st-append-text st13 (shl-ri reg-rax 3)
   in let st15 = st-append-text st14 (add-rr reg-rax reg-rbx)
   in let st16 = st-append-text st15 (cmp-rr reg-rax reg-r10)
   in let path3-pos = st16.text-len
   in let st17 = st-append-text st16 (jcc cc-ne 0)
   in HelpResult2 {
    cg = st17,
    p1 = in-place-pos,
    p2 = path3-pos
   }

  emit-list-insert-at-grow : CodegenState -> CodegenState
  emit-list-insert-at-grow (st) =
    let st0 = st-append-text st (mov-rr reg-rax reg-rcx)
   in let st1 = st-append-text st0 (shl-ri reg-rax 1)
   in let st2 = st-append-text st1 (cmp-ri reg-rax 4)
   in let cap-ok-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ge 0)
   in let st4 = st-append-text st3 (li reg-rax 4)
   in let st5 = patch-jcc-at st4 cap-ok-pos (st4.text-len)
   in let st6 = st-append-text st5 (mov-store reg-rbx reg-rax (0 - 8))
   in let st7 = st-append-text st6 (sub-rr reg-rax reg-rcx)
   in let st8 = st-append-text st7 (shl-ri reg-rax 3)
   in st-append-text st8 (add-rr reg-r10 reg-rax)

  emit-list-insert-at-shift : CodegenState -> Integer -> CodegenState
  emit-list-insert-at-shift (st) (in-place-pos) =
    let st0 = patch-jcc-at st in-place-pos (st.text-len)
   in let st1 = st-append-text st0 (mov-rr reg-r11 reg-r14)
   in let st2 = st-append-text st1 (sub-ri reg-r11 1)
   in let shift-loop = st2.text-len
   in let st3 = st-append-text st2 (cmp-rr reg-r11 reg-r12)
   in let shift-done-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-l 0)
   in let st5 = st-append-text st4 (mov-rr reg-rdx reg-r11)
   in let st6 = st-append-text st5 (shl-ri reg-rdx 3)
   in let st7 = st-append-text st6 (mov-rr reg-rax reg-rbx)
   in let st8 = st-append-text st7 (add-rr reg-rax reg-rdx)
   in let st9 = st-append-text st8 (mov-load reg-rcx reg-rax 8)
