   in let st1 = st-append-text st0 (mov-store reg-r14 reg-r13 0)
   in let st2 = st-append-text st1 (mov-rr reg-rax reg-r13)
   in let st3 = st-append-text st2 (add-ri reg-rax 15)
   in let st4 = st-append-text st3 (and-ri reg-rax (0 - 8))
   in st-append-text st4 (add-rr reg-r10 reg-rax)

