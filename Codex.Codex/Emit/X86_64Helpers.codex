   in let st3 = st-append-text st2 (mov-rr reg-rax reg-rdi)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-rsi)
   in let st5 = st-append-text st4 (movzx-byte reg-rax reg-rax 8)
   in let st6 = st-append-text st5 (mov-rr reg-rdx reg-r14)
   in let st7 = st-append-text st6 (add-rr reg-rdx reg-r13)
   in let st8 = st-append-text st7 (add-rr reg-rdx reg-rsi)
   in let st9 = st-append-text st8 (mov-store-byte reg-rdx reg-rax 8)
   in let st10 = st-append-text st9 (add-ri reg-rsi 1)
   in let st11 = st-append-text st10 (jmp (byte-loop - (list-length (st10.text) + 5)))
   in let st12 = patch-jcc-at st11 byte-done-pos (list-length (st11.text))
   in let st13 = st-append-text st12 (add-rr reg-r13 reg-rcx)
   in let st14 = st-append-text st13 (add-ri reg-r11 1)
   in let st15 = st-append-text st14 (jmp (copy-loop - (list-length (st14.text) + 5)))
   in patch-jcc-at st15 copy-done-pos (list-length (st15.text))

  emit-text-concat-list : CodegenState -> CodegenState
  emit-text-concat-list (st) =
    let st0 = emit-text-concat-list-len-pass st
   in let st1 = emit-text-concat-list-alloc st0
   in let outer = emit-text-concat-list-copy-outer st1
   in let st2 = emit-text-concat-list-copy-inner (outer.cg) (outer.p1) (outer.p2)
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-r14)
   in let st4 = st-append-text st3 (pop-r reg-r14)
   in let st5 = st-append-text st4 (pop-r reg-r13)
   in let st6 = st-append-text st5 (pop-r reg-r12)
   in let st7 = st-append-text st6 (pop-r reg-rbx)
   in st-append-text st7 x86-ret

Section: __str_replace

 Replaces all occurrences of a substring with another.
 RDI = text, RSI = old, RDX = new, returns RAX = result text.
 Scans linearly, copies to a new heap buffer.

  emit-str-replace-prologue : CodegenState -> CodegenState
  emit-str-replace-prologue (st) =
    let st0 = record-func-offset st "__str_replace"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (push-r reg-r14)
   in let st5 = st-append-text st4 (push-r reg-r15)
   in let st6 = st-append-text st5 (mov-rr reg-rbx reg-rdi)
   in let st7 = st-append-text st6 (mov-rr reg-r12 reg-rsi)
   in let st8 = st-append-text st7 (mov-rr reg-r13 reg-rdx)
   in let st9 = st-append-text st8 (mov-rr reg-r14 reg-r10)
   in let st10 = st-append-text st9 (li reg-r15 0)
   in let st11 = st-append-text st10 (li reg-rcx 0)
   in st-append-text st11 (mov-load reg-rax reg-rbx 0)

  emit-str-replace-main-head : CodegenState -> HelpResult4
  emit-str-replace-main-head (st) =
    let main-loop = list-length (st.text)
   in let st0 = st-append-text st (mov-load reg-rax reg-rbx 0)
   in let st1 = st-append-text st0 (cmp-rr reg-rcx reg-rax)
   in let done-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = st-append-text st2 (mov-load reg-rdx reg-r12 0)
   in let st4 = st-append-text st3 (test-rr reg-rdx reg-rdx)
   in let no-match-empty-pos = list-length (st4.text)
   in let st5 = st-append-text st4 (jcc cc-e 0)
   in let st6 = st-append-text st5 (mov-rr reg-rsi reg-rcx)
   in let st7 = st-append-text st6 (add-rr reg-rsi reg-rdx)
   in let st8 = st-append-text st7 (cmp-rr reg-rsi reg-rax)
   in let cant-match-pos = list-length (st8.text)
   in let st9 = st-append-text st8 (jcc cc-g 0)
   in HelpResult4 {
    cg = st9,
    p1 = done-pos,
    p2 = main-loop,
    p3 = no-match-empty-pos,
    p4 = cant-match-pos
   }

  emit-str-replace-cmp : CodegenState -> HelpResult2
  emit-str-replace-cmp (st) =
    let st0 = st-append-text st (li reg-rsi 0)
   in let cmp-loop = list-length (st0.text)
   in let st1 = st-append-text st0 (cmp-rr reg-rsi reg-rdx)
   in let match-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-rbx)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-rcx)
   in let st5 = st-append-text st4 (add-rr reg-rax reg-rsi)
   in let st6 = st-append-text st5 (movzx-byte reg-rax reg-rax 8)
   in let st7 = st-append-text st6 (mov-rr reg-rdi reg-r12)
   in let st8 = st-append-text st7 (add-rr reg-rdi reg-rsi)
   in let st9 = st-append-text st8 (movzx-byte reg-rdi reg-rdi 8)
   in let st10 = st-append-text st9 (cmp-rr reg-rax reg-rdi)
   in let mismatch-pos = list-length (st10.text)
   in let st11 = st-append-text st10 (jcc cc-ne 0)
   in let st12 = st-append-text st11 (add-ri reg-rsi 1)
   in let st13 = st-append-text st12 (jmp (cmp-loop - (list-length (st12.text) + 5)))
   in HelpResult2 {
    cg = st13,
    p1 = match-pos,
    p2 = mismatch-pos
   }

  emit-str-replace-copy-new : CodegenState -> Integer -> CodegenState
  emit-str-replace-copy-new (st) (main-loop) =
    let st0 = st-append-text st (mov-load reg-rdx reg-r13 0)
   in let st1 = st-append-text st0 (li reg-rsi 0)
   in let copy-loop = list-length (st1.text)
   in let st2 = st-append-text st1 (cmp-rr reg-rsi reg-rdx)
   in let copy-done-pos = list-length (st2.text)
   in let st3 = st-append-text st2 (jcc cc-ge 0)
   in let st4 = st-append-text st3 (mov-rr reg-rax reg-r13)
   in let st5 = st-append-text st4 (add-rr reg-rax reg-rsi)
   in let st6 = st-append-text st5 (movzx-byte reg-rax reg-rax 8)
   in let st7 = st-append-text st6 (mov-rr reg-rdi reg-r14)
   in let st8 = st-append-text st7 (add-rr reg-rdi reg-r15)
   in let st9 = st-append-text st8 (mov-store-byte reg-rdi reg-rax 8)
   in let st10 = st-append-text st9 (add-ri reg-r15 1)
   in let st11 = st-append-text st10 (add-ri reg-rsi 1)
   in let st12 = st-append-text st11 (jmp (copy-loop - (list-length (st11.text) + 5)))
   in let st13 = patch-jcc-at st12 copy-done-pos (list-length (st12.text))
   in let st14 = st-append-text st13 (mov-load reg-rdx reg-r12 0)
   in let st15 = st-append-text st14 (add-rr reg-rcx reg-rdx)
   in st-append-text st15 (jmp (main-loop - (list-length (st15.text) + 5)))

  emit-str-replace-no-match : CodegenState -> Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-str-replace-no-match (st) (mismatch-pos) (no-match-empty-pos) (cant-match-pos) (main-loop) =
    let st0 = patch-jcc-at st mismatch-pos (list-length (st.text))
   in let st1 = patch-jcc-at st0 no-match-empty-pos (list-length (st0.text))
   in let st2 = patch-jcc-at st1 cant-match-pos (list-length (st1.text))
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-rbx)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-rcx)
   in let st5 = st-append-text st4 (movzx-byte reg-rax reg-rax 8)
   in let st6 = st-append-text st5 (mov-rr reg-rdi reg-r14)
   in let st7 = st-append-text st6 (add-rr reg-rdi reg-r15)
   in let st8 = st-append-text st7 (mov-store-byte reg-rdi reg-rax 8)
   in let st9 = st-append-text st8 (add-ri reg-r15 1)
   in let st10 = st-append-text st9 (add-ri reg-rcx 1)
   in st-append-text st10 (jmp (main-loop - (list-length (st10.text) + 5)))

  emit-str-replace-done : CodegenState -> Integer -> CodegenState
  emit-str-replace-done (st) (done-pos) =
    let st0 = patch-jcc-at st done-pos (list-length (st.text))
   in let st1 = st-append-text st0 (mov-store reg-r14 reg-r15 0)
   in let st2 = st-append-text st1 (mov-rr reg-rax reg-r15)
   in let st3 = st-append-text st2 (add-ri reg-rax 15)
   in let st4 = st-append-text st3 (and-ri reg-rax (0 - 8))
   in let st5 = st-append-text st4 (lea reg-r10 reg-r14 0)
   in let st6 = st-append-text st5 (add-rr reg-r10 reg-rax)
   in let st7 = st-append-text st6 (mov-rr reg-rax reg-r14)
   in let st8 = st-append-text st7 (pop-r reg-r15)
   in let st9 = st-append-text st8 (pop-r reg-r14)
   in let st10 = st-append-text st9 (pop-r reg-r13)
   in let st11 = st-append-text st10 (pop-r reg-r12)
   in let st12 = st-append-text st11 (pop-r reg-rbx)
   in st-append-text st12 x86-ret

  emit-str-replace : CodegenState -> CodegenState
  emit-str-replace (st) =
    let st0 = emit-str-replace-prologue st
   in let head = emit-str-replace-main-head st0
   in let cmp = emit-str-replace-cmp (head.cg)
   in let st1 = emit-str-replace-copy-new (cmp.cg) (head.p2)
   in let st2 = emit-str-replace-no-match st1 (cmp.p2) (head.p3) (head.p4) (head.p2)
   in emit-str-replace-done st2 (head.p1)

Section: __text_split

 Splits a string by a single-character delimiter.
 RDI = text, RSI = delimiter string, returns RAX = list of text pointers.

  emit-text-split-prologue : CodegenState -> CodegenState
  emit-text-split-prologue (st) =
    let st0 = record-func-offset st "__text_split"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (push-r reg-r14)
   in let st5 = st-append-text st4 (push-r reg-r15)
   in let st6 = st-append-text st5 (mov-rr reg-rbx reg-rdi)
   in let st7 = st-append-text st6 (mov-load reg-r12 reg-rbx 0)
   in let st8 = st-append-text st7 (movzx-byte reg-r13 reg-rsi 8)
   in let st9 = st-append-text st8 (mov-rr reg-r14 reg-r10)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-r12)
   in let st11 = st-append-text st10 (add-ri reg-rax 2)
   in let st12 = st-append-text st11 (shl-ri reg-rax 3)
   in let st13 = st-append-text st12 (add-rr reg-r10 reg-rax)
   in let st14 = st-append-text st13 (li reg-r15 0)
   in let st15 = st-append-text st14 (li reg-r11 0)
   in st-append-text st15 (mov-rr reg-rcx reg-r11)

  emit-text-split-scan-head : CodegenState -> HelpResult2
  emit-text-split-scan-head (st) =
    let scan-loop = list-length (st.text)
   in let st0 = st-append-text st (cmp-rr reg-r11 reg-r12)
   in let scan-done-pos = list-length (st0.text)
   in let st1 = st-append-text st0 (jcc cc-ge 0)
   in let st2 = st-append-text st1 (mov-rr reg-rax reg-rbx)
   in let st3 = st-append-text st2 (add-rr reg-rax reg-r11)
   in let st4 = st-append-text st3 (movzx-byte reg-rax reg-rax 8)
   in let st5 = st-append-text st4 (cmp-rr reg-rax reg-r13)
   in let not-delim-pos = list-length (st5.text)
   in let st6 = st-append-text st5 (jcc cc-ne 0)
   in HelpResult2 {
    cg = st6,
    p1 = scan-done-pos,
    p2 = not-delim-pos
   }

  emit-text-split-emit-seg : CodegenState -> Integer -> CodegenState
  emit-text-split-emit-seg (st) (scan-loop) =
    let st0 = st-append-text st (mov-rr reg-rax reg-r11)
   in let st1 = st-append-text st0 (sub-rr reg-rax reg-rcx)
   in let st2 = st-append-text st1 (mov-rr reg-rdi reg-r10)
   in let st3 = st-append-text st2 (mov-store reg-rdi reg-rax 0)
   in let st4 = st-append-text st3 (push-r reg-rax)
   in let st5 = st-append-text st4 (add-ri reg-rax 15)
   in let st6 = st-append-text st5 (and-ri reg-rax (0 - 8))
   in let st7 = st-append-text st6 (add-rr reg-r10 reg-rax)
   in let st8 = st-append-text st7 (pop-r reg-rax)
   in let st9 = st-append-text st8 (push-r reg-r11)
   in st-append-text st9 (li reg-rsi 0)

  emit-text-split-seg-copy : CodegenState -> Integer -> CodegenState
  emit-text-split-seg-copy (st) (scan-loop) =
    let seg-copy = list-length (st.text)
   in let st0 = st-append-text st (cmp-rr reg-rsi reg-rax)
   in let seg-done-pos = list-length (st0.text)
   in let st1 = st-append-text st0 (jcc cc-ge 0)
   in let st2 = st-append-text st1 (mov-rr reg-rdx reg-rbx)
   in let st3 = st-append-text st2 (add-rr reg-rdx reg-rcx)
   in let st4 = st-append-text st3 (add-rr reg-rdx reg-rsi)
   in let st5 = st-append-text st4 (movzx-byte reg-rdx reg-rdx 8)
   in let st6 = st-append-text st5 (mov-rr reg-r11 reg-rdi)
   in let st7 = st-append-text st6 (add-rr reg-r11 reg-rsi)
   in let st8 = st-append-text st7 (mov-store-byte reg-r11 reg-rdx 8)
   in let st9 = st-append-text st8 (add-ri reg-rsi 1)
   in let st10 = st-append-text st9 (jmp (seg-copy - (list-length (st9.text) + 5)))
   in let st11 = patch-jcc-at st10 seg-done-pos (list-length (st10.text))
   in let st12 = st-append-text st11 (pop-r reg-r11)
   in let st13 = st-append-text st12 (mov-rr reg-rax reg-r15)
   in let st14 = st-append-text st13 (shl-ri reg-rax 3)
   in let st15 = st-append-text st14 (add-rr reg-rax reg-r14)
   in let st16 = st-append-text st15 (mov-store reg-rax reg-rdi 8)
   in let st17 = st-append-text st16 (add-ri reg-r15 1)
   in let st18 = st-append-text st17 (add-ri reg-r11 1)
   in st-append-text st18 (mov-rr reg-rcx reg-r11)

  emit-text-split-not-delim : CodegenState -> Integer -> Integer -> CodegenState
  emit-text-split-not-delim (st) (not-delim-pos) (scan-loop) =
    let st0 = st-append-text st (jmp (scan-loop - (list-length (st.text) + 5)))
   in let st1 = patch-jcc-at st0 not-delim-pos (list-length (st0.text))
   in let st2 = st-append-text st1 (add-ri reg-r11 1)
   in st-append-text st2 (jmp (scan-loop - (list-length (st2.text) + 5)))

  emit-text-split-final-seg : CodegenState -> Integer -> CodegenState
  emit-text-split-final-seg (st) (scan-done-pos) =
    let st0 = patch-jcc-at st scan-done-pos (list-length (st.text))
   in let st1 = st-append-text st0 (mov-rr reg-rax reg-r12)
   in let st2 = st-append-text st1 (sub-rr reg-rax reg-rcx)
   in let st3 = st-append-text st2 (mov-rr reg-rdi reg-r10)
   in let st4 = st-append-text st3 (mov-store reg-rdi reg-rax 0)
   in let st5 = st-append-text st4 (push-r reg-rax)
   in let st6 = st-append-text st5 (add-ri reg-rax 15)
   in let st7 = st-append-text st6 (and-ri reg-rax (0 - 8))
   in let st8 = st-append-text st7 (add-rr reg-r10 reg-rax)
   in st-append-text st8 (pop-r reg-rax)

  emit-text-split-final-copy : CodegenState -> CodegenState
  emit-text-split-final-copy (st) =
    let st0 = st-append-text st (li reg-rsi 0)
   in let last-copy = list-length (st0.text)
   in let st1 = st-append-text st0 (cmp-rr reg-rsi reg-rax)
   in let last-done-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = st-append-text st2 (mov-rr reg-rdx reg-rbx)
   in let st4 = st-append-text st3 (add-rr reg-rdx reg-rcx)
   in let st5 = st-append-text st4 (add-rr reg-rdx reg-rsi)
   in let st6 = st-append-text st5 (movzx-byte reg-rdx reg-rdx 8)
   in let st7 = st-append-text st6 (mov-rr reg-r11 reg-rdi)
   in let st8 = st-append-text st7 (add-rr reg-r11 reg-rsi)
   in let st9 = st-append-text st8 (mov-store-byte reg-r11 reg-rdx 8)
   in let st10 = st-append-text st9 (add-ri reg-rsi 1)
   in let st11 = st-append-text st10 (jmp (last-copy - (list-length (st10.text) + 5)))
   in patch-jcc-at st11 last-done-pos (list-length (st11.text))

  emit-text-split-epilogue : CodegenState -> CodegenState
  emit-text-split-epilogue (st) =
    let st0 = st-append-text st (mov-rr reg-rax reg-r15)
   in let st1 = st-append-text st0 (shl-ri reg-rax 3)
   in let st2 = st-append-text st1 (add-rr reg-rax reg-r14)
   in let st3 = st-append-text st2 (mov-store reg-rax reg-rdi 8)
   in let st4 = st-append-text st3 (add-ri reg-r15 1)
   in let st5 = st-append-text st4 (mov-store reg-r14 reg-r15 0)
   in let st6 = st-append-text st5 (mov-rr reg-rax reg-r14)
   in let st7 = st-append-text st6 (pop-r reg-r15)
   in let st8 = st-append-text st7 (pop-r reg-r14)
   in let st9 = st-append-text st8 (pop-r reg-r13)
   in let st10 = st-append-text st9 (pop-r reg-r12)
   in let st11 = st-append-text st10 (pop-r reg-rbx)
   in st-append-text st11 x86-ret

  emit-text-split : CodegenState -> CodegenState
  emit-text-split (st) =
    let st0 = emit-text-split-prologue st
   in let head = emit-text-split-scan-head st0
   in let scan-loop = list-length (st0.text)
   in let st1 = emit-text-split-emit-seg (head.cg) scan-loop
   in let st2 = emit-text-split-seg-copy st1 scan-loop
   in let st3 = emit-text-split-not-delim st2 (head.p2) scan-loop
   in let st4 = emit-text-split-final-seg st3 (head.p1)
   in let st5 = emit-text-split-final-copy st4
   in emit-text-split-epilogue st5

Section: Helpers Entry Point

  emit-runtime-helpers : CodegenState -> CodegenState
  emit-runtime-helpers (st) =
    let st0 = emit-str-concat st
   in let st1 = emit-str-eq st0
   in let st2 = emit-itoa st1
   in let st3 = emit-ipow st2
   in let st4 = emit-text-to-int st3
   in let st5 = emit-text-starts-with st4
   in let st6 = emit-text-contains st5
   in let st7 = emit-text-compare st6
   in let st8 = emit-str-replace st7
   in let st9 = emit-list-snoc st8
   in let st10 = emit-list-cons st9
   in let st11 = emit-list-append st10
   in let st12 = emit-list-insert-at st11
   in let st13 = emit-list-contains st12
   in let st14 = emit-text-concat-list st13
   in emit-text-split st14
