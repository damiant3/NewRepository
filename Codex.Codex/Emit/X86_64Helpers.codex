   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (mov-rr reg-rbx reg-rdi)
   in let st5 = st-append-text st4 (mov-rr reg-r12 reg-rsi)
   in let st6 = st-append-text st5 (mov-rr reg-r13 reg-rcx)
   in let st7 = st-append-text st6 (shl-ri reg-r13 1)
   in let st8 = st-append-text st7 (cmp-ri reg-r13 4)
   in let cap-ok2-pos = list-length (st8.text)
