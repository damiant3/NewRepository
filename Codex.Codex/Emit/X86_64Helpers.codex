Chapter: X86-64 Code Generator

 Runtime helper state records, the helpers entry point, I/O boundary
 helpers (CCE<->Unicode conversion, serial I/O), buffer helpers, and
 binary-output helpers. Text/number helpers live in
 X86_64TextHelpers.codex; list helpers in X86_64ListHelpers.codex.

Section: State Records
  StrEqHeadResult = record {
    cg : CodegenState,
    len-ne-pos : Integer
  }

  StrEqLoopResult = record {
    cg : CodegenState,
    loop-done-pos : Integer,
    byte-ne-pos : Integer
  }

  ItoaZeroResult = record {
    cg : CodegenState,
    skip-digits-pos : Integer
  }

  StrConcatCheckResult = record {
    cg : CodegenState,
    slow-path-pos : Integer
  }

  StrConcatFastResult = record {
    cg : CodegenState,
    fast-done-pos : Integer
  }

  HelpResult1 = record {
    cg : CodegenState,
    p1 : Integer
  }

  HelpResult2 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer
  }

  HelpResult3 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer,
    p3 : Integer
  }

  HelpResult4 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer,
    p3 : Integer,
    p4 : Integer
  }

Section: Helpers Entry Point
Section: I/O Boundary Helpers
  emit-cce-to-unicode-helper : CodegenState -> CodegenState
  emit-cce-to-unicode-helper (st) =
   let st1 = record-func-offset st "__cce_to_unicode"
   in let st2 = emit-load-rodata-addr st1 reg-rax cce-to-unicode-rodata-offset
   in let st3 = st-append-text st2 (add-rr reg-rax reg-rdi)
   in let st4 = st-append-text st3 (movzx-byte reg-rax reg-rax 0)
   in st-append-text st4 x86-ret

  emit-unicode-to-cce-helper : CodegenState -> CodegenState
  emit-unicode-to-cce-helper (st) =
   let st1 = record-func-offset st "__unicode_to_cce"
   in let st2 = emit-load-rodata-addr st1 reg-rax unicode-to-cce-rodata-offset
   in let st3 = st-append-text st2 (add-rr reg-rax reg-rdi)
   in let st4 = st-append-text st3 (movzx-byte reg-rax reg-rax 0)
   in st-append-text st4 x86-ret

  emit-read-line-helper : CodegenState -> CodegenState
  emit-read-line-helper (st) =
   let st1 = record-func-offset st "__read_line"
   in let st2 = st-append-text st1 (push-r reg-rbx)
   in let st3 = st-append-text st2 (push-r reg-r12)
   in let st4 = emit-load-rodata-addr st3 reg-r12 unicode-to-cce-rodata-offset
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-r10)
   in let st6 = st-append-text st5 (li reg-rcx 0)
   in let read-byte = st6.text-len
   in let st7 = st-append-text st6 (push-r reg-rcx)
   in let wait-loop = st7.text-len
   in let st8 = st-append-text st7 (li reg-rdi serial-write-pos-addr)
   in let st9 = st-append-text st8 (mov-load reg-rsi reg-rdi 0)
   in let st10 = st-append-text st9 (li reg-rdi serial-read-pos-addr)
   in let st11 = st-append-text st10 (mov-load reg-r11 reg-rdi 0)
   in let st12 = st-append-text st11 (cmp-rr reg-rsi reg-r11)
   in let has-data = st12.text-len
   in let st13 = st-append-text st12 (jcc cc-ne 0)
   in let st14 = st-append-text st13 hlt
   in let st15 = st-append-text st14 (jmp (wait-loop - (st14.text-len + 5)))
   in let st16 = patch-jcc-at st15 has-data (st15.text-len)
   in let st17 = st-append-text st16 (mov-rr reg-rax reg-r11)
   in let st18 = st-append-text st17 (and-ri reg-rax serial-ring-buf-mask)
   in let st19 = st-append-text st18 (add-ri reg-rax serial-ring-buf-addr)
   in let st20 = st-append-text st19 (movzx-byte reg-rax reg-rax 0)
   in let st21 = st-append-text st20 (add-ri reg-r11 1)
   in let st22 = st-append-text st21 (li reg-rdi serial-read-pos-addr)
   in let st23 = st-append-text st22 (mov-store reg-rdi reg-r11 0)
   in let st24 = st-append-text st23 (cmp-ri reg-rax 13)
   in let skip-cr = st24.text-len
   in let st25 = st-append-text st24 (jcc cc-e 0)
   in let st26 = st-append-text st25 (pop-r reg-rcx)
   in let st27 = st-append-text st26 (push-r reg-rcx)
   in let st28 = st-append-text st27 (mov-rr reg-rsi reg-rbx)
   in let st29 = st-append-text st28 (add-rr reg-rsi reg-rcx)
   in let st30 = st-append-text st29 (add-ri reg-rsi 8)
   in let st31 = st-append-text st30 [136, 6]
   in let st32 = st-append-text st31 (li reg-rax 1)
   in let st33 = patch-jcc-at st32 skip-cr wait-loop
   in let st34 = st-append-text st33 (pop-r reg-rcx)
   in let st35 = st-append-text st34 (test-rr reg-rax reg-rax)
   in let eof = st35.text-len
   in let st36 = st-append-text st35 (jcc cc-le 0)
   in let st37 = st-append-text st36 (mov-rr reg-rdx reg-rbx)
   in let st38 = st-append-text st37 (add-rr reg-rdx reg-rcx)
   in let st39 = st-append-text st38 (movzx-byte reg-rdx reg-rdx 8)
   in let st40 = st-append-text st39 (cmp-ri reg-rdx 10)
   in let got-nl = st40.text-len
   in let st41 = st-append-text st40 (jcc cc-e 0)
   in let st42 = st-append-text st41 (mov-rr reg-rsi reg-rbx)
   in let st43 = st-append-text st42 (add-rr reg-rsi reg-rcx)
   in let st44 = st-append-text st43 (add-ri reg-rsi 8)
   in let st45 = st-append-text st44 (movzx-byte reg-rax reg-rsi 0)
   in let st46 = st-append-text st45 (add-rr reg-rax reg-r12)
   in let st47 = st-append-text st46 (movzx-byte reg-rax reg-rax 0)
   in let st48 = st-append-text st47 [136, 6]
   in let st49 = st-append-text st48 (add-ri reg-rcx 1)
   in let st50 = st-append-text st49 (jmp (read-byte - (st49.text-len + 5)))
   in let st51 = patch-jcc-at st50 eof (st50.text-len)
   in let st52 = patch-jcc-at st51 got-nl (st51.text-len)
   in let st53 = st-append-text st52 (mov-store reg-rbx reg-rcx 0)
   in let st54 = st-append-text st53 (mov-rr reg-rax reg-rcx)
   in let st55 = st-append-text st54 (add-ri reg-rax 15)
   in let st56 = st-append-text st55 (and-ri reg-rax (0 - 8))
   in let st57 = st-append-text st56 (add-rr reg-r10 reg-rax)
   in let st58 = st-append-text st57 (mov-rr reg-rax reg-rbx)
   in let st59 = st-append-text st58 (pop-r reg-r12)
   in let st60 = st-append-text st59 (pop-r reg-rbx)
   in st-append-text st60 x86-ret

  emit-read-file-helper : CodegenState -> CodegenState
  emit-read-file-helper (st) =
   let st1 = record-func-offset st "__read_file"
   in let st2 = emit-call-to st1 "__bare_metal_read_serial"
   in st-append-text st2 x86-ret

  emit-bare-metal-read-serial : CodegenState -> CodegenState
  emit-bare-metal-read-serial (st) =
   let st1 = record-func-offset st "__bare_metal_read_serial"
   in let st2 = st-append-text st1 (push-r reg-rbx)
   in let st3 = st-append-text st2 (push-r reg-rcx)
   in let st3a = st-append-text st3 (push-r reg-r12)
   in let st4 = emit-load-rodata-addr st3a reg-r12 unicode-to-cce-rodata-offset
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-r10)
   in let st6 = st-append-text st5 (li reg-rcx 0)
   in let read-loop = st6.text-len
   in let wait-loop = st6.text-len
   in let st7 = st-append-text st6 (li reg-rdi serial-write-pos-addr)
   in let st8 = st-append-text st7 (mov-load reg-rsi reg-rdi 0)
   in let st9 = st-append-text st8 (li reg-rdi serial-read-pos-addr)
   in let st10 = st-append-text st9 (mov-load reg-r11 reg-rdi 0)
   in let st11 = st-append-text st10 (cmp-rr reg-rsi reg-r11)
   in let has-data = st11.text-len
   in let st12 = st-append-text st11 (jcc cc-ne 0)
   in let st13 = st-append-text st12 hlt
   in let st14 = st-append-text st13 (jmp (wait-loop - (st13.text-len + 5)))
   in let st15 = patch-jcc-at st14 has-data (st14.text-len)
   in let st16 = st-append-text st15 (mov-rr reg-rax reg-r11)
   in let st17 = st-append-text st16 (and-ri reg-rax serial-ring-buf-mask)
   in let st18 = st-append-text st17 (add-ri reg-rax serial-ring-buf-addr)
   in let st19 = st-append-text st18 (movzx-byte reg-rax reg-rax 0)
   in let st20 = st-append-text st19 (add-ri reg-r11 1)
   in let st21 = st-append-text st20 (li reg-rdi serial-read-pos-addr)
   in let st22 = st-append-text st21 (mov-store reg-rdi reg-r11 0)
   in let st23 = st-append-text st22 (cmp-ri reg-rax 4)
   in let got-eot = st23.text-len
   in let st24 = st-append-text st23 (jcc cc-e 0)
   in let st25 = st-append-text st24 (test-rr reg-rax reg-rax)
   in let got-null = st25.text-len
   in let st26 = st-append-text st25 (jcc cc-e 0)
   in let st27 = st-append-text st26 (cmp-ri reg-rax 13)
   in let skip-cr = st27.text-len
   in let st28 = st-append-text st27 (jcc cc-e 0)
   in let st29 = st-append-text st28 (add-rr reg-rax reg-r12)
   in let st30 = st-append-text st29 (movzx-byte reg-rax reg-rax 0)
   in let st31 = st-append-text st30 (mov-rr reg-rsi reg-rbx)
   in let st32 = st-append-text st31 (add-rr reg-rsi reg-rcx)
   in let st33 = st-append-text st32 (add-ri reg-rsi 8)
   in let st34 = st-append-text st33 [136, 6]
   in let st35 = st-append-text st34 (add-ri reg-rcx 1)
   in let st36 = patch-jcc-at st35 skip-cr (st35.text-len)
   in let st37 = st-append-text st36 (jmp (read-loop - (st36.text-len + 5)))
   in let st38 = patch-jcc-at st37 got-eot (st37.text-len)
   in let st39 = patch-jcc-at st38 got-null (st38.text-len)
   in let st40 = st-append-text st39 (mov-store reg-rbx reg-rcx 0)
   in let st41 = st-append-text st40 (mov-rr reg-rax reg-rcx)
   in let st42 = st-append-text st41 (add-ri reg-rax 15)
   in let st43 = st-append-text st42 (and-ri reg-rax (0 - 8))
   in let st44 = st-append-text st43 (add-ri reg-rax 8)
   in let st45 = st-append-text st44 (add-rr reg-r10 reg-rax)
   in let st46 = st-append-text st45 (mov-rr reg-rax reg-rbx)
   in let st47 = st-append-text st46 (pop-r reg-r12)
   in let st48 = st-append-text st47 (pop-r reg-rcx)
   in let st49 = st-append-text st48 (pop-r reg-rbx)
   in st-append-text st49 x86-ret

  emit-runtime-helpers : CodegenState -> CodegenState
  emit-runtime-helpers (st) =
    let st0 = emit-str-concat st
   in let st1 = emit-str-eq st0
   in let st2 = emit-itoa st1
   in let st3 = emit-ipow st2
   in let st4 = emit-text-to-int st3
   in let st5 = emit-text-starts-with st4
   in let st6 = emit-text-contains st5
   in let st7 = emit-text-compare st6
   in let st8 = emit-str-replace st7
   in let st9 = emit-list-snoc st8
   in let st10 = emit-list-cons st9
   in let st11 = emit-list-append st10
   in let st12 = emit-list-insert-at st11
   in let st12b = emit-list-set-at st12
   in let st13 = emit-list-contains st12b
   in let st14 = emit-text-concat-list st13
   in let st15 = emit-text-split st14
   in let st16 = emit-cce-to-unicode-helper st15
   in let st17 = emit-unicode-to-cce-helper st16
   in let st18 = emit-read-line-helper st17
   in let st19 = emit-read-file-helper st18
   in let st20 = emit-bare-metal-read-serial st19
   in let st21 = emit-write-binary-helper st20
   in let st22 = emit-buf-write-bytes-helper st21
   in let st23 = emit-buf-read-bytes-helper st22
   in emit-list-concat-many-helper st23

Section: Buffer Helpers
  emit-buf-write-bytes-helper : CodegenState -> CodegenState
  emit-buf-write-bytes-helper (st) =
   let st1 = record-func-offset st "__buf_write_bytes"
   in let st2 = st-append-text st1 (push-r reg-rbx ++ push-r reg-r12 ++ push-r reg-r13)
   in let st3 = st-append-text st2 (mov-rr reg-rbx reg-rdi)
   in let st4 = st-append-text st3 (add-rr reg-rbx reg-rsi)
   in let st5 = st-append-text st4 (mov-rr reg-r12 reg-rdx)
   in let st6 = st-append-text st5 (mov-load reg-r13 reg-r12 0)
   in let st7 = st-append-text st6 (li reg-rcx 0)
   in let st8 = st-append-text st7 (cmp-rr reg-rcx reg-r13)
   in let skip-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ge 0)
   in let loop-top = st9.text-len
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-rcx)
   in let st11 = st-append-text st10 (shl-ri reg-rax 3)
   in let st12 = st-append-text st11 (add-rr reg-rax reg-r12)
   in let st13 = st-append-text st12 (mov-load reg-rax reg-rax 8)
   in let st14 = st-append-text st13 (mov-store-byte reg-rbx reg-rax 0)
   in let st15 = st-append-text st14 (add-ri reg-rbx 1)
   in let st16 = st-append-text st15 (add-ri reg-rcx 1)
   in let st17 = st-append-text st16 (cmp-rr reg-rcx reg-r13)
   in let back-pos = st17.text-len
   in let st18 = st-append-text st17 (jcc cc-l 0)
   in let st19 = patch-jcc-at st18 back-pos loop-top
   in let st20 = patch-jcc-at st19 skip-pos (st19.text-len)
   in let st21 = st-append-text st20 (add-rr reg-rsi reg-r13)
   in let st22 = st-append-text st21 (mov-rr reg-rax reg-rsi)
   in st-append-text st22 (pop-r reg-r13 ++ pop-r reg-r12 ++ pop-r reg-rbx ++ x86-ret)

  emit-buf-read-bytes-helper : CodegenState -> CodegenState
  emit-buf-read-bytes-helper (st) =
   let st1 = record-func-offset st "__buf_read_bytes"
   in let st2 = st-append-text st1 (push-r reg-rbx ++ push-r reg-r12 ++ push-r reg-r13 ++ push-r reg-r14)
   in let st3 = st-append-text st2 (mov-rr reg-r12 reg-rdi)
   in let st4 = st-append-text st3 (add-rr reg-r12 reg-rsi)
   in let st5 = st-append-text st4 (mov-rr reg-r13 reg-rdx)
   in let st6 = st-append-text st5 (mov-store reg-r10 reg-r13 0)
   in let st7 = st-append-text st6 (add-ri reg-r10 8)
   in let st8 = st-append-text st7 (mov-rr reg-rbx reg-r10)
   in let st9 = st-append-text st8 (mov-store reg-r10 reg-r13 0)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-r13)
   in let st11 = st-append-text st10 (add-ri reg-rax 1)
   in let st12 = st-append-text st11 (shl-ri reg-rax 3)
   in let st13 = st-append-text st12 (add-rr reg-r10 reg-rax)
   in let st14 = st-append-text st13 (li reg-rcx 0)
   in let st15 = st-append-text st14 (cmp-rr reg-rcx reg-r13)
   in let skip-pos = st15.text-len
   in let st16 = st-append-text st15 (jcc cc-ge 0)
   in let loop-top = st16.text-len
   in let st17 = st-append-text st16 (mov-rr reg-r14 reg-r12)
   in let st18 = st-append-text st17 (add-rr reg-r14 reg-rcx)
   in let st19 = st-append-text st18 (movzx-byte reg-r14 reg-r14 0)
   in let st20 = st-append-text st19 (mov-rr reg-rax reg-rcx)
   in let st21 = st-append-text st20 (shl-ri reg-rax 3)
   in let st22 = st-append-text st21 (add-rr reg-rax reg-rbx)
   in let st23 = st-append-text st22 (mov-store reg-rax reg-r14 8)
   in let st24 = st-append-text st23 (add-ri reg-rcx 1)
   in let st25 = st-append-text st24 (cmp-rr reg-rcx reg-r13)
   in let back-pos = st25.text-len
   in let st26 = st-append-text st25 (jcc cc-l 0)
   in let st27 = patch-jcc-at st26 back-pos loop-top
   in let st28 = patch-jcc-at st27 skip-pos (st27.text-len)
   in let st29 = st-append-text st28 (mov-rr reg-rax reg-rbx)
   in st-append-text st29 (pop-r reg-r14 ++ pop-r reg-r13 ++ pop-r reg-r12 ++ pop-r reg-rbx ++ x86-ret)

Section: Binary Output
  emit-write-binary-helper : CodegenState -> CodegenState
  emit-write-binary-helper (st) =
   let st1 = record-func-offset st "__write_binary"
   in let st2 = st-append-text st1 (push-r reg-rbx)
   in let st3 = st-append-text st2 (push-r reg-rcx)
   in let st4 = st-append-text st3 (push-r reg-r11)
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-rdi)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rbx 0)
   in let st7 = st-append-text st6 (li reg-r11 0)
   in let loop-top = st7.text-len
   in let st8 = st-append-text st7 (cmp-rr reg-r11 reg-rcx)
   in let done-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ge 0)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-r11)
   in let st11 = st-append-text st10 (shl-ri reg-rax 3)
   in let st12 = st-append-text st11 (add-rr reg-rax reg-rbx)
   in let st13 = st-append-text st12 (mov-load reg-rax reg-rax 8)
   in let st14 = st-append-text st13 (push-r reg-rax)
   in let wait-top = st14.text-len
   in let st15 = st-append-text st14 (li reg-rdx 1021)
   in let st16 = st-append-text st15 [236]
   in let st17 = st-append-text st16 [168, 32]
   in let thr-ready = st17.text-len
   in let st18 = st-append-text st17 (jcc cc-ne 0)
   in let st19 = st-append-text st18 (jmp (wait-top - (st18.text-len + 5)))
   in let st20 = patch-jcc-at st19 thr-ready (st19.text-len)
   in let st21 = st-append-text st20 (pop-r reg-rax)
   in let st22 = st-append-text st21 (li reg-rdx 1016)
   in let st23 = st-append-text st22 out-dx-al
   in let st24 = st-append-text st23 (add-ri reg-r11 1)
   in let st25 = st-append-text st24 (jmp (loop-top - (st24.text-len + 5)))
   in let st26 = patch-jcc-at st25 done-pos (st25.text-len)
   in let st27 = st-append-text st26 (pop-r reg-r11)
   in let st28 = st-append-text st27 (pop-r reg-rcx)
   in let st29 = st-append-text st28 (pop-r reg-rbx)
   in st-append-text st29 x86-ret

  emit-linked-list-to-list-helper : CodegenState -> CodegenState
  emit-linked-list-to-list-helper (st) =
   let st1 = record-func-offset st "__linked_list_to_list"
   in let st2 = st-append-text st1 (push-r reg-rbp)
   in let st3 = st-append-text st2 (mov-rr reg-rbp reg-rsp)
   in let st4 = st-append-text st3 (push-r reg-rbx)
   in let st5 = st-append-text st4 (push-r reg-r12)
   in let st6 = st-append-text st5 (push-r reg-r13)
   in let st7 = st-append-text st6 (mov-rr reg-rbx reg-rdi)
   in let st8 = st-append-text st7 (li reg-r12 0)
   in let st9 = st-append-text st8 (mov-rr reg-rcx reg-rbx)
   in let count-loop = st9.text-len
   in let st10 = st-append-text st9 (test-rr reg-rcx reg-rcx)
   in let count-done = st10.text-len
   in let st11 = st-append-text st10 (jcc cc-e 0)
   in let st12 = st-append-text st11 (add-ri reg-r12 1)
   in let st13 = st-append-text st12 (mov-load reg-rcx reg-rcx 8)
   in let st14 = st-append-text st13 (jmp (count-loop - (st13.text-len + 5)))
   in let st15 = patch-jcc-at st14 count-done (st14.text-len)
   in let st16 = st-append-text st15 (mov-rr reg-r13 reg-r10)
   in let st17 = st-append-text st16 (mov-store reg-r13 reg-r12 0)
   in let st18 = st-append-text st17 (mov-rr reg-rax reg-r12)
   in let st19 = st-append-text st18 (add-ri reg-rax 1)
   in let st20 = st-append-text st19 (shl-ri reg-rax 3)
   in let st21 = st-append-text st20 (add-rr reg-r10 reg-rax)
   in let st22 = st-append-text st21 (mov-rr reg-rcx reg-rbx)
   in let st23 = st-append-text st22 (mov-rr reg-rdx reg-r12)
   in let fill-loop = st23.text-len
   in let st24 = st-append-text st23 (test-rr reg-rcx reg-rcx)
   in let fill-done = st24.text-len
   in let st25 = st-append-text st24 (jcc cc-e 0)
   in let st26 = st-append-text st25 (sub-ri reg-rdx 1)
   in let st27 = st-append-text st26 (mov-load reg-rax reg-rcx 0)
   in let st28 = st-append-text st27 (mov-rr reg-rsi reg-rdx)
   in let st29 = st-append-text st28 (add-ri reg-rsi 1)
   in let st30 = st-append-text st29 (shl-ri reg-rsi 3)
   in let st31 = st-append-text st30 (add-rr reg-rsi reg-r13)
   in let st32 = st-append-text st31 (mov-store reg-rsi reg-rax 0)
   in let st33 = st-append-text st32 (mov-load reg-rcx reg-rcx 8)
   in let st34 = st-append-text st33 (jmp (fill-loop - (st33.text-len + 5)))
   in let st35 = patch-jcc-at st34 fill-done (st34.text-len)
   in let st36 = st-append-text st35 (mov-rr reg-rax reg-r13)
   in let st37 = st-append-text st36 (pop-r reg-r13)
   in let st38 = st-append-text st37 (pop-r reg-r12)
   in let st39 = st-append-text st38 (pop-r reg-rbx)
   in let st40 = st-append-text st39 (pop-r reg-rbp)
   in st-append-text st40 x86-ret


