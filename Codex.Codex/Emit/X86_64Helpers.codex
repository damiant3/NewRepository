    let st0 = record-func-offset st "__text_concat_list"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (push-r reg-r14)
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-rdi)
   in let st6 = st-append-text st5 (mov-load reg-r12 reg-rbx 0)
   in let st7 = st-append-text st6 (li reg-r13 0)
   in let st8 = st-append-text st7 (li reg-r11 0)
   in let len-loop = list-length (st8.text)
   in let st9 = st-append-text st8 (cmp-rr reg-r11 reg-r12)
   in let len-done-pos = list-length (st9.text)
   in let st10 = st-append-text st9 (jcc cc-ge 0)
   in let st11 = st-append-text st10 (mov-rr reg-rax reg-r11)
   in let st12 = st-append-text st11 (shl-ri reg-rax 3)
   in let st13 = st-append-text st12 (add-rr reg-rax reg-rbx)
   in let st14 = st-append-text st13 (mov-load reg-rax reg-rax 8)
   in let st15 = st-append-text st14 (mov-load reg-rax reg-rax 0)
   in let st16 = st-append-text st15 (add-rr reg-r13 reg-rax)
   in let st17 = st-append-text st16 (add-ri reg-r11 1)
   in let st18 = st-append-text st17 (jmp (len-loop - (list-length (st17.text) + 5)))
   in patch-jcc-at st18 len-done-pos (list-length (st18.text))

