   in let st4 = st-append-text st3 (mov-rr reg-rax reg-r11)
   in let st5 = st-append-text st4 (shl-ri reg-rax 3)
   in let st6 = st-append-text st5 (add-rr reg-rax reg-rbx)
   in let st7 = st-append-text st6 (mov-load reg-rdi reg-rax 8)
   in let st8 = st-append-text st7 (mov-load reg-rcx reg-rdi 0)
