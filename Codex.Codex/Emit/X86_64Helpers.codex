   in let st12 = st-append-text st11 (mov-store reg-r10 reg-r13 0)
   in let st13 = st-append-text st12 (add-ri reg-r10 8)
   in let st14 = st-append-text st13 (mov-rr reg-rax reg-r10)
   in let st15 = st-append-text st14 (mov-rr reg-rdx reg-r13)
   in let st16 = st-append-text st15 (add-ri reg-rdx 1)
   in let st17 = st-append-text st16 (shl-ri reg-rdx 3)
   in st-append-text st17 (add-rr reg-r10 reg-rdx)

  emit-list-snoc-path3-copy : CodegenState -> CodegenState
