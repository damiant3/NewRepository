  emit-bit-op-2 : CodegenState -> List IRExpr -> (Integer -> Integer -> List Integer) -> EmitResult
  emit-bit-op-2 (st) (args) (op-bytes) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let ld0 = load-local (r1.state) (loc0.reg)
   in let rd = alloc-temp (ld0.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-rr (rd.reg) (ld0.reg) ++ op-bytes (rd.reg) (r1.reg)),
    reg = rd.reg
   }

  emit-bit-shift : CodegenState -> List IRExpr -> (Integer -> List Integer) -> EmitResult
  emit-bit-shift (st) (args) (shift-bytes) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let st2 = st-append-text (r1.state) (mov-rr reg-rcx (r1.reg))
   in let ld0 = load-local st2 (loc0.reg)
   in let rd = alloc-temp (ld0.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-rr (rd.reg) (ld0.reg) ++ shift-bytes (rd.reg)),
    reg = rd.reg
   }

  emit-bit-not : CodegenState -> List IRExpr -> EmitResult
  emit-bit-not (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r0.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-rr (rd.reg) (r0.reg) ++ not-r (rd.reg)),
    reg = rd.reg
   }

  emit-builtin : CodegenState -> Text -> List IRExpr -> EmitResult
  emit-builtin (st) (name) (args) =
    if name == "print-line" then emit-print-line-builtin st args
    else if name == "read-file" then emit-read-file-builtin st args
    else if name == "write-file" then emit-write-file-builtin st args
    else if name == "read-line" then emit-read-line-builtin st
    else if name == "write-binary" then emit-write-binary-builtin st args
    else if name == "text-length" then emit-text-length-builtin st args
    else if name == "integer-to-text" then emit-helper-call-1 st args "__itoa"
    else if name == "show" then emit-show-builtin st args
    else if name == "text-to-integer" then emit-helper-call-1 st args "__text_to_int"
    else if name == "text-replace" then emit-helper-call-3 st args "__str_replace"
    else if name == "text-contains" then emit-helper-call-2 st args "__text_contains"
    else if name == "text-starts-with" then emit-helper-call-2 st args "__text_starts_with"
    else if name == "text-compare" then emit-helper-call-2 st args "__text_compare"
    else if name == "text-concat-list" then emit-helper-call-1 st args "__text_concat_list"
    else if name == "text-split" then emit-helper-call-2 st args "__text_split"
    else if name == "substring" then emit-substring-builtin st args
    else if name == "list-length" then emit-list-length-builtin st args
    else if name == "list-at" then emit-list-at-builtin st args
    else if name == "list-cons" then emit-helper-call-2 st args "__list_cons"
    else if name == "list-append" then emit-helper-call-2 st args "__list_append"
    else if name == "list-snoc" then emit-helper-call-2 st args "__list_snoc"
    else if name == "list-insert-at" then emit-helper-call-3 st args "__list_insert_at"
    else if name == "list-set-at" then emit-helper-call-3 st args "__list_set_at"
    else if name == "list-contains" then emit-helper-call-2 st args "__list_contains"
    else if name == "char-at" then emit-char-at-builtin st args
    else if name == "char-code-at" then emit-char-code-at-builtin st args
    else if name == "char-code" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "code-to-char" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "char-to-text" then emit-char-to-text-builtin st args
    else if name == "is-letter" then emit-is-letter-builtin st args
    else if name == "is-digit" then emit-is-digit-builtin st args
    else if name == "is-whitespace" then emit-is-whitespace-builtin st args
    else if name == "negate" then emit-negate-builtin st args
    else if name == "get-args" then emit-get-args-builtin st
    else if name == "current-dir" then emit-current-dir-builtin st
    else if name == "record-set" then emit-record-set-builtin st args
    else if name == "linked-list-empty" then emit-linked-list-empty-builtin st args
    else if name == "linked-list-push" then emit-linked-list-push-builtin st args
    else if name == "linked-list-to-list" then emit-linked-list-to-list-builtin st args
    else if name == "heap-save" then emit-heap-save-builtin st
    else if name == "heap-restore" then emit-heap-restore-builtin st args
    else if name == "heap-advance" then emit-heap-advance-builtin st args
    else if name == "list-with-capacity" then emit-list-with-capacity-builtin st args
    else if name == "buf-write-byte" then emit-buf-write-byte-builtin st args
    else if name == "buf-write-bytes" then emit-buf-write-bytes-builtin st args
    else if name == "buf-read-bytes" then emit-buf-read-bytes-builtin st args
    else if name == "bit-and" then emit-bit-op-2 st args and-rr
    else if name == "bit-or" then emit-bit-op-2 st args or-rr
    else if name == "bit-xor" then emit-bit-op-2 st args xor-rr
    else if name == "bit-shl" then emit-bit-shift st args shl-cl
    else if name == "bit-shr" then emit-bit-shift st args shr-cl
    else if name == "bit-not" then emit-bit-not st args
    else emit-file-exists-builtin st args


