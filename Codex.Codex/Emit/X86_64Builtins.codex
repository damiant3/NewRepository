  }

  emit-list-with-capacity-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-list-with-capacity-builtin (st) (args) =
   let cap-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (cap-result.state)
   in let st1 = st-append-text (rd.state) (mov-store reg-r10 (cap-result.reg) 0)
   in let st2 = st-append-text st1 (add-ri reg-r10 8)
   in let st3 = st-append-text st2 (mov-rr (rd.reg) reg-r10)
   in let zero-tmp = alloc-temp st3
   in let st4 = st-append-text (zero-tmp.state) (li (zero-tmp.reg) 0)
   in let st5 = st-append-text st4 (mov-store reg-r10 (zero-tmp.reg) 0)
   in let adv-tmp = alloc-temp st5
   in let st6 = st-append-text (adv-tmp.state) (mov-rr (adv-tmp.reg) (cap-result.reg))
   in let st7 = st-append-text st6 (shl-ri (adv-tmp.reg) 3)
   in let st8 = st-append-text st7 (add-ri (adv-tmp.reg) 8)
   in EmitResult {
   state = st-append-text st8 (add-rr reg-r10 (adv-tmp.reg)),
   reg = rd.reg
  }

  emit-buf-write-byte-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-buf-write-byte-builtin (st) (args) =
   let base-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let base-loc = alloc-local (base-result.state)
   in let st1 = store-local (base-loc.state) (base-loc.reg) (base-result.reg)
   in let off-result = emit-expr st1 (list-at args 1)
   in let off-loc = alloc-local (off-result.state)
   in let st2 = store-local (off-loc.state) (off-loc.reg) (off-result.reg)
   in let byte-result = emit-expr st2 (list-at args 2)
   in let byte-loc = alloc-local (byte-result.state)
   in let st3 = store-local (byte-loc.state) (byte-loc.reg) (byte-result.reg)
   in let addr = alloc-temp st3
   in let base2 = load-local (addr.state) (base-loc.reg)
   in let off2 = load-local (base2.state) (off-loc.reg)
   in let st4 = st-append-text (off2.state) (mov-rr (addr.reg) (base2.reg))
   in let st5 = st-append-text st4 (add-rr (addr.reg) (off2.reg))
   in let byte2 = load-local st5 (byte-loc.reg)
   in let st6 = st-append-text (byte2.state) (mov-store-byte (addr.reg) (byte2.reg) 0)
   in let rd = alloc-temp st6
   in let off3 = load-local (rd.state) (off-loc.reg)
   in let st7 = st-append-text (off3.state) (mov-rr (rd.reg) (off3.reg))
   in EmitResult {
   state = st-append-text st7 (add-ri (rd.reg) 1),
   reg = rd.reg
  }

  emit-buf-write-bytes-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-buf-write-bytes-builtin (st) (args) =
   let base-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let base-loc = alloc-local (base-result.state)
   in let st1 = store-local (base-loc.state) (base-loc.reg) (base-result.reg)
   in let off-result = emit-expr st1 (list-at args 1)
   in let off-loc = alloc-local (off-result.state)
   in let st2 = store-local (off-loc.state) (off-loc.reg) (off-result.reg)
   in let list-result = emit-expr st2 (list-at args 2)
   in let st3 = st-append-text (list-result.state) (mov-rr reg-rdx (list-result.reg))
   in let off2 = load-local st3 (off-loc.reg)
   in let st4 = st-append-text (off2.state) (mov-rr reg-rsi (off2.reg))
   in let base2 = load-local st4 (base-loc.reg)
   in let st5 = st-append-text (base2.state) (mov-rr reg-rdi (base2.reg))
   in let st6 = emit-call-to st5 "__buf_write_bytes"
