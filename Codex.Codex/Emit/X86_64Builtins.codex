   reg = rd.reg
  }

  emit-write-binary-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-write-binary-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (mov-rr reg-rdi (r.reg))
   in let st2 = emit-call-to st1 "__write_binary"
   in let rd = alloc-temp st2
