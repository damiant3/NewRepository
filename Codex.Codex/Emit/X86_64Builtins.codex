  }

  emit-write-file-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-write-file-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let r1 = emit-expr (r0.state) (list-at args 1)
   in let st1 = emit-print-text-no-newline (r1.state) (r1.reg)
   in let rd = alloc-temp st1
   in EmitResult {
   state = st-append-text (rd.state) (li (rd.reg) 0),
   reg = rd.reg
  }

  emit-read-line-builtin : CodegenState -> EmitResult
  emit-read-line-builtin (st) =
    let st1 = emit-call-to st "__read_line"
   in let rd = alloc-temp st1
   in EmitResult {
