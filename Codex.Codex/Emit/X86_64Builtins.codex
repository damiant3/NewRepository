  emit-linked-list-empty-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-linked-list-empty-builtin (st) (args) =
   let rd = alloc-temp st
   in EmitResult {
   state = st-append-text (rd.state) (li (rd.reg) 0),
   reg = rd.reg
  }

  emit-linked-list-push-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-linked-list-push-builtin (st) (args) =
   let list-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let list-loc = alloc-local (list-result.state)
   in let st1 = store-local (list-loc.state) (list-loc.reg) (list-result.reg)
   in let val-result = emit-expr st1 (list-at args 1)
   in let val-loc = alloc-local (val-result.state)
   in let st2 = store-local (val-loc.state) (val-loc.reg) (val-result.reg)
   in let ptr = alloc-temp st2
   in let st3 = st-append-text (ptr.state) (mov-rr (ptr.reg) reg-r10)
   in let vr = load-local st3 (val-loc.reg)
   in let st4 = st-append-text (vr.state) (mov-store (ptr.reg) (vr.reg) 0)
   in let lr = load-local st4 (list-loc.reg)
   in let st5 = st-append-text (lr.state) (mov-store (ptr.reg) (lr.reg) 8)
   in let st6 = st-append-text st5 (add-ri reg-r10 16)
   in EmitResult {
   state = st6,
   reg = ptr.reg
  }

  emit-linked-list-to-list-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-linked-list-to-list-builtin (st) (args) =
   let head-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (head-result.state) (mov-rr reg-rdi (head-result.reg))
   in let st2 = emit-call-to st1 "__linked_list_to_list"
   in let rd = alloc-temp st2
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-rax),
   reg = rd.reg
  }

  emit-record-set-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-record-set-builtin (st) (args) =
    let rec-result = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rec-loc = alloc-local (rec-result.state)
   in let st1 = store-local (rec-loc.state) (rec-loc.reg) (rec-result.reg)
   in let field-name = when (list-at args 1)
    is IrTextLit (s) (sp) -> s
    is otherwise -> ""
   in let rec-ty = resolve-constructed-ty st (ir-expr-type (list-at args 0))
   in let val-result = emit-expr st1 (list-at args 2)
   in let loaded = load-local (val-result.state) (rec-loc.reg)
   in when rec-ty
    is RecordTy (rname) (rfields) ->
     let field-idx = find-record-field-index rfields field-name 0
     in EmitResult {
      state = st-append-text (loaded.state) (mov-store (loaded.reg) (val-result.reg) (field-idx * 8)),
      reg = loaded.reg
     }
    is otherwise ->
     let st-err = st-add-error (loaded.state) cdx-ir-error ("record-set: unresolved type for field '" ++ field-name ++ "'") (ir-expr-span (list-at args 0))
     in EmitResult {
      state = st-append-text st-err [15, 11],
      reg = loaded.reg
     }

  emit-heap-save-builtin : CodegenState -> EmitResult
  emit-heap-save-builtin (st) =
   let rd = alloc-temp st
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-r10),
   reg = rd.reg
  }

  emit-heap-restore-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-heap-restore-builtin (st) (args) =
   let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r.state)
   in EmitResult {
   state = st-append-text (rd.state) (li (rd.reg) 0),
   reg = rd.reg
  }

  emit-heap-advance-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-heap-advance-builtin (st) (args) =
