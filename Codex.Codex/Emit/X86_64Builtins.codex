Chapter: X86-64 Code Generator

Section: Builtin Detection
  is-string-builtin : Text -> Boolean
  is-string-builtin (name) =
    if name == "text-length" then True
    else if name == "integer-to-text" then True
    else if name == "show" then True
    else if name == "text-to-integer" then True
    else if name == "text-replace" then True
    else if name == "text-contains" then True
    else if name == "text-starts-with" then True
    else if name == "text-compare" then True
    else if name == "text-concat-list" then True
    else if name == "text-split" then True
    else if name == "substring" then True
    else False

  is-list-builtin : Text -> Boolean
  is-list-builtin (name) =
    if name == "list-length" then True
    else if name == "list-at" then True
    else if name == "list-cons" then True
    else if name == "list-append" then True
    else if name == "list-snoc" then True
    else if name == "list-insert-at" then True
    else if name == "list-set-at" then True
    else if name == "list-contains" then True
    else False

  is-char-builtin : Text -> Boolean
  is-char-builtin (name) =
    if name == "char-at" then True
    else if name == "char-code-at" then True
    else if name == "char-code" then True
    else if name == "code-to-char" then True
    else if name == "char-to-text" then True
    else if name == "is-letter" then True
    else if name == "is-digit" then True
    else if name == "is-whitespace" then True
    else False

  is-io-builtin : Text -> Boolean
  is-io-builtin (name) =
    if name == "print-line" then True
    else if name == "read-file" then True
    else if name == "write-file" then True
    else if name == "read-line" then True
    else if name == "write-binary" then True
    else False

  is-misc-builtin : Text -> Boolean
  is-misc-builtin (name) =
    if name == "negate" then True
    else if name == "get-args" then True
    else if name == "current-dir" then True
    else if name == "file-exists" then True
    else if name == "record-set" then True
    else if name == "linked-list-empty" then True
    else if name == "linked-list-push" then True
    else if name == "linked-list-to-list" then True
    else if name == "heap-save" then True
    else if name == "heap-restore" then True
    else if name == "heap-advance" then True
    else if name == "list-with-capacity" then True
    else if name == "buf-write-byte" then True
    else if name == "buf-write-bytes" then True
    else if name == "buf-read-bytes" then True
    else if name == "bit-and" then True
    else if name == "bit-or" then True
    else if name == "bit-xor" then True
    else if name == "bit-shl" then True
    else if name == "bit-shr" then True
    else if name == "bit-not" then True
    else False

  is-builtin : Text -> Boolean
  is-builtin (name) =
    if is-string-builtin name then True
    else if is-list-builtin name then True
    else if is-char-builtin name then True
    else if is-io-builtin name then True
    else is-misc-builtin name

Section: Builtin Emission
  emit-helper-call-1 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-1 (st) (args) (helper) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (mov-rr reg-rdi (r.reg))
   in let st2 = emit-call-to st1 helper
   in let tmp = alloc-temp st2
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  emit-helper-call-2 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-2 (st) (args) (helper) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loaded = load-local (r1.state) (loc.reg)
   in let st2 = st-append-text (loaded.state) (mov-rr reg-rsi (r1.reg))
   in let st3 = st-append-text st2 (mov-rr reg-rdi (loaded.reg))
   in let st4 = emit-call-to st3 helper
   in let tmp = alloc-temp st4
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  emit-helper-call-3 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-3 (st) (args) (helper) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loc1 = alloc-local (r1.state)
   in let st2 = store-local (loc1.state) (loc1.reg) (r1.reg)
   in let r2 = emit-expr st2 (list-at args 2)
   in let st3 = st-append-text (r2.state) (mov-rr reg-rdx (r2.reg))
   in let ld1 = load-local st3 (loc1.reg)
   in let st4 = st-append-text (ld1.state) (mov-rr reg-rsi (ld1.reg))
   in let ld0 = load-local st4 (loc0.reg)
   in let st5 = st-append-text (ld0.state) (mov-rr reg-rdi (ld0.reg))
   in let st6 = emit-call-to st5 helper
   in let tmp = alloc-temp st6
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  emit-text-length-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-text-length-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let tmp = alloc-temp (r.state)
   in EmitResult {
   state = st-append-text (tmp.state) (mov-load (tmp.reg) (r.reg) 0),
   reg = tmp.reg
  }

  emit-list-length-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-list-length-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let tmp = alloc-temp (r.state)
   in EmitResult {
   state = st-append-text (tmp.state) (mov-load (tmp.reg) (r.reg) 0),
   reg = tmp.reg
  }

  emit-list-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-list-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let list-loaded = load-local (r1.state) (loc.reg)
   in let addr = alloc-temp (list-loaded.state)
   in let st2 = st-append-text (addr.state) (mov-rr (addr.reg) (r1.reg))
   in let st3 = st-append-text st2 (shl-ri (addr.reg) 3)
   in let st4 = st-append-text st3 (add-rr (addr.reg) (list-loaded.reg))
   in let rd = alloc-temp st4
   in EmitResult {
   state = st-append-text (rd.state) (mov-load (rd.reg) (addr.reg) 8),
   reg = rd.reg
  }

  emit-char-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let str-loaded = load-local (r1.state) (loc.reg)
   in let st2 = st-append-text (str-loaded.state) (add-rr (r1.reg) (str-loaded.reg))
   in let st3 = st-append-text st2 (movzx-byte (r1.reg) (r1.reg) 8)
   in EmitResult {
   state = st3,
   reg = r1.reg
  }

  emit-char-code-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-code-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let text-loaded = load-local (r1.state) (loc.reg)
   in let rd = alloc-temp (text-loaded.state)
   in let st2 = st-append-text (rd.state) (mov-rr (rd.reg) (text-loaded.reg))
   in let st3 = st-append-text st2 (add-rr (rd.reg) (r1.reg))
   in let st4 = st-append-text st3 (movzx-byte (rd.reg) (rd.reg) 8)
   in EmitResult {
   state = st4,
   reg = rd.reg
  }

  emit-char-to-text-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-to-text-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in let ptr-loc = alloc-local st1
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st2 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st3 = store-local st2 (ptr-loc.reg) (ptr-tmp.reg)
   in let st4 = st-append-text st3 (add-ri reg-r10 16)
   in let st5 = st-append-text st4 (li reg-r11 1)
   in let ptr-loaded = load-local st5 (ptr-loc.reg)
   in let st6 = st-append-text (ptr-loaded.state) (mov-store (ptr-loaded.reg) reg-r11 0)
   in let code-loaded = load-local st6 (loc.reg)
   in let ptr-loaded2 = load-local (code-loaded.state) (ptr-loc.reg)
   in let st7 = st-append-text (ptr-loaded2.state) (mov-store-byte (ptr-loaded2.reg) (code-loaded.reg) 8)
   in let result = load-local st7 (ptr-loc.reg)
   in EmitResult {
   state = result.state,
   reg = result.reg
  }

  emit-is-letter-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-letter-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (sub-ri (r.reg) 13)
   in let st2 = st-append-text st1 (cmp-ri (r.reg) 51)
   in let st3 = st-append-text st2 (setcc cc-be (r.reg))
   in let st4 = st-append-text st3 (movzx-byte-self (r.reg))
   in EmitResult {
   state = st4,
   reg = r.reg
  }

  emit-is-digit-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-digit-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (sub-ri (r.reg) 3)
   in let st2 = st-append-text st1 (cmp-ri (r.reg) 9)
   in let st3 = st-append-text st2 (setcc cc-be (r.reg))
   in let st4 = st-append-text st3 (movzx-byte-self (r.reg))
   in EmitResult {
   state = st4,
   reg = r.reg
  }

  emit-is-whitespace-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-whitespace-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (cmp-ri (r.reg) 2)
   in let st2 = st-append-text st1 (setcc cc-be (r.reg))
   in let st3 = st-append-text st2 (movzx-byte-self (r.reg))
   in EmitResult {
   state = st3,
   reg = r.reg
  }

  emit-negate-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-negate-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r.state)
   in let st1 = st-append-text (rd.state) (mov-rr (rd.reg) (r.reg))
   in let st2 = st-append-text st1 (neg-r (rd.reg))
   in EmitResult {
   state = st2,
   reg = rd.reg
  }

  emit-get-args-builtin : CodegenState -> EmitResult
  emit-get-args-builtin (st) =
    let rd = alloc-temp st
   in let st1 = st-append-text (rd.state) (li reg-r11 0)
   in let st2 = st-append-text st1 (mov-store reg-r10 reg-r11 0)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let st4 = st-append-text st3 (mov-rr (rd.reg) reg-r10)
   in let st5 = st-append-text st4 (mov-store reg-r10 reg-r11 0)
   in let st6 = st-append-text st5 (add-ri reg-r10 8)
   in EmitResult {
   state = st6,
   reg = rd.reg
  }

  emit-current-dir-builtin : CodegenState -> EmitResult
  emit-current-dir-builtin (st) =
    let rd = alloc-temp st
   in let st1 = st-append-text (rd.state) (mov-rr (rd.reg) reg-r10)
   in let st2 = st-append-text st1 (li reg-r11 0)
   in let st3 = st-append-text st2 (mov-store reg-r10 reg-r11 0)
   in let st4 = st-append-text st3 (add-ri reg-r10 8)
   in EmitResult {
   state = st4,
   reg = rd.reg
  }

  emit-file-exists-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-file-exists-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r.state)
   in let st1 = st-append-text (rd.state) (li (rd.reg) 1)
   in EmitResult {
   state = st1,
   reg = rd.reg
  }

  emit-substring-alloc : CodegenState -> Integer -> Integer -> Integer -> CodegenState
  emit-substring-alloc (st) (str-loc) (start-loc) (len-loc) =
    let len-loaded = load-local st len-loc
   in let st0 = st-append-text (len-loaded.state) (mov-rr reg-r11 (len-loaded.reg))
   in let st1 = st-append-text st0 (add-ri reg-r11 15)
   in let st2 = st-append-text st1 (and-ri reg-r11 (0 - 8))
   in st-append-text st2 (add-rr reg-r10 reg-r11)

  emit-substring-copy : CodegenState -> Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-substring-copy (st) (str-loc) (start-loc) (len-loc) (ptr-loc) =
    let st0 = st-append-text st (li reg-r11 0)
   in let sub-loop = st0.text-len
   in let len-ld = load-local st0 len-loc
   in let st1 = st-append-text (len-ld.state) (cmp-rr reg-r11 (len-ld.reg))
   in let sub-exit-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let src-ld = load-local st2 str-loc
   in let start-ld = load-local (src-ld.state) start-loc
   in let st3 = st-append-text (start-ld.state) (mov-rr reg-rsi (src-ld.reg))
   in let st4 = st-append-text st3 (add-rr reg-rsi (start-ld.reg))
   in let st5 = st-append-text st4 (add-rr reg-rsi reg-r11)
   in let st6 = st-append-text st5 (movzx-byte reg-rsi reg-rsi 8)
   in let ptr-ld = load-local st6 ptr-loc
   in let st7 = st-append-text (ptr-ld.state) (mov-rr reg-rdx (ptr-ld.reg))
   in let st8 = st-append-text st7 (add-rr reg-rdx reg-r11)
   in let st9 = st-append-text st8 (mov-store-byte reg-rdx reg-rsi 8)
   in let st10 = st-append-text st9 (add-ri reg-r11 1)
   in let st11 = st-append-text st10 (jmp (sub-loop - (st10.text-len + 5)))
   in patch-jcc-at st11 sub-exit-pos (st11.text-len)

  emit-substring-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-substring-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loc1 = alloc-local (r1.state)
   in let st2 = store-local (loc1.state) (loc1.reg) (r1.reg)
   in let r2 = emit-expr st2 (list-at args 2)
   in let loc2 = alloc-local (r2.state)
   in let st3 = store-local (loc2.state) (loc2.reg) (r2.reg)
   in let ptr-loc = alloc-local st3
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st4 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st5 = store-local st4 (ptr-loc.reg) (ptr-tmp.reg)
   in let len-ld = load-local st5 (loc2.reg)
   in let ptr-ld = load-local (len-ld.state) (ptr-loc.reg)
   in let st6 = st-append-text (ptr-ld.state) (mov-store (ptr-ld.reg) (len-ld.reg) 0)
   in let st7 = emit-substring-alloc st6 (loc0.reg) (loc1.reg) (loc2.reg)
   in let st8 = emit-substring-copy st7 (loc0.reg) (loc1.reg) (loc2.reg) (ptr-loc.reg)
   in let result = load-local st8 (ptr-loc.reg)
   in EmitResult {
   state = result.state,
   reg = result.reg
  }

  emit-print-line-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-print-line-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = emit-print-text (r.state) (r.reg)
   in let rd = alloc-temp st1
   in EmitResult {
   state = st-append-text (rd.state) (li (rd.reg) 0),
   reg = rd.reg
  }

  emit-read-file-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-read-file-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (mov-rr reg-rdi (r.reg))
   in let st2 = emit-call-to st1 "__bare_metal_read_serial"
   in let rd = alloc-temp st2
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-rax),
