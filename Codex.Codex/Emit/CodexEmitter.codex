Chapter: Codex Emitter

 Emits Codex source code from the IR.

Section: Type Definition Emission
  emit-type-defs : List ATypeDef -> Integer -> Text
  emit-type-defs (tds) (i) =
   if i == list-length tds then ""
   else emit-type-def (list-at tds i) ++ "\n" ++ emit-type-defs tds (i + 1)

  emit-type-def : ATypeDef -> Text
  emit-type-def (td) =
   when td
    is ARecordTypeDef (name) (tparams) (fields) (s) ->
     name.value ++ " = record {" ++ emit-record-field-defs fields 0 ++ "\n}\n"
    is AVariantTypeDef (name) (tparams) (ctors) (s) ->
     name.value ++ " =\n" ++ emit-variant-ctors ctors 0

  emit-record-field-defs : List ARecordFieldDef -> Integer -> Text
  emit-record-field-defs (fields) (i) =
   if i == list-length fields then ""
   else let f = list-at fields i
   in let comma = if i > 0 then "," else ""
   in comma ++ "\n " ++ f.name.value ++ " : " ++ emit-type-expr (f.type-expr) ++ emit-record-field-defs fields (i + 1)

  emit-variant-ctors : List AVariantCtorDef -> Integer -> Text
  emit-variant-ctors (ctors) (i) =
   if i == list-length ctors then ""
   else let c = list-at ctors i
   in " | " ++ c.name.value ++ emit-ctor-fields (c.fields) 0 ++ "\n" ++ emit-variant-ctors ctors (i + 1)

  emit-ctor-fields : List ATypeExpr -> Integer -> Text
  emit-ctor-fields (fields) (i) =
   if i == list-length fields then ""
   else " (" ++ emit-type-expr (list-at fields i) ++ ")" ++ emit-ctor-fields fields (i + 1)

  emit-type-expr : ATypeExpr -> Text
  emit-type-expr (te) =
   when te
    is ANamedType (name) (s) -> name.value
    is AFunType (p) (r) (s) -> emit-fun-param p ++ " -> " ++ emit-type-expr r
    is AAppType (base) (args) (s) -> emit-type-expr base ++ " " ++ emit-type-expr-args args 0
    is AEffectType (effs) (ret) (s) -> "[" ++ emit-effect-names effs 0 ++ "] " ++ emit-type-expr ret

  emit-fun-param : ATypeExpr -> Text
  emit-fun-param (te) =
   when te
    is AFunType (p) (r) (s) -> "(" ++ emit-type-expr te ++ ")"
    is otherwise -> emit-type-expr te

  emit-type-expr-args : List ATypeExpr -> Integer -> Text
  emit-type-expr-args (args) (i) =
   if i == list-length args then ""
   else let sep = if i > 0 then " " else ""
   in sep ++ emit-type-expr-wrapped (list-at args i) ++ emit-type-expr-args args (i + 1)

  emit-type-expr-wrapped : ATypeExpr -> Text
  emit-type-expr-wrapped (te) =
   when te
    is AFunType (p) (r) (s) -> "(" ++ emit-type-expr te ++ ")"
    is AAppType (base) (args) (s) -> "(" ++ emit-type-expr te ++ ")"
    is otherwise -> emit-type-expr te

  emit-effect-names : List Name -> Integer -> Text
  emit-effect-names (effs) (i) =
   if i == list-length effs then ""
   else let sep = if i > 0 then ", " else ""
   in sep ++ (list-at effs i).value ++ emit-effect-names effs (i + 1)

Section: TypeVar Normalization
  TypeVarMap = record {
   entries : List Integer,
   next-id : Integer
  }

  empty-tvar-map : TypeVarMap = TypeVarMap { entries = [], next-id = 0 }

  tvar-map-lookup : List Integer -> Integer -> Integer -> Integer
  tvar-map-lookup (entries) (id) (i) =
   if i >= list-length entries then -1
   else if list-at entries i == id then i
   else tvar-map-lookup entries id (i + 1)

  tvar-map-insert : TypeVarMap -> Integer -> TypeVarMap
  tvar-map-insert (m) (id) =
   if tvar-map-lookup (m.entries) id 0 >= 0 then m
   else TypeVarMap { entries = list-snoc (m.entries) id, next-id = m.next-id + 1 }

  collect-tvars : CodexType -> TypeVarMap -> TypeVarMap
  collect-tvars (ty) (m) =
   when ty
    is TypeVar (id) -> tvar-map-insert m id
    is ForAllTy (id) (body) -> collect-tvars body (tvar-map-insert m id)
    is FunTy (p) (r) -> collect-tvars r (collect-tvars p m)
    is ListTy (elem) -> collect-tvars elem m
    is LinkedListTy (elem) -> collect-tvars elem m
    is EffectfulTy (effs) (ret) -> collect-tvars ret m
    is otherwise -> m

  normalize-type : CodexType -> TypeVarMap -> CodexType
  normalize-type (ty) (m) =
   when ty
    is TypeVar (id) -> TypeVar (tvar-map-lookup (m.entries) id 0)
    is ForAllTy (id) (body) -> ForAllTy (tvar-map-lookup (m.entries) id 0) (normalize-type body m)
    is FunTy (p) (r) -> FunTy (normalize-type p m) (normalize-type r m)
    is ListTy (elem) -> ListTy (normalize-type elem m)
    is LinkedListTy (elem) -> LinkedListTy (normalize-type elem m)
    is EffectfulTy (effs) (ret) -> EffectfulTy effs (normalize-type ret m)
    is otherwise -> ty

  normalize-type-vars : CodexType -> CodexType
  normalize-type-vars (ty) =
   let m = collect-tvars ty empty-tvar-map
   in if m.next-id == 0 then ty
      else normalize-type ty m

Section: CodexType Emission
  emit-type : CodexType -> Text
  emit-type (ty) =
   when ty
    is IntegerTy -> "Integer"
    is NumberTy -> "Number"
    is TextTy -> "Text"
    is BooleanTy -> "Boolean"
    is CharTy -> "Char"
    is VoidTy -> "Nothing"
    is NothingTy -> "Nothing"
    is ErrorTy -> "Unknown"
    is FunTy (p) (r) -> wrap-fun-param p ++ " -> " ++ emit-type r
    is ListTy (elem) -> "List " ++ wrap-complex elem
    is LinkedListTy (elem) -> "LinkedList " ++ wrap-complex elem
    is TypeVar (id) -> "a" ++ integer-to-text id
    is ForAllTy (id) (body) -> emit-type body
    is SumTy (name) (ctors) -> name.value
    is RecordTy (name) (fields) -> name.value
    is ConstructedTy (name) (args) -> name.value
    is EffectfulTy (effs) (ret) -> "[" ++ emit-type-effect-names effs 0 ++ "] " ++ emit-type ret

  wrap-fun-param : CodexType -> Text
  wrap-fun-param (ty) =
   when ty
    is FunTy (p) (r) -> "(" ++ emit-type ty ++ ")"
    is otherwise -> emit-type ty

  wrap-complex : CodexType -> Text
  wrap-complex (ty) =
   when ty
    is FunTy (p) (r) -> "(" ++ emit-type ty ++ ")"
    is ListTy (elem) -> "(" ++ emit-type ty ++ ")"
    is LinkedListTy (elem) -> "(" ++ emit-type ty ++ ")"
    is otherwise -> emit-type ty

  emit-type-effect-names : List Name -> Integer -> Text
  emit-type-effect-names (effs) (i) =
   if i == list-length effs then ""
   else let sep = if i > 0 then ", " else ""
   in sep ++ (list-at effs i).value ++ emit-type-effect-names effs (i + 1)

Section: Definition Emission
  emit-def : IRDef -> List Text -> Text
  emit-def (d) (ctor-names) =
   if skip-def d ctor-names then ""
   else let norm-ty = normalize-type-vars (d.type-val)
   in let sig = d.name ++ " : " ++ emit-type norm-ty ++ "\n" ++ d.name ++ emit-def-params (d.params) 0
   in sig ++ " =\n " ++ emit-expr (d.body) ctor-names 1 ++ "\n"

  is-match-body : IRExpr -> Boolean
  is-match-body (e) =
   when e
    is IrMatch (scrut) (branches) (ty) (sp) -> True
    is otherwise -> False

  skip-def : IRDef -> List Text -> Boolean
  skip-def (d) (ctor-names) =
   if list-contains ctor-names (d.name) then True
   else if text-length (d.name) == 0 then True
   else let first = char-code-at (d.name) 0
   in if first < 13 then True
      else if first > 38 then True
      else False

  is-upper : Integer -> Boolean
  is-upper (c) =
   let code = char-code-at "A" 0
   in let code-z = char-code-at "Z" 0
   in c >= code & c <= code-z

  is-error-body : IRExpr -> Boolean
  is-error-body (e) =
   when e
    is IrError (msg) (ty) (sp) -> True
    is otherwise -> False

  error-message : IRExpr -> Text
  error-message (e) =
   when e
    is IrError (msg) (ty) (sp) -> msg
    is otherwise -> ""

  is-lower-start : Text -> Boolean
  is-lower-start (s) =
   if text-length s == 0 then False
   else let c = char-code-at s 0
   in let code-a = char-code-at "a" 0
   in let code-z = char-code-at "z" 0
   in c >= code-a & c <= code-z

  emit-def-params : List IRParam -> Integer -> Text
  emit-def-params (params) (i) =
   if i == list-length params then ""
   else let p = list-at params i
   in " (" ++ p.name ++ ")" ++ emit-def-params params (i + 1)

Section: Expression Emission
  emit-expr : IRExpr -> List Text -> Integer -> Text
  emit-expr (e) (ctors) (indent) =
   when e
    is IrIntLit (n) (sp) -> integer-to-text n
    is IrNumLit (n) (sp) -> integer-to-text n
    is IrTextLit (s) (sp) -> "\"" ++ escape-text s ++ "\""
    is IrBoolLit (b) (sp) -> if b then "True" else "False"
    is IrCharLit (n) (sp) -> "'" ++ escape-char n ++ "'"
    is IrName (n) (ty) (sp) -> n
    is IrBinary (op) (l) (r) (ty) (sp) -> emit-binary op l r ctors indent
    is IrNegate (operand) (sp) -> "-" ++ emit-expr operand ctors indent
    is IrIf (c) (t) (el) (ty) (sp) -> emit-if c t el ctors indent 0
    is IrLet (name) (ty) (val) (body) (sp) -> emit-let name val body ctors indent
    is IrApply (f) (a) (ty) (sp) -> emit-apply e ctors indent
    is IrLambda (params) (body) (ty) (sp) -> emit-lambda params body ctors indent
    is IrList (elems) (ty) (sp) -> emit-list elems ctors indent
    is IrMatch (scrut) (branches) (ty) (sp) -> emit-match scrut branches ctors indent
    is IrDo (stmts) (ty) (sp) -> emit-do stmts ctors indent
    is IrRecord (name) (fields) (ty) (sp) -> emit-record name fields ctors indent
    is IrFieldAccess (rec) (field) (ty) (sp) -> emit-field-access rec field ctors indent
    is IrFork (body) (ty) (sp) -> "fork (" ++ emit-expr body ctors indent ++ ")"
    is IrAwait (task) (ty) (sp) -> "await (" ++ emit-expr task ctors indent ++ ")"
    is IrHandle (eff) (body) (clauses) (ty) (sp) -> emit-handle eff body clauses ctors indent
    is IrError (msg) (ty) (sp) -> "0"

Section: Binary Operators
  emit-binary : IRBinaryOp -> IRExpr -> IRExpr -> List Text -> Integer -> Text
  emit-binary (op) (l) (r) (ctors) (indent) =
   wrap-binary-left op l ctors indent ++ " " ++ bin-op-text op ++ " " ++ wrap-binary-right op r ctors indent

  wrap-binary-left : IRBinaryOp -> IRExpr -> List Text -> Integer -> Text
  wrap-binary-left (parent-op) (e) (ctors) (indent) =
   when e
    is IrBinary (child-op) (l2) (r2) (ty) (sp) -> if bin-op-prec child-op < bin-op-prec parent-op then "(" ++ emit-expr e ctors indent ++ ")"
    else emit-expr e ctors indent
    is IrIf (c) (t) (el) (ty) (sp) -> "(" ++ emit-expr e ctors indent ++ ")"
    is otherwise -> emit-expr e ctors indent

  wrap-binary-right : IRBinaryOp -> IRExpr -> List Text -> Integer -> Text
  wrap-binary-right (parent-op) (e) (ctors) (indent) =
   when e
    is IrBinary (child-op) (l2) (r2) (ty) (sp) -> if needs-right-wrap parent-op child-op then "(" ++ emit-expr e ctors indent ++ ")"
    else emit-expr e ctors indent
    is IrIf (c) (t) (el) (ty) (sp) -> "(" ++ emit-expr e ctors indent ++ ")"
    is otherwise -> emit-expr e ctors indent

  needs-right-wrap : IRBinaryOp -> IRBinaryOp -> Boolean
  needs-right-wrap (parent) (child) =
   if bin-op-prec child < bin-op-prec parent then True
   else if bin-op-prec child > bin-op-prec parent then False
   else if bin-op-text parent == bin-op-text child then if is-associative-op parent then False else True
   else True

  is-associative-op : IRBinaryOp -> Boolean
  is-associative-op (op) =
   when op
    is IrAddInt -> True
    is IrAddNum -> True
    is IrMulInt -> True
    is IrMulNum -> True
    is IrAppendText -> True
    is IrAppendList -> True
    is IrConsList -> True
    is IrAnd -> True
    is IrOr -> True
    is otherwise -> False

  bin-op-prec : IRBinaryOp -> Integer
  bin-op-prec (op) =
   when op
    is IrOr -> 2
    is IrAnd -> 3
    is IrEq -> 4
    is IrNotEq -> 4
    is IrLt -> 4
    is IrGt -> 4
    is IrLtEq -> 4
    is IrGtEq -> 4
    is IrAppendText -> 5
    is IrAppendList -> 5
    is IrConsList -> 5
    is IrAddInt -> 6
    is IrSubInt -> 6
    is IrAddNum -> 6
    is IrSubNum -> 6
    is IrMulInt -> 7
    is IrDivInt -> 7
    is IrMulNum -> 7
    is IrDivNum -> 7
    is IrPowInt -> 8
    is otherwise -> 0

  bin-op-text : IRBinaryOp -> Text
  bin-op-text (op) =
   when op
    is IrAddInt -> "+"
    is IrSubInt -> "-"
    is IrMulInt -> "*"
    is IrDivInt -> "/"
    is IrPowInt -> "^"
    is IrAddNum -> "+"
    is IrSubNum -> "-"
    is IrMulNum -> "*"
    is IrDivNum -> "/"
    is IrEq -> "=="
    is IrNotEq -> "/="
    is IrLt -> "<"
    is IrGt -> ">"
    is IrLtEq -> "<="
    is IrGtEq -> ">="
    is IrAnd -> "&"
    is IrOr -> "|"
    is IrAppendText -> "++"
    is IrAppendList -> "++"
    is IrConsList -> "::"

Section: If/Then/Else
  emit-if : IRExpr -> IRExpr -> IRExpr -> List Text -> Integer -> Integer -> Text
  emit-if (c) (t) (el) (ctors) (indent) (else-offset) =
   "if " ++ emit-expr c ctors indent ++ " then " ++ emit-expr t ctors indent ++ "\n" ++ make-indent indent ++ pad-spaces else-offset ++ "else " ++ emit-else el ctors indent else-offset

  emit-else : IRExpr -> List Text -> Integer -> Integer -> Text
  emit-else (el) (ctors) (indent) (else-offset) =
   when el
    is IrIf (c2) (t2) (el2) (ty) (sp) -> emit-if c2 t2 el2 ctors indent else-offset
    is otherwise -> emit-expr el ctors indent

  pad-spaces : Integer -> Text
  pad-spaces (n) =
   if n <= 0 then ""
   else " " ++ pad-spaces (n - 1)

Section: Let
  emit-let : Text -> IRExpr -> IRExpr -> List Text -> Integer -> Text
  emit-let (name) (val) (body) (ctors) (indent) =
   "let " ++ name ++ " = " ++ emit-expr val ctors (indent + 1) ++ "\n" ++ make-indent indent ++ "in " ++ emit-let-body body ctors indent

  emit-let-body : IRExpr -> List Text -> Integer -> Text
  emit-let-body (body) (ctors) (indent) =
   when body
    is IrIf (c) (t) (el) (ty) (sp) -> emit-if c t el ctors indent 3
    is otherwise -> emit-expr body ctors indent

Section: Apply
  emit-apply : IRExpr -> List Text -> Integer -> Text
  emit-apply (e) (ctors) (indent) =
   let chain = collect-apply-chain e []
   in let func = chain.root
   in let args = chain.args
   in emit-expr func ctors indent ++ emit-apply-args args ctors indent 0 (list-length args) (is-ctor-name func ctors)

  emit-apply-args : List IRExpr -> List Text -> Integer -> Integer -> Integer -> Boolean -> Text
  emit-apply-args (args) (ctors) (indent) (i) (len) (is-ctor) =
   if i == len then ""
   else let arg = list-at args i
   in " " ++ wrap-arg arg ctors indent is-ctor ++ emit-apply-args args ctors indent (i + 1) len is-ctor

  wrap-arg : IRExpr -> List Text -> Integer -> Boolean -> Text
  wrap-arg (e) (ctors) (indent) (is-ctor) =
   if needs-parens e is-ctor then "(" ++ emit-expr e ctors indent ++ ")"
   else emit-expr e ctors indent

  is-ctor-name : IRExpr -> List Text -> Boolean
  is-ctor-name (e) (ctors) =
   when e
    is IrName (n) (ty) (sp) -> list-contains ctors n
    is otherwise -> False

  needs-parens : IRExpr -> Boolean -> Boolean
  needs-parens (e) (is-ctor) =
   when e
    is IrApply (f) (a) (ty) (sp) -> True
    is IrBinary (op) (l) (r) (ty) (sp) -> True
    is IrIf (c) (t) (el) (ty) (sp) -> True
    is IrLet (name) (ty) (val) (body) (sp) -> True
    is IrMatch (scrut) (branches) (ty) (sp) -> True
    is IrNegate (operand) (sp) -> True
    is IrLambda (params) (body) (ty) (sp) -> True
    is IrFieldAccess (rec) (field) (ty) (sp) -> True
    is IrRecord (name) (fields) (ty) (sp) -> True
    is otherwise -> False

Section: Lambda
  emit-lambda : List IRParam -> IRExpr -> List Text -> Integer -> Text
  emit-lambda (params) (body) (ctors) (indent) =
   "\\" ++ emit-lambda-params params 0 ++ " -> " ++ emit-expr body ctors indent

  emit-lambda-params : List IRParam -> Integer -> Text
  emit-lambda-params (params) (i) =
   if i == list-length params then ""
   else let p = list-at params i
   in let sep = if i > 0 then " " else ""
   in sep ++ p.name ++ emit-lambda-params params (i + 1)

Section: List
  emit-list : List IRExpr -> List Text -> Integer -> Text
  emit-list (elems) (ctors) (indent) =
   "[" ++ emit-list-elems elems ctors indent 0 ++ "]"

  emit-list-elems : List IRExpr -> List Text -> Integer -> Integer -> Text
  emit-list-elems (elems) (ctors) (indent) (i) =
   if i == list-length elems then ""
   else let sep = if i > 0 then ", " else ""
   in sep ++ emit-expr (list-at elems i) ctors indent ++ emit-list-elems elems ctors indent (i + 1)

Section: Match
  emit-match : IRExpr -> List IRBranch -> List Text -> Integer -> Text
  emit-match (scrut) (branches) (ctors) (indent) =
   "when " ++ emit-expr scrut ctors indent ++ emit-branches branches ctors indent 0

  emit-branches : List IRBranch -> List Text -> Integer -> Integer -> Text
  emit-branches (branches) (ctors) (indent) (i) =
   if i == list-length branches then ""
   else let b = list-at branches i
   in "\n" ++ make-indent (indent + 1) ++ "is " ++ emit-pattern (b.pattern) ++ " -> " ++ emit-expr (b.body) ctors (indent + 1) ++ emit-branches branches ctors indent (i + 1)

  emit-pattern : IRPat -> Text
  emit-pattern (p) =
   when p
    is IrVarPat (name) (ty) (sp) -> name
    is IrLitPat (text) (ty) (sp) -> text
    is IrCtorPat (name) (subs) (ty) (sp) -> name ++ emit-sub-patterns subs 0
    is IrWildPat (sp) -> "otherwise"

  emit-sub-patterns : List IRPat -> Integer -> Text
  emit-sub-patterns (subs) (i) =
   if i == list-length subs then ""
   else " (" ++ emit-pattern (list-at subs i) ++ ")" ++ emit-sub-patterns subs (i + 1)

Section: Do Blocks
  emit-do : List IRDoStmt -> List Text -> Integer -> Text
  emit-do (stmts) (ctors) (indent) =
   "do" ++ emit-do-stmts stmts ctors indent 0

  emit-do-stmts : List IRDoStmt -> List Text -> Integer -> Integer -> Text
  emit-do-stmts (stmts) (ctors) (indent) (i) =
   if i == list-length stmts then ""
   else let s = list-at stmts i
   in "\n" ++ make-indent (indent + 1) ++ emit-do-stmt s ctors (indent + 1) ++ emit-do-stmts stmts ctors indent (i + 1)

  emit-do-stmt : IRDoStmt -> List Text -> Integer -> Text
  emit-do-stmt (s) (ctors) (indent) =
   when s
    is IrDoBind (name) (ty) (val) (sp) -> name ++ " <- " ++ emit-expr val ctors indent
    is IrDoExec (e) (sp) -> emit-expr e ctors indent

Section: Records
  emit-record : Text -> List IRFieldVal -> List Text -> Integer -> Text
  emit-record (name) (fields) (ctors) (indent) =
   if list-length fields <= 1 then name ++ " {" ++ emit-record-fields-inline fields ctors indent 0 ++ " }"
   else name ++ " {\n" ++ emit-record-fields-multi fields ctors indent 0 ++ make-indent indent ++ "}"

  emit-record-fields-inline : List IRFieldVal -> List Text -> Integer -> Integer -> Text
  emit-record-fields-inline (fields) (ctors) (indent) (i) =
   if i == list-length fields then ""
   else let f = list-at fields i
   in let sep = if i > 0 then "," else ""
   in sep ++ " " ++ f.name ++ " = " ++ emit-expr (f.value) ctors indent ++ emit-record-fields-inline fields ctors indent (i + 1)

  emit-record-fields-multi : List IRFieldVal -> List Text -> Integer -> Integer -> Text
  emit-record-fields-multi (fields) (ctors) (indent) (i) =
   if i == list-length fields then ""
   else let f = list-at fields i
   in let comma = if i < list-length fields - 1 then "," else ""
   in make-indent (indent + 1) ++ f.name ++ " = " ++ emit-expr (f.value) ctors (indent + 1) ++ comma ++ "\n" ++ emit-record-fields-multi fields ctors indent (i + 1)

Section: Field Access
  emit-field-access : IRExpr -> Text -> List Text -> Integer -> Text
  emit-field-access (rec) (field) (ctors) (indent) =
   when rec
    is IrName (n) (ty) (sp) -> n ++ "." ++ field
    is IrFieldAccess (r) (f) (ty) (sp) -> emit-field-access r f ctors indent ++ "." ++ field
    is otherwise -> "(" ++ emit-expr rec ctors indent ++ ")." ++ field

Section: Handle
  emit-handle : Text -> IRExpr -> List IRHandleClause -> List Text -> Integer -> Text
  emit-handle (eff) (body) (clauses) (ctors) (indent) =
   "handle " ++ emit-expr body ctors indent ++ " with" ++ emit-handle-clauses clauses ctors indent 0

  emit-handle-clauses : List IRHandleClause -> List Text -> Integer -> Integer -> Text
  emit-handle-clauses (clauses) (ctors) (indent) (i) =
   if i == list-length clauses then ""
   else let c = list-at clauses i
   in "\n" ++ make-indent (indent + 1) ++ c.op-name ++ " (" ++ c.resume-name ++ ") -> " ++ emit-expr (c.body) ctors (indent + 1) ++ emit-handle-clauses clauses ctors indent (i + 1)

Section: Constructor Name Collection
  collect-ctor-names : List ATypeDef -> Integer -> List Text
  collect-ctor-names (type-defs) (i) =
   if i == list-length type-defs then []
   else let td = list-at type-defs i
   in let names = when td
     is AVariantTypeDef (name) (tparams) (ctors) (s) -> collect-variant-ctor-names ctors 0 []
     is ARecordTypeDef (name) (tparams) (fields) (s) -> [name.value]
   in names ++ collect-ctor-names type-defs (i + 1)

  collect-variant-ctor-names : List AVariantCtorDef -> Integer -> List Text -> List Text
  collect-variant-ctor-names (ctors) (i) (acc) =
   if i == list-length ctors then acc
   else let c = list-at ctors i
   in collect-variant-ctor-names ctors (i + 1) (list-snoc acc (c.name.value))

Section: Utilities
  is-simple : IRExpr -> Boolean
  is-simple (e) =
   when e
    is IrIntLit (n) (sp) -> True
    is IrNumLit (n) (sp) -> True
    is IrTextLit (s) (sp) -> True
    is IrBoolLit (b) (sp) -> True
    is IrCharLit (n) (sp) -> True
    is IrName (n) (ty) (sp) -> True
    is IrFieldAccess (r) (f) (ty) (sp) -> True
    is otherwise -> False

  make-indent : Integer -> Text
  make-indent (n) =
   if n == 0 then ""
   else " " ++ make-indent (n - 1)

  escape-text : Text -> Text
  escape-text (s) =
   text-concat-list (escape-text-collect s 0 (text-length s) [])

  escape-text-collect : Text -> Integer -> Integer -> List Text -> List Text
  escape-text-collect (s) (i) (len) (acc) =
   if i == len then acc
   else let c = char-code-at s i
   in escape-text-collect s (i + 1) len (list-snoc acc (escape-one-char c))

  escape-one-char : Integer -> Text
  escape-one-char (c) =
   if c == char-code-at "\\" 0 then "\\\\"
   else if c == char-code-at "\"" 0 then "\\\""
   else if c == char-code-at "\n" 0 then "\\n"
   else char-to-text (code-to-char c)

  escape-char : Integer -> Text
  escape-char (c) =
   if c == char-code-at "\n" 0 then "\\n"
   else if c == char-code-at "\\" 0 then "\\\\"
   else if c == char-code-at "'" 0 then "\\'"
   else char-to-text (code-to-char c)

Section: Chapter Emission
  emit-full-chapter : IRChapter -> List ATypeDef -> Text
  emit-full-chapter (m) (type-defs) =
   let ctor-names = collect-ctor-names type-defs 0
   in let header = if m.chapter-title == "" then ""
      else "Chapter: " ++ m.chapter-title ++ "\n\n"
        ++ if m.prose == "" then "" else " " ++ m.prose ++ "\n\n"
   in header ++ emit-type-defs type-defs 0 ++ emit-all-defs (m.defs) ctor-names 0

  emit-all-defs : List IRDef -> List Text -> Integer -> Text
  emit-all-defs (defs) (ctor-names) (i) =
   if i == list-length defs then ""
   else emit-def (list-at defs i) ctor-names ++ "\n" ++ emit-all-defs defs ctor-names (i + 1)

  emit-def-list : List IRDef -> List Text -> Integer -> Text
  emit-def-list (defs) (ctor-names) (i) =
   if i == list-length defs then ""
   else emit-def (list-at defs i) ctor-names ++ "\n" ++ emit-def-list defs ctor-names (i + 1)

  filter-defs : List IRDef -> List Text -> Integer -> Integer -> List IRDef -> List IRDef
  filter-defs (defs) (ctor-names) (i) (len) (acc) =
   if i == len then acc
   else let d = list-at defs i
   in let next = filter-defs defs ctor-names (i + 1) len
   in if skip-def d ctor-names then next acc
      else if has-def-named acc (d.name) 0 (list-length acc) then let dominated = def-score d > def-score-named acc (d.name) 0 (list-length acc)
   in if dominated then next (replace-def acc (d.name) d 0 (list-length acc))
              else next acc
      else next (list-snoc acc d)

  def-score : IRDef -> Integer
  def-score (d) =
   list-length (d.params) * 100 + body-depth (d.body)

  def-score-named : List IRDef -> Text -> Integer -> Integer -> Integer
  def-score-named (defs) (name) (i) (len) =
   if i == len then 0
   else if (list-at defs i).name == name then def-score (list-at defs i)
   else def-score-named defs name (i + 1) len

  body-depth : IRExpr -> Integer
  body-depth (e) =
   when e
    is IrName (n) (ty) (sp) -> 1
    is IrIntLit (n) (sp) -> 1
    is IrTextLit (s) (sp) -> 1
    is IrBoolLit (b) (sp) -> 1
    is IrFieldAccess (r) (f) (ty) (sp) -> 2
    is IrApply (f) (a) (ty) (sp) -> 3 + body-depth f
    is IrLet (name) (ty) (val) (body) (sp) -> 5 + body-depth body
    is IrIf (c) (t) (el) (ty) (sp) -> 5 + body-depth t
    is IrMatch (s) (bs) (ty) (sp) -> 10
    is IrLambda (ps) (b) (ty) (sp) -> 5
    is IrDo (stmts) (ty) (sp) -> 5
    is IrRecord (n) (fs) (ty) (sp) -> 3
    is otherwise -> 1

  has-def-named : List IRDef -> Text -> Integer -> Integer -> Boolean
  has-def-named (defs) (name) (i) (len) =
   if i == len then False
   else if (list-at defs i).name == name then True
   else has-def-named defs name (i + 1) len

  replace-def : List IRDef -> Text -> IRDef -> Integer -> Integer -> List IRDef
  replace-def (defs) (name) (new-def) (i) (len) =
   if i == len then defs
   else if (list-at defs i).name == name then list-set defs i new-def
   else replace-def defs name new-def (i + 1) len

  list-set : List IRDef -> Integer -> IRDef -> List IRDef
  list-set (xs) (idx) (val) =
   list-set-loop xs idx val 0 (list-length xs) []

  list-set-loop : List IRDef -> Integer -> IRDef -> Integer -> Integer -> List IRDef -> List IRDef
  list-set-loop (xs) (idx) (val) (i) (len) (acc) =
   if i == len then acc
   else if i == idx then list-set-loop xs idx val (i + 1) len (list-snoc acc val)
   else list-set-loop xs idx val (i + 1) len (list-snoc acc (list-at xs i))

