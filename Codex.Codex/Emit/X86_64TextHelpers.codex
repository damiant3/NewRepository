Chapter: X86-64 Code Generator

 Text and number runtime helpers emitted into every x86-64-bare
 binary: string comparison, integer<->text conversion, string concat,
 power, substring operations, split, and replace.

Section: __str_eq
  emit-str-eq-head : CodegenState -> StrEqHeadResult
  emit-str-eq-head (st) =
    let st0 = record-func-offset st "__str_eq"
   in let st1 = st-append-text st0 (cmp-rr reg-rdi reg-rsi)
   in let not-same-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ne 0)
   in let st3 = st-append-text st2 (li reg-rax 1)
   in let st4 = st-append-text st3 x86-ret
   in let st5 = patch-jcc-at st4 not-same-pos (st4.text-len)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rdi 0)
   in let st7 = st-append-text st6 (mov-load reg-rdx reg-rsi 0)
   in let st8 = st-append-text st7 (cmp-rr reg-rcx reg-rdx)
   in let len-ne-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ne 0)
   in StrEqHeadResult {
    cg = st9,
    len-ne-pos = len-ne-pos
   }

  emit-str-eq-byte-loop : CodegenState -> StrEqLoopResult
  emit-str-eq-byte-loop (st) =
    let st0 = st-append-text st (li reg-r11 0)
   in let loop-pos = st0.text-len
   in let st1 = st-append-text st0 (cmp-rr reg-r11 reg-rcx)
   in let loop-done-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-rdi)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-r11)
   in let st5 = st-append-text st4 (movzx-byte reg-rax reg-rax 8)
   in let st6 = st-append-text st5 (mov-rr reg-rdx reg-rsi)
   in let st7 = st-append-text st6 (add-rr reg-rdx reg-r11)
   in let st8 = st-append-text st7 (movzx-byte reg-rdx reg-rdx 8)
   in let st9 = st-append-text st8 (cmp-rr reg-rax reg-rdx)
   in let byte-ne-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-ne 0)
   in let st11 = st-append-text st10 (add-ri reg-r11 1)
   in let st12 = st-append-text st11 (jmp (loop-pos - (st11.text-len + 5)))
   in StrEqLoopResult {
    cg = st12,
    loop-done-pos = loop-done-pos,
    byte-ne-pos = byte-ne-pos
   }

  emit-str-eq : CodegenState -> CodegenState
  emit-str-eq (st) =
    let head = emit-str-eq-head st
   in let lp = emit-str-eq-byte-loop (head.cg)
   in let st1 = patch-jcc-at (lp.cg) (lp.loop-done-pos) (lp.cg.text-len)
   in let st2 = st-append-text st1 (li reg-rax 1)
   in let st3 = st-append-text st2 x86-ret
   in let st4 = patch-jcc-at st3 (head.len-ne-pos) (st3.text-len)
   in let st5 = patch-jcc-at st4 (lp.byte-ne-pos) (st4.text-len)
   in let st6 = st-append-text st5 (li reg-rax 0)
   in st-append-text st6 x86-ret

Section: __itoa
  emit-itoa-setup : CodegenState -> CodegenState
  emit-itoa-setup (st) =
    let st0 = record-func-offset st "__itoa"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (sub-ri reg-rsp 32)
   in let st4 = st-append-text st3 (mov-rr reg-rbx reg-rdi)
   in let st5 = st-append-text st4 (li reg-r12 0)
   in let st6 = st-append-text st5 (cmp-ri reg-rbx 0)
   in let not-neg-pos = st6.text-len
   in let st7 = st-append-text st6 (jcc cc-ge 0)
   in let st8 = st-append-text st7 (neg-r reg-rbx)
   in let st9 = st-append-text st8 (li reg-r12 1)
   in patch-jcc-at st9 not-neg-pos (st9.text-len)

  emit-itoa-zero-guard : CodegenState -> ItoaZeroResult
  emit-itoa-zero-guard (st) =
    let st0 = st-append-text st (li reg-rcx 0)
   in let st1 = st-append-text st0 (li reg-r11 10)
   in let st2 = st-append-text st1 (test-rr reg-rbx reg-rbx)
   in let not-zero-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ne 0)
   in let st4 = st-append-text st3 (li reg-rsi 3)
   in let st5 = st-append-text st4 (mov-store-byte reg-rsp reg-rsi 0)
   in let st6 = st-append-text st5 (li reg-rcx 1)
   in let skip-digits-pos = st6.text-len
   in let st7 = st-append-text st6 (jmp 0)
   in let st8 = patch-jcc-at st7 not-zero-pos (st7.text-len)
   in ItoaZeroResult {
    cg = st8,
    skip-digits-pos = skip-digits-pos
   }

  emit-itoa-digit-loop : CodegenState -> CodegenState
  emit-itoa-digit-loop (st) =
    let digit-loop = st.text-len
   in let st0 = st-append-text st (test-rr reg-rbx reg-rbx)
   in let digit-done-pos = st0.text-len
   in let st1 = st-append-text st0 (jcc cc-e 0)
   in let st2 = st-append-text st1 (mov-rr reg-rax reg-rbx)
   in let st3 = st-append-text st2 cqo
   in let st4 = st-append-text st3 (idiv-r reg-r11)
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-rax)
   in let st6 = st-append-text st5 (add-ri reg-rdx 3)
   in let st7 = st-append-text st6 (mov-rr reg-rsi reg-rsp)
   in let st8 = st-append-text st7 (add-rr reg-rsi reg-rcx)
   in let st9 = st-append-text st8 (mov-store-byte reg-rsi reg-rdx 0)
   in let st10 = st-append-text st9 (add-ri reg-rcx 1)
   in let st11 = st-append-text st10 (jmp (digit-loop - (st10.text-len + 5)))
   in patch-jcc-at st11 digit-done-pos (st11.text-len)

  emit-itoa-heap-alloc : CodegenState -> CodegenState
  emit-itoa-heap-alloc (st) =
    let st0 = st-append-text st (mov-rr reg-rdx reg-rcx)
   in let st1 = st-append-text st0 (add-rr reg-rdx reg-r12)
   in let st2 = st-append-text st1 (mov-rr reg-rax reg-r10)
   in let st3 = st-append-text st2 (mov-rr reg-rsi reg-rdx)
   in let st4 = st-append-text st3 (add-ri reg-rsi 15)
   in let st5 = st-append-text st4 (and-ri reg-rsi (0 - 8))
   in let st6 = st-append-text st5 (add-rr reg-r10 reg-rsi)
   in let st7 = st-append-text st6 (mov-store reg-rax reg-rdx 0)
   in let st8 = st-append-text st7 (li reg-r11 0)
   in let st9 = st-append-text st8 (test-rr reg-r12 reg-r12)
   in let no-minus-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-e 0)
   in let st11 = st-append-text st10 (li reg-rsi 73)
   in let st12 = st-append-text st11 (mov-store-byte reg-rax reg-rsi 8)
   in let st13 = st-append-text st12 (li reg-r11 1)
   in patch-jcc-at st13 no-minus-pos (st13.text-len)

  emit-itoa-copy-and-epilogue : CodegenState -> CodegenState
  emit-itoa-copy-and-epilogue (st) =
    let copy-loop = st.text-len
   in let st0 = st-append-text st (test-rr reg-rcx reg-rcx)
   in let copy-done-pos = st0.text-len
   in let st1 = st-append-text st0 (jcc cc-e 0)
   in let st2 = st-append-text st1 (sub-ri reg-rcx 1)
   in let st3 = st-append-text st2 (mov-rr reg-rsi reg-rsp)
   in let st4 = st-append-text st3 (add-rr reg-rsi reg-rcx)
   in let st5 = st-append-text st4 (movzx-byte reg-rsi reg-rsi 0)
   in let st6 = st-append-text st5 (mov-rr reg-rdx reg-rax)
   in let st7 = st-append-text st6 (add-rr reg-rdx reg-r11)
   in let st8 = st-append-text st7 (mov-store-byte reg-rdx reg-rsi 8)
   in let st9 = st-append-text st8 (add-ri reg-r11 1)
   in let st10 = st-append-text st9 (jmp (copy-loop - (st9.text-len + 5)))
   in let st11 = patch-jcc-at st10 copy-done-pos (st10.text-len)
   in let st12 = st-append-text st11 (add-ri reg-rsp 32)
   in let st13 = st-append-text st12 (pop-r reg-r12)
   in let st14 = st-append-text st13 (pop-r reg-rbx)
   in st-append-text st14 x86-ret

  emit-itoa : CodegenState -> CodegenState
  emit-itoa (st) =
    let st0 = emit-itoa-setup st
   in let zero = emit-itoa-zero-guard st0
   in let st1 = emit-itoa-digit-loop (zero.cg)
   in let st2 = patch-jmp-at st1 (zero.skip-digits-pos) (st1.text-len)
   in let st3 = emit-itoa-heap-alloc st2
   in emit-itoa-copy-and-epilogue st3

Section: __str_concat
  emit-str-concat-prologue : CodegenState -> StrConcatCheckResult
  emit-str-concat-prologue (st) =
    let st0 = record-func-offset st "__str_concat"
   in let st1 = st-append-text st0 (push-r reg-rbx)
   in let st2 = st-append-text st1 (push-r reg-r12)
   in let st3 = st-append-text st2 (push-r reg-r13)
   in let st4 = st-append-text st3 (mov-rr reg-rbx reg-rdi)
   in let st5 = st-append-text st4 (mov-rr reg-r12 reg-rsi)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rbx 0)
   in let st7 = st-append-text st6 (mov-load reg-rdx reg-r12 0)
   in let st8 = st-append-text st7 (mov-rr reg-r11 reg-rcx)
   in let st9 = st-append-text st8 (add-ri reg-r11 15)
   in let st10 = st-append-text st9 (and-ri reg-r11 (0 - 8))
   in let st11 = st-append-text st10 (mov-rr reg-r13 reg-rbx)
   in let st12 = st-append-text st11 (add-rr reg-r13 reg-r11)
   in let st13 = st-append-text st12 (cmp-rr reg-r13 reg-r10)
   in let slow-path-pos = st13.text-len
   in let st14 = st-append-text st13 (jcc cc-ne 0)
   in StrConcatCheckResult {
    cg = st14,
    slow-path-pos = slow-path-pos
   }

  emit-str-concat-fast-copy : CodegenState -> CodegenState
  emit-str-concat-fast-copy (st) =
    let st0 = st-append-text st (mov-rr reg-r13 reg-rcx)
   in let st1 = st-append-text st0 (add-rr reg-r13 reg-rdx)
   in let st2 = st-append-text st1 (mov-store reg-rbx reg-r13 0)
   in let st3 = st-append-text st2 (li reg-r11 0)
   in let fast-loop = st3.text-len
   in let st4 = st-append-text st3 (cmp-rr reg-r11 reg-rdx)
   in let fast-exit-pos = st4.text-len
   in let st5 = st-append-text st4 (jcc cc-ge 0)
   in let st6 = st-append-text st5 (mov-rr reg-rsi reg-r12)
   in let st7 = st-append-text st6 (add-rr reg-rsi reg-r11)
   in let st8 = st-append-text st7 (movzx-byte reg-rsi reg-rsi 8)
   in let st9 = st-append-text st8 (mov-rr reg-rdi reg-rbx)
   in let st10 = st-append-text st9 (add-rr reg-rdi reg-rcx)
   in let st11 = st-append-text st10 (add-rr reg-rdi reg-r11)
   in let st12 = st-append-text st11 (mov-store-byte reg-rdi reg-rsi 8)
   in let st13 = st-append-text st12 (add-ri reg-r11 1)
   in let st14 = st-append-text st13 (jmp (fast-loop - (st13.text-len + 5)))
   in patch-jcc-at st14 fast-exit-pos (st14.text-len)

  emit-str-concat-fast-bump : CodegenState -> StrConcatFastResult
  emit-str-concat-fast-bump (st) =
    let st0 = st-append-text st (mov-rr reg-r11 reg-r13)
   in let st1 = st-append-text st0 (add-ri reg-r11 15)
   in let st2 = st-append-text st1 (and-ri reg-r11 (0 - 8))
   in let st3 = st-append-text st2 (lea reg-r10 reg-rbx 0)
   in let st4 = st-append-text st3 (add-rr reg-r10 reg-r11)
   in let st5 = st-append-text st4 (mov-rr reg-rax reg-rbx)
   in let fast-done-pos = st5.text-len
   in let st6 = st-append-text st5 (jmp 0)
   in StrConcatFastResult {
    cg = st6,
    fast-done-pos = fast-done-pos
   }

  emit-str-concat-slow-alloc : CodegenState -> Integer -> CodegenState
  emit-str-concat-slow-alloc (st) (slow-path-pos) =
    let st0 = patch-jcc-at st slow-path-pos (st.text-len)
   in let st1 = st-append-text st0 (mov-rr reg-r13 reg-rcx)
   in let st2 = st-append-text st1 (add-rr reg-r13 reg-rdx)
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-r10)
   in let st4 = st-append-text st3 (mov-rr reg-r11 reg-r13)
   in let st5 = st-append-text st4 (add-ri reg-r11 15)
   in let st6 = st-append-text st5 (and-ri reg-r11 (0 - 8))
   in let st7 = st-append-text st6 (add-rr reg-r10 reg-r11)
   in st-append-text st7 (mov-store reg-rax reg-r13 0)

  emit-str-concat-slow-copy1 : CodegenState -> CodegenState
  emit-str-concat-slow-copy1 (st) =
    let st0 = st-append-text st (mov-load reg-rcx reg-rbx 0)
   in let st1 = st-append-text st0 (li reg-r11 0)
   in let loop1 = st1.text-len
   in let st2 = st-append-text st1 (cmp-rr reg-r11 reg-rcx)
   in let exit1-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ge 0)
   in let st4 = st-append-text st3 (mov-rr reg-rdx reg-rbx)
   in let st5 = st-append-text st4 (add-rr reg-rdx reg-r11)
   in let st6 = st-append-text st5 (movzx-byte reg-rdx reg-rdx 8)
   in let st7 = st-append-text st6 (mov-rr reg-rsi reg-rax)
   in let st8 = st-append-text st7 (add-rr reg-rsi reg-r11)
   in let st9 = st-append-text st8 (mov-store-byte reg-rsi reg-rdx 8)
   in let st10 = st-append-text st9 (add-ri reg-r11 1)
   in let st11 = st-append-text st10 (jmp (loop1 - (st10.text-len + 5)))
   in patch-jcc-at st11 exit1-pos (st11.text-len)

  emit-str-concat-slow-copy2 : CodegenState -> Integer -> CodegenState
  emit-str-concat-slow-copy2 (st) (fast-done-pos) =
    let st0 = st-append-text st (mov-load reg-rcx reg-rbx 0)
   in let st1 = st-append-text st0 (mov-load reg-rdx reg-r12 0)
   in let st2 = st-append-text st1 (li reg-r11 0)
   in let loop2 = st2.text-len
   in let st3 = st-append-text st2 (cmp-rr reg-r11 reg-rdx)
   in let exit2-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ge 0)
   in let st5 = st-append-text st4 (mov-rr reg-rsi reg-r12)
   in let st6 = st-append-text st5 (add-rr reg-rsi reg-r11)
   in let st7 = st-append-text st6 (movzx-byte reg-rsi reg-rsi 8)
   in let st8 = st-append-text st7 (mov-rr reg-rdi reg-rax)
   in let st9 = st-append-text st8 (add-rr reg-rdi reg-rcx)
   in let st10 = st-append-text st9 (add-rr reg-rdi reg-r11)
   in let st11 = st-append-text st10 (mov-store-byte reg-rdi reg-rsi 8)
   in let st12 = st-append-text st11 (add-ri reg-r11 1)
   in let st13 = st-append-text st12 (jmp (loop2 - (st12.text-len + 5)))
   in let st14 = patch-jcc-at st13 exit2-pos (st13.text-len)
   in patch-jmp-at st14 fast-done-pos (st14.text-len)

  emit-str-concat : CodegenState -> CodegenState
  emit-str-concat (st) =
    let prologue = emit-str-concat-prologue st
   in let st0 = emit-str-concat-fast-copy (prologue.cg)
   in let fast = emit-str-concat-fast-bump st0
   in let st1 = emit-str-concat-slow-alloc (fast.cg) (prologue.slow-path-pos)
   in let st2 = emit-str-concat-slow-copy1 st1
   in let st3 = emit-str-concat-slow-copy2 st2 (fast.fast-done-pos)
   in let st4 = st-append-text st3 (pop-r reg-r13)
   in let st5 = st-append-text st4 (pop-r reg-r12)
   in let st6 = st-append-text st5 (pop-r reg-rbx)
   in st-append-text st6 x86-ret

Section: __ipow
  emit-ipow-setup : CodegenState -> HelpResult2
  emit-ipow-setup (st) =
    let st0 = record-func-offset st "__ipow"
   in let st1 = st-append-text st0 (li reg-rax 1)
   in let st2 = st-append-text st1 (cmp-ri reg-rsi 0)
   in let neg-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-l 0)
   in let zero-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-e 0)
   in HelpResult2 {
    cg = st4,
    p1 = neg-pos,
    p2 = zero-pos
   }

  emit-ipow-loop : CodegenState -> CodegenState
  emit-ipow-loop (st) =
    let loop-top = st.text-len
   in let st0 = st-append-text st (mov-rr reg-rcx reg-rsi)
   in let st1 = st-append-text st0 (and-ri reg-rcx 1)
   in let skip-mul-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let st3 = st-append-text st2 (imul-rr reg-rax reg-rdi)
   in let st4 = patch-jcc-at st3 skip-mul-pos (st3.text-len)
   in let st5 = st-append-text st4 (imul-rr reg-rdi reg-rdi)
   in let st6 = st-append-text st5 (shr-ri reg-rsi 1)
   in let st7 = st-append-text st6 (cmp-ri reg-rsi 0)
   in let jmp-loop-pos = st7.text-len
   in let st8 = st-append-text st7 (jcc cc-g 0)
   in patch-jcc-at st8 jmp-loop-pos loop-top

  emit-ipow : CodegenState -> CodegenState
  emit-ipow (st) =
    let setup = emit-ipow-setup st
   in let st0 = emit-ipow-loop (setup.cg)
   in let st1 = patch-jcc-at st0 (setup.p2) (st0.text-len)
   in let st2 = st-append-text st1 x86-ret
   in let st3 = patch-jcc-at st2 (setup.p1) (st2.text-len)
   in let st4 = st-append-text st3 (li reg-rax 0)
   in st-append-text st4 x86-ret

Section: __text_to_int
  emit-text-to-int-setup : CodegenState -> HelpResult1
  emit-text-to-int-setup (st) =
    let st0 = record-func-offset st "__text_to_int"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rdi 0)
   in let st2 = st-append-text st1 (lea reg-rdi reg-rdi 8)
   in let st3 = st-append-text st2 (li reg-rax 0)
   in let st4 = st-append-text st3 (li reg-r11 0)
   in let st5 = st-append-text st4 (li reg-rsi 0)
   in let st6 = st-append-text st5 (test-rr reg-rcx reg-rcx)
   in let empty-pos = st6.text-len
   in let st7 = st-append-text st6 (jcc cc-e 0)
   in let st8 = st-append-text st7 (movzx-byte reg-rdx reg-rdi 0)
   in let st9 = st-append-text st8 (cmp-ri reg-rdx 73)
   in let not-minus-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-ne 0)
   in let st11 = st-append-text st10 (li reg-rsi 1)
   in let st12 = st-append-text st11 (add-ri reg-r11 1)
   in let st13 = patch-jcc-at st12 not-minus-pos (st12.text-len)
   in HelpResult1 {
    cg = st13,
    p1 = empty-pos
   }

  emit-text-to-int-parse : CodegenState -> CodegenState
  emit-text-to-int-parse (st) =
    let parse-loop = st.text-len
   in let st0 = st-append-text st (cmp-rr reg-r11 reg-rcx)
   in let parse-done-pos = st0.text-len
   in let st1 = st-append-text st0 (jcc cc-ge 0)
   in let st2 = st-append-text st1 (mov-rr reg-rdx reg-rdi)
   in let st3 = st-append-text st2 (add-rr reg-rdx reg-r11)
   in let st4 = st-append-text st3 (movzx-byte reg-rdx reg-rdx 0)
   in let st5 = st-append-text st4 (sub-ri reg-rdx 3)
   in let st6 = st-append-text st5 (push-r reg-rdx)
   in let st7 = st-append-text st6 (mov-rr reg-rdx reg-rax)
   in let st8 = st-append-text st7 (shl-ri reg-rax 3)
   in let st9 = st-append-text st8 (add-rr reg-rax reg-rdx)
   in let st10 = st-append-text st9 (add-rr reg-rax reg-rdx)
   in let st11 = st-append-text st10 (pop-r reg-rdx)
   in let st12 = st-append-text st11 (add-rr reg-rax reg-rdx)
   in let st13 = st-append-text st12 (add-ri reg-r11 1)
   in let st14 = st-append-text st13 (jmp (parse-loop - (st13.text-len + 5)))
   in patch-jcc-at st14 parse-done-pos (st14.text-len)

  emit-text-to-int : CodegenState -> CodegenState
  emit-text-to-int (st) =
    let setup = emit-text-to-int-setup st
   in let st0 = emit-text-to-int-parse (setup.cg)
   in let st1 = st-append-text st0 (test-rr reg-rsi reg-rsi)
   in let no-neg-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let st3 = st-append-text st2 (neg-r reg-rax)
   in let st4 = patch-jcc-at st3 no-neg-pos (st3.text-len)
   in let st5 = patch-jcc-at st4 (setup.p1) (st4.text-len)
   in st-append-text st5 x86-ret

Section: __text_starts_with
  emit-text-starts-with-head : CodegenState -> HelpResult1
  emit-text-starts-with-head (st) =
    let st0 = record-func-offset st "__text_starts_with"
   in let st1 = st-append-text st0 (mov-load reg-rcx reg-rdi 0)
   in let st2 = st-append-text st1 (mov-load reg-rdx reg-rsi 0)
   in let st3 = st-append-text st2 (cmp-rr reg-rdx reg-rcx)
   in let too-long-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-g 0)
   in HelpResult1 {
    cg = st4,
    p1 = too-long-pos
   }

