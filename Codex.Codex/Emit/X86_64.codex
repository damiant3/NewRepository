Chapter: X86-64 Code Generator

 Core emission: function prologue/epilogue, local variable management,
 expression lowering, and call emission. Compound-expression emission
 (apply, closures, records, match, list) lives in X86_64Compound.codex.

Section: Function Emission
  emit-sub-rsp-imm32 : Integer -> List Integer
  emit-sub-rsp-imm32 (imm) =
   [72, 129, 236] ++ write-i32 imm

  emit-prologue : CodegenState -> CodegenState
  emit-prologue (st) =
   let st1 = st-append-text st (push-r reg-rbp ++ mov-rr reg-rbp reg-rsp ++ push-r reg-rbx ++ push-r reg-r12 ++ push-r reg-r13 ++ push-r reg-r14)
   in let st2 = st-append-text st1 (li reg-r11 stack-min-rsp-addr)
   in let st3 = st-append-text st2 (mov-load reg-r11 reg-r11 0)
   in let st4 = st-append-text st3 (cmp-rr reg-rsp reg-r11)
   in let skip-pos = st4.text-len
   in let st5 = st-append-text st4 (jcc cc-ae 0)
   in let st6 = st-append-text st5 (li reg-r11 stack-min-rsp-addr)
   in let st7 = st-append-text st6 (mov-store reg-r11 reg-rsp 0)
   in let st8 = patch-jcc-at st7 skip-pos (st7.text-len)
   in let st9 = st-append-text st8 (cmp-rr reg-rsp reg-r10)
   in let check-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-b 0)
   in record-set st10 "stack-overflow-checks" (list-snoc (st10.stack-overflow-checks) check-pos)

  emit-epilogue : CodegenState -> CodegenState
  emit-epilogue (st) =
   st-append-text st (lea reg-rsp reg-rbp (0 - 32) ++ pop-r reg-r14 ++ pop-r reg-r13 ++ pop-r reg-r12 ++ pop-r reg-rbx ++ pop-r reg-rbp ++ x86-ret)

  bind-params : CodegenState -> List IRParam -> Integer -> CodegenState
  bind-params (st) (params) (i) =
   if i == list-length params then st
   else let p = list-at params i
   in let loc = alloc-local st
   in let st1 = if i < 6 then store-local (loc.state) (loc.reg) (list-at arg-regs i)
   else let stack-offset = 16 + (i - 6) * 8
   in let tmp = alloc-temp (loc.state)
   in store-local (st-append-text (tmp.state) (mov-load (tmp.reg) reg-rbp stack-offset)) (loc.reg) (tmp.reg)
   in bind-params (add-local st1 (p.name) (loc.reg)) params (i + 1)

  is-self-call : IRExpr -> Text -> Boolean
  is-self-call (expr) (func-name) =
   when expr
    is IrApply (f) (a) (t) (sp) -> is-self-call f func-name
    is IrName (n) (t) (sp) -> n == func-name
    is otherwise -> False

  has-tail-call : IRExpr -> Text -> Boolean
  has-tail-call (expr) (func-name) =
   when expr
    is IrIf (c) (th) (el) (t) (sp) -> has-tail-call th func-name | has-tail-call el func-name
    is IrLet (n) (t) (v) (b) (sp) -> has-tail-call b func-name
    is IrMatch (s) (bs) (t) (sp) -> has-tail-call-branches bs func-name 0
    is IrApply (f) (a) (t) (sp) -> is-self-call expr func-name
    is IrAct (stmts) (t) (sp) -> has-tail-call-act stmts func-name
    is otherwise -> False

  has-tail-call-act : List IRActStmt -> Text -> Boolean
  has-tail-call-act (stmts) (func-name) =
   let len = list-length stmts
   in if len == 0 then False
    else let last = list-at stmts (len - 1)
     in when last
      is IrDoExec (e) (sp) -> has-tail-call e func-name
      is otherwise -> False

  has-tail-call-branches : List IRBranch -> Text -> Integer -> Boolean
  has-tail-call-branches (branches) (func-name) (i) =
   if i == list-length branches then False
   else let b = list-at branches i
   in if has-tail-call (b.body) func-name then True
      else has-tail-call-branches branches func-name (i + 1)

  should-tco : IRDef -> Boolean
  should-tco (def) =
   if list-length (def.params) > 0 then has-tail-call (def.body) (def.name)
   else False

  st-set-tail-pos : CodegenState -> Boolean -> CodegenState
  st-set-tail-pos (st) (v) =
   record-set st "tco" (record-set (st.tco) "in-tail-pos" v)

  TcoAllocResult = record {
   alloc-state : CodegenState,
   alloc-locals : List Integer
  }

  pre-alloc-tco-temps : CodegenState -> Integer -> Integer -> List Integer -> TcoAllocResult
  pre-alloc-tco-temps (st) (i) (count) (acc) =
   if i == count then TcoAllocResult {
    alloc-state = st,
    alloc-locals = acc
  }
   else let loc = alloc-local st
   in pre-alloc-tco-temps (loc.state) (i + 1) count (list-snoc acc (loc.reg))

  collect-param-locals : List LocalBinding -> List IRParam -> Integer -> List Integer -> List Integer
  collect-param-locals (bindings) (params) (i) (acc) =
   if i == list-length params then acc
   else let p = list-at params i
   in let slot = lookup-local bindings (p.name)
   in collect-param-locals bindings params (i + 1) (list-snoc acc slot)

  emit-function : CodegenState -> IRDef -> CodegenState
  emit-function (st) (def) =
   let st1 = reset-func-state st (def.name)
   in let st2 = emit-prologue st1
   in let frame-patch-pos = st2.text-len
   in let st3 = st-append-text st2 (emit-sub-rsp-imm32 0)
   in let st4 = bind-params st3 (def.params) 0
   in let is-tco = should-tco def
   in let st5 = if is-tco then let tco-alloc = pre-alloc-tco-temps st4 0 (list-length (def.params)) []
   in let st-a = tco-alloc.alloc-state
   in let p-locals = collect-param-locals (st-a.locals) (def.params) 0 []
   in record-set st-a "tco" (TcoState {
       active = True,
       in-tail-pos = True,
       loop-top = st-a.text-len,
       param-locals = p-locals,
       temp-locals = tco-alloc.alloc-locals,
       current-func = def.name,
       saved-next-local = st-a.next-local,
       saved-next-temp = st-a.next-temp
      })
    else st4
   in let result = emit-expr st5 (def.body)
   in let st6 = if result.reg == reg-rax then result.state
    else st-append-text (result.state) (mov-rr reg-rax (result.reg))
   in let st7 = emit-epilogue st6
   in let frame-size = align-16 (st7.spill-count * 8)
   in st-add-deferred-patch st7 (make-i32-patch (frame-patch-pos + 3) frame-size)

  emit-all-defs : CodegenState -> List IRDef -> Integer -> CodegenState
  emit-all-defs (st) (defs) (i) =
   if i == list-length defs then st
   else emit-all-defs (emit-function st (list-at defs i)) defs (i + 1)

Section: Local Variable Management
  lookup-local : List LocalBinding -> Text -> Integer
  lookup-local (bindings) (name) =
   lookup-local-loop bindings name 0 (list-length bindings)

  lookup-local-loop : List LocalBinding -> Text -> Integer -> Integer -> Integer
  lookup-local-loop (bindings) (name) (i) (len) =
   if i == len then -1
   else let b = list-at bindings i
   in if b.name == name then b.slot
      else lookup-local-loop bindings name (i + 1) len

  add-local : CodegenState -> Text -> Integer -> CodegenState
  add-local (st) (name) (slot) =
   record-set st "locals" ([LocalBinding {
     name = name,
     slot = slot
    }] ++ (st.locals))

Section: Expression Emission
  emit-expr : CodegenState -> IRExpr -> EmitResult
  emit-expr (st) (expr) =
   when expr
    is IrIntLit (value) (sp) -> emit-int-lit st value
    is IrNumLit (value) (sp) -> emit-int-lit st value
    is IrBoolLit (value) (sp) -> emit-int-lit st (if value then 1 else 0)
    is IrCharLit (value) (sp) -> emit-int-lit st value
    is IrTextLit (value) (sp) -> emit-text-lit st value
    is IrNegate (operand) (sp) -> emit-negate st operand
    is IrError (msg) (ty) (sp) -> emit-int-lit (st-add-error st cdx-ir-error msg sp) 0
    is IrName (name) (ty) (sp) -> emit-name st name ty
    is IrLet (name) (ty) (value) (body) (sp) -> emit-let st name value body
    is IrBinary (op) (left) (right) (ty) (sp) -> emit-binary st op left right
    is IrIf (cond) (then-e) (else-e) (ty) (sp) -> emit-if st cond then-e else-e
    is IrApply (func) (arg) (ty) (sp) -> emit-apply st func arg ty
    is IrRecord (rname) (fields) (ty) (sp) -> emit-record st fields ty
    is IrFieldAccess (rec) (field) (ty) (sp) -> emit-field-access st rec field
    is IrMatch (scrut) (branches) (ty) (sp) -> emit-match st scrut branches
    is IrList (elems) (ty) (sp) -> emit-list st elems
    is IrAct (stmts) (ty) (sp) -> emit-act-stmts st stmts 0 (list-length stmts)
    is otherwise -> EmitResult {
     state = st,
     reg = reg-rax
    }

  emit-act-stmts : CodegenState -> List IRActStmt -> Integer -> Integer -> EmitResult
  emit-act-stmts (st) (stmts) (i) (len) =
   if i == len then EmitResult { state = st, reg = reg-rax }
   else let s = list-at stmts i
    in when s
     is IrDoBind (name) (ty) (val) (sp) ->
      let val-result = emit-expr st val
      in let loc = alloc-local (val-result.state)
       in let st1 = store-local (loc.state) (loc.reg) (val-result.reg)
        in let st2 = add-local st1 name (loc.reg)
         in emit-act-stmts st2 stmts (i + 1) len
     is IrDoExec (e) (sp) ->
      if i == len - 1 then emit-expr st e
      else let r = emit-expr st e
       in emit-act-stmts (r.state) stmts (i + 1) len

  emit-text-lit : CodegenState -> Text -> EmitResult
  emit-text-lit (st) (value) =
   let len = text-length value
   in let rodata-off = st.rodata-len
   in let str-bytes = append-text-bytes (write-i64 len) value 0 len
   in let padded = pad-to-8 str-bytes
   in let new-rodata-len = buf-write-bytes (st.rodata-buf-addr) (st.rodata-len) padded
   in let st1 = record-set st "rodata-len" new-rodata-len
   in let fixup = RodataFixup {
    patch-offset = st1.text-len + 2,
    rodata-offset = rodata-off
   }
   in let st2 = st-append-text st1 (mov-ri64 reg-rax 0)
   in let st3 = record-set st2 "rodata-fixups" (list-snoc (st2.rodata-fixups) fixup)
   in let rd = alloc-temp st3
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-rax),
   reg = rd.reg
  }

  append-text-bytes : List Integer -> Text -> Integer -> Integer -> List Integer
  append-text-bytes (acc) (s) (i) (len) =
   if i == len then acc
   else append-text-bytes (list-snoc acc (char-code-at s i)) s (i + 1) len

  pad-to-8 : List Integer -> List Integer
  pad-to-8 (xs) =
   let rem = int-mod (list-length xs) 8
   in if rem == 0 then xs
    else pad-to-8 (list-snoc xs 0)

  emit-negate : CodegenState -> IRExpr -> EmitResult
  emit-negate (st) (operand) =
   let r = emit-expr st operand
   in let rd = alloc-temp (r.state)
   in let st1 = st-append-text (rd.state) (mov-rr (rd.reg) (r.reg))
   in EmitResult {
   state = st-append-text st1 (neg-r (rd.reg)),
   reg = rd.reg
  }

  emit-show-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-show-builtin (st) (args) =
   let arg = list-at args 0
   in when ir-expr-type arg
    is BooleanTy -> emit-show-bool st arg
    is otherwise -> emit-helper-call-1 st args "__itoa"

  emit-show-bool : CodegenState -> IRExpr -> EmitResult
  emit-show-bool (st) (arg) =
   let val-result = emit-expr (st-set-tail-pos st False) arg
   in let st1 = st-append-text (val-result.state) (test-rr (val-result.reg) (val-result.reg))
   in let je-false-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let true-result = emit-text-lit st2 "True"
   in let result-loc = alloc-local (true-result.state)
   in let st3 = store-local (result-loc.state) (result-loc.reg) (true-result.reg)
   in let jmp-end-pos = st3.text-len
   in let st4 = st-append-text st3 (jmp 0)
   in let st5 = patch-jcc-at st4 je-false-pos (st4.text-len)
   in let false-result = emit-text-lit st5 "False"
   in let st6 = store-local (false-result.state) (result-loc.reg) (false-result.reg)
   in let st7 = patch-jmp-at st6 jmp-end-pos (st6.text-len)
   in load-local st7 (result-loc.reg)

  emit-num-arith : CodegenState -> Integer -> Integer -> Integer -> EmitResult
  emit-num-arith (st) (l-reg) (r-reg) (sse-op) =
   let rd = alloc-temp st
   in EmitResult {
   state = st-append-text (rd.state) (
    movq-to-xmm 0 l-reg
    ++ movq-to-xmm 1 r-reg
    ++ [242, 15, sse-op, modrm 3 0 1]
    ++ movq-from-xmm (rd.reg) 0
   ),
   reg = rd.reg
  }

  emit-num-comparison : CodegenState -> Integer -> Integer -> Integer -> EmitResult
  emit-num-comparison (st) (cc) (l-reg) (r-reg) =
   let rd = alloc-temp st
   in EmitResult {
   state = st-append-text (rd.state) (
    movq-to-xmm 0 l-reg
    ++ movq-to-xmm 1 r-reg
    ++ ucomisd-xmm 0 1
    ++ setcc cc (rd.reg)
    ++ movzx-byte-self (rd.reg)
   ),
   reg = rd.reg
  }

  emit-int-lit : CodegenState -> Integer -> EmitResult
  emit-int-lit (st) (value) =
   let tmp = alloc-temp st
   in EmitResult {
   state = st-append-text (tmp.state) (li (tmp.reg) value),
   reg = tmp.reg
  }

  find-ctor-tag : List SumCtor -> Text -> Integer -> Integer
  find-ctor-tag (ctors) (name) (i) =
   if i == list-length ctors then -1
   else let c = list-at ctors i
   in if c.name.value == name then i
      else find-ctor-tag ctors name (i + 1)

  emit-name : CodegenState -> Text -> CodexType -> EmitResult
  emit-name (st) (name) (ty) =
   let slot = lookup-local (st.locals) name
   in if slot >= 0 then load-local st slot
      else emit-name-nonlocal st name ty

  emit-name-nonlocal : CodegenState -> Text -> CodexType -> EmitResult
  emit-name-nonlocal (st) (name) (ty) =
   if name == "heap-save" then emit-heap-save-builtin st
   else let resolved = resolve-to-sum-with-defs st ty
   in when resolved
    is SumTy (sname) (ctors) ->
     let tag = find-ctor-tag ctors name 0
     in if tag >= 0 then emit-nullary-ctor st tag
        else emit-name-as-call st name
    is FunTy (pt) (rt) -> emit-partial-application st name []
    is otherwise -> emit-name-as-call st name

  resolve-to-sum : CodexType -> CodexType
  resolve-to-sum (ty) =
   when ty
    is SumTy (sn) (cs) -> ty
    is EffectfulTy (effs) (ret) -> resolve-to-sum ret
    is otherwise -> ty

  resolve-to-sum-with-defs : CodegenState -> CodexType -> CodexType
  resolve-to-sum-with-defs (st) (ty) =
   let resolved = resolve-constructed-ty st ty
   in when resolved
    is SumTy (sn) (cs) -> resolved
    is EffectfulTy (effs) (ret) -> resolve-to-sum-with-defs st ret
    is otherwise -> resolved

  emit-nullary-ctor : CodegenState -> Integer -> EmitResult
  emit-nullary-ctor (st) (tag) =
   let ptr-loc = alloc-local st
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let tag-tmp = alloc-temp st3
   in let st4 = st-append-text (tag-tmp.state) (li (tag-tmp.reg) tag)
   in let ptr-load = load-local st4 (ptr-loc.reg)
   in let st5 = st-append-text (ptr-load.state) (mov-store (ptr-load.reg) (tag-tmp.reg) 0)
   in load-local st5 (ptr-loc.reg)

  emit-name-as-call : CodegenState -> Text -> EmitResult
  emit-name-as-call (st) (name) =
   if name == "read-line" then emit-read-line-builtin st
   else let st1 = emit-call-to st name
   in let tmp = alloc-temp st1
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  emit-let : CodegenState -> Text -> IRExpr -> IRExpr -> EmitResult
  emit-let (st) (name) (value) (body) =
   let saved-tail = st.tco.in-tail-pos
   in let val-result = emit-expr (st-set-tail-pos st False) value
   in let loc = alloc-local (val-result.state)
   in let st1 = store-local (loc.state) (loc.reg) (val-result.reg)
   in let st2 = add-local st1 name (loc.reg)
   in emit-expr (st-set-tail-pos st2 saved-tail) body

  is-append-list-op : IRBinaryOp -> Boolean
  is-append-list-op (op) =
   when op
    is IrAppendList -> True
    is otherwise -> False

  flatten-append-chain : IRExpr -> List IRExpr -> List IRExpr
  flatten-append-chain (e) (acc) =
   when e
    is IrBinary (op) (l) (r) (ty) (sp) ->
     if is-append-list-op op then flatten-append-chain l (flatten-append-chain r acc)
     else [e] ++ acc
    is otherwise -> [e] ++ acc

  emit-concat-many-eval : CodegenState -> List IRExpr -> Integer -> Integer -> List Integer -> ConcatManyEval
  emit-concat-many-eval (st) (exprs) (i) (n) (locals) =
   if i >= n then ConcatManyEval { state = st, locals = locals }
   else let r = emit-expr (st-set-tail-pos st False) (list-at exprs i)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in emit-concat-many-eval st1 exprs (i + 1) n (list-snoc locals (loc.reg))

  ConcatManyEval = record {
   state : CodegenState,
   locals : List Integer
  }

  emit-concat-many-store-ptrs : CodegenState -> List Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-concat-many-store-ptrs (st) (locals) (i) (n) (arr-reg) =
   if i >= n then st
   else let loaded = load-local st (list-at locals i)
   in let st1 = st-append-text (loaded.state) (mov-store arr-reg (loaded.reg) (i * 8))
   in emit-concat-many-store-ptrs st1 locals (i + 1) n arr-reg

  emit-concat-many : CodegenState -> List IRExpr -> EmitResult
  emit-concat-many (st) (exprs) =
   let n = list-length exprs
   in let eval = emit-concat-many-eval st exprs 0 n []
   in let st1 = eval.state
   in let arr = alloc-temp st1
   in let st2 = st-append-text (arr.state) (mov-rr (arr.reg) reg-r10)
   in let st3 = st-append-text st2 (add-ri reg-r10 (n * 8))
   in let st4 = emit-concat-many-store-ptrs st3 (eval.locals) 0 n (arr.reg)
   in let st5 = st-append-text st4 (mov-rr reg-rdi (arr.reg))
   in let st6 = st-append-text st5 (li reg-rsi n)
   in let st7 = emit-call-to st6 "__list_concat_many"
   in let rd = alloc-temp st7
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-rax),
   reg = rd.reg
  }

  emit-binary : CodegenState -> IRBinaryOp -> IRExpr -> IRExpr -> EmitResult
  emit-binary (st) (op) (left) (right) =
   if is-append-list-op op then emit-append-list st left right
   else emit-binary-standard st op left right

  emit-append-list : CodegenState -> IRExpr -> IRExpr -> EmitResult
  emit-append-list (st) (left) (right) =
   let chain = flatten-append-chain left [right]
   in emit-concat-many st chain

  emit-binary-standard : CodegenState -> IRBinaryOp -> IRExpr -> IRExpr -> EmitResult
  emit-binary-standard (st) (op) (left) (right) =
   let l = emit-expr st left
   in let l-loc = alloc-local (l.state)
   in let st1 = store-local (l-loc.state) (l-loc.reg) (l.reg)
   in let r = emit-expr st1 right
   in let r-loc = alloc-local (r.state)
   in let st2 = store-local (r-loc.state) (r-loc.reg) (r.reg)
   in let l-load = load-local st2 (l-loc.reg)
   in let r-load = load-local (l-load.state) (r-loc.reg)
   in let operand-ty = ir-expr-type left
   in emit-binary-op (r-load.state) op (l-load.reg) (r-load.reg) operand-ty

  emit-binary-op : CodegenState -> IRBinaryOp -> Integer -> Integer -> CodexType -> EmitResult
  emit-binary-op (st) (op) (l-reg) (r-reg) (operand-ty) =
   let rd = alloc-temp st
   in when op
    is IrAddInt -> EmitResult {
     state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ add-rr (rd.reg) r-reg),
     reg = rd.reg
    }
    is IrSubInt -> EmitResult {
     state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ sub-rr (rd.reg) r-reg),
     reg = rd.reg
    }
    is IrMulInt -> EmitResult {
     state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ imul-rr (rd.reg) r-reg),
     reg = rd.reg
    }
    is IrDivInt -> EmitResult {
     state = st-append-text (rd.state) (mov-rr reg-rax l-reg ++ cqo ++ idiv-r r-reg ++ mov-rr (rd.reg) reg-rax),
     reg = rd.reg
    }
    is IrAddNum -> emit-num-arith st l-reg r-reg 88
    is IrSubNum -> emit-num-arith st l-reg r-reg 92
    is IrMulNum -> emit-num-arith st l-reg r-reg 89
    is IrDivNum -> emit-num-arith st l-reg r-reg 94
    is IrEq -> emit-eq-op st l-reg r-reg operand-ty
    is IrNotEq -> emit-neq-op st l-reg r-reg operand-ty
    is IrLt -> emit-comparison st cc-l l-reg r-reg
    is IrGt -> emit-comparison st cc-g l-reg r-reg
    is IrLtEq -> emit-comparison st cc-le l-reg r-reg
    is IrGtEq -> emit-comparison st cc-ge l-reg r-reg
    is IrAnd -> EmitResult {
     state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ and-rr (rd.reg) r-reg),
     reg = rd.reg
    }
    is IrOr -> EmitResult {
     state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ add-rr (rd.reg) r-reg),
     reg = rd.reg
    }
    is IrAppendText -> emit-helper-call-2-regs st l-reg r-reg "__str_concat"
    is IrAppendList -> emit-helper-call-2-regs st l-reg r-reg "__list_append"
    is IrConsList -> emit-helper-call-2-regs st l-reg r-reg "__list_cons"
    is otherwise -> EmitResult {
     state = st,
     reg = reg-rax
    }

  emit-helper-call-2-regs : CodegenState -> Integer -> Integer -> Text -> EmitResult
  emit-helper-call-2-regs (st) (l-reg) (r-reg) (name) =
   let st1 = st-append-text st (mov-rr reg-rdi l-reg ++ mov-rr reg-rsi r-reg)
   in let st2 = emit-call-to st1 name
   in let rd = alloc-temp st2
   in EmitResult {
   state = st-append-text (rd.state) (mov-rr (rd.reg) reg-rax),
   reg = rd.reg
  }

  emit-eq-op : CodegenState -> Integer -> Integer -> CodexType -> EmitResult
  emit-eq-op (st) (l-reg) (r-reg) (ty) =
   let resolved = resolve-to-sum-with-defs st ty
   in when resolved
    is TextTy -> emit-helper-call-2-regs st l-reg r-reg "__str_eq"
    is NumberTy -> emit-num-comparison st cc-e l-reg r-reg
    is SumTy (sn) (cs) -> emit-sum-tag-comparison st cc-e l-reg r-reg
    is otherwise -> emit-comparison st cc-e l-reg r-reg

  emit-neq-op : CodegenState -> Integer -> Integer -> CodexType -> EmitResult
  emit-neq-op (st) (l-reg) (r-reg) (ty) =
   let resolved = resolve-to-sum-with-defs st ty
   in when resolved
    is TextTy ->
     let eq-result = emit-helper-call-2-regs st l-reg r-reg "__str_eq"
     in let rd = alloc-temp (eq-result.state)
     in EmitResult {
      state = st-append-text (rd.state) (cmp-ri (eq-result.reg) 0 ++ setcc cc-e (rd.reg) ++ movzx-byte-self (rd.reg)),
      reg = rd.reg
     }
    is NumberTy -> emit-num-comparison st cc-ne l-reg r-reg
    is SumTy (sn) (cs) -> emit-sum-tag-comparison st cc-ne l-reg r-reg
    is otherwise -> emit-comparison st cc-ne l-reg r-reg

  emit-sum-tag-comparison : CodegenState -> Integer -> Integer -> Integer -> EmitResult
  emit-sum-tag-comparison (st) (cc) (l-reg) (r-reg) =
   let l-tag = alloc-temp st
   in let st1 = st-append-text (l-tag.state) (mov-load (l-tag.reg) l-reg 0)
   in let r-tag = alloc-temp st1
   in let st2 = st-append-text (r-tag.state) (mov-load (r-tag.reg) r-reg 0)
   in emit-comparison st2 cc (l-tag.reg) (r-tag.reg)

  emit-comparison : CodegenState -> Integer -> Integer -> Integer -> EmitResult
  emit-comparison (st) (cc) (l-reg) (r-reg) =
   let rd = alloc-temp st
   in EmitResult {
   state = st-append-text (rd.state) (cmp-rr l-reg r-reg ++ setcc cc (rd.reg) ++ movzx-byte-self (rd.reg)),
   reg = rd.reg
  }

  emit-if : CodegenState -> IRExpr -> IRExpr -> IRExpr -> EmitResult
  emit-if (st) (cond) (then-e) (else-e) =
   let saved-tail = st.tco.in-tail-pos
   in let cond-result = emit-expr (st-set-tail-pos st False) cond
   in let st1 = st-append-text (cond-result.state) (test-rr (cond-result.reg) (cond-result.reg))
   in let je-false-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let then-result = emit-expr (st-set-tail-pos st2 saved-tail) then-e
   in let result-loc = alloc-local (then-result.state)
   in let st3 = store-local (result-loc.state) (result-loc.reg) (then-result.reg)
   in let jmp-end-pos = st3.text-len
   in let st4 = st-append-text st3 (jmp 0)
   in let st5 = patch-jcc-at st4 je-false-pos (st4.text-len)
   in let else-result = emit-expr (st-set-tail-pos st5 saved-tail) else-e
   in let st6 = store-local (else-result.state) (result-loc.reg) (else-result.reg)
   in let st7 = patch-jmp-at st6 jmp-end-pos (st6.text-len)
   in load-local st7 (result-loc.reg)

Section: Call Emission
  emit-call-to : CodegenState -> Text -> CodegenState
  emit-call-to (st) (target) =
   let patch-pos = st.text-len
   in let st1 = st-append-text st (x86-call 0)
   in record-set st1 "call-patches" (list-snoc (st1.call-patches) (CallPatch {
     patch-offset = patch-pos,
     target = target
    }))


