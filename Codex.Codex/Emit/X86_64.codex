Chapter: X86-64 Code Generator

 Bare-metal x86-64 code generator for the Second Bootstrap Phase 3.
 Takes an IRModule and produces a bootable ELF binary as List Integer.
 Uses the instruction encoder from X86_64Encoder.codex and the ELF
 builder from ElfWriter.codex. All codegen state is threaded through
 functions as an immutable record.

 M3.1 scope: a program whose main returns an integer literal compiles
 to a bare-metal ELF that boots in QEMU and prints the value to serial.

Section: Record Types

  FuncOffset = record {
   name : Text,
   offset : Integer
  }

  CallPatch = record {
   patch-offset : Integer,
   target : Text
  }

  LocalBinding = record {
   name : Text,
   slot : Integer
  }

  FuncAddrFixup = record {
   patch-offset : Integer,
   target : Text
  }

  TcoState = record {
   active : Boolean,
   in-tail-pos : Boolean,
   loop-top : Integer,
   param-locals : List Integer,
   temp-locals : List Integer,
   current-func : Text,
   saved-next-local : Integer,
   saved-next-temp : Integer
  }

  CodegenState = record {
   text : List Integer,
   rodata : List Integer,
   func-offsets : List FuncOffset,
   call-patches : List CallPatch,
   func-addr-fixups : List FuncAddrFixup,
   locals : List LocalBinding,
   next-temp : Integer,
   next-local : Integer,
   spill-count : Integer,
   load-local-toggle : Integer,
   tco : TcoState
  }

  EmitResult = record {
   state : CodegenState,
   reg : Integer
  }

  TrampolineResult = record {
   bytes : List Integer,
   far-jump-patch-pos : Integer
  }

  FlatApply = record {
   func-name : Text,
   args : List IRExpr
  }

  SavedArgs = record {
   state : CodegenState,
   locals : List Integer
  }

  FieldLocal = record {
   name : Text,
   slot : Integer
  }

  EvalFieldsResult = record {
   state : CodegenState,
   field-locals : List FieldLocal
  }

  MatchBranchState = record {
   cg-state : CodegenState,
   end-patches : List Integer
  }

Section: Constants

  default-tco-state : TcoState
  default-tco-state =
   TcoState {
    active = False,
    in-tail-pos = False,
    loop-top = 0,
    param-locals = [],
    temp-locals = [],
    current-func = "",
    saved-next-local = 0,
    saved-next-temp = 0
   }

  temp-regs : List Integer
  temp-regs = [0, 1, 2, 6, 7, 11]

  local-regs : List Integer
  local-regs = [3, 12, 13, 14]

  spill-base : Integer
  spill-base = 32

  bare-metal-load-addr : Integer
  bare-metal-load-addr = 1048576

  bare-metal-stack-top : Integer
  bare-metal-stack-top = 67108864

Section: State Helpers

  empty-codegen-state : CodegenState
  empty-codegen-state =
   CodegenState {
    text = [],
    rodata = [],
    func-offsets = [],
    call-patches = [],
    func-addr-fixups = [],
    locals = [],
    next-temp = 0,
    next-local = 0,
    spill-count = 0,
    load-local-toggle = 0,
    tco = default-tco-state
   }

  st-append-text : CodegenState -> List Integer -> CodegenState
  st-append-text (st) (bytes) =
   CodegenState {
    text = st.text ++ bytes,
    rodata = (st.rodata),
    func-offsets = (st.func-offsets),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = (st.locals),
    next-temp = (st.next-temp),
    next-local = (st.next-local),
    spill-count = (st.spill-count),
    load-local-toggle = (st.load-local-toggle),
    tco = (st.tco)
   }

  st-with-text : CodegenState -> List Integer -> CodegenState
  st-with-text (st) (new-text) =
   CodegenState {
    text = new-text,
    rodata = (st.rodata),
    func-offsets = (st.func-offsets),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = (st.locals),
    next-temp = (st.next-temp),
    next-local = (st.next-local),
    spill-count = (st.spill-count),
    load-local-toggle = (st.load-local-toggle),
    tco = (st.tco)
   }

  record-func-offset : CodegenState -> Text -> CodegenState
  record-func-offset (st) (name) =
   CodegenState {
    text = (st.text),
    rodata = (st.rodata),
    func-offsets = list-snoc (st.func-offsets) (FuncOffset { name = name, offset = list-length (st.text) }),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = (st.locals),
    next-temp = (st.next-temp),
    next-local = (st.next-local),
    spill-count = (st.spill-count),
    load-local-toggle = (st.load-local-toggle),
    tco = (st.tco)
   }

  lookup-func-offset : List FuncOffset -> Text -> Integer
  lookup-func-offset (entries) (name) =
   lookup-func-offset-loop entries name 0 (list-length entries)

  lookup-func-offset-loop : List FuncOffset -> Text -> Integer -> Integer -> Integer
  lookup-func-offset-loop (entries) (name) (i) (len) =
   if i == len then 0
   else let e = list-at entries i
   in if e.name == name then e.offset
      else lookup-func-offset-loop entries name (i + 1) len

  reset-func-state : CodegenState -> Text -> CodegenState
  reset-func-state (st) (name) =
   CodegenState {
    text = (st.text),
    rodata = (st.rodata),
    func-offsets = list-snoc (st.func-offsets) (FuncOffset { name = name, offset = list-length (st.text) }),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = [],
    next-temp = 0,
    next-local = 0,
    spill-count = 0,
    load-local-toggle = 0,
    tco = default-tco-state
   }

Section: Register Allocation

 The temp pool recycles RAX, RCX, RDX, RSI, RDI, R11 in round-robin
 order. The local pool assigns RBX, R12, R13, R14 monotonically, then
 spills to the stack at offsets below RBP. R8 and R9 alternate as
 scratch registers for loading spilled locals. RSP, RBP, R10, and R15
 are reserved for the frame pointer, heap, and result space.

  alloc-temp : CodegenState -> EmitResult
  alloc-temp (st) =
   let idx = int-mod (st.next-temp) 6
   in let reg = list-at temp-regs idx
   in EmitResult {
    state = CodegenState {
     text = (st.text),
     rodata = (st.rodata),
     func-offsets = (st.func-offsets),
     call-patches = (st.call-patches),
     func-addr-fixups = (st.func-addr-fixups),
     locals = (st.locals),
     next-temp = st.next-temp + 1,
     next-local = (st.next-local),
     spill-count = (st.spill-count),
     load-local-toggle = (st.load-local-toggle),
     tco = (st.tco)
    },
    reg = reg
   }

  alloc-local : CodegenState -> EmitResult
  alloc-local (st) =
   if st.next-local < 4 then let reg = list-at local-regs (st.next-local)
   in EmitResult {
     state = CodegenState {
      text = (st.text),
      rodata = (st.rodata),
      func-offsets = (st.func-offsets),
      call-patches = (st.call-patches),
      func-addr-fixups = (st.func-addr-fixups),
      locals = (st.locals),
      next-temp = (st.next-temp),
      next-local = st.next-local + 1,
      spill-count = (st.spill-count),
      load-local-toggle = (st.load-local-toggle),
      tco = (st.tco)
     },
     reg = reg
    }
   else let slot = spill-base + st.spill-count
   in EmitResult {
     state = CodegenState {
      text = (st.text),
      rodata = (st.rodata),
      func-offsets = (st.func-offsets),
      call-patches = (st.call-patches),
      func-addr-fixups = (st.func-addr-fixups),
      locals = (st.locals),
      next-temp = (st.next-temp),
      next-local = st.next-local + 1,
      spill-count = st.spill-count + 1,
      load-local-toggle = (st.load-local-toggle),
      tco = (st.tco)
     },
     reg = slot
    }

  store-local : CodegenState -> Integer -> Integer -> CodegenState
  store-local (st) (local) (value-reg) =
   if local < spill-base then if local == value-reg then st
   else st-append-text st (mov-rr local value-reg)
   else let offset = 0 - ((local - spill-base + 1) * 8 + 32)
   in st-append-text st (mov-store reg-rbp value-reg offset)

  load-local : CodegenState -> Integer -> EmitResult
  load-local (st) (local) =
   if local < spill-base then EmitResult { state = st, reg = local }
   else let scratch = if int-mod (st.load-local-toggle) 2 == 0 then reg-r8 else reg-r9
   in let offset = 0 - ((local - spill-base + 1) * 8 + 32)
   in EmitResult {
     state = CodegenState {
      text = st.text ++ mov-load scratch reg-rbp offset,
      rodata = (st.rodata),
      func-offsets = (st.func-offsets),
      call-patches = (st.call-patches),
      func-addr-fixups = (st.func-addr-fixups),
      locals = (st.locals),
      next-temp = (st.next-temp),
      next-local = (st.next-local),
      spill-count = (st.spill-count),
      load-local-toggle = st.load-local-toggle + 1,
      tco = (st.tco)
     },
     reg = scratch
    }

Section: Byte Patching

 Replaces four bytes at a given offset in a list with the little-endian
 encoding of an integer value. This is O(n) per patch but only called
 once per function for frame size and once per call site.

  patch-i32-at : List Integer -> Integer -> Integer -> List Integer
  patch-i32-at (bytes) (pos) (value) =
   let new-bytes = write-i32 value
   in patch-4-loop bytes pos new-bytes 0 (list-length bytes) []

  patch-4-loop : List Integer -> Integer -> List Integer -> Integer -> Integer -> List Integer -> List Integer
  patch-4-loop (bytes) (pos) (new-bytes) (i) (len) (acc) =
   if i == len then acc
   else if i >= pos & i < pos + 4 then patch-4-loop bytes pos new-bytes (i + 1) len (list-snoc acc (list-at new-bytes (i - pos)))
   else patch-4-loop bytes pos new-bytes (i + 1) len (list-snoc acc (list-at bytes i))

  patch-jcc-at : CodegenState -> Integer -> Integer -> CodegenState
  patch-jcc-at (st) (jcc-pos) (target-pos) =
   let rel32 = target-pos - (jcc-pos + 6)
   in st-with-text st (patch-i32-at (st.text) (jcc-pos + 2) rel32)

  patch-jmp-at : CodegenState -> Integer -> Integer -> CodegenState
  patch-jmp-at (st) (jmp-pos) (target-pos) =
   let rel32 = target-pos - (jmp-pos + 5)
   in st-with-text st (patch-i32-at (st.text) (jmp-pos + 1) rel32)

  patch-call-at : CodegenState -> Integer -> Integer -> CodegenState
  patch-call-at (st) (call-pos) (target-pos) =
   let rel32 = target-pos - (call-pos + 5)
   in st-with-text st (patch-i32-at (st.text) (call-pos + 1) rel32)

  PatchEntry = record {
   pos : Integer,
   b0 : Integer,
   b1 : Integer,
   b2 : Integer,
   b3 : Integer
  }

  make-i32-patch : Integer -> Integer -> PatchEntry
  make-i32-patch (pos) (value) =
   let bs = write-i32 value
   in PatchEntry { pos = pos, b0 = list-at bs 0, b1 = list-at bs 1, b2 = list-at bs 2, b3 = list-at bs 3 }

  apply-all-patches : List Integer -> List PatchEntry -> List Integer
  apply-all-patches (bytes) (patches) =
   apply-patch-walk bytes patches 0 (list-length bytes) []

  apply-patch-walk : List Integer -> List PatchEntry -> Integer -> Integer -> List Integer -> List Integer
  apply-patch-walk (bytes) (patches) (i) (len) (acc) =
   if i == len then acc
   else let b = find-patch-byte patches i 0 (list-length patches)
   in if b >= 0 then apply-patch-walk bytes patches (i + 1) len (list-snoc acc b)
      else apply-patch-walk bytes patches (i + 1) len (list-snoc acc (list-at bytes i))

  find-patch-byte : List PatchEntry -> Integer -> Integer -> Integer -> Integer
  find-patch-byte (patches) (i) (j) (len) =
   if j == len then 0 - 1
   else let p = list-at patches j
   in if i == p.pos then p.b0
      else if i == p.pos + 1 then p.b1
      else if i == p.pos + 2 then p.b2
      else if i == p.pos + 3 then p.b3
      else find-patch-byte patches i (j + 1) len

  collect-call-patches : List CallPatch -> List FuncOffset -> Integer -> List PatchEntry -> List PatchEntry
  collect-call-patches (patches) (offsets) (i) (acc) =
   if i == list-length patches then acc
   else let p = list-at patches i
   in let target-offset = lookup-func-offset offsets (p.target)
   in let rel32 = target-offset - (p.patch-offset + 5)
   in collect-call-patches patches offsets (i + 1) (list-snoc acc (make-i32-patch (p.patch-offset + 1) rel32))

  patch-calls : CodegenState -> CodegenState
  patch-calls (st) =
   let entries = collect-call-patches (st.call-patches) (st.func-offsets) 0 []
   in st-with-text st (apply-all-patches (st.text) entries)

  align-16 : Integer -> Integer
  align-16 (n) =
   let r = int-mod n 16
   in if r == 0 then n else n + 16 - r

Section: Function Emission

  emit-sub-rsp-imm32 : Integer -> List Integer
  emit-sub-rsp-imm32 (imm) =
   [72, 129, 236] ++ write-i32 imm

  emit-prologue : CodegenState -> CodegenState
  emit-prologue (st) =
   st-append-text st (push-r reg-rbp ++ mov-rr reg-rbp reg-rsp ++ push-r reg-rbx ++ push-r reg-r12 ++ push-r reg-r13 ++ push-r reg-r14)

  emit-epilogue : CodegenState -> CodegenState
  emit-epilogue (st) =
   st-append-text st (lea reg-rsp reg-rbp (0 - 32) ++ pop-r reg-r14 ++ pop-r reg-r13 ++ pop-r reg-r12 ++ pop-r reg-rbx ++ pop-r reg-rbp ++ x86-ret)

  bind-params : CodegenState -> List IRParam -> Integer -> CodegenState
  bind-params (st) (params) (i) =
   if i == list-length params then st
   else let p = list-at params i
   in let loc = alloc-local st
   in let st1 = if i < 6 then store-local (loc.state) (loc.reg) (list-at arg-regs i)
     else let stack-offset = 16 + (i - 6) * 8
      in let tmp = alloc-temp (loc.state)
      in store-local (st-append-text (tmp.state) (mov-load (tmp.reg) reg-rbp stack-offset)) (loc.reg) (tmp.reg)
   in bind-params (add-local st1 (p.name) (loc.reg)) params (i + 1)

  is-self-call : IRExpr -> Text -> Boolean
  is-self-call (expr) (func-name) =
   when expr
    if IrApply (f) (a) (t) -> is-self-call f func-name
    if IrName (n) (t) -> n == func-name
    if _ -> False

  has-tail-call : IRExpr -> Text -> Boolean
  has-tail-call (expr) (func-name) =
   when expr
    if IrIf (c) (th) (el) (t) -> has-tail-call th func-name | has-tail-call el func-name
    if IrLet (n) (t) (v) (b) -> has-tail-call b func-name
    if IrMatch (s) (bs) (t) -> has-tail-call-branches bs func-name 0
    if IrApply (f) (a) (t) -> is-self-call expr func-name
    if _ -> False

  has-tail-call-branches : List IRBranch -> Text -> Integer -> Boolean
  has-tail-call-branches (branches) (func-name) (i) =
   if i == list-length branches then False
   else let b = list-at branches i
   in if has-tail-call (b.body) func-name then True
      else has-tail-call-branches branches func-name (i + 1)

  should-tco : IRDef -> Boolean
  should-tco (def) =
   if list-length (def.params) > 0 then has-tail-call (def.body) (def.name)
   else False

  st-set-tail-pos : CodegenState -> Boolean -> CodegenState
  st-set-tail-pos (st) (v) =
   CodegenState {
    text = (st.text),
    rodata = (st.rodata),
    func-offsets = (st.func-offsets),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = (st.locals),
    next-temp = (st.next-temp),
    next-local = (st.next-local),
    spill-count = (st.spill-count),
    load-local-toggle = (st.load-local-toggle),
    tco = TcoState {
     active = st.tco.active,
     in-tail-pos = v,
     loop-top = st.tco.loop-top,
     param-locals = st.tco.param-locals,
     temp-locals = st.tco.temp-locals,
     current-func = st.tco.current-func,
     saved-next-local = st.tco.saved-next-local,
     saved-next-temp = st.tco.saved-next-temp
    }
   }

  TcoAllocResult = record {
   alloc-state : CodegenState,
   alloc-locals : List Integer
  }

  pre-alloc-tco-temps : CodegenState -> Integer -> Integer -> List Integer -> TcoAllocResult
  pre-alloc-tco-temps (st) (i) (count) (acc) =
   if i == count then TcoAllocResult { alloc-state = st, alloc-locals = acc }
   else let loc = alloc-local st
   in pre-alloc-tco-temps (loc.state) (i + 1) count (list-snoc acc (loc.reg))

  collect-param-locals : List LocalBinding -> List IRParam -> Integer -> List Integer -> List Integer
  collect-param-locals (bindings) (params) (i) (acc) =
   if i == list-length params then acc
   else let p = list-at params i
   in let slot = lookup-local bindings (p.name)
   in collect-param-locals bindings params (i + 1) (list-snoc acc slot)

  emit-function : CodegenState -> IRDef -> CodegenState
  emit-function (st) (def) =
   let st1 = reset-func-state st (def.name)
   in let st2 = emit-prologue st1
   in let frame-patch-pos = list-length (st2.text)
   in let st3 = st-append-text st2 (emit-sub-rsp-imm32 0)
   in let st4 = bind-params st3 (def.params) 0
   in let is-tco = should-tco def
   in let st5 = if is-tco then let tco-alloc = pre-alloc-tco-temps st4 0 (list-length (def.params)) []
     in let st-a = tco-alloc.alloc-state
     in let p-locals = collect-param-locals (st-a.locals) (def.params) 0 []
     in CodegenState {
      text = (st-a.text),
      rodata = (st-a.rodata),
      func-offsets = (st-a.func-offsets),
      call-patches = (st-a.call-patches),
      func-addr-fixups = (st-a.func-addr-fixups),
      locals = (st-a.locals),
      next-temp = (st-a.next-temp),
      next-local = (st-a.next-local),
      spill-count = (st-a.spill-count),
      load-local-toggle = (st-a.load-local-toggle),
      tco = TcoState {
       active = True,
       in-tail-pos = True,
       loop-top = list-length (st-a.text),
       param-locals = p-locals,
       temp-locals = (tco-alloc.alloc-locals),
       current-func = (def.name),
       saved-next-local = (st-a.next-local),
       saved-next-temp = (st-a.next-temp)
      }
     }
    else st4
   in let result = emit-expr st5 (def.body)
   in let st6 = if (result.reg) == reg-rax then result.state
    else st-append-text (result.state) (mov-rr reg-rax (result.reg))
   in let st7 = emit-epilogue st6
   in let frame-size = align-16 ((st7.spill-count) * 8)
   in st-with-text st7 (patch-i32-at (st7.text) (frame-patch-pos + 3) frame-size)

  emit-all-defs : CodegenState -> List IRDef -> Integer -> CodegenState
  emit-all-defs (st) (defs) (i) =
   if i == list-length defs then st
   else emit-all-defs (emit-function st (list-at defs i)) defs (i + 1)

Section: Local Variable Management

  lookup-local : List LocalBinding -> Text -> Integer
  lookup-local (bindings) (name) =
   lookup-local-loop bindings name 0 (list-length bindings)

  lookup-local-loop : List LocalBinding -> Text -> Integer -> Integer -> Integer
  lookup-local-loop (bindings) (name) (i) (len) =
   if i == len then 0 - 1
   else let b = list-at bindings i
   in if b.name == name then b.slot
      else lookup-local-loop bindings name (i + 1) len

  add-local : CodegenState -> Text -> Integer -> CodegenState
  add-local (st) (name) (slot) =
   CodegenState {
    text = (st.text),
    rodata = (st.rodata),
    func-offsets = (st.func-offsets),
    call-patches = (st.call-patches),
    func-addr-fixups = (st.func-addr-fixups),
    locals = list-snoc (st.locals) (LocalBinding { name = name, slot = slot }),
    next-temp = (st.next-temp),
    next-local = (st.next-local),
    spill-count = (st.spill-count),
    load-local-toggle = (st.load-local-toggle),
    tco = (st.tco)
   }

Section: Expression Emission

  emit-expr : CodegenState -> IRExpr -> EmitResult
  emit-expr (st) (expr) =
   when expr
    if IrIntLit (value) -> emit-int-lit st value
    if IrBoolLit (value) -> emit-int-lit st (if value then 1 else 0)
    if IrName (name) (ty) -> emit-name st name ty
    if IrLet (name) (ty) (value) (body) -> emit-let st name value body
    if IrBinary (op) (left) (right) (ty) -> emit-binary st op left right
    if IrIf (cond) (then-e) (else-e) (ty) -> emit-if st cond then-e else-e
    if IrApply (func) (arg) (ty) -> emit-apply st func arg ty
    if IrRecord (rname) (fields) (ty) -> emit-record st fields ty
    if IrFieldAccess (rec) (field) (ty) -> emit-field-access st rec field
    if IrMatch (scrut) (branches) (ty) -> emit-match st scrut branches
    if IrList (elems) (ty) -> emit-list st elems
    if _ -> EmitResult { state = st, reg = reg-rax }

  emit-int-lit : CodegenState -> Integer -> EmitResult
  emit-int-lit (st) (value) =
   let tmp = alloc-temp st
   in EmitResult {
    state = st-append-text (tmp.state) (li (tmp.reg) value),
    reg = (tmp.reg)
   }

  find-ctor-tag : List SumCtor -> Text -> Integer -> Integer
  find-ctor-tag (ctors) (name) (i) =
   if i == list-length ctors then 0 - 1
   else let c = list-at ctors i
   in if c.name.value == name then i
      else find-ctor-tag ctors name (i + 1)

  emit-name : CodegenState -> Text -> CodexType -> EmitResult
  emit-name (st) (name) (ty) =
   let slot = lookup-local (st.locals) name
   in if slot >= 0 then load-local st slot
      else emit-name-nonlocal st name ty

  emit-name-nonlocal : CodegenState -> Text -> CodexType -> EmitResult
  emit-name-nonlocal (st) (name) (ty) =
   when ty
    if SumTy (sname) (ctors) ->
     let tag = find-ctor-tag ctors name 0
     in if tag >= 0 then emit-nullary-ctor st tag
        else emit-name-as-call st name
    if FunTy (pt) (rt) -> emit-partial-application st name []
    if _ -> emit-name-as-call st name

  emit-nullary-ctor : CodegenState -> Integer -> EmitResult
  emit-nullary-ctor (st) (tag) =
   let ptr-loc = alloc-local st
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let tag-tmp = alloc-temp st3
   in let st4 = st-append-text (tag-tmp.state) (li (tag-tmp.reg) tag)
   in let ptr-load = load-local st4 (ptr-loc.reg)
   in let st5 = st-append-text (ptr-load.state) (mov-store (ptr-load.reg) (tag-tmp.reg) 0)
   in load-local st5 (ptr-loc.reg)

  emit-name-as-call : CodegenState -> Text -> EmitResult
  emit-name-as-call (st) (name) =
   let st1 = emit-call-to st name
   in let tmp = alloc-temp st1
   in EmitResult {
    state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
    reg = (tmp.reg)
   }

  emit-let : CodegenState -> Text -> IRExpr -> IRExpr -> EmitResult
  emit-let (st) (name) (value) (body) =
   let saved-tail = st.tco.in-tail-pos
   in let val-result = emit-expr (st-set-tail-pos st False) value
   in let loc = alloc-local (val-result.state)
   in let st1 = store-local (loc.state) (loc.reg) (val-result.reg)
   in let st2 = add-local st1 name (loc.reg)
   in emit-expr (st-set-tail-pos st2 saved-tail) body

  emit-binary : CodegenState -> IRBinaryOp -> IRExpr -> IRExpr -> EmitResult
  emit-binary (st) (op) (left) (right) =
   let l = emit-expr st left
   in let l-loc = alloc-local (l.state)
   in let st1 = store-local (l-loc.state) (l-loc.reg) (l.reg)
   in let r = emit-expr st1 right
   in let r-loc = alloc-local (r.state)
   in let st2 = store-local (r-loc.state) (r-loc.reg) (r.reg)
   in let l-load = load-local st2 (l-loc.reg)
   in let r-load = load-local (l-load.state) (r-loc.reg)
   in emit-binary-op (r-load.state) op (l-load.reg) (r-load.reg)

  emit-binary-op : CodegenState -> IRBinaryOp -> Integer -> Integer -> EmitResult
  emit-binary-op (st) (op) (l-reg) (r-reg) =
   let rd = alloc-temp st
   in when op
    if IrAddInt -> EmitResult { state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ add-rr (rd.reg) r-reg), reg = (rd.reg) }
    if IrSubInt -> EmitResult { state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ sub-rr (rd.reg) r-reg), reg = (rd.reg) }
    if IrMulInt -> EmitResult { state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ imul-rr (rd.reg) r-reg), reg = (rd.reg) }
    if IrDivInt -> EmitResult { state = st-append-text (rd.state) (mov-rr reg-rax l-reg ++ cqo ++ idiv-r r-reg ++ mov-rr (rd.reg) reg-rax), reg = (rd.reg) }
    if IrEq -> emit-comparison st cc-e l-reg r-reg
    if IrNotEq -> emit-comparison st cc-ne l-reg r-reg
    if IrLt -> emit-comparison st cc-l l-reg r-reg
    if IrGt -> emit-comparison st cc-g l-reg r-reg
    if IrLtEq -> emit-comparison st cc-le l-reg r-reg
    if IrGtEq -> emit-comparison st cc-ge l-reg r-reg
    if IrAnd -> EmitResult { state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ and-rr (rd.reg) r-reg), reg = (rd.reg) }
    if IrOr -> EmitResult { state = st-append-text (rd.state) (mov-rr (rd.reg) l-reg ++ add-rr (rd.reg) r-reg), reg = (rd.reg) }
    if _ -> EmitResult { state = st, reg = reg-rax }

  emit-comparison : CodegenState -> Integer -> Integer -> Integer -> EmitResult
  emit-comparison (st) (cc) (l-reg) (r-reg) =
   let rd = alloc-temp st
   in EmitResult {
    state = st-append-text (rd.state) (cmp-rr l-reg r-reg ++ setcc cc (rd.reg) ++ movzx-byte-self (rd.reg)),
    reg = (rd.reg)
   }

  emit-if : CodegenState -> IRExpr -> IRExpr -> IRExpr -> EmitResult
  emit-if (st) (cond) (then-e) (else-e) =
   let saved-tail = st.tco.in-tail-pos
   in let cond-result = emit-expr (st-set-tail-pos st False) cond
   in let st1 = st-append-text (cond-result.state) (test-rr (cond-result.reg) (cond-result.reg))
   in let je-false-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let then-result = emit-expr (st-set-tail-pos st2 saved-tail) then-e
   in let result-loc = alloc-local (then-result.state)
   in let st3 = store-local (result-loc.state) (result-loc.reg) (then-result.reg)
   in let jmp-end-pos = list-length (st3.text)
   in let st4 = st-append-text st3 (jmp 0)
   in let st5 = patch-jcc-at st4 je-false-pos (list-length (st4.text))
   in let else-result = emit-expr (st-set-tail-pos st5 saved-tail) else-e
   in let st6 = store-local (else-result.state) (result-loc.reg) (else-result.reg)
   in let st7 = patch-jmp-at st6 jmp-end-pos (list-length (st6.text))
   in load-local st7 (result-loc.reg)

Section: Builtin Detection

  is-string-builtin : Text -> Boolean
  is-string-builtin (name) =
    if name == "text-length" then True
    else if name == "integer-to-text" then True
    else if name == "show" then True
    else if name == "text-to-integer" then True
    else if name == "text-replace" then True
    else if name == "text-contains" then True
    else if name == "text-starts-with" then True
    else if name == "text-compare" then True
    else if name == "text-concat-list" then True
    else if name == "text-split" then True
    else if name == "substring" then True
    else False

  is-list-builtin : Text -> Boolean
  is-list-builtin (name) =
    if name == "list-length" then True
    else if name == "list-at" then True
    else if name == "list-cons" then True
    else if name == "list-append" then True
    else if name == "list-snoc" then True
    else if name == "list-insert-at" then True
    else if name == "list-contains" then True
    else False

  is-char-builtin : Text -> Boolean
  is-char-builtin (name) =
    if name == "char-at" then True
    else if name == "char-code-at" then True
    else if name == "char-code" then True
    else if name == "code-to-char" then True
    else if name == "char-to-text" then True
    else if name == "is-letter" then True
    else if name == "is-digit" then True
    else if name == "is-whitespace" then True
    else False

  is-misc-builtin : Text -> Boolean
  is-misc-builtin (name) =
    if name == "negate" then True
    else if name == "get-args" then True
    else if name == "current-dir" then True
    else if name == "file-exists" then True
    else False

  is-builtin : Text -> Boolean
  is-builtin (name) =
    if is-string-builtin name then True
    else if is-list-builtin name then True
    else if is-char-builtin name then True
    else is-misc-builtin name

Section: Builtin Emission

 Wires Codex operations to inline sequences or runtime helper calls.
 All builtins here operate on CCE natively. I/O boundary builtins
 (print-line, read-file, write-file) are deferred to Phase 7.

  emit-helper-call-1 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-1 (st) (args) (helper) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (mov-rr reg-rdi (r.reg))
   in let st2 = emit-call-to st1 helper
   in let tmp = alloc-temp st2
   in EmitResult { state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax), reg = (tmp.reg) }

  emit-helper-call-2 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-2 (st) (args) (helper) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loaded = load-local (r1.state) (loc.reg)
   in let st2 = st-append-text (loaded.state) (mov-rr reg-rsi (r1.reg))
   in let st3 = st-append-text st2 (mov-rr reg-rdi (loaded.reg))
   in let st4 = emit-call-to st3 helper
   in let tmp = alloc-temp st4
   in EmitResult { state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax), reg = (tmp.reg) }

  emit-helper-call-3 : CodegenState -> List IRExpr -> Text -> EmitResult
  emit-helper-call-3 (st) (args) (helper) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loc1 = alloc-local (r1.state)
   in let st2 = store-local (loc1.state) (loc1.reg) (r1.reg)
   in let r2 = emit-expr st2 (list-at args 2)
   in let st3 = st-append-text (r2.state) (mov-rr reg-rdx (r2.reg))
   in let ld1 = load-local st3 (loc1.reg)
   in let st4 = st-append-text (ld1.state) (mov-rr reg-rsi (ld1.reg))
   in let ld0 = load-local st4 (loc0.reg)
   in let st5 = st-append-text (ld0.state) (mov-rr reg-rdi (ld0.reg))
   in let st6 = emit-call-to st5 helper
   in let tmp = alloc-temp st6
   in EmitResult { state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax), reg = (tmp.reg) }

  emit-text-length-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-text-length-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let tmp = alloc-temp (r.state)
   in EmitResult { state = st-append-text (tmp.state) (mov-load (tmp.reg) (r.reg) 0), reg = (tmp.reg) }

  emit-list-length-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-list-length-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let tmp = alloc-temp (r.state)
   in EmitResult { state = st-append-text (tmp.state) (mov-load (tmp.reg) (r.reg) 0), reg = (tmp.reg) }

  emit-list-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-list-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let list-loaded = load-local (r1.state) (loc.reg)
   in let addr = alloc-temp (list-loaded.state)
   in let st2 = st-append-text (addr.state) (mov-rr (addr.reg) (r1.reg))
   in let st3 = st-append-text st2 (shl-ri (addr.reg) 3)
   in let st4 = st-append-text st3 (add-rr (addr.reg) (list-loaded.reg))
   in let rd = alloc-temp st4
   in EmitResult { state = st-append-text (rd.state) (mov-load (rd.reg) (addr.reg) 8), reg = (rd.reg) }

  emit-char-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let str-loaded = load-local (r1.state) (loc.reg)
   in let st2 = st-append-text (str-loaded.state) (add-rr (r1.reg) (str-loaded.reg))
   in let st3 = st-append-text st2 (movzx-byte (r1.reg) (r1.reg) 8)
   in EmitResult { state = st3, reg = (r1.reg) }

  emit-char-code-at-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-code-at-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r0.state)
   in let st1 = store-local (loc.state) (loc.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let text-loaded = load-local (r1.state) (loc.reg)
   in let rd = alloc-temp (text-loaded.state)
   in let st2 = st-append-text (rd.state) (mov-rr (rd.reg) (text-loaded.reg))
   in let st3 = st-append-text st2 (add-rr (rd.reg) (r1.reg))
   in let st4 = st-append-text st3 (movzx-byte (rd.reg) (rd.reg) 8)
   in EmitResult { state = st4, reg = (rd.reg) }

  emit-char-to-text-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-char-to-text-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in let ptr-loc = alloc-local st1
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st2 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st3 = store-local st2 (ptr-loc.reg) (ptr-tmp.reg)
   in let st4 = st-append-text st3 (add-ri reg-r10 16)
   in let st5 = st-append-text st4 (li reg-r11 1)
   in let ptr-loaded = load-local st5 (ptr-loc.reg)
   in let st6 = st-append-text (ptr-loaded.state) (mov-store (ptr-loaded.reg) reg-r11 0)
   in let code-loaded = load-local st6 (loc.reg)
   in let ptr-loaded2 = load-local (code-loaded.state) (ptr-loc.reg)
   in let st7 = st-append-text (ptr-loaded2.state) (mov-store-byte (ptr-loaded2.reg) (code-loaded.reg) 8)
   in let result = load-local st7 (ptr-loc.reg)
   in EmitResult { state = (result.state), reg = (result.reg) }

  emit-is-letter-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-letter-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (sub-ri (r.reg) 13)
   in let st2 = st-append-text st1 (cmp-ri (r.reg) 51)
   in let st3 = st-append-text st2 (setcc cc-be (r.reg))
   in let st4 = st-append-text st3 (movzx-byte-self (r.reg))
   in EmitResult { state = st4, reg = (r.reg) }

  emit-is-digit-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-digit-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (sub-ri (r.reg) 3)
   in let st2 = st-append-text st1 (cmp-ri (r.reg) 9)
   in let st3 = st-append-text st2 (setcc cc-be (r.reg))
   in let st4 = st-append-text st3 (movzx-byte-self (r.reg))
   in EmitResult { state = st4, reg = (r.reg) }

  emit-is-whitespace-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-is-whitespace-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let st1 = st-append-text (r.state) (cmp-ri (r.reg) 2)
   in let st2 = st-append-text st1 (setcc cc-be (r.reg))
   in let st3 = st-append-text st2 (movzx-byte-self (r.reg))
   in EmitResult { state = st3, reg = (r.reg) }

  emit-negate-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-negate-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r.state)
   in let st1 = st-append-text (rd.state) (mov-rr (rd.reg) (r.reg))
   in let st2 = st-append-text st1 (neg-r (rd.reg))
   in EmitResult { state = st2, reg = (rd.reg) }

  emit-get-args-builtin : CodegenState -> EmitResult
  emit-get-args-builtin (st) =
    let rd = alloc-temp st
   in let st1 = st-append-text (rd.state) (li reg-r11 0)
   in let st2 = st-append-text st1 (mov-store reg-r10 reg-r11 0)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let st4 = st-append-text st3 (mov-rr (rd.reg) reg-r10)
   in let st5 = st-append-text st4 (mov-store reg-r10 reg-r11 0)
   in let st6 = st-append-text st5 (add-ri reg-r10 8)
   in EmitResult { state = st6, reg = (rd.reg) }

  emit-current-dir-builtin : CodegenState -> EmitResult
  emit-current-dir-builtin (st) =
    let rd = alloc-temp st
   in let st1 = st-append-text (rd.state) (mov-rr (rd.reg) reg-r10)
   in let st2 = st-append-text st1 (li reg-r11 0)
   in let st3 = st-append-text st2 (mov-store reg-r10 reg-r11 0)
   in let st4 = st-append-text st3 (add-ri reg-r10 8)
   in EmitResult { state = st4, reg = (rd.reg) }

  emit-file-exists-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-file-exists-builtin (st) (args) =
    let r = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let rd = alloc-temp (r.state)
   in let st1 = st-append-text (rd.state) (li (rd.reg) 1)
   in EmitResult { state = st1, reg = (rd.reg) }

  emit-substring-alloc : CodegenState -> Integer -> Integer -> Integer -> CodegenState
  emit-substring-alloc (st) (str-loc) (start-loc) (len-loc) =
    let len-loaded = load-local st len-loc
   in let st0 = st-append-text (len-loaded.state) (mov-rr reg-r11 (len-loaded.reg))
   in let st1 = st-append-text st0 (add-ri reg-r11 15)
   in let st2 = st-append-text st1 (and-ri reg-r11 (0 - 8))
   in st-append-text st2 (add-rr reg-r10 reg-r11)

  emit-substring-copy : CodegenState -> Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-substring-copy (st) (str-loc) (start-loc) (len-loc) (ptr-loc) =
    let st0 = st-append-text st (li reg-r11 0)
   in let sub-loop = list-length (st0.text)
   in let len-ld = load-local st0 len-loc
   in let st1 = st-append-text (len-ld.state) (cmp-rr reg-r11 (len-ld.reg))
   in let sub-exit-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let src-ld = load-local st2 str-loc
   in let start-ld = load-local (src-ld.state) start-loc
   in let st3 = st-append-text (start-ld.state) (mov-rr reg-rsi (src-ld.reg))
   in let st4 = st-append-text st3 (add-rr reg-rsi (start-ld.reg))
   in let st5 = st-append-text st4 (add-rr reg-rsi reg-r11)
   in let st6 = st-append-text st5 (movzx-byte reg-rsi reg-rsi 8)
   in let ptr-ld = load-local st6 ptr-loc
   in let st7 = st-append-text (ptr-ld.state) (mov-rr reg-rdx (ptr-ld.reg))
   in let st8 = st-append-text st7 (add-rr reg-rdx reg-r11)
   in let st9 = st-append-text st8 (mov-store-byte reg-rdx reg-rsi 8)
   in let st10 = st-append-text st9 (add-ri reg-r11 1)
   in let st11 = st-append-text st10 (jmp (sub-loop - (list-length (st10.text) + 5)))
   in patch-jcc-at st11 sub-exit-pos (list-length (st11.text))

  emit-substring-builtin : CodegenState -> List IRExpr -> EmitResult
  emit-substring-builtin (st) (args) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let loc1 = alloc-local (r1.state)
   in let st2 = store-local (loc1.state) (loc1.reg) (r1.reg)
   in let r2 = emit-expr st2 (list-at args 2)
   in let loc2 = alloc-local (r2.state)
   in let st3 = store-local (loc2.state) (loc2.reg) (r2.reg)
   in let ptr-loc = alloc-local st3
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st4 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st5 = store-local st4 (ptr-loc.reg) (ptr-tmp.reg)
   in let len-ld = load-local st5 (loc2.reg)
   in let ptr-ld = load-local (len-ld.state) (ptr-loc.reg)
   in let st6 = st-append-text (ptr-ld.state) (mov-store (ptr-ld.reg) (len-ld.reg) 0)
   in let st7 = emit-substring-alloc st6 (loc0.reg) (loc1.reg) (loc2.reg)
   in let st8 = emit-substring-copy st7 (loc0.reg) (loc1.reg) (loc2.reg) (ptr-loc.reg)
   in let result = load-local st8 (ptr-loc.reg)
   in EmitResult { state = (result.state), reg = (result.reg) }

  emit-builtin : CodegenState -> Text -> List IRExpr -> EmitResult
  emit-builtin (st) (name) (args) =
    if name == "text-length" then emit-text-length-builtin st args
    else if name == "integer-to-text" then emit-helper-call-1 st args "__itoa"
    else if name == "show" then emit-helper-call-1 st args "__itoa"
    else if name == "text-to-integer" then emit-helper-call-1 st args "__text_to_int"
    else if name == "text-replace" then emit-helper-call-3 st args "__str_replace"
    else if name == "text-contains" then emit-helper-call-2 st args "__text_contains"
    else if name == "text-starts-with" then emit-helper-call-2 st args "__text_starts_with"
    else if name == "text-compare" then emit-helper-call-2 st args "__text_compare"
    else if name == "text-concat-list" then emit-helper-call-1 st args "__text_concat_list"
    else if name == "text-split" then emit-helper-call-2 st args "__text_split"
    else if name == "substring" then emit-substring-builtin st args
    else if name == "list-length" then emit-list-length-builtin st args
    else if name == "list-at" then emit-list-at-builtin st args
    else if name == "list-cons" then emit-helper-call-2 st args "__list_cons"
    else if name == "list-append" then emit-helper-call-2 st args "__list_append"
    else if name == "list-snoc" then emit-helper-call-2 st args "__list_snoc"
    else if name == "list-insert-at" then emit-helper-call-3 st args "__list_insert_at"
    else if name == "list-contains" then emit-helper-call-2 st args "__list_contains"
    else if name == "char-at" then emit-char-at-builtin st args
    else if name == "char-code-at" then emit-char-code-at-builtin st args
    else if name == "char-code" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "code-to-char" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "char-to-text" then emit-char-to-text-builtin st args
    else if name == "is-letter" then emit-is-letter-builtin st args
    else if name == "is-digit" then emit-is-digit-builtin st args
    else if name == "is-whitespace" then emit-is-whitespace-builtin st args
    else if name == "negate" then emit-negate-builtin st args
    else if name == "get-args" then emit-get-args-builtin st
    else if name == "current-dir" then emit-current-dir-builtin st
    else emit-file-exists-builtin st args

Section: Function Application

 Flattens curried IrApply chains into a function name and argument list,
 evaluates arguments, loads them into argument registers via a two-phase
 push/pop sequence (to avoid R8/R9 spill conflicts), emits the call,
 and moves the result from RAX to a temp register.

  flatten-apply : IRExpr -> List IRExpr -> FlatApply
  flatten-apply (expr) (acc) =
   when expr
    if IrApply (f) (a) (t) -> flatten-apply f ([a] ++ acc)
    if IrName (n) (t) -> FlatApply { func-name = n, args = acc }
    if _ -> FlatApply { func-name = "", args = acc }

  save-args-loop : CodegenState -> List IRExpr -> Integer -> List Integer -> SavedArgs
  save-args-loop (st) (args) (i) (acc) =
   if i == list-length args then SavedArgs { state = st, locals = acc }
   else let r = emit-expr st (list-at args i)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in save-args-loop st1 args (i + 1) (list-snoc acc (loc.reg))

  push-reg-args : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  push-reg-args (st) (arg-locals) (i) (count) =
   if i == count then st
   else let loaded = load-local st (list-at arg-locals i)
   in push-reg-args (st-append-text (loaded.state) (push-r (loaded.reg))) arg-locals (i + 1) count

  pop-to-arg-regs : CodegenState -> Integer -> CodegenState
  pop-to-arg-regs (st) (i) =
   if i < 0 then st
   else pop-to-arg-regs (st-append-text st (pop-r (list-at arg-regs i))) (i - 1)

  push-stack-args : CodegenState -> List Integer -> Integer -> CodegenState
  push-stack-args (st) (arg-locals) (i) =
   if i < 6 then st
   else let loaded = load-local st (list-at arg-locals i)
   in push-stack-args (st-append-text (loaded.state) (push-r (loaded.reg))) arg-locals (i - 1)

  emit-apply : CodegenState -> IRExpr -> IRExpr -> CodexType -> EmitResult
  emit-apply (st) (func-expr) (arg-expr) (result-ty) =
   let full-expr = IrApply func-expr arg-expr result-ty
   in if (st.tco.active) & (st.tco.in-tail-pos) & is-self-call full-expr (st.tco.current-func) then emit-tail-call st func-expr arg-expr
      else let flat = flatten-apply func-expr [arg-expr]
      in if is-builtin (flat.func-name) then emit-builtin st (flat.func-name) (flat.args)
         else when result-ty
          if SumTy (sname) (ctors) ->
           let tag = find-ctor-tag ctors (flat.func-name) 0
           in if tag >= 0 then emit-sum-ctor st (flat.args) tag
              else emit-direct-call st flat
          if FunTy (pt) (rt) ->
           let is-local = lookup-local (st.locals) (flat.func-name) >= 0
           in if is-local then emit-indirect-call st flat
              else emit-partial-application st (flat.func-name) (flat.args)
          if _ ->
           let is-local = lookup-local (st.locals) (flat.func-name) >= 0
           in if is-local then emit-indirect-call st flat
              else emit-direct-call st flat

  emit-direct-call : CodegenState -> FlatApply -> EmitResult
  emit-direct-call (st) (flat) =
   let saved = save-args-loop (st-set-tail-pos st False) (flat.args) 0 []
   in let arg-count = list-length (flat.args)
   in let st1 = push-stack-args (saved.state) (saved.locals) (arg-count - 1)
   in let reg-count = if arg-count < 6 then arg-count else 6
   in let st2 = push-reg-args st1 (saved.locals) 0 reg-count
   in let st3 = pop-to-arg-regs st2 (reg-count - 1)
   in let st4 = emit-call-to st3 (flat.func-name)
   in let stack-arg-count = arg-count - 6
   in let st5 = if stack-arg-count > 0 then st-append-text st4 (add-ri reg-rsp (stack-arg-count * 8))
    else st4
   in let tmp = alloc-temp st5
   in EmitResult {
    state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
    reg = (tmp.reg)
   }

  emit-indirect-call : CodegenState -> FlatApply -> EmitResult
  emit-indirect-call (st) (flat) =
   let saved = save-args-loop (st-set-tail-pos st False) (flat.args) 0 []
   in let arg-count = list-length (flat.args)
   in let reg-count = if arg-count < 6 then arg-count else 6
   in let st1 = push-reg-args (saved.state) (saved.locals) 0 reg-count
   in let st2 = pop-to-arg-regs st1 (reg-count - 1)
   in let closure-load = load-local st2 (lookup-local (st2.locals) (flat.func-name))
   in let st3 = st-append-text (closure-load.state) (mov-rr reg-r11 (closure-load.reg))
   in let st4 = st-append-text st3 (mov-load reg-rax reg-r11 0)
   in let st5 = st-append-text st4 [255, 208]
   in let tmp = alloc-temp st5
   in EmitResult {
    state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
    reg = (tmp.reg)
   }

  flatten-tail-args : IRExpr -> List IRExpr -> List IRExpr
  flatten-tail-args (expr) (acc) =
   when expr
    if IrApply (f) (a) (t) -> flatten-tail-args f ([a] ++ acc)
    if _ -> acc

  eval-tail-args : CodegenState -> List IRExpr -> List Integer -> Integer -> CodegenState
  eval-tail-args (st) (args) (temp-locals) (i) =
   if i == list-length args then st
   else let st-notail = st-set-tail-pos st False
   in let r = emit-expr st-notail (list-at args i)
   in let st1 = store-local (r.state) (list-at temp-locals i) (r.reg)
   in eval-tail-args st1 args temp-locals (i + 1)

  copy-temps-to-params : CodegenState -> List Integer -> List Integer -> Integer -> CodegenState
  copy-temps-to-params (st) (temp-locals) (param-locals) (i) =
   if i == list-length temp-locals then st
   else let loaded = load-local st (list-at temp-locals i)
   in let st1 = store-local (loaded.state) (list-at param-locals i) (loaded.reg)
   in copy-temps-to-params st1 temp-locals param-locals (i + 1)

  emit-tail-call : CodegenState -> IRExpr -> IRExpr -> EmitResult
  emit-tail-call (st) (func-expr) (arg-expr) =
   let args = flatten-tail-args func-expr [arg-expr]
   in let st1 = eval-tail-args st args (st.tco.temp-locals) 0
   in let st2 = copy-temps-to-params st1 (st.tco.temp-locals) (st.tco.param-locals) 0
   in let rel32 = (st.tco.loop-top) - (list-length (st2.text) + 5)
   in let st3 = st-append-text st2 (jmp rel32)
   in let dummy = alloc-temp st3
   in EmitResult {
    state = st-append-text (dummy.state) (li (dummy.reg) 0),
    reg = (dummy.reg)
   }

  emit-sum-ctor : CodegenState -> List IRExpr -> Integer -> EmitResult
  emit-sum-ctor (st) (args) (tag) =
   let saved = save-args-loop st args 0 []
   in let field-count = list-length args
   in let total-size = (1 + field-count) * 8
   in let ptr-loc = alloc-local (saved.state)
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 total-size)
   in let tag-tmp = alloc-temp st3
   in let st4 = st-append-text (tag-tmp.state) (li (tag-tmp.reg) tag)
   in let ptr-load1 = load-local st4 (ptr-loc.reg)
   in let st5 = st-append-text (ptr-load1.state) (mov-store (ptr-load1.reg) (tag-tmp.reg) 0)
   in let st6 = emit-store-ctor-fields st5 (saved.locals) (ptr-loc.reg) 0
   in load-local st6 (ptr-loc.reg)

  emit-store-ctor-fields : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-ctor-fields (st) (field-locals) (ptr-loc) (i) =
   if i == list-length field-locals then st
   else let val = load-local st (list-at field-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-ctor-fields st1 field-locals ptr-loc (i + 1)

Section: Closures and Partial Application

  emit-load-func-addr : CodegenState -> Integer -> Text -> CodegenState
  emit-load-func-addr (st) (reg) (func-name) =
   let fixup = FuncAddrFixup { patch-offset = list-length (st.text) + 2, target = func-name }
   in let st1 = st-append-text st (mov-ri64 reg 0)
   in CodegenState {
    text = (st1.text),
    rodata = (st1.rodata),
    func-offsets = (st1.func-offsets),
    call-patches = (st1.call-patches),
    func-addr-fixups = list-snoc (st1.func-addr-fixups) fixup,
    locals = (st1.locals),
    next-temp = (st1.next-temp),
    next-local = (st1.next-local),
    spill-count = (st1.spill-count),
    load-local-toggle = (st1.load-local-toggle),
    tco = (st1.tco)
   }

  emit-trampoline-shift-args : CodegenState -> Integer -> Integer -> CodegenState
  emit-trampoline-shift-args (st) (i) (num-captures) =
   if i < 0 then st
   else if i + num-captures < 6 then emit-trampoline-shift-args (st-append-text st (mov-rr (list-at arg-regs (i + num-captures)) (list-at arg-regs i))) (i - 1) num-captures
   else emit-trampoline-shift-args st (i - 1) num-captures

  emit-trampoline-load-captures : CodegenState -> Integer -> Integer -> CodegenState
  emit-trampoline-load-captures (st) (i) (num-captures) =
   if i == num-captures then st
   else if i < 6 then emit-trampoline-load-captures (st-append-text st (mov-load (list-at arg-regs i) reg-r11 (8 + i * 8))) (i + 1) num-captures
   else st

  emit-partial-application : CodegenState -> Text -> List IRExpr -> EmitResult
  emit-partial-application (st) (func-name) (captured-args) =
   let saved = save-args-loop (st-set-tail-pos st False) captured-args 0 []
   in let num-captures = list-length captured-args
   in let tramp-name = func-name ++ "__tramp__" ++ integer-to-text num-captures ++ "__" ++ integer-to-text (list-length (saved.state.text))
   in let jmp-over-pos = list-length (saved.state.text)
   in let st1 = st-append-text (saved.state) (jmp 0)
   in let st2 = record-func-offset st1 tramp-name
   in let st3 = emit-trampoline-shift-args st2 5 num-captures
   in let st4 = emit-trampoline-load-captures st3 0 num-captures
   in let st5 = emit-load-func-addr st4 reg-rax func-name
   in let st6 = st-append-text st5 [255, 224]
   in let st7 = patch-jmp-at st6 jmp-over-pos (list-length (st6.text))
   in let closure-size = (1 + num-captures) * 8
   in let ptr-loc = alloc-local st7
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st8 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st9 = store-local st8 (ptr-loc.reg) (ptr-tmp.reg)
   in let st10 = st-append-text st9 (add-ri reg-r10 closure-size)
   in let st11 = emit-load-func-addr st10 reg-rax tramp-name
   in let ptr-load1 = load-local st11 (ptr-loc.reg)
   in let st12 = st-append-text (ptr-load1.state) (mov-store (ptr-load1.reg) reg-rax 0)
   in let st13 = emit-store-closure-captures st12 (saved.locals) (ptr-loc.reg) 0
   in load-local st13 (ptr-loc.reg)

  emit-store-closure-captures : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-closure-captures (st) (cap-locals) (ptr-loc) (i) =
   if i == list-length cap-locals then st
   else let val = load-local st (list-at cap-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-closure-captures st1 cap-locals ptr-loc (i + 1)

  collect-func-addr-patches : List FuncAddrFixup -> List FuncOffset -> Integer -> Integer -> List PatchEntry -> List PatchEntry
  collect-func-addr-patches (fixups) (offsets) (text-base) (i) (acc) =
   if i == list-length fixups then acc
   else let f = list-at fixups i
   in let func-offset = lookup-func-offset offsets (f.target)
   in let addr = text-base + func-offset
   in let addr-bytes = write-i64 addr
   in let p0 = PatchEntry { pos = (f.patch-offset), b0 = list-at addr-bytes 0, b1 = list-at addr-bytes 1, b2 = list-at addr-bytes 2, b3 = list-at addr-bytes 3 }
   in let p1 = PatchEntry { pos = (f.patch-offset) + 4, b0 = list-at addr-bytes 4, b1 = list-at addr-bytes 5, b2 = list-at addr-bytes 6, b3 = list-at addr-bytes 7 }
   in collect-func-addr-patches fixups offsets text-base (i + 1) (acc ++ [p0, p1])

Section: Record Emission

  find-record-field-index : List RecordField -> Text -> Integer -> Integer
  find-record-field-index (fields) (name) (i) =
   if i == list-length fields then 0
   else let f = list-at fields i
   in if f.name.value == name then i
      else find-record-field-index fields name (i + 1)

  emit-eval-record-fields : CodegenState -> List IRFieldVal -> Integer -> List FieldLocal -> EvalFieldsResult
  emit-eval-record-fields (st) (fields) (i) (acc) =
   if i == list-length fields then EvalFieldsResult { state = st, field-locals = acc }
   else let fv = list-at fields i
   in let r = emit-expr st (fv.value)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in emit-eval-record-fields st1 fields (i + 1) (list-snoc acc (FieldLocal { name = fv.name, slot = loc.reg }))

  find-field-local-slot : List FieldLocal -> Text -> Integer -> Integer
  find-field-local-slot (fls) (name) (i) =
   if i == list-length fls then 0 - 1
   else let fl = list-at fls i
   in if fl.name == name then fl.slot
      else find-field-local-slot fls name (i + 1)

  emit-store-record-fields-by-type : CodegenState -> List RecordField -> List FieldLocal -> Integer -> Integer -> CodegenState
  emit-store-record-fields-by-type (st) (type-fields) (field-locals) (ptr-loc) (i) =
   if i == list-length type-fields then st
   else let tf = list-at type-fields i
   in let slot = find-field-local-slot field-locals (tf.name.value) 0
   in if slot >= 0 then let val = load-local st slot
      in let ptr = load-local (val.state) ptr-loc
      in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (i * 8))
      in emit-store-record-fields-by-type st1 type-fields field-locals ptr-loc (i + 1)
     else emit-store-record-fields-by-type st type-fields field-locals ptr-loc (i + 1)

  emit-store-record-fields-by-list : CodegenState -> List FieldLocal -> Integer -> Integer -> CodegenState
  emit-store-record-fields-by-list (st) (field-locals) (ptr-loc) (i) =
   if i == list-length field-locals then st
   else let fl = list-at field-locals i
   in let val = load-local st (fl.slot)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (i * 8))
   in emit-store-record-fields-by-list st1 field-locals ptr-loc (i + 1)

  emit-record : CodegenState -> List IRFieldVal -> CodexType -> EmitResult
  emit-record (st) (fields) (ty) =
   let evaled = emit-eval-record-fields st fields 0 []
   in let field-count = list-length fields
   in let total-size = field-count * 8
   in let ptr-loc = alloc-local (evaled.state)
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 total-size)
   in let st4 = when ty
    if RecordTy (rname) (type-fields) -> emit-store-record-fields-by-type st3 type-fields (evaled.field-locals) (ptr-loc.reg) 0
    if _ -> emit-store-record-fields-by-list st3 (evaled.field-locals) (ptr-loc.reg) 0
   in load-local st4 (ptr-loc.reg)

  emit-field-access : CodegenState -> IRExpr -> Text -> EmitResult
  emit-field-access (st) (rec-expr) (field-name) =
   let rec-ty = ir-expr-type rec-expr
   in let field-idx = when rec-ty
    if RecordTy (rname) (rfields) -> find-record-field-index rfields field-name 0
    if _ -> 0
   in let rec-result = emit-expr st rec-expr
   in let rd = alloc-temp (rec-result.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-load (rd.reg) (rec-result.reg) (field-idx * 8)),
    reg = (rd.reg)
   }

Section: Pattern Matching

  emit-match : CodegenState -> IRExpr -> List IRBranch -> EmitResult
  emit-match (st) (scrut-expr) (branches) =
   let saved-tail = st.tco.in-tail-pos
   in let scrut-result = emit-expr (st-set-tail-pos st False) scrut-expr
   in let scrut-loc = alloc-local (scrut-result.state)
   in let st1 = store-local (scrut-loc.state) (scrut-loc.reg) (scrut-result.reg)
   in let st1a = st-set-tail-pos st1 saved-tail
   in let result-loc = alloc-local st1a
   in let mbs = MatchBranchState { cg-state = st1a, end-patches = [] }
   in let mbs-final = emit-match-branch-loop mbs (scrut-loc.reg) (result-loc.reg) branches 0 (list-length branches)
   in let st-end = patch-match-end-jumps (mbs-final.cg-state) (mbs-final.end-patches) 0
   in load-local st-end (result-loc.reg)

  emit-match-branch-loop : MatchBranchState -> Integer -> Integer -> List IRBranch -> Integer -> Integer -> MatchBranchState
  emit-match-branch-loop (mbs) (scrut-loc) (result-loc) (branches) (i) (total) =
   if i == total then mbs
   else let b = list-at branches i
   in let mbs1 = emit-one-match-branch mbs scrut-loc result-loc b (i < total - 1)
   in emit-match-branch-loop mbs1 scrut-loc result-loc branches (i + 1) total

  emit-one-match-branch : MatchBranchState -> Integer -> Integer -> IRBranch -> Boolean -> MatchBranchState
  emit-one-match-branch (mbs) (scrut-loc) (result-loc) (branch) (needs-jmp-end) =
   let pat-result = emit-pattern (mbs.cg-state) scrut-loc (branch.pattern)
   in let body-result = emit-expr (pat-result.state) (branch.body)
   in let st1 = store-local (body-result.state) result-loc (body-result.reg)
   in let st2 = if needs-jmp-end then let jmp-pos = list-length (st1.text)
     in MatchBranchState {
      cg-state = st-append-text st1 (jmp 0),
      end-patches = list-snoc (mbs.end-patches) jmp-pos
     }
    else MatchBranchState { cg-state = st1, end-patches = mbs.end-patches }
   in let st3 = if pat-result.next-branch-patch >= 0 then MatchBranchState {
     cg-state = patch-jcc-at (st2.cg-state) (pat-result.next-branch-patch) (list-length (st2.cg-state.text)),
     end-patches = (st2.end-patches)
    }
    else st2
   in st3

  EmitPatternResult = record {
   state : CodegenState,
   next-branch-patch : Integer
  }

  emit-pattern : CodegenState -> Integer -> IRPat -> EmitPatternResult
  emit-pattern (st) (scrut-loc) (pat) =
   when pat
    if IrWildPat -> EmitPatternResult { state = st, next-branch-patch = 0 - 1 }
    if IrVarPat (name) (ty) ->
     let var-loc = alloc-local st
     in let loaded = load-local (var-loc.state) scrut-loc
     in let st1 = store-local (loaded.state) (var-loc.reg) (loaded.reg)
     in EmitPatternResult { state = add-local st1 name (var-loc.reg), next-branch-patch = 0 - 1 }
    if IrCtorPat (name) (sub-pats) (ty) ->
     let scrut-load = load-local st scrut-loc
     in let tag-reg = alloc-temp (scrut-load.state)
     in let st1 = st-append-text (tag-reg.state) (mov-load (tag-reg.reg) (scrut-load.reg) 0)
     in let expected-tag = when ty
      if SumTy (sname) (ctors) -> find-ctor-tag ctors name 0
      if _ -> 0
     in let st2 = st-append-text st1 (cmp-ri (tag-reg.reg) expected-tag)
     in let jcc-pos = list-length (st2.text)
     in let st3 = st-append-text st2 (jcc cc-ne 0)
     in let st4 = bind-ctor-fields st3 scrut-loc sub-pats 0
     in EmitPatternResult { state = st4, next-branch-patch = jcc-pos }
    if IrLitPat (value) (ty) ->
     EmitPatternResult { state = st, next-branch-patch = 0 - 1 }

  bind-ctor-fields : CodegenState -> Integer -> List IRPat -> Integer -> CodegenState
  bind-ctor-fields (st) (scrut-loc) (sub-pats) (i) =
   if i == list-length sub-pats then st
   else let sub = list-at sub-pats i
   in when sub
     if IrVarPat (name) (ty) ->
      let field-loc = alloc-local st
      in let scrut-load = load-local (field-loc.state) scrut-loc
      in let field-val = alloc-temp (scrut-load.state)
      in let st1 = st-append-text (field-val.state) (mov-load (field-val.reg) (scrut-load.reg) ((1 + i) * 8))
      in let st2 = store-local st1 (field-loc.reg) (field-val.reg)
      in bind-ctor-fields (add-local st2 name (field-loc.reg)) scrut-loc sub-pats (i + 1)
     if _ -> bind-ctor-fields st scrut-loc sub-pats (i + 1)

  patch-match-end-jumps : CodegenState -> List Integer -> Integer -> CodegenState
  patch-match-end-jumps (st) (patches) (i) =
   if i == list-length patches then st
   else patch-match-end-jumps (patch-jmp-at st (list-at patches i) (list-length (st.text))) patches (i + 1)

Section: List Emission

  emit-eval-list-elems : CodegenState -> List IRExpr -> Integer -> List Integer -> SavedArgs
  emit-eval-list-elems (st) (elems) (i) (acc) =
   if i == list-length elems then SavedArgs { state = st, locals = acc }
   else let r = emit-expr st (list-at elems i)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in emit-eval-list-elems st1 elems (i + 1) (list-snoc acc (loc.reg))

  emit-store-list-elems : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-list-elems (st) (elem-locals) (ptr-loc) (i) =
   if i == list-length elem-locals then st
   else let val = load-local st (list-at elem-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-list-elems st1 elem-locals ptr-loc (i + 1)

  emit-list : CodegenState -> List IRExpr -> EmitResult
  emit-list (st) (elems) =
   let saved = emit-eval-list-elems st elems 0 []
   in let count = list-length elems
   in let cap-tmp = alloc-temp (saved.state)
   in let st1 = st-append-text (cap-tmp.state) (li (cap-tmp.reg) count)
   in let st2 = st-append-text st1 (mov-store reg-r10 (cap-tmp.reg) 0)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let ptr-loc = alloc-local st3
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st4 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st5 = store-local st4 (ptr-loc.reg) (ptr-tmp.reg)
   in let st6 = st-append-text st5 (add-ri reg-r10 ((count + 1) * 8))
   in let len-tmp = alloc-temp st6
   in let st7 = st-append-text (len-tmp.state) (li (len-tmp.reg) count)
   in let ptr-load = load-local st7 (ptr-loc.reg)
   in let st8 = st-append-text (ptr-load.state) (mov-store (ptr-load.reg) (len-tmp.reg) 0)
   in let st9 = emit-store-list-elems st8 (saved.locals) (ptr-loc.reg) 0
   in load-local st9 (ptr-loc.reg)

Section: 32-bit Bare-Metal Trampoline

 The PVH entry enters in 32-bit protected mode with paging disabled.
 This byte sequence sets up identity-mapped page tables covering 64 MB
 as 32 huge pages of 2 MB each, enables PAE and long mode, turns on
 paging, loads a 64-bit GDT, and far-jumps to the 64-bit __start
 entry point. The far-jump target address is patched after all code
 is emitted. Total size is 170 bytes.

 All bytes are 32-bit x86 machine code because the encoder only
 handles 64-bit instructions. The multiboot header occupies the first
 12 bytes, and the PVH ELF entry offset is 12 to skip past the header.

  multiboot-header : List Integer
  multiboot-header =
   write-i32 464367618 ++ write-i32 0 ++ write-i32 3830599678

  tramp-clear-pages : List Integer
  tramp-clear-pages =
   [250, 191, 0, 16, 0, 0, 185, 0, 12, 0, 0, 49, 192, 243, 171]

  tramp-page-tables : List Integer
  tramp-page-tables =
   [199, 5, 0, 16, 0, 0, 3, 32, 0, 0, 199, 5, 0, 32, 0, 0, 3, 48, 0, 0, 191, 0, 48, 0, 0, 185, 32, 0, 0, 0, 184, 131, 0, 0, 0, 137, 7, 199, 71, 4, 0, 0, 0, 0, 131, 199, 8, 5, 0, 0, 32, 0, 73, 117, 236]

  tramp-enable-long-mode : List Integer
  tramp-enable-long-mode =
   [184, 0, 16, 0, 0, 15, 34, 216, 15, 32, 224, 131, 200, 32, 15, 34, 224, 185, 128, 0, 0, 192, 15, 50, 13, 0, 1, 0, 0, 15, 48, 15, 32, 192, 13, 0, 0, 0, 128, 15, 34, 192]

  trampoline-code : List Integer
  trampoline-code =
   tramp-clear-pages ++ tramp-page-tables ++ tramp-enable-long-mode

  tramp-gdt-data : List Integer
  tramp-gdt-data =
   [235, 30, 0, 0, 0, 0, 0, 0, 0, 0, 255, 255, 0, 0, 0, 154, 175, 0, 255, 255, 0, 0, 0, 146, 207, 0]

  trampoline-gdt-section : List Integer
  trampoline-gdt-section =
   tramp-gdt-data ++ write-i16 23 ++ write-i32 (bare-metal-load-addr + 126) ++ [15, 1, 21] ++ write-i32 (bare-metal-load-addr + 150) ++ [234, 0, 0, 0, 0, 8, 0]

  bare-metal-trampoline : TrampolineResult
  bare-metal-trampoline =
   let bytes = multiboot-header ++ trampoline-code ++ trampoline-gdt-section
   in TrampolineResult { bytes = bytes, far-jump-patch-pos = 163 }

Section: Serial I/O

 COM1 data port is 1016 (0x3F8) and the line status register is at
 1021 (0x3FD). Bit 5 of the LSR indicates the transmit holding
 register is empty and ready to accept a byte. The wait loop reads
 the LSR with IN AL, DX (byte 236) and tests bit 5 with TEST AL, 32
 (bytes 168, 32). These two-byte encodings are not in the instruction
 encoder because they use implicit register forms.

  emit-out-byte : CodegenState -> Integer -> Integer -> CodegenState
  emit-out-byte (st) (port) (value) =
   let st1 = st-append-text st (li reg-rdx port)
   in let st2 = st-append-text st1 (li reg-rax value)
   in st-append-text st2 out-dx-al

  emit-com1-init : CodegenState -> CodegenState
  emit-com1-init (st) =
   let st1 = emit-out-byte st 1019 128
   in let st2 = emit-out-byte st1 1016 1
   in let st3 = emit-out-byte st2 1017 0
   in let st4 = emit-out-byte st3 1019 3
   in let st5 = emit-out-byte st4 1018 199
   in emit-out-byte st5 1020 11

  emit-serial-wait-and-send : CodegenState -> Integer -> CodegenState
  emit-serial-wait-and-send (st) (byte-val) =
   let wait-top = list-length (st.text)
   in let st1 = st-append-text st (li reg-rdx 1021)
   in let st2 = st-append-text st1 [236]
   in let st3 = st-append-text st2 [168, 32]
   in let jne-pos = list-length (st3.text)
   in let st4 = st-append-text st3 (jcc cc-ne 0)
   in let st5 = st-append-text st4 (jmp (wait-top - (list-length (st4.text) + 5)))
   in let st6 = patch-jcc-at st5 jne-pos (list-length (st5.text))
   in let st7 = st-append-text st6 (li reg-rdx 1016)
   in let st8 = st-append-text st7 (li reg-rax byte-val)
   in st-append-text st8 out-dx-al

  emit-serial-send-rdi : CodegenState -> CodegenState
  emit-serial-send-rdi (st) =
   let wait-top = list-length (st.text)
   in let st1 = st-append-text st (li reg-rdx 1021)
   in let st2 = st-append-text st1 [236]
   in let st3 = st-append-text st2 [168, 32]
   in let jne-pos = list-length (st3.text)
   in let st4 = st-append-text st3 (jcc cc-ne 0)
   in let st5 = st-append-text st4 (jmp (wait-top - (list-length (st4.text) + 5)))
   in let st6 = patch-jcc-at st5 jne-pos (list-length (st5.text))
   in let st7 = st-append-text st6 (li reg-rdx 1016)
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rdi)
   in st-append-text st8 out-dx-al

Section: Inline Integer Print

 Converts the integer in RAX to decimal ASCII digits and sends each
 to the COM1 serial port. Handles zero and negative values. Extracts
 digits by repeated division by 10, pushes them to the stack in
 reverse order, then pops and prints each one. Clobbers RAX, RBX,
 RCX, RDX, RDI, and R11.

  ItoaState = record {
   cg : CodegenState,
   jmp-done-zero-pos : Integer
  }

  emit-itoa-zero-check : CodegenState -> ItoaState
  emit-itoa-zero-check (st) =
   let st1 = st-append-text st (mov-rr reg-rbx reg-rax)
   in let st2 = st-append-text st1 (test-rr reg-rbx reg-rbx)
   in let jne-pos = list-length (st2.text)
   in let st3 = st-append-text st2 (jcc cc-ne 0)
   in let st4 = emit-serial-wait-and-send st3 48
   in let jmp-pos = list-length (st4.text)
   in let st5 = st-append-text st4 (jmp 0)
   in let st6 = patch-jcc-at st5 jne-pos (list-length (st5.text))
   in ItoaState { cg = st6, jmp-done-zero-pos = jmp-pos }

  emit-itoa-sign-and-digits : CodegenState -> CodegenState
  emit-itoa-sign-and-digits (st) =
   let st1 = st-append-text st (test-rr reg-rbx reg-rbx)
   in let jns-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = emit-serial-wait-and-send st2 45
   in let st4 = st-append-text st3 (neg-r reg-rbx)
   in let st5 = patch-jcc-at st4 jns-pos (list-length (st4.text))
   in let st6 = st-append-text st5 (li reg-rcx 0)
   in let st7 = st-append-text st6 (li reg-r11 10)
   in let loop-top = list-length (st7.text)
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rbx)
   in let st9 = st-append-text st8 cqo
   in let st10 = st-append-text st9 (idiv-r reg-r11)
   in let st11 = st-append-text st10 (mov-rr reg-rbx reg-rax)
   in let st12 = st-append-text st11 (add-ri reg-rdx 48)
   in let st13 = st-append-text st12 (push-r reg-rdx)
   in let st14 = st-append-text st13 (add-ri reg-rcx 1)
   in let st15 = st-append-text st14 (test-rr reg-rbx reg-rbx)
   in st-append-text st15 (jcc cc-ne (loop-top - (list-length (st15.text) + 6)))

  emit-itoa-print-loop : CodegenState -> CodegenState
  emit-itoa-print-loop (st) =
   let loop-top = list-length (st.text)
   in let st1 = st-append-text st (test-rr reg-rcx reg-rcx)
   in let je-pos = list-length (st1.text)
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let st3 = st-append-text st2 (pop-r reg-rdi)
   in let st4 = st-append-text st3 (push-r reg-rcx)
   in let st5 = emit-serial-send-rdi st4
   in let st6 = st-append-text st5 (pop-r reg-rcx)
   in let st7 = st-append-text st6 (sub-ri reg-rcx 1)
   in let st8 = st-append-text st7 (jmp (loop-top - (list-length (st7.text) + 5)))
   in patch-jcc-at st8 je-pos (list-length (st8.text))

  emit-inline-itoa-and-print : CodegenState -> CodegenState
  emit-inline-itoa-and-print (st) =
   let zero = emit-itoa-zero-check st
   in let st1 = emit-itoa-sign-and-digits (zero.cg)
   in let st2 = emit-itoa-print-loop st1
   in patch-jmp-at st2 (zero.jmp-done-zero-pos) (list-length (st2.text))

Section: Call Emission

  emit-call-to : CodegenState -> Text -> CodegenState
  emit-call-to (st) (target) =
   let patch-pos = list-length (st.text)
   in let st1 = st-append-text st (x86-call 0)
   in CodegenState {
    text = (st1.text),
    rodata = (st1.rodata),
    func-offsets = (st1.func-offsets),
    call-patches = list-snoc (st1.call-patches) (CallPatch { patch-offset = patch-pos, target = target }),
    func-addr-fixups = (st1.func-addr-fixups),
    locals = (st1.locals),
    next-temp = (st1.next-temp),
    next-local = (st1.next-local),
    spill-count = (st1.spill-count),
    load-local-toggle = (st1.load-local-toggle),
    tco = (st1.tco)
   }

Section: Bare-Metal Start

 The __start function is the 64-bit entry point reached after the
 trampoline switches to long mode. It sets up the stack pointer,
 initializes the COM1 UART for serial output, calls main, converts
 the integer return value to decimal, prints it to serial, and halts.

  bare-metal-heap-base : Integer
  bare-metal-heap-base = 4194304

  emit-start : CodegenState -> CodegenState
  emit-start (st) =
   let st1 = record-func-offset st "__start"
   in let st2 = st-append-text st1 (li reg-rsp bare-metal-stack-top)
   in let st3 = st-append-text st2 (mov-rr reg-rbp reg-rsp)
   in let st3a = st-append-text st3 (li reg-r10 bare-metal-heap-base)
   in let st4 = emit-com1-init st3a
   in let st5 = emit-call-to st4 "main"
   in let st6 = emit-inline-itoa-and-print st5
   in let st7 = emit-serial-wait-and-send st6 10
   in st-append-text st7 hlt

Section: Module Entry Point

 Orchestrates the full compilation pipeline. Builds the 32-bit
 trampoline, emits all function definitions, emits __start, patches
 the trampoline far-jump to point at __start, patches all call sites,
 and wraps everything in a bare-metal ELF with entry offset 12.

  x86-64-emit-module : IRModule -> List Integer
  x86-64-emit-module (m) =
   let tramp = bare-metal-trampoline
   in let st0 = CodegenState {
    text = (tramp.bytes),
    rodata = [],
    func-offsets = [],
    call-patches = [],
    func-addr-fixups = [],
    locals = [],
    next-temp = 0,
    next-local = 0,
    spill-count = 0,
    load-local-toggle = 0,
    tco = default-tco-state
   }
   in let st0a = emit-runtime-helpers st0
   in let st1 = emit-all-defs st0a (m.defs) 0
   in let st2 = emit-start st1
   in let start-offset = lookup-func-offset (st2.func-offsets) "__start"
   in let start-addr = bare-metal-load-addr + start-offset
   in let far-jump-entry = make-i32-patch ((tramp.far-jump-patch-pos) + 1) start-addr
   in let call-entries = collect-call-patches (st2.call-patches) (st2.func-offsets) 0 []
   in let addr-entries = collect-func-addr-patches (st2.func-addr-fixups) (st2.func-offsets) bare-metal-load-addr 0 []
   in let all-patches = [far-jump-entry] ++ call-entries ++ addr-entries
   in let st3 = st-with-text st2 (apply-all-patches (st2.text) all-patches)
   in build-elf-32-bare (st3.text) (st3.rodata) 12
