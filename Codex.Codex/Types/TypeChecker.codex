Chapter: Type Checker

 Bidirectional type checker for Codex.

Section: Resolve Type Expression
  resolve-type-expr : List TypeBinding -> ATypeExpr -> CodexType
  resolve-type-expr (tdm) (texpr) =
   when texpr
    if ANamedType (name) (s) -> resolve-type-name tdm (name.value)
    if AFunType (param) (ret) (s) -> FunTy (resolve-type-expr tdm param) (resolve-type-expr tdm ret)
    if AAppType (ctor) (args) (s) -> resolve-applied-type tdm ctor args
    if AEffectType (effs) (ret) (s) -> resolve-type-expr tdm ret

  resolve-applied-type : List TypeBinding -> ATypeExpr -> List ATypeExpr -> CodexType
  resolve-applied-type (tdm) (ctor) (args) =
   when ctor
    if ANamedType (name) (s) ->
     if name.value == "List" then if list-length args == 1 then ListTy (resolve-type-expr tdm (list-at args 0))
       else ListTy ErrorTy
      else if name.value == "LinkedList" then if list-length args == 1 then LinkedListTy (resolve-type-expr tdm (list-at args 0))
       else LinkedListTy ErrorTy
      else ConstructedTy name (resolve-type-expr-list tdm args 0 (list-length args) [])
    if _ -> resolve-type-expr tdm ctor

  resolve-type-expr-list : List TypeBinding -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List CodexType
  resolve-type-expr-list (tdm) (args) (i) (len) (acc) =
   if i == len then acc
   else resolve-type-expr-list tdm args (i + 1) len (list-snoc acc (resolve-type-expr tdm (list-at args i)))

  resolve-type-name : List TypeBinding -> Text -> CodexType
  resolve-type-name (tdm) (name) =
   if name == "Integer" then IntegerTy
   else if name == "Number" then NumberTy
   else if name == "Text" then TextTy
   else if name == "Boolean" then BooleanTy
   else if name == "Char" then CharTy
   else if name == "Nothing" then NothingTy
   else lookup-type-def tdm name

  lookup-type-def : List TypeBinding -> Text -> CodexType
  lookup-type-def (tdm) (name) =
   let len = list-length tdm
   in if len == 0 then ConstructedTy (Name { value = name }) []
   else let pos = bsearch-text-pos tdm name 0 len
   in if pos >= len then ConstructedTy (Name { value = name }) []
   else let b = list-at tdm pos
   in if b.name == name then b.bound-type
         else ConstructedTy (Name { value = name }) []

Section: Parameterize Type
  is-value-name : Text -> Boolean
  is-value-name (name) =
   if text-length name == 0 then False
   else let code = char-code (char-at name 0)
   in code >= char-code 'e' & code <= char-code 'z'

  ParamEntry = record {
   param-name : Text,
   var-id : Integer
  }

  ParamResult = record {
   parameterized : CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-type : UnificationState -> CodexType -> ParamResult
  parameterize-type (st) (ty) =
   let r = parameterize-walk st [] ty
   in let wrapped = wrap-forall-from-entries (r.walked) (r.entries) 0 (list-length (r.entries))
   in ParamResult {
    parameterized = wrapped,
    entries = r.entries,
    state = r.state
   }

  wrap-forall-from-entries : CodexType -> List ParamEntry -> Integer -> Integer -> CodexType
  wrap-forall-from-entries (ty) (entries) (i) (len) =
   if i == len then ty
   else let e = list-at entries i
   in ForAllTy (e.var-id) (wrap-forall-from-entries ty entries (i + 1) len)

  WalkResult = record {
   walked : CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-walk : UnificationState -> List ParamEntry -> CodexType -> WalkResult
  parameterize-walk (st) (entries) (ty) =
   when ty
    if ConstructedTy (name) (args) ->
     if list-length args == 0 & is-value-name (name.value)
      then
       let looked = find-param-entry entries (name.value) 0 (list-length entries)
       in if looked >= 0 then WalkResult {
        walked = TypeVar looked,
        entries = entries,
        state = st
       }
       else let fr = fresh-and-advance st
       in when fr.var-type
          if TypeVar (new-id) ->
           let new-entry = ParamEntry {
            param-name = name.value,
            var-id = new-id
           }
       in WalkResult {
            walked = fr.var-type,
            entries = entries ++ [new-entry],
            state = fr.state
           }
          if _ -> WalkResult {
           walked = ty,
           entries = entries,
           state = fr.state
          }
      else let args-r = parameterize-walk-list st entries args 0 (list-length args) []
      in WalkResult {
        walked = ConstructedTy name (args-r.walked-list),
        entries = args-r.entries,
        state = args-r.state
       }
    if FunTy (param) (ret) ->
     let pr = parameterize-walk st entries param
     in let rr = parameterize-walk (pr.state) (pr.entries) ret
     in WalkResult {
      walked = FunTy (pr.walked) (rr.walked),
      entries = rr.entries,
      state = rr.state
     }
    if ListTy (elem) ->
     let er = parameterize-walk st entries elem
     in WalkResult {
      walked = ListTy (er.walked),
      entries = er.entries,
      state = er.state
     }
    if LinkedListTy (elem) ->
     let er = parameterize-walk st entries elem
     in WalkResult {
      walked = LinkedListTy (er.walked),
      entries = er.entries,
      state = er.state
     }
    if ForAllTy (id) (body) ->
     let br = parameterize-walk st entries body
     in WalkResult {
      walked = ForAllTy id (br.walked),
      entries = br.entries,
      state = br.state
     }
    if _ -> WalkResult {
     walked = ty,
     entries = entries,
     state = st
    }

  find-param-entry : List ParamEntry -> Text -> Integer -> Integer -> Integer
  find-param-entry (entries) (name) (i) (len) =
   if i == len then -1
   else let e = list-at entries i
   in if e.param-name == name then e.var-id
      else find-param-entry entries name (i + 1) len

  WalkListResult = record {
   walked-list : List CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-walk-list : UnificationState -> List ParamEntry -> List CodexType -> Integer -> Integer -> List CodexType -> WalkListResult
  parameterize-walk-list (st) (entries) (args) (i) (len) (acc) =
   if i == len then WalkListResult {
    walked-list = acc,
    entries = entries,
    state = st
   }
   else let r = parameterize-walk st entries (list-at args i)
   in parameterize-walk-list (r.state) (r.entries) args (i + 1) len (list-snoc acc (r.walked))

Section: Check Definition
  check-def : UnificationState -> TypeEnv -> ADef -> CheckResult
  check-def (st) (env) (def) =
   let declared = resolve-declared-type st env def
   in let env2 = bind-def-params (declared.state) (declared.env) (def.params) (declared.expected-type) 0 (list-length (def.params))
   in let body-r = infer-expr (env2.state) (env2.env) (def.body)
   in let u = unify (body-r.state) (env2.remaining-type) (body-r.inferred-type)
   in CheckResult {
    inferred-type = declared.expected-type,
    state = u.state
   }

  DefSetup = record {
   expected-type : CodexType,
   remaining-type : CodexType,
   state : UnificationState,
   env : TypeEnv
  }

  resolve-declared-type : UnificationState -> TypeEnv -> ADef -> DefSetup
  resolve-declared-type (st) (env) (def) =
   if list-length (def.declared-type) == 0
    then
     let fr = fresh-and-advance st
     in DefSetup {
      expected-type = fr.var-type,
      remaining-type = fr.var-type,
      state = fr.state,
      env = env
     }
    else let env-type = env-lookup env (def.name.value)
    in let inst = instantiate-type st env-type
    in DefSetup {
      expected-type = inst.var-type,
      remaining-type = inst.var-type,
      state = inst.state,
      env = env
     }

  DefParamResult = record {
   state : UnificationState,
   env : TypeEnv,
   remaining-type : CodexType
  }

  bind-def-params : UnificationState -> TypeEnv -> List AParam -> CodexType -> Integer -> Integer -> DefParamResult
  bind-def-params (st) (env) (params) (remaining) (i) (len) =
   if i == len then DefParamResult {
    state = st,
    env = env,
    remaining-type = remaining
   }
   else let p = list-at params i
   in when remaining
     if FunTy (param-ty) (ret-ty) ->
      let env2 = env-bind env (p.name.value) param-ty
   in bind-def-params st env2 params ret-ty (i + 1) len
     if _ ->
      let fr = fresh-and-advance st
   in let env2 = env-bind env (p.name.value) (fr.var-type)
   in bind-def-params (fr.state) env2 params remaining (i + 1) len

Section: Check Chapter
  ChapterResult = record {
   types : List TypeBinding,
   state : UnificationState
  }

  check-chapter : AChapter -> ChapterResult
  check-chapter (mod) =
   let tdm = build-type-def-map (mod.type-defs) 0 (list-length (mod.type-defs)) []
   in let tenv = register-type-defs empty-unification-state builtin-type-env tdm (mod.type-defs) 0 (list-length (mod.type-defs))
   in let env = register-all-defs (tenv.state) (tenv.env) tdm (mod.defs) 0 (list-length (mod.defs))
   in check-all-defs (env.state) (env.env) (mod.defs) 0 (list-length (mod.defs)) []

  register-all-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ADef -> Integer -> Integer -> LetBindResult
  register-all-defs (st) (env) (tdm) (defs) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let def = list-at defs i
   in let ty = if list-length (def.declared-type) == 0 then let fr = fresh-and-advance st
   in let env2 = env-bind env (def.name.value) (fr.var-type)
   in LetBindResult {
          state = fr.state,
          env = env2
         }
   else let resolved = resolve-type-expr tdm (list-at (def.declared-type) 0)
   in let pr = parameterize-type st resolved
   in LetBindResult {
          state = pr.state,
          env = env-bind env (def.name.value) (pr.parameterized)
         }
   in register-all-defs (ty.state) (ty.env) tdm defs (i + 1) len

  check-all-defs : UnificationState -> TypeEnv -> List ADef -> Integer -> Integer -> List TypeBinding -> ChapterResult
  check-all-defs (st) (env) (defs) (i) (len) (acc) =
   if i == len then ChapterResult {
    types = acc,
    state = st
   }
   else let def = list-at defs i
   in let r = check-def st env def
   in let resolved = deep-resolve (r.state) (r.inferred-type)
   in let entry = TypeBinding {
    name = def.name.value,
    bound-type = resolved
   }
   in check-all-defs (r.state) env defs (i + 1) len (list-snoc acc entry)

Section: Register Type Definitions
  build-type-def-map : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  build-type-def-map (tdefs) (i) (len) (acc) =
   if i == len then acc
   else let td = list-at tdefs i
   in let entry = when td
       if AVariantTypeDef (name) (type-params) (ctors) (s) ->
        let sum-ctors = build-sum-ctors tdefs ctors 0 (list-length ctors) [] acc
   in TypeBinding {
         name = name.value,
         bound-type = SumTy name sum-ctors
        }
       if ARecordTypeDef (name) (type-params) (fields) (s) ->
        let rec-fields = build-record-fields-for-map tdefs fields 0 (list-length fields) [] acc
   in TypeBinding {
         name = name.value,
         bound-type = RecordTy name rec-fields
        }
   in build-type-def-map tdefs (i + 1) len (list-insert-at acc (bsearch-text-pos acc (entry.name) 0 (list-length acc)) entry)

  build-sum-ctors : List ATypeDef -> List AVariantCtorDef -> Integer -> Integer -> List SumCtor -> List TypeBinding -> List SumCtor
  build-sum-ctors (tdefs) (ctors) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else let c = list-at ctors i
   in let field-types = resolve-type-expr-list-for-map tdefs (c.fields) 0 (list-length (c.fields)) [] partial-tdm
   in let sc = SumCtor {
    name = c.name,
    fields = field-types
   }
   in build-sum-ctors tdefs ctors (i + 1) len (list-snoc acc sc) partial-tdm

  build-record-fields-for-map : List ATypeDef -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List TypeBinding -> List RecordField
  build-record-fields-for-map (tdefs) (fields) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else let f = list-at fields i
   in let rfield = RecordField {
    name = f.name,
    type-val = resolve-type-expr partial-tdm (f.type-expr)
   }
   in build-record-fields-for-map tdefs fields (i + 1) len (list-snoc acc rfield) partial-tdm

  resolve-type-expr-list-for-map : List ATypeDef -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List TypeBinding -> List CodexType
  resolve-type-expr-list-for-map (tdefs) (args) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else resolve-type-expr-list-for-map tdefs args (i + 1) len (list-snoc acc (resolve-type-expr partial-tdm (list-at args i))) partial-tdm

  register-type-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ATypeDef -> Integer -> Integer -> LetBindResult
  register-type-defs (st) (env) (tdm) (tdefs) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let td = list-at tdefs i
   in let r = register-one-type-def st env tdm td
   in register-type-defs (r.state) (r.env) tdm tdefs (i + 1) len

  register-one-type-def : UnificationState -> TypeEnv -> List TypeBinding -> ATypeDef -> LetBindResult
  register-one-type-def (st) (env) (tdm) (td) =
   when td
    if AVariantTypeDef (name) (type-params) (ctors) (s) ->
     let result-ty = lookup-type-def tdm (name.value)
     in register-variant-ctors st env tdm ctors result-ty 0 (list-length ctors)
    if ARecordTypeDef (name) (type-params) (fields) (s) ->
     let resolved-fields = build-record-fields tdm fields 0 (list-length fields) []
     in let result-ty = RecordTy name resolved-fields
     in let ctor-ty = build-record-ctor-type tdm fields result-ty 0 (list-length fields)
     in LetBindResult {
      state = st,
      env = env-bind env (name.value) ctor-ty
     }

  build-record-fields : List TypeBinding -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
  build-record-fields (tdm) (fields) (i) (len) (acc) =
   if i == len then acc
   else let f = list-at fields i
   in let rfield = RecordField {
    name = f.name,
    type-val = resolve-type-expr tdm (f.type-expr)
   }
   in build-record-fields tdm fields (i + 1) len (list-snoc acc rfield)

  lookup-record-field : List RecordField -> Text -> CodexType
  lookup-record-field (fields) (name) =
   if list-length fields == 0 then ErrorTy
   else let f = list-at fields 0
   in if f.name.value == name then f.type-val
      else lookup-record-field-loop fields name 1 (list-length fields)

  lookup-record-field-loop : List RecordField -> Text -> Integer -> Integer -> CodexType
  lookup-record-field-loop (fields) (name) (i) (len) =
   if i == len then ErrorTy
   else let f = list-at fields i
   in if f.name.value == name then f.type-val
      else lookup-record-field-loop fields name (i + 1) len

  register-variant-ctors : UnificationState -> TypeEnv -> List TypeBinding -> List AVariantCtorDef -> CodexType -> Integer -> Integer -> LetBindResult
  register-variant-ctors (st) (env) (tdm) (ctors) (result-ty) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let ctor = list-at ctors i
   in let ctor-ty = build-ctor-type tdm (ctor.fields) result-ty 0 (list-length (ctor.fields))
   in let env2 = env-bind env (ctor.name.value) ctor-ty
   in register-variant-ctors st env2 tdm ctors result-ty (i + 1) len

  build-ctor-type : List TypeBinding -> List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
  build-ctor-type (tdm) (fields) (result) (i) (len) =
   if i == len then result
   else let rest = build-ctor-type tdm fields result (i + 1) len
   in FunTy (resolve-type-expr tdm (list-at fields i)) rest

  build-record-ctor-type : List TypeBinding -> List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
  build-record-ctor-type (tdm) (fields) (result) (i) (len) =
   if i == len then result
   else let f = list-at fields i
   in let rest = build-record-ctor-type tdm fields result (i + 1) len
   in FunTy (resolve-type-expr tdm (f.type-expr)) rest

