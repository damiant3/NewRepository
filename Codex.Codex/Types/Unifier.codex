Chapter: Unification

  Type unification for the Codex type checker. The UnificationState
  is threaded through all operations — it tracks type variable
  substitutions, a counter for generating fresh variables, and
  accumulated diagnostics.

  Naming convention: the state is called a UnificationState because
  its mutations serve a specific purpose — unifying type variables
  with concrete types during type inference. It is not a general
  mutable reference.

Section: State

    UnificationState = record {
      substitutions : List SubstEntry,
      next-id : Integer,
      errors : List Diagnostic
    }

    SubstEntry = record {
      var-id : Integer,
      resolved-type : CodexType
    }

    UnifyResult = record {
      success : Boolean,
      state : UnificationState
    }

Section: Construction

    empty-unification-state : UnificationState
    empty-unification-state =
      UnificationState { substitutions = [], next-id = 2, errors = [] }

Section: Fresh Variables

    fresh-var : UnificationState -> CodexType
    fresh-var (st) = TypeVar st.next-id

    advance-id : UnificationState -> UnificationState
    advance-id (st) =
      UnificationState { substitutions = st.substitutions, next-id = st.next-id + 1, errors = st.errors }

    fresh-and-advance : UnificationState -> FreshResult
    fresh-and-advance (st) =
      FreshResult { var-type = TypeVar st.next-id, state = advance-id st }

    FreshResult = record {
      var-type : CodexType,
      state : UnificationState
    }

Section: Substitution Lookup

    subst-lookup : Integer -> List SubstEntry -> CodexType
    subst-lookup (var-id) (entries) =
      subst-lookup-loop var-id entries 0 (list-length entries)

    subst-lookup-loop : Integer -> List SubstEntry -> Integer -> Integer -> CodexType
    subst-lookup-loop (var-id) (entries) (i) (len) =
      if i == len then ErrorTy
      else
        let entry = list-at entries i
        in if entry.var-id == var-id then entry.resolved-type
           else subst-lookup-loop var-id entries (i + 1) len

    has-subst : Integer -> List SubstEntry -> Boolean
    has-subst (var-id) (entries) =
      has-subst-loop var-id entries 0 (list-length entries)

    has-subst-loop : Integer -> List SubstEntry -> Integer -> Integer -> Boolean
    has-subst-loop (var-id) (entries) (i) (len) =
      if i == len then False
      else
        let entry = list-at entries i
        in if entry.var-id == var-id then True
           else has-subst-loop var-id entries (i + 1) len

Section: Resolve

    resolve : UnificationState -> CodexType -> CodexType
    resolve (st) (ty) =
      when ty
        if TypeVar (id) ->
          if has-subst id st.substitutions
            then resolve st (subst-lookup id st.substitutions)
            else ty
        if _ -> ty

Section: Add Substitution

    add-subst : UnificationState -> Integer -> CodexType -> UnificationState
    add-subst (st) (var-id) (ty) =
      UnificationState {
        substitutions = st.substitutions ++ [SubstEntry { var-id = var-id, resolved-type = ty }],
        next-id = st.next-id,
        errors = st.errors
      }

Section: Add Error

    add-unify-error : UnificationState -> Text -> Text -> UnificationState
    add-unify-error (st) (code) (msg) =
      UnificationState {
        substitutions = st.substitutions,
        next-id = st.next-id,
        errors = st.errors ++ [make-error code msg]
      }

Section: Occurs Check

    occurs-in : UnificationState -> Integer -> CodexType -> Boolean
    occurs-in (st) (var-id) (ty) =
      let resolved = resolve st ty
      in when resolved
        if TypeVar (id) -> id == var-id
        if FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
        if ListTy (elem) -> occurs-in st var-id elem
        if _ -> False

Section: Unify

    unify : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify (st) (a) (b) =
      let ra = resolve st a
      in let rb = resolve st b
      in unify-resolved st ra rb

    unify-resolved : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-resolved (st) (a) (b) =
      if types-equal a b then UnifyResult { success = True, state = st }
      else when a
        if TypeVar (id-a) ->
          if occurs-in st id-a b
            then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
            else UnifyResult { success = True, state = add-subst st id-a b }
        if _ -> unify-rhs st a b

    types-equal : CodexType -> CodexType -> Boolean
    types-equal (a) (b) =
      when a
        if TypeVar (id-a) -> types-equal-typevar id-a b
        if IntegerTy -> is-integer-ty b
        if NumberTy -> is-number-ty b
        if TextTy -> is-text-ty b
        if BooleanTy -> is-boolean-ty b
        if NothingTy -> is-nothing-ty b
        if VoidTy -> is-void-ty b
        if ErrorTy -> is-error-ty b
        if _ -> False

    types-equal-typevar : Integer -> CodexType -> Boolean
    types-equal-typevar (id-a) (b) =
      when b
        if TypeVar (id-b) -> id-a == id-b
        if _ -> False

    is-integer-ty : CodexType -> Boolean
    is-integer-ty (t) = when t
      if IntegerTy -> True
      if _ -> False

    is-number-ty : CodexType -> Boolean
    is-number-ty (t) = when t
      if NumberTy -> True
      if _ -> False

    is-text-ty : CodexType -> Boolean
    is-text-ty (t) = when t
      if TextTy -> True
      if _ -> False

    is-boolean-ty : CodexType -> Boolean
    is-boolean-ty (t) = when t
      if BooleanTy -> True
      if _ -> False

    is-nothing-ty : CodexType -> Boolean
    is-nothing-ty (t) = when t
      if NothingTy -> True
      if _ -> False

    is-void-ty : CodexType -> Boolean
    is-void-ty (t) = when t
      if VoidTy -> True
      if _ -> False

    is-error-ty : CodexType -> Boolean
    is-error-ty (t) = when t
      if ErrorTy -> True
      if _ -> False

    unify-rhs : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-rhs (st) (a) (b) =
      when b
        if TypeVar (id-b) ->
          if occurs-in st id-b a
            then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
            else UnifyResult { success = True, state = add-subst st id-b a }
        if _ -> unify-structural st a b

    unify-structural : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-structural (st) (a) (b) =
      when a
        if IntegerTy -> unify-b-integer st a b
        if NumberTy -> unify-b-number st a b
        if TextTy -> unify-b-text st a b
        if BooleanTy -> unify-b-boolean st a b
        if NothingTy -> unify-b-nothing st a b
        if VoidTy -> unify-b-void st a b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if FunTy (pa) (ra) -> unify-b-fun st a pa ra b
        if ListTy (ea) -> unify-b-list st a ea b
        if ConstructedTy (na) (args-a) -> unify-b-constructed st a na args-a b
        if SumTy (sa-name) (sa-ctors) -> unify-b-sum st a sa-name b
        if RecordTy (ra-name) (ra-fields) -> unify-b-record st a ra-name b
        if ForAllTy (id) (body) -> unify st body b
        if _ -> unify-b-wildcard st a b

    unify-b-integer : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-integer (st) (a) (b) =
      when b
        if IntegerTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-number : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-number (st) (a) (b) =
      when b
        if NumberTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-text : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-text (st) (a) (b) =
      when b
        if TextTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-boolean : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-boolean (st) (a) (b) =
      when b
        if BooleanTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-nothing : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-nothing (st) (a) (b) =
      when b
        if NothingTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-void : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-void (st) (a) (b) =
      when b
        if VoidTy -> UnifyResult { success = True, state = st }
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> UnifyResult
    unify-b-fun (st) (a) (pa) (ra) (b) =
      when b
        if FunTy (pb) (rb) -> unify-fun st pa ra pb rb
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-list : UnificationState -> CodexType -> CodexType -> CodexType -> UnifyResult
    unify-b-list (st) (a) (ea) (b) =
      when b
        if ListTy (eb) -> unify st ea eb
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-constructed : UnificationState -> CodexType -> Name -> List CodexType -> CodexType -> UnifyResult
    unify-b-constructed (st) (a) (na) (args-a) (b) =
      when b
        if ConstructedTy (nb) (args-b) ->
          if na.value == nb.value
            then unify-constructed-args st args-a args-b 0 (list-length args-a)
            else unify-mismatch st a b
        if SumTy (sb-name) (sb-ctors) ->
          if na.value == sb-name.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if RecordTy (rb-name) (rb-fields) ->
          if na.value == rb-name.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-sum : UnificationState -> CodexType -> Name -> CodexType -> UnifyResult
    unify-b-sum (st) (a) (sa-name) (b) =
      when b
        if SumTy (sb-name) (sb-ctors) ->
          if sa-name.value == sb-name.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if ConstructedTy (nb) (args-b) ->
          if sa-name.value == nb.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-record : UnificationState -> CodexType -> Name -> CodexType -> UnifyResult
    unify-b-record (st) (a) (ra-name) (b) =
      when b
        if RecordTy (rb-name) (rb-fields) ->
          if ra-name.value == rb-name.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if ConstructedTy (nb) (args-b) ->
          if ra-name.value == nb.value then UnifyResult { success = True, state = st }
          else unify-mismatch st a b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-b-wildcard : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-b-wildcard (st) (a) (b) =
      when b
        if ErrorTy -> UnifyResult { success = True, state = st }
        if _ -> unify-mismatch st a b

    unify-constructed-args : UnificationState -> List CodexType -> List CodexType -> Integer -> Integer -> UnifyResult
    unify-constructed-args (st) (args-a) (args-b) (i) (len) =
      if i == len then UnifyResult { success = True, state = st }
      else
        if i >= list-length args-b then UnifyResult { success = True, state = st }
        else
          let r = unify st (list-at args-a i) (list-at args-b i)
          in if r.success then unify-constructed-args r.state args-a args-b (i + 1) len
             else r

    unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> UnifyResult
    unify-fun (st) (pa) (ra) (pb) (rb) =
      let r1 = unify st pa pb
      in if r1.success then unify r1.state ra rb
         else r1

    unify-mismatch : UnificationState -> CodexType -> CodexType -> UnifyResult
    unify-mismatch (st) (a) (b) =
      UnifyResult { success = False, state = add-unify-error st "CDX2001" ("Type mismatch: " ++ type-tag a ++ " vs " ++ type-tag b) }

    type-tag : CodexType -> Text
    type-tag (ty) =
      when ty
        if IntegerTy -> "Integer"
        if NumberTy -> "Number"
        if TextTy -> "Text"
        if BooleanTy -> "Boolean"
        if VoidTy -> "Void"
        if NothingTy -> "Nothing"
        if ErrorTy -> "Error"
        if FunTy (p) (r) -> "Fun"
        if ListTy (e) -> "List"
        if TypeVar (id) -> "T" ++ integer-to-text id
        if ForAllTy (id) (body) -> "ForAll"
        if SumTy (name) (ctors) -> "Sum:" ++ name.value
        if RecordTy (name) (fields) -> "Rec:" ++ name.value
        if ConstructedTy (name) (args) -> "Con:" ++ name.value

Section: Deep Resolve

    deep-resolve : UnificationState -> CodexType -> CodexType
    deep-resolve (st) (ty) =
      let resolved = resolve st ty
      in when resolved
        if FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
        if ListTy (elem) -> ListTy (deep-resolve st elem)
        if ConstructedTy (name) (args) -> ConstructedTy name (deep-resolve-list st args 0 (list-length args) [])
        if ForAllTy (id) (body) -> ForAllTy id (deep-resolve st body)
        if SumTy (name) (ctors) -> resolved
        if RecordTy (name) (fields) -> resolved
        if _ -> resolved

    deep-resolve-list : UnificationState -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
    deep-resolve-list (st) (args) (i) (len) (acc) =
      if i == len then acc
      else deep-resolve-list st args (i + 1) len (acc ++ [deep-resolve st (list-at args i)])
