Chapter: Unification

 Type unification for the Codex type checker. The UnificationState
 is threaded through all operations — it tracks type variable
 substitutions, a counter for generating fresh variables, and
 accumulated diagnostics.

 Naming convention: the state is called a UnificationState because
 its mutations serve a specific purpose — unifying type variables
 with concrete types during type inference. It is not a general
 mutable reference.

Section: State
  UnificationState = record {
   substitutions : List CodexType,
   next-id : Integer,
   bag : DiagnosticBag
  }

  UnifyResult = record {
   success : Boolean,
   state : UnificationState
  }

Section: Construction
  empty-unification-state : UnificationState
  empty-unification-state =
   UnificationState {
    substitutions = [TypeVar 0, TypeVar 1],
    next-id = 2,
    bag = empty-bag
   }

Section: Fresh Variables
  fresh-var : UnificationState -> CodexType
  fresh-var (st) =
   TypeVar (st.next-id)

  advance-id : UnificationState -> UnificationState
  advance-id (st) =
   UnificationState {
    substitutions = list-snoc (st.substitutions) (TypeVar (st.next-id)),
    next-id = st.next-id + 1,
    bag = st.bag
   }

  fresh-and-advance : UnificationState -> FreshResult
  fresh-and-advance (st) =
   FreshResult {
    var-type = TypeVar (st.next-id),
    state = advance-id st
   }

  FreshResult = record {
   var-type : CodexType,
   state : UnificationState
  }

Section: Resolve
  resolve : UnificationState -> CodexType -> CodexType
  resolve (st) (ty) =
   when ty
    is TypeVar (id) ->
     if id >= list-length (st.substitutions) then ty
     else let slot = list-at (st.substitutions) id
     in if slot-is-unbound slot id then ty else resolve st slot
    is otherwise -> ty

  slot-is-unbound : CodexType -> Integer -> Boolean
  slot-is-unbound (slot) (id) =
   when slot
    is TypeVar (slot-id) -> slot-id == id
    is otherwise -> False

Section: Add Substitution
  add-subst : UnificationState -> Integer -> CodexType -> UnificationState
  add-subst (st) (var-id) (ty) =
   UnificationState {
    substitutions = list-set-at (st.substitutions) var-id ty,
    next-id = st.next-id,
    bag = st.bag
   }

Section: Add Error
  add-unify-error : UnificationState -> Integer -> Text -> SourceSpan -> UnificationState
  add-unify-error (st) (code) (msg) (span) =
   UnificationState {
    substitutions = st.substitutions,
    next-id = st.next-id,
    bag = bag-add (st.bag) (make-error code msg span)
   }

Section: Occurs Check
  occurs-in : UnificationState -> Integer -> CodexType -> Boolean
  occurs-in (st) (var-id) (ty) =
   let resolved = resolve st ty
   in when resolved
    is TypeVar (id) -> id == var-id
    is FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
    is ListTy (elem) -> occurs-in st var-id elem
    is LinkedListTy (elem) -> occurs-in st var-id elem
    is otherwise -> False

Section: Unify
  unify : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify (st) (a) (b) (span) =
   let ra = resolve st a
   in let rb = resolve st b
   in unify-resolved st ra rb span

  unify-resolved : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-resolved (st) (a) (b) (span) =
   if types-equal a b then UnifyResult {
    success = True,
    state = st
   }
   else when a
    is TypeVar (id-a) ->
     if occurs-in st id-a b then UnifyResult {
      success = False,
      state = add-unify-error st cdx-infinite-type "Infinite type" span
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-a b
      }
    is otherwise -> unify-rhs st a b span

  types-equal : CodexType -> CodexType -> Boolean
  types-equal (a) (b) =
   when a
    is TypeVar (id-a) -> when b
     is TypeVar (id-b) -> id-a == id-b
     is otherwise -> False
    is IntegerTy -> when b
     is IntegerTy -> True
     is otherwise -> False
    is NumberTy -> when b
     is NumberTy -> True
     is otherwise -> False
    is TextTy -> when b
     is TextTy -> True
     is otherwise -> False
    is BooleanTy -> when b
     is BooleanTy -> True
     is otherwise -> False
    is CharTy -> when b
     is CharTy -> True
     is otherwise -> False
    is NothingTy -> when b
     is NothingTy -> True
     is otherwise -> False
    is VoidTy -> when b
     is VoidTy -> True
     is otherwise -> False
    is ErrorTy -> when b
     is ErrorTy -> True
     is otherwise -> False
    is otherwise -> False

  unify-rhs : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-rhs (st) (a) (b) (span) =
   when b
    is TypeVar (id-b) ->
     if occurs-in st id-b a then UnifyResult {
      success = False,
      state = add-unify-error st cdx-infinite-type "Infinite type" span
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-b a
      }
    is otherwise -> unify-structural st a b span

  unify-structural : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-structural (st) (a) (b) (span) =
   when a
    is IntegerTy -> when b
     is IntegerTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is NumberTy -> when b
     is NumberTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is TextTy -> when b
     is TextTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is BooleanTy -> when b
     is BooleanTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is NothingTy -> when b
     is NothingTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is VoidTy -> when b
     is VoidTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ErrorTy -> UnifyResult {
     success = True,
     state = st
    }
    is FunTy (pa) (ra) -> when b
     is FunTy (pb) (rb) -> unify-fun st pa ra pb rb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ListTy (ea) -> when b
     is ListTy (eb) -> unify st ea eb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is LinkedListTy (ea) -> when b
     is LinkedListTy (eb) -> unify st ea eb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ConstructedTy (na) (args-a) -> when b
     is ConstructedTy (nb) (args-b) ->
      if na.value == nb.value then unify-constructed-args st args-a args-b 0 (list-length args-a) span
       else unify-mismatch st a b span
     is SumTy (sb-name) (sb-ctors) ->
      if na.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is RecordTy (rb-name) (rb-fields) ->
      if na.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is SumTy (sa-name) (sa-ctors) -> when b
     is SumTy (sb-name) (sb-ctors) ->
      if sa-name.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ConstructedTy (nb) (args-b) ->
      if sa-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is RecordTy (ra-name) (ra-fields) -> when b
     is RecordTy (rb-name) (rb-fields) ->
      if ra-name.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ConstructedTy (nb) (args-b) ->
      if ra-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ForAllTy (id) (body) -> unify st body b span
    is EffectfulTy (effs-a) (ret-a) -> when b
     is EffectfulTy (effs-b) (ret-b) -> unify st ret-a ret-b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify st ret-a b span
    is otherwise -> when b
     is EffectfulTy (effs-b) (ret-b) -> unify st a ret-b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span

  unify-constructed-args : UnificationState -> List CodexType -> List CodexType -> Integer -> Integer -> SourceSpan -> UnifyResult
  unify-constructed-args (st) (args-a) (args-b) (i) (len) (span) =
   if i == len then UnifyResult {
    success = True,
    state = st
   }
   else if i >= list-length args-b then UnifyResult {
    success = True,
    state = st
   }
   else let r = unify st (list-at args-a i) (list-at args-b i) span
   in if r.success then unify-constructed-args (r.state) args-a args-b (i + 1) len span
        else r

  unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-fun (st) (pa) (ra) (pb) (rb) (span) =
   let r1 = unify st pa pb span
   in if r1.success then unify (r1.state) ra rb span
      else r1

  unify-mismatch : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-mismatch (st) (a) (b) (span) =
   UnifyResult {
    success = False,
    state = add-unify-error st cdx-type-mismatch ("Type mismatch: " ++ type-tag a ++ " vs " ++ type-tag b) span
   }

  type-tag : CodexType -> Text
  type-tag (ty) =
   when ty
    is IntegerTy -> "Integer"
    is NumberTy -> "Number"
    is TextTy -> "Text"
    is BooleanTy -> "Boolean"
    is CharTy -> "Char"
    is VoidTy -> "Void"
    is NothingTy -> "Nothing"
    is ErrorTy -> "Error"
    is FunTy (p) (r) -> "Fun"
    is ListTy (e) -> "List"
    is LinkedListTy (e) -> "LinkedList"
    is TypeVar (id) -> "T" ++ integer-to-text id
    is ForAllTy (id) (body) -> "ForAll"
    is SumTy (name) (ctors) -> "Sum:" ++ name.value
    is RecordTy (name) (fields) -> "Rec:" ++ name.value
    is ConstructedTy (name) (args) -> "Con:" ++ name.value
    is EffectfulTy (effs) (ret) -> "Effectful"

Section: Deep Resolve
  deep-resolve : UnificationState -> CodexType -> CodexType
  deep-resolve (st) (ty) =
   let resolved = resolve st ty
   in when resolved
    is FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
    is ListTy (elem) -> ListTy (deep-resolve st elem)
    is LinkedListTy (elem) -> LinkedListTy (deep-resolve st elem)
    is ConstructedTy (name) (args) -> ConstructedTy name (deep-resolve-list st args 0 (list-length args) [])
    is ForAllTy (id) (body) -> ForAllTy id (deep-resolve st body)
    is EffectfulTy (effs) (ret) -> EffectfulTy effs (deep-resolve st ret)
    is SumTy (name) (ctors) -> resolved
    is RecordTy (name) (fields) -> resolved
    is otherwise -> resolved

  deep-resolve-list : UnificationState -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
  deep-resolve-list (st) (args) (i) (len) (acc) =
   if i == len then acc
   else deep-resolve-list st args (i + 1) len (list-snoc acc (deep-resolve st (list-at args i)))

