Chapter: Unification

 Type unification for the Codex type checker. The UnificationState
 is threaded through all operations — it tracks type variable
 substitutions, a counter for generating fresh variables, and
 accumulated diagnostics.

 Naming convention: the state is called a UnificationState because
 its mutations serve a specific purpose — unifying type variables
 with concrete types during type inference. It is not a general
 mutable reference.

Section: State

  UnificationState = record {
   substitutions : List SubstEntry,
   next-id : Integer,
   errors : List Diagnostic
  }

  SubstEntry = record {
   var-id : Integer,
   resolved-type : CodexType
  }

  UnifyResult = record {
   success : Boolean,
   state : UnificationState
  }

Section: Construction

  empty-unification-state : UnificationState
  empty-unification-state =
   UnificationState {
    substitutions = [],
    next-id = 2,
    errors = []
   }

Section: Fresh Variables

  fresh-var : UnificationState -> CodexType
  fresh-var (st) =
   TypeVar (st.next-id)

  advance-id : UnificationState -> UnificationState
  advance-id (st) =
   UnificationState {
    substitutions = st.substitutions,
    next-id = st.next-id + 1,
    errors = st.errors
   }

  fresh-and-advance : UnificationState -> FreshResult
  fresh-and-advance (st) =
   FreshResult {
    var-type = TypeVar (st.next-id),
    state = advance-id st
   }

  FreshResult = record {
   var-type : CodexType,
   state : UnificationState
  }

Section: Substitution Lookup (binary search on sorted substitutions)

  subst-lookup : Integer -> List SubstEntry -> CodexType
  subst-lookup (var-id) (entries) =
   let len = list-length entries
   in if len == 0 then ErrorTy
      else let pos = bsearch-int-pos entries var-id 0 len
   in if pos >= len then ErrorTy
      else let entry = list-at entries pos
      in if entry.var-id == var-id then entry.resolved-type else ErrorTy

  has-subst : Integer -> List SubstEntry -> Boolean
  has-subst (var-id) (entries) =
   let len = list-length entries
   in if len == 0 then False
      else let pos = bsearch-int-pos entries var-id 0 len
   in if pos >= len then False
      else (list-at entries pos).var-id == var-id

Section: Resolve

  resolve : UnificationState -> CodexType -> CodexType
  resolve (st) (ty) =
   when ty
    if TypeVar (id) ->
     if has-subst id (st.substitutions) then resolve st (subst-lookup id (st.substitutions))
      else ty
    if _ -> ty

Section: Add Substitution

  add-subst : UnificationState -> Integer -> CodexType -> UnificationState
  add-subst (st) (var-id) (ty) =
   let entry = SubstEntry {
    var-id = var-id,
    resolved-type = ty
   }
   in let pos = bsearch-int-pos (st.substitutions) var-id 0 (list-length (st.substitutions))
   in UnificationState {
    substitutions = list-insert-at (st.substitutions) pos entry,
    next-id = st.next-id,
    errors = st.errors
   }

Section: Add Error

  add-unify-error : UnificationState -> Text -> Text -> UnificationState
  add-unify-error (st) (code) (msg) =
   UnificationState {
    substitutions = st.substitutions,
    next-id = st.next-id,
    errors = st.errors ++ [make-error code msg]
   }

Section: Occurs Check

  occurs-in : UnificationState -> Integer -> CodexType -> Boolean
  occurs-in (st) (var-id) (ty) =
   let resolved = resolve st ty
   in when resolved
    if TypeVar (id) -> id == var-id
    if FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
    if ListTy (elem) -> occurs-in st var-id elem
    if _ -> False

Section: Unify

  unify : UnificationState -> CodexType -> CodexType -> UnifyResult
  unify (st) (a) (b) =
   let ra = resolve st a
   in let rb = resolve st b
   in unify-resolved st ra rb

  unify-resolved : UnificationState -> CodexType -> CodexType -> UnifyResult
  unify-resolved (st) (a) (b) =
   if types-equal a b then UnifyResult {
    success = True,
    state = st
   }
   else when a
    if TypeVar (id-a) ->
     if occurs-in st id-a b then UnifyResult {
      success = False,
      state = add-unify-error st "CDX2010" "Infinite type"
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-a b
      }
    if _ -> unify-rhs st a b

  types-equal : CodexType -> CodexType -> Boolean
  types-equal (a) (b) =
   when a
    if TypeVar (id-a) -> when b
     if TypeVar (id-b) -> id-a == id-b
     if _ -> False
    if IntegerTy -> when b
     if IntegerTy -> True
     if _ -> False
    if NumberTy -> when b
     if NumberTy -> True
     if _ -> False
    if TextTy -> when b
     if TextTy -> True
     if _ -> False
    if BooleanTy -> when b
     if BooleanTy -> True
     if _ -> False
    if CharTy -> when b
     if CharTy -> True
     if _ -> False
    if NothingTy -> when b
     if NothingTy -> True
     if _ -> False
    if VoidTy -> when b
     if VoidTy -> True
     if _ -> False
    if ErrorTy -> when b
     if ErrorTy -> True
     if _ -> False
    if _ -> False

  unify-rhs : UnificationState -> CodexType -> CodexType -> UnifyResult
  unify-rhs (st) (a) (b) =
   when b
    if TypeVar (id-b) ->
     if occurs-in st id-b a then UnifyResult {
      success = False,
      state = add-unify-error st "CDX2010" "Infinite type"
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-b a
      }
    if _ -> unify-structural st a b

  unify-structural : UnificationState -> CodexType -> CodexType -> UnifyResult
  unify-structural (st) (a) (b) =
   when a
    if IntegerTy -> when b
     if IntegerTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if NumberTy -> when b
     if NumberTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if TextTy -> when b
     if TextTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if BooleanTy -> when b
     if BooleanTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if NothingTy -> when b
     if NothingTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if VoidTy -> when b
     if VoidTy -> UnifyResult {
      success = True,
      state = st
     }
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if ErrorTy -> UnifyResult {
     success = True,
     state = st
    }
    if FunTy (pa) (ra) -> when b
     if FunTy (pb) (rb) -> unify-fun st pa ra pb rb
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if ListTy (ea) -> when b
     if ListTy (eb) -> unify st ea eb
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if ConstructedTy (na) (args-a) -> when b
     if ConstructedTy (nb) (args-b) ->
      if na.value == nb.value then unify-constructed-args st args-a args-b 0 (list-length args-a)
       else unify-mismatch st a b
     if SumTy (sb-name) (sb-ctors) ->
      if na.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if RecordTy (rb-name) (rb-fields) ->
      if na.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if SumTy (sa-name) (sa-ctors) -> when b
     if SumTy (sb-name) (sb-ctors) ->
      if sa-name.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if ConstructedTy (nb) (args-b) ->
      if sa-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if RecordTy (ra-name) (ra-fields) -> when b
     if RecordTy (rb-name) (rb-fields) ->
      if ra-name.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if ConstructedTy (nb) (args-b) ->
      if ra-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b
    if ForAllTy (id) (body) -> unify st body b
    if _ -> when b
     if ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     if _ -> unify-mismatch st a b

  unify-constructed-args : UnificationState -> List CodexType -> List CodexType -> Integer -> Integer -> UnifyResult
  unify-constructed-args (st) (args-a) (args-b) (i) (len) =
   if i == len then UnifyResult {
    success = True,
    state = st
   }
   else if i >= list-length args-b then UnifyResult {
    success = True,
    state = st
   }
   else let r = unify st (list-at args-a i) (list-at args-b i)
     in if r.success then unify-constructed-args (r.state) args-a args-b (i + 1) len
        else r

  unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> UnifyResult
  unify-fun (st) (pa) (ra) (pb) (rb) =
   let r1 = unify st pa pb
   in if r1.success then unify (r1.state) ra rb
      else r1

  unify-mismatch : UnificationState -> CodexType -> CodexType -> UnifyResult
  unify-mismatch (st) (a) (b) =
   UnifyResult {
    success = False,
    state = add-unify-error st "CDX2001" ("Type mismatch: " ++ type-tag a ++ " vs " ++ type-tag b)
   }

  type-tag : CodexType -> Text
  type-tag (ty) =
   when ty
    if IntegerTy -> "Integer"
    if NumberTy -> "Number"
    if TextTy -> "Text"
    if BooleanTy -> "Boolean"
    if CharTy -> "Char"
    if VoidTy -> "Void"
    if NothingTy -> "Nothing"
    if ErrorTy -> "Error"
    if FunTy (p) (r) -> "Fun"
    if ListTy (e) -> "List"
    if TypeVar (id) -> "T" ++ integer-to-text id
    if ForAllTy (id) (body) -> "ForAll"
    if SumTy (name) (ctors) -> "Sum:" ++ name.value
    if RecordTy (name) (fields) -> "Rec:" ++ name.value
    if ConstructedTy (name) (args) -> "Con:" ++ name.value

Section: Deep Resolve

  deep-resolve : UnificationState -> CodexType -> CodexType
  deep-resolve (st) (ty) =
   let resolved = resolve st ty
   in when resolved
    if FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
    if ListTy (elem) -> ListTy (deep-resolve st elem)
    if ConstructedTy (name) (args) -> ConstructedTy name (deep-resolve-list st args 0 (list-length args) [])
    if ForAllTy (id) (body) -> ForAllTy id (deep-resolve st body)
    if SumTy (name) (ctors) -> resolved
    if RecordTy (name) (fields) -> resolved
    if _ -> resolved

  deep-resolve-list : UnificationState -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
  deep-resolve-list (st) (args) (i) (len) (acc) =
   if i == len then acc
   else deep-resolve-list st args (i + 1) len (list-snoc acc (deep-resolve st (list-at args i)))

