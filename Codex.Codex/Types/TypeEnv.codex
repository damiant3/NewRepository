Chapter: Type Environment

 An immutable mapping from names to types, used during type checking.
 The environment is extended when entering let bindings, lambda
 parameters, and match branches, then restored on exit.

Section: Environment Type

  TypeEnv = record {
   bindings : List TypeBinding
  }

  TypeBinding = record {
   name : Text,
   bound-type : CodexType
  }

Section: Construction

  empty-type-env : TypeEnv
  empty-type-env = TypeEnv { bindings = [] }

Section: Lookup (binary search on sorted bindings)

  env-lookup : TypeEnv -> Text -> CodexType
  env-lookup (env) (name) =
   let len = list-length (env.bindings)
   in if len == 0 then ErrorTy
   else let pos = bsearch-text-pos (env.bindings) name 0 len
    in if pos >= len then ErrorTy
    else let b = list-at (env.bindings) pos
     in if b.name == name then b.bound-type else ErrorTy

  env-has : TypeEnv -> Text -> Boolean
  env-has (env) (name) =
   let len = list-length (env.bindings)
   in if len == 0 then False
   else let pos = bsearch-text-pos (env.bindings) name 0 len
    in if pos >= len then False
    else (list-at (env.bindings) pos).name == name

Section: Bind (sorted insert via list-insert-at)

  env-bind : TypeEnv -> Text -> CodexType -> TypeEnv
  env-bind (env) (name) (ty) =
   let len = list-length (env.bindings)
   in let pos = bsearch-text-pos (env.bindings) name 0 len
   in TypeEnv { bindings = list-insert-at (env.bindings) pos (TypeBinding { name = name, bound-type = ty }) }

Section: Builtins

  builtin-type-env : TypeEnv
  builtin-type-env =
   let e = empty-type-env
   in let e2 = env-bind e "negate" (FunTy IntegerTy IntegerTy)
   in let e3 = env-bind e2 "text-length" (FunTy TextTy IntegerTy)
   in let e4 = env-bind e3 "integer-to-text" (FunTy IntegerTy TextTy)
   in let e5 = env-bind e4 "char-at" (FunTy TextTy (FunTy IntegerTy CharTy))
   in let e5b = env-bind e5 "char-to-text" (FunTy CharTy TextTy)
   in let e6 = env-bind e5b "substring" (FunTy TextTy (FunTy IntegerTy (FunTy IntegerTy TextTy)))
   in let e7 = env-bind e6 "is-letter" (FunTy CharTy BooleanTy)
   in let e8 = env-bind e7 "is-digit" (FunTy CharTy BooleanTy)
   in let e9 = env-bind e8 "is-whitespace" (FunTy CharTy BooleanTy)
   in let e10 = env-bind e9 "char-code" (FunTy CharTy IntegerTy)
   in let e10b = env-bind e10 "char-code-at" (FunTy TextTy (FunTy IntegerTy IntegerTy))
   in let e11 = env-bind e10b "code-to-char" (FunTy IntegerTy CharTy)
   in let e12 = env-bind e11 "text-replace" (FunTy TextTy (FunTy TextTy (FunTy TextTy TextTy)))
   in let e13 = env-bind e12 "text-to-integer" (FunTy TextTy IntegerTy)
   in let e14 = env-bind e13 "show" (ForAllTy 0 (FunTy (TypeVar 0) TextTy))
   in let e15 = env-bind e14 "print-line" (FunTy TextTy NothingTy)
   in let e16 = env-bind e15 "list-length" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) IntegerTy))
   in let e16b = env-bind e16 "list-insert-at" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy IntegerTy (FunTy (TypeVar 0) (ListTy (TypeVar 0))))))
   in let e16c = env-bind e16b "text-compare" (FunTy TextTy (FunTy TextTy IntegerTy))
   in let e16d = env-bind e16c "list-snoc" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy (TypeVar 0) (ListTy (TypeVar 0)))))
   in let e17 = env-bind e16d "list-at" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy IntegerTy (TypeVar 0))))
   in let e18 = env-bind e17 "map" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 0) (TypeVar 1)) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 1))))))
   in let e19 = env-bind e18 "filter" (ForAllTy 0 (FunTy (FunTy (TypeVar 0) BooleanTy) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 0)))))
   in let e20 = env-bind e19 "fold" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 1) (FunTy (TypeVar 0) (TypeVar 1))) (FunTy (TypeVar 1) (FunTy (ListTy (TypeVar 0)) (TypeVar 1))))))
   in let e21 = env-bind e20 "read-line" TextTy
   in let e22 = env-bind e21 "read-file" (FunTy TextTy TextTy)
   in let e23 = env-bind e22 "write-file" (FunTy TextTy (FunTy TextTy NothingTy))
   in let e24 = env-bind e23 "file-exists" (FunTy TextTy BooleanTy)
   in let e25 = env-bind e24 "list-files" (FunTy TextTy (FunTy TextTy (ListTy TextTy)))
   in let e26 = env-bind e25 "text-split" (FunTy TextTy (FunTy TextTy (ListTy TextTy)))
   in let e27 = env-bind e26 "text-contains" (FunTy TextTy (FunTy TextTy BooleanTy))
   in let e28 = env-bind e27 "text-starts-with" (FunTy TextTy (FunTy TextTy BooleanTy))
   in let e29 = env-bind e28 "get-args" (ListTy TextTy)
   in let e30 = env-bind e29 "get-env" (FunTy TextTy TextTy)
   in let e31 = env-bind e30 "current-dir" TextTy
   in let e32 = env-bind e31 "fork" (ForAllTy 0 (FunTy (FunTy NothingTy (TypeVar 0)) (ConstructedTy (Name { value = "Task" }) [TypeVar 0])))
   in let e33 = env-bind e32 "await" (ForAllTy 0 (FunTy (ConstructedTy (Name { value = "Task" }) [TypeVar 0]) (TypeVar 0)))
   in let e34 = env-bind e33 "par" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 0) (TypeVar 1)) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 1))))))
   in let e35 = env-bind e34 "race" (ForAllTy 0 (FunTy (ListTy (FunTy NothingTy (TypeVar 0))) (TypeVar 0)))
   in let e36 = env-bind e35 "text-concat-list" (FunTy (ListTy TextTy) TextTy)
   in e36
