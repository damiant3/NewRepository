Chapter: AST Nodes

 The abstract syntax tree is the desugared representation used
 by the type checker and later stages. CST nodes carry tokens;
 AST nodes carry Names and resolved literal values.

Section: Names and Literals

  LiteralKind =
   | IntLit
   | NumLit
   | TextLit
   | CharLit
   | BoolLit

  BinaryOp =
   | OpAdd
   | OpSub
   | OpMul
   | OpDiv
   | OpPow
   | OpEq
   | OpNotEq
   | OpLt
   | OpGt
   | OpLtEq
   | OpGtEq
   | OpDefEq
   | OpAppend
   | OpCons
   | OpAnd
   | OpOr

Section: Expressions

  AExpr =
   | ALitExpr (Text) (LiteralKind)
   | ANameExpr (Name)
   | AApplyExpr (AExpr) (AExpr)
   | ABinaryExpr (AExpr) (BinaryOp) (AExpr)
   | AUnaryExpr (AExpr)
   | AIfExpr (AExpr) (AExpr) (AExpr)
   | ALetExpr (List ALetBind) (AExpr)
   | ALambdaExpr (List Name) (AExpr)
   | AMatchExpr (AExpr) (List AMatchArm)
   | AListExpr (List AExpr)
   | ARecordExpr (Name) (List AFieldExpr)
   | AFieldAccess (AExpr) (Name)
   | ADoExpr (List ADoStmt)
   | AHandleExpr (Name) (AExpr) (List AHandleClause)
   | AErrorExpr (Text)

  ALetBind = record {
   name : Name,
   value : AExpr
  }

  AMatchArm = record {
   pattern : APat,
   body : AExpr
  }

  AFieldExpr = record {
   name : Name,
   value : AExpr
  }

  ADoStmt =
   | ADoBindStmt (Name) (AExpr)
   | ADoExprStmt (AExpr)

  AHandleClause = record {
   op-name : Name,
   resume-name : Name,
   body : AExpr
  }

Section: Patterns

  APat =
   | AVarPat (Name)
   | ALitPat (Text) (LiteralKind)
   | ACtorPat (Name) (List APat)
   | AWildPat

Section: Type Expressions

  ATypeExpr =
   | ANamedType (Name)
   | AFunType (ATypeExpr) (ATypeExpr)
   | AAppType (ATypeExpr) (List ATypeExpr)
   | AEffectType (List Name) (ATypeExpr)

Section: Definitions

  AParam = record {
   name : Name
  }

  ADef = record {
   name : Name,
   params : List AParam,
   declared-type : List ATypeExpr,
   body : AExpr,
   chapter-slug : Text
  }

  ARecordFieldDef = record {
   name : Name,
   type-expr : ATypeExpr
  }

  AVariantCtorDef = record {
   name : Name,
   fields : List ATypeExpr
  }

  ATypeDef =
   | ARecordTypeDef (Name) (List Name) (List ARecordFieldDef)
   | AVariantTypeDef (Name) (List Name) (List AVariantCtorDef)

  AEffectOpDef = record {
   name : Name,
   type-expr : ATypeExpr
  }

  AEffectDef = record {
   name : Name,
   ops : List AEffectOpDef
  }

Section: Chapter

  ACitesDecl = record {
   chapter-name : Name,
   selected-names : List Name
  }

  AChapter = record {
   name : Name,
   defs : List ADef,
   type-defs : List ATypeDef,
   effect-defs : List AEffectDef,
   citations : List ACitesDecl,
   chapter-title : Text,
   prose : Text,
   section-titles : List Text
  }

