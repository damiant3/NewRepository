Chapter: Main

 Entry point for the Codex compiler. Reads a source file path from stdin,
 compiles the source, and writes the C# output.

Section: Pipeline

  compile : Text -> Text -> Text
  compile (source) (module-name) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
    in let doc = parse-document st
     in let ast = desugar-document doc module-name
      in let check-result = check-module ast
       in let ir = lower-module ast check-result.types check-result.state
        in emit-full-module ir ast.type-defs

Section: Pipeline with Name Resolution

  compile-checked : Text -> Text -> CompileResult
  compile-checked (source) (module-name) =
   compile-with-imports source module-name []

  compile-with-imports : Text -> Text -> List ResolveResult -> CompileResult
  compile-with-imports (source) (module-name) (imported) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
    in let doc = parse-document st
     in let ast = desugar-document doc module-name
      in let resolve-result = resolve-module-with-imports ast imported
       in if list-length resolve-result.errors > 0
        then CompileError resolve-result.errors
        else
         let check-result = check-module ast
         in let ir = lower-module ast check-result.types check-result.state
          in CompileOk (emit-full-module ir ast.type-defs) check-result

  CompileResult =
   | CompileOk (Text) (ModuleResult)
   | CompileError (List Diagnostic)

Section: Entry Point

  main : [Console, FileSystem] Nothing
  main = do
   path <- read-line
   source <- read-file path
   print-line (compile source "Program")
