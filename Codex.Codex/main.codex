Chapter: Main

 Entry point for the Codex compiler.

  cites CSharpEmitter (emit-full-chapter)
  cites CodexEmitter (emit-type-defs, emit-def, collect-ctor-names)
  cites TypeChecker (resolve-type-expr)
  cites X86-64 (x86-64-emit-chapter)

Section: Pipeline

  compile : Text -> Text -> Text
  compile (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0 []
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
   in let ast = desugar-document doc chapter-name
   in let scoped = scope-achapter ast colliding assignments
   in let check-result = check-chapter scoped
   in let ir = lower-chapter scoped (check-result.types) (check-result.state)
   in emit-full-chapter ir (scoped.type-defs)

Section: Pipeline with Name Resolution

  compile-checked : Text -> Text -> CompileResult
  compile-checked (source) (chapter-name) =
   compile-with-citations source chapter-name []

  compile-with-citations : Text -> Text -> List ResolveResult -> CompileResult
  compile-with-citations (source) (chapter-name) (imported) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let doc = parse-document st
   in if bag-has-errors (doc.parse-bag) then CompileError (bag-diagnostics (doc.parse-bag))
      else let ast = desugar-document doc chapter-name
   in let resolve-result = resolve-chapter-with-citations ast imported
   in let post-resolve = bag-merge (doc.parse-bag) (resolve-result.bag)
   in if bag-has-errors (resolve-result.bag) then CompileError (bag-diagnostics post-resolve)
      else let check-result = check-chapter ast
   in let post-check = bag-merge post-resolve (check-result.state.bag)
   in if bag-has-errors (check-result.state.bag) then CompileError (bag-diagnostics post-check)
      else let ir = lower-chapter ast (check-result.types) (check-result.state)
   in CompileOk (emit-full-chapter ir (ast.type-defs)) check-result

  CompileResult =
   | CompileOk (Text) (ChapterResult)
   | CompileError (List Diagnostic)

Section: Streaming Pipeline

  compile-streaming : Text -> Text -> [Console] Nothing
  compile-streaming (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let doc = parse-document st
   in do
       print-parse-errors (bag-diagnostics (doc.parse-bag)) 0
       let ast = desugar-document doc chapter-name
       in let check-result = check-chapter ast
       in let ctor-types = collect-ctor-bindings (ast.type-defs) 0 (list-length (ast.type-defs)) []
       in let all-types = ctor-types ++ check-result.types ++ builtin-type-env.bindings
       in let ctor-names = collect-ctor-names (ast.type-defs) 0
       in do
           print-line (emit-type-defs (ast.type-defs) 0)
           stream-defs (ast.defs) all-types (check-result.state) ctor-names 0 (list-length (ast.defs))
           print-line ""

  print-parse-errors : List Diagnostic -> Integer -> [Console] Nothing
  print-parse-errors (errors) (i) =
   if i == list-length errors then print-line ""
   else do
     print-line (diagnostic-display (list-at errors i) empty-file-table)
     print-parse-errors errors (i + 1)

  stream-defs : List ADef -> List TypeBinding -> UnificationState -> List Text -> Integer -> Integer -> [Console] Nothing
  stream-defs (defs) (types) (ust) (ctor-names) (i) (len) =
   if i == len then print-line ""
   else let def = list-at defs i
   in let ir-def = lower-def def types ust
   in if is-error-body (ir-def.body) then print-line ("COMPILE-ERROR: def '" ++ ir-def.name ++ "' has error body: " ++ error-message (ir-def.body))
   else let text = emit-def ir-def ctor-names
   in do
       print-line text
       stream-defs defs types ust ctor-names (i + 1) len

Section: Streaming Pipeline v2

  compile-streaming-v2 : Text -> Text -> [Console] Nothing
  compile-streaming-v2 (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let type-defs = map-list desugar-type-def (scan.type-defs)
   in let headers = scan.def-headers
   in let assignments = build-all-assignments headers 0 []
   in let colliding = find-colliding-names assignments
   in do
    compile-with-scope tokens type-defs headers assignments colliding

  compile-with-scope : List Token -> List ATypeDef -> List DefHeader -> List ChapterAssignment -> List Text -> [Console] Nothing
  compile-with-scope (tokens) (type-defs) (headers) (assignments) (colliding) =
   let scoped-headers = scope-def-headers headers colliding assignments 0 []
   in let tdm = build-type-def-map type-defs 0 (list-length type-defs) []
   in let tenv = register-type-defs empty-unification-state builtin-type-env tdm type-defs 0 (list-length type-defs)
   in let env = register-def-headers (tenv.state) (tenv.env) tdm scoped-headers 0 (list-length scoped-headers)
   in let ctor-types = collect-ctor-bindings type-defs 0 (list-length type-defs) []
   in let all-types = ctor-types ++ env.env.bindings
   in let ctor-names = collect-ctor-names type-defs 0
   in do
    print-line (emit-type-defs type-defs 0)
    emit-defs-scoped tokens headers all-types (env.state) ctor-names colliding assignments 0 (list-length headers)
    print-line ""

  register-def-headers : UnificationState -> TypeEnv -> List TypeBinding -> List DefHeader -> Integer -> Integer -> LetBindResult
  register-def-headers (st) (env) (tdm) (headers) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let hdr = list-at headers i
   in let declared = desugar-annotations (hdr.ann)
   in let ty = if list-length declared == 0 then let fr = fresh-and-advance st
     in let env2 = env-bind env (hdr.name.text) (fr.var-type)
     in LetBindResult {
      state = fr.state,
      env = env2
     }
     else let resolved = resolve-type-expr tdm (list-at declared 0)
     in let pr = parameterize-type st resolved
     in LetBindResult {
      state = pr.state,
      env = env-bind env (hdr.name.text) (pr.parameterized)
     }
   in register-def-headers (ty.state) (ty.env) tdm headers (i + 1) len

  check-defs-streaming : List Token -> List DefHeader -> UnificationState -> TypeEnv -> Integer -> Integer -> List TypeBinding -> ChapterResult
  check-defs-streaming (tokens) (headers) (ust) (env) (i) (len) (acc) =
   if i == len then ChapterResult {
    types = acc,
    state = ust
   }
   else let hdr = list-at headers i
   in let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos,
    bag = empty-bag
   }
   in let body-result = parse-expr body-st
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef = desugar-def def
   in let r = check-def ust env adef
   in let resolved = deep-resolve (r.state) (r.inferred-type)
   in let entry = TypeBinding {
    name = adef.name.value,
    bound-type = resolved
   }
   in check-defs-streaming tokens headers (r.state) env (i + 1) len (list-snoc acc entry)

  emit-defs-streaming : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> Integer -> Integer -> [Console] Nothing
  emit-defs-streaming (tokens) (headers) (all-types) (ust) (ctor-names) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos,
    bag = empty-bag
   }
   in let body-result = parse-expr body-st
   in let parse-errs = unwrap-parse-errors body-result
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef = desugar-def def
   in let ir-def = lower-def adef all-types ust
   in emit-streaming-def-checked (hdr.name.text) parse-errs ir-def ctor-names tokens headers all-types ust (i + 1) len

  emit-streaming-def-checked : Text -> List Diagnostic -> IRDef -> List Text -> List Token -> List DefHeader -> List TypeBinding -> UnificationState -> Integer -> Integer -> [Console] Nothing
  emit-streaming-def-checked (def-name) (parse-errs) (ir-def) (ctor-names) (tokens) (headers) (all-types) (ust) (next-i) (len) =
   if list-length parse-errs > 0 then print-def-parse-errors def-name parse-errs
   else if is-error-body (ir-def.body) then print-line ("COMPILE-ERROR: def '" ++ ir-def.name ++ "' has error body: " ++ error-message (ir-def.body))
   else let text = emit-def ir-def ctor-names
   in if text == "" then emit-defs-streaming tokens headers all-types ust ctor-names next-i len
   else do
    print-line text
    emit-defs-streaming tokens headers all-types ust ctor-names next-i len

  emit-defs-scoped : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> Integer -> Integer -> [Console] Nothing
  emit-defs-scoped (tokens) (headers) (all-types) (ust) (ctor-names) (colliding) (assignments) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in let rn = build-chapter-rename-map colliding assignments (hdr.chapter-slug)
   in emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn (hdr.chapter-slug) i len

  emit-defs-same-chapter : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> List RenameEntry -> Text -> Integer -> Integer -> [Console] Nothing
  emit-defs-same-chapter (tokens) (headers) (all-types) (ust) (ctor-names) (colliding) (assignments) (rn) (cur-slug) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in if hdr.chapter-slug /= cur-slug
      then emit-defs-scoped tokens headers all-types ust ctor-names colliding assignments i len
      else emit-one-scoped-def tokens hdr all-types ust ctor-names colliding assignments rn headers i len

  emit-one-scoped-def : List Token -> DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> List RenameEntry -> List DefHeader -> Integer -> Integer -> [Console] Nothing
  emit-one-scoped-def (tokens) (hdr) (all-types) (ust) (ctor-names) (colliding) (assignments) (rn) (headers) (i) (len) =
   let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos,
    bag = empty-bag
   }
   in let body-result = parse-expr body-st
   in let parse-errs = unwrap-parse-errors body-result
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef-raw = desugar-def def
   in let scoped-name = scope-def-name colliding assignments (adef-raw.name.value) (hdr.chapter-slug)
   in let adef = ADef {
    name = make-name scoped-name,
    params = adef-raw.params,
    declared-type = adef-raw.declared-type,
    body = adef-raw.body,
    chapter-slug = adef-raw.chapter-slug,
    span = adef-raw.span
   }
   in let ir-def = lower-def adef all-types ust
   in let scoped-body = rename-ir-expr rn (ir-def.body)
   in let scoped-def = IRDef {
    name = ir-def.name,
    params = ir-def.params,
    type-val = ir-def.type-val,
    body = scoped-body,
    chapter-slug = hdr.chapter-slug,
    span = ir-def.span
   }
   in emit-scoped-def-checked (hdr.name.text) parse-errs scoped-def ctor-names tokens headers all-types ust colliding assignments rn (hdr.chapter-slug) (i + 1) len

  emit-scoped-def-checked : Text -> List Diagnostic -> IRDef -> List Text -> List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> List ChapterAssignment -> List RenameEntry -> Text -> Integer -> Integer -> [Console] Nothing
  emit-scoped-def-checked (def-name) (parse-errs) (scoped-def) (ctor-names) (tokens) (headers) (all-types) (ust) (colliding) (assignments) (rn) (slug) (next-i) (len) =
   if list-length parse-errs > 0 then print-def-parse-errors def-name parse-errs
   else if is-error-body (scoped-def.body) then print-line ("COMPILE-ERROR: def '" ++ scoped-def.name ++ "' has error body: " ++ error-message (scoped-def.body))
   else let text = emit-def scoped-def ctor-names
   in if text == "" then emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn slug next-i len
   else do
    print-line text
    emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn slug next-i len

  unwrap-body : ParseExprResult -> Expr
  unwrap-body (r) =
   when r
    if ExprOk (e) (st) -> e

  unwrap-parse-errors : ParseExprResult -> List Diagnostic
  unwrap-parse-errors (r) =
   when r
    if ExprOk (e) (st) -> bag-diagnostics (st.bag)

  print-def-parse-errors : Text -> List Diagnostic -> [Console] Nothing
  print-def-parse-errors (def-name) (errs) =
   if list-length errs == 0 then print-line ""
   else do
    print-line ("PARSE-ERRORS in '" ++ def-name ++ "':")
    print-parse-errors errs 0

Section: Whitespace Normalization

  normalize-whitespace : Text -> Text
  normalize-whitespace (s) =
   let r = text-replace s "\n\n\n" "\n\n"
   in if text-length r == text-length s then s
      else normalize-whitespace r

Section: Binary Compilation

  BinaryScan = record {
   tokens : List Token,
   type-defs : List ATypeDef,
   headers : List DefHeader,
   citations : List CitesDecl,
   n-defs : Integer
  }

  BinaryScope = record {
   scan : BinaryScan,
   assignments : List ChapterAssignment,
   colliding : List Text,
   scoped-headers : List DefHeader
  }

  BinaryEnv = record {
   scope : BinaryScope,
   ust : UnificationState,
   ctor-types : List TypeBinding,
   all-types : List TypeBinding
  }

  BinaryAnalysis = record {
   env : BinaryEnv,
   parse-results : List ParsedDef,
   bad-full : List Text,
   all-parse-bag : DiagnosticBag
  }

  bin-tokenize : Text -> BinaryScan
  bin-tokenize (source) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in BinaryScan {
    tokens = tokens,
    type-defs = map-list desugar-type-def (scan.type-defs),
    headers = scan.def-headers,
    citations = scan.citations,
    n-defs = list-length (scan.def-headers)
   }

  bin-scope : BinaryScan -> BinaryScope
  bin-scope (scan) =
   let assignments = build-all-assignments (scan.headers) 0 []
   in let colliding = find-colliding-names assignments
   in let scoped-headers = scope-def-headers (scan.headers) colliding assignments 0 []
   in BinaryScope {
    scan = scan,
    assignments = assignments,
    colliding = colliding,
    scoped-headers = scoped-headers
   }

  bin-build-env : BinaryScope -> BinaryEnv
  bin-build-env (scope) =
   let scan = scope.scan
   in let tdm = build-type-def-map (scan.type-defs) 0 (list-length (scan.type-defs)) []
   in let tenv = register-type-defs empty-unification-state builtin-type-env tdm (scan.type-defs) 0 (list-length (scan.type-defs))
   in let env = register-def-headers (tenv.state) (tenv.env) tdm (scope.scoped-headers) 0 (list-length (scope.scoped-headers))
   in let ctor-types = collect-ctor-bindings (scan.type-defs) 0 (list-length (scan.type-defs)) []
   in BinaryEnv {
    scope = scope,
    ust = env.state,
    ctor-types = ctor-types,
    all-types = ctor-types ++ env.env.bindings
   }

  bin-analyze : BinaryEnv -> BinaryAnalysis
  bin-analyze (benv) =
   let scope = benv.scope
   in let scan = scope.scan
   in let parse-results = parse-all-bodies (scan.tokens) (scan.headers) 0 (scan.n-defs) []
   in let chapter-bags = group-parse-bags parse-results 0 []
   in let bad-initial = collect-bad-chapters chapter-bags 0 []
   in let bad-full = close-bad-chapters-under-citations bad-initial (scan.citations)
   in let all-parse-bag = merge-all-parse-bags parse-results 0 empty-bag
   in BinaryAnalysis {
    env = benv,
    parse-results = parse-results,
    bad-full = bad-full,
    all-parse-bag = all-parse-bag
   }

  bin-emit-codegen : BinaryAnalysis -> CodegenState
  bin-emit-codegen (an) =
   let benv = an.env
   in let scope = benv.scope
   in let cg0 = x86-64-init-codegen-streaming (benv.ctor-types) (scope.scan.n-defs)
   in let cg0-seeded = record-set cg0 "bag" (an.all-parse-bag)
   in let pre-rt-wm = heap-save
   in let cg1 = emit-runtime-helpers cg0-seeded
   in let rt-cleanup = heap-restore pre-rt-wm
   in let watermark = heap-save
   in let tramp = bare-metal-trampoline
   in emit-defs-binary-gated (an.parse-results) (an.bad-full) (benv.all-types) (benv.ust) (scope.colliding) (scope.assignments) cg1 watermark 0 (list-length (an.parse-results))

  bin-finalize : CodegenState -> EmitChapterResult
  bin-finalize (cg) =
   let tramp = bare-metal-trampoline
   in x86-64-finalize cg (tramp.far-jump-patch-pos)

  compile-to-binary : Text -> Text -> EmitChapterResult
  compile-to-binary (source) (chapter-name) =
   let scan = bin-tokenize source
   in let scope = bin-scope scan
   in let benv = bin-build-env scope
   in let an = bin-analyze benv
   in let cg = bin-emit-codegen an
   in bin-finalize cg

Section: Header Scoping
  scope-def-headers : List DefHeader -> List Text -> List ChapterAssignment -> Integer -> List DefHeader -> List DefHeader
  scope-def-headers (headers) (colliding) (assignments) (i) (acc) =
   if i == list-length headers then acc
   else let h = list-at headers i
   in let scoped-text = scope-def-name colliding assignments (h.name.text) (h.chapter-slug)
   in let scoped-tok = Token {
    kind = h.name.kind,
    text = scoped-text,
    offset = h.name.offset,
    line = h.name.line,
    column = h.name.column,
    file-id = h.name.file-id
   }
   in scope-def-headers headers colliding assignments (i + 1) (list-snoc acc (DefHeader {
    name = scoped-tok,
    params = h.params,
    ann = h.ann,
    body-pos = h.body-pos,
    chapter-slug = h.chapter-slug
   }))

Section: Per-def Parse Collection

  ParsedDef = record {
   header : DefHeader,
   body : Expr,
   parse-bag : DiagnosticBag
  }

  parse-all-bodies : List Token -> List DefHeader -> Integer -> Integer -> List ParsedDef -> List ParsedDef
  parse-all-bodies (tokens) (headers) (i) (n) (acc) =
   if i >= n then acc
   else let hdr = list-at headers i
   in let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos,
    bag = empty-bag
   }
   in let body-result = parse-expr body-st
   in let bag = parse-bag-of body-result
   in let body = unwrap-body body-result
   in parse-all-bodies tokens headers (i + 1) n (list-snoc acc (ParsedDef { header = hdr, body = body, parse-bag = bag }))

  parse-bag-of : ParseExprResult -> DiagnosticBag
  parse-bag-of (r) =
   when r
    if ExprOk (e) (st) -> st.bag

  merge-all-parse-bags : List ParsedDef -> Integer -> DiagnosticBag -> DiagnosticBag
  merge-all-parse-bags (pds) (i) (acc) =
   if i == list-length pds then acc
   else merge-all-parse-bags pds (i + 1) (bag-merge acc ((list-at pds i).parse-bag))

Section: Chapter Gating

  ChapterBag = record {
   slug : Text,
   bag : DiagnosticBag
  }

  group-parse-bags : List ParsedDef -> Integer -> List ChapterBag -> List ChapterBag
  group-parse-bags (pds) (i) (acc) =
   if i == list-length pds then acc
   else let pd = list-at pds i
   in group-parse-bags pds (i + 1) (chapter-bag-insert acc (pd.header.chapter-slug) (pd.parse-bag) 0 (list-length acc))

  chapter-bag-insert : List ChapterBag -> Text -> DiagnosticBag -> Integer -> Integer -> List ChapterBag
  chapter-bag-insert (acc) (slug) (bag) (i) (len) =
   if i >= len then list-snoc acc (ChapterBag { slug = slug, bag = bag })
   else let cb = list-at acc i
   in if cb.slug == slug then replace-at acc i (ChapterBag { slug = slug, bag = bag-merge (cb.bag) bag }) 0 len []
   else chapter-bag-insert acc slug bag (i + 1) len

  replace-at : List ChapterBag -> Integer -> ChapterBag -> Integer -> Integer -> List ChapterBag -> List ChapterBag
  replace-at (xs) (target) (new-val) (i) (n) (acc) =
   if i == n then acc
   else if i == target then replace-at xs target new-val (i + 1) n (list-snoc acc new-val)
   else replace-at xs target new-val (i + 1) n (list-snoc acc (list-at xs i))

  collect-bad-chapters : List ChapterBag -> Integer -> List Text -> List Text
  collect-bad-chapters (cbs) (i) (acc) =
   if i == list-length cbs then acc
   else let cb = list-at cbs i
   in if bag-has-errors (cb.bag) then collect-bad-chapters cbs (i + 1) (list-snoc acc (cb.slug))
   else collect-bad-chapters cbs (i + 1) acc

  has-slug : List Text -> Text -> Boolean
  has-slug (xs) (name) =
   has-slug-loop xs name 0 (list-length xs)

  has-slug-loop : List Text -> Text -> Integer -> Integer -> Boolean
  has-slug-loop (xs) (name) (i) (n) =
   if i == n then False
   else if list-at xs i == name then True
   else has-slug-loop xs name (i + 1) n

  close-bad-chapters-under-citations : List Text -> List CitesDecl -> List Text
  close-bad-chapters-under-citations (bad) (citations) =
   let bad2 = propagate-bad-once bad citations 0 (list-length citations)
   in if list-length bad2 == list-length bad then bad
      else close-bad-chapters-under-citations bad2 citations

  propagate-bad-once : List Text -> List CitesDecl -> Integer -> Integer -> List Text
  propagate-bad-once (bad) (citations) (i) (n) =
   if i == n then bad
   else let c = list-at citations i
   in let cited = c.chapter-name.text
   in let citer = c.citing-chapter
   in if has-slug bad cited then if has-slug bad citer then propagate-bad-once bad citations (i + 1) n
         else propagate-bad-once (list-snoc bad citer) citations (i + 1) n
      else propagate-bad-once bad citations (i + 1) n

Section: Gated Binary Emit

  emit-defs-binary-gated : List ParsedDef -> List Text -> List TypeBinding -> UnificationState -> List Text -> List ChapterAssignment -> CodegenState -> Integer -> Integer -> Integer -> CodegenState
  emit-defs-binary-gated (pds) (bad-chapters) (all-types) (ust) (colliding) (assignments) (cg) (watermark) (i) (n) =
   if i >= n then cg
   else let pd = list-at pds i
   in let hdr = pd.header
   in let slug = hdr.chapter-slug
   in if has-slug bad-chapters slug then emit-defs-binary-gated pds bad-chapters all-types ust colliding assignments cg watermark (i + 1) n
      else let rn = build-chapter-rename-map colliding assignments slug
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = pd.body,
    chapter-slug = slug
   }
   in let adef-raw = desugar-def def
   in let scoped-name = scope-def-name colliding assignments (adef-raw.name.value) slug
   in let adef = ADef {
    name = make-name scoped-name,
    params = adef-raw.params,
    declared-type = adef-raw.declared-type,
    body = adef-raw.body,
    chapter-slug = adef-raw.chapter-slug,
    span = adef-raw.span
   }
   in let ir-def = lower-def adef all-types ust
   in let scoped-body = rename-ir-expr rn (ir-def.body)
   in let scoped = IRDef {
    name = ir-def.name,
    params = ir-def.params,
    type-val = ir-def.type-val,
    body = scoped-body,
    chapter-slug = slug,
    span = ir-def.span
   }
   in let cg2 = emit-function cg scoped
   in emit-defs-binary-gated pds bad-chapters all-types ust colliding assignments cg2 watermark (i + 1) n

  print-codegen-errors : List Diagnostic -> Integer -> Integer -> [Console] Nothing
  print-codegen-errors (errs) (i) (len) =
   if i == len then print-line ""
   else do
    print-line (diagnostic-display (list-at errs i) empty-file-table)
    print-codegen-errors errs (i + 1) len

  print-codegen-error-header : List Diagnostic -> [Console] Nothing
  print-codegen-error-header (errs) =
   let n = list-length errs
   in if n == 0 then print-line ""
   else do
    print-line ("CODEGEN-ERRORS:" ++ integer-to-text n)
    print-codegen-errors errs 0 n

Section: Entry Point

  emit-binary : Text -> [Console, FileSystem] Nothing
  emit-binary (source) =
   let result = compile-to-binary source "Codex_Codex"
   in do
    print-codegen-error-header (bag-diagnostics (result.bag))
    print-line ("SIZE:" ++ integer-to-text (list-length (result.bytes)))
    write-binary (result.bytes)

  emit-defs-diag-loop : List ParsedDef -> List Text -> List TypeBinding -> UnificationState -> List Text -> List ChapterAssignment -> CodegenState -> Integer -> Integer -> Integer -> [Console] CodegenState
  emit-defs-diag-loop (pds) (bad-chapters) (all-types) (ust) (colliding) (assignments) (cg) (watermark) (i) (n) =
   if i >= n then cg
   else let pd = list-at pds i
   in let hdr = pd.header
   in let slug = hdr.chapter-slug
   in do
    print-line ("PH:def:" ++ integer-to-text i ++ ":" ++ hdr.name.text)
    if has-slug bad-chapters slug then emit-defs-diag-loop pds bad-chapters all-types ust colliding assignments cg watermark (i + 1) n
    else let rn = build-chapter-rename-map colliding assignments slug
    in let def = Def {
     name = hdr.name,
     params = hdr.params,
     ann = hdr.ann,
     body = pd.body,
     chapter-slug = slug
    }
    in let adef-raw = desugar-def def
    in let scoped-name = scope-def-name colliding assignments (adef-raw.name.value) slug
    in let adef = ADef {
     name = make-name scoped-name,
     params = adef-raw.params,
     declared-type = adef-raw.declared-type,
     body = adef-raw.body,
     chapter-slug = adef-raw.chapter-slug,
     span = adef-raw.span
    }
    in let ir-def = lower-def adef all-types ust
    in do
     print-line ("PH:lowered:" ++ integer-to-text i)
     let scoped-body = rename-ir-expr rn (ir-def.body)
     in let scoped = IRDef {
      name = ir-def.name,
      params = ir-def.params,
      type-val = ir-def.type-val,
      body = scoped-body,
      chapter-slug = slug,
      span = ir-def.span
     }
     in do
      print-line ("PH:renamed:" ++ integer-to-text i)
      let cg2 = emit-function cg scoped
      in do
       print-line ("PH:emitted:" ++ integer-to-text i)
       emit-defs-diag-loop pds bad-chapters all-types ust colliding assignments cg2 watermark (i + 1) n

  emit-binary-diag : Text -> [Console, FileSystem] Nothing
  emit-binary-diag (source) = do
   print-line "PH:tokenize"
   let scan = bin-tokenize source
   in do
    print-line "PH:scope"
    let scope = bin-scope scan
    in do
     print-line "PH:build-env"
     let benv = bin-build-env scope
     in do
      print-line "PH:analyze"
      let an = bin-analyze benv
      in do
       print-line "PH:codegen"
       let benv = an.env
       in let scope = benv.scope
       in let cg0 = x86-64-init-codegen-streaming (benv.ctor-types) (scope.scan.n-defs)
       in let cg0-seeded = record-set cg0 "bag" (an.all-parse-bag)
       in do
        print-line "PH:codegen-rt"
        let cg1 = emit-runtime-helpers cg0-seeded
        in let watermark = heap-save
        in do
         print-line "PH:codegen-defs"
         cg <- emit-defs-diag-loop (an.parse-results) (an.bad-full) (benv.all-types) (benv.ust) (scope.colliding) (scope.assignments) cg1 watermark 0 (list-length (an.parse-results))
         print-line "PH:finalize"
         let result = bin-finalize cg
         in do
          print-line "PH:compile-done"
          print-codegen-error-header (bag-diagnostics (result.bag))
          print-line ("SIZE:" ++ integer-to-text (list-length (result.bytes)))
          write-binary (result.bytes)
          print-line "PH:wrote"

  main : [Console, FileSystem] Nothing
  main = do
   mode <- read-line
   source <- read-file mode
   let clean = normalize-whitespace source
   in if mode == "BINARY" then emit-binary clean
      else if mode == "BINARY-DIAG" then emit-binary-diag clean
      else compile-streaming-v2 clean "Program"

