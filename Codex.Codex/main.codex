Chapter: Main

 Entry point for the Codex compiler.

  cites Emit chapter Codex Emitter (emit-type-defs, emit-def, collect-ctor-names)
  cites Emit chapter X86-64 Code Generator (x86-64-emit-chapter)

Section: Pipeline

  compile-text : Text -> Text -> Text
  compile-text (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0 []
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
   in let ast = desugar-document doc chapter-name
   in let scoped = scope-achapter ast colliding assignments
   in let check-result = check-chapter scoped
   in let ir = lower-chapter scoped (check-result.types) (check-result.state)
   in let ctor-names = collect-ctor-names (scoped.type-defs) 0
   in emit-type-defs (scoped.type-defs) 0 ++ emit-text-defs (ir.defs) ctor-names 0

  emit-text-defs : List IRDef -> List Text -> Integer -> Text
  emit-text-defs (defs) (ctor-names) (i) =
   if i == list-length defs then ""
   else emit-def (list-at defs i) ctor-names ++ "\n" ++ emit-text-defs defs ctor-names (i + 1)

Section: Whitespace Normalization

  normalize-whitespace : Text -> Text
  normalize-whitespace (s) =
   let r = text-replace s "\n\n\n" "\n\n"
   in if text-length r == text-length s then s
      else normalize-whitespace r

Section: Binary Compilation

  compile-to-binary : Text -> Text -> EmitChapterResult
  compile-to-binary (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0 []
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
   in let ast = desugar-document doc chapter-name
   in let scoped = scope-achapter ast colliding assignments
   in let cite-bag = check-duplicate-cites (scoped.citations)
   in let check-result = check-chapter scoped
   in let ir = lower-chapter scoped (check-result.types) (check-result.state)
   in let ctor-types = collect-ctor-bindings (scoped.type-defs) 0 (list-length (scoped.type-defs)) []
   in let emit-result = x86-64-emit-chapter ir ctor-types
   in EmitChapterResult {
    bytes = emit-result.bytes,
    bag = bag-merge cite-bag (emit-result.bag)
   }

Section: Codegen Diagnostics

  print-codegen-errors : List Diagnostic -> Integer -> Integer -> [Console] Nothing
  print-codegen-errors (errs) (i) (len) =
   if i == len then print-line ""
   else act
    print-line (diagnostic-display (list-at errs i) empty-file-table)
    print-codegen-errors errs (i + 1) len
   end

  print-codegen-error-header : List Diagnostic -> [Console] Nothing
  print-codegen-error-header (errs) =
   let n = list-length errs
   in if n == 0 then print-line ""
   else act
    print-line ("CODEGEN-ERRORS:" ++ integer-to-text n)
    print-codegen-errors errs 0 n
   end

Section: Entry Point

  emit-binary : Text -> [Console, FileSystem] Nothing
  emit-binary (source) =
   let result = compile-to-binary source "Codex_Codex"
   in act
    print-codegen-error-header (bag-diagnostics (result.bag))
    print-line ("SIZE:" ++ integer-to-text (list-length (result.bytes)))
    write-binary (result.bytes)
   end

  main : [Console, FileSystem] Nothing = act
   mode <- read-line
   source <- read-file mode
   let clean = normalize-whitespace source
   in if mode == "BINARY" then emit-binary clean
      else print-line (compile-text clean "Program")
  end

