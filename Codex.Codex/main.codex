Chapter: Main

 Entry point for the Codex compiler. Reads a source file path from stdin,
 compiles the source, and writes the C# output.

  cites CSharpEmitter (emit-full-chapter)
  cites CodexEmitter (emit-type-defs, emit-def, collect-ctor-names)
  cites TypeChecker (resolve-type-expr)

Section: Pipeline

  compile : Text -> Text -> Text
  compile (source) (chapter-name) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
     in let ast = desugar-document doc chapter-name
      in let check-result = check-chapter ast
       in let ir = lower-chapter ast (check-result.types) (check-result.state)
        in let scoped-ir = scope-ir-chapter ir colliding assignments
         in emit-full-chapter scoped-ir (ast.type-defs)


Section: Pipeline with Name Resolution

  compile-checked : Text -> Text -> CompileResult
  compile-checked (source) (chapter-name) =
   compile-with-citations source chapter-name []

  compile-with-citations : Text -> Text -> List ResolveResult -> CompileResult
  compile-with-citations (source) (chapter-name) (imported) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
   in let doc = parse-document st
     in let ast = desugar-document doc chapter-name
      in let resolve-result = resolve-chapter-with-citations ast imported
       in if list-length (resolve-result.errors) > 0 then CompileError (resolve-result.errors)
          else let check-result = check-chapter ast
         in let ir = lower-chapter ast (check-result.types) (check-result.state)
          in CompileOk (emit-full-chapter ir (ast.type-defs)) check-result

  CompileResult =
   | CompileOk (Text) (ChapterResult)
   | CompileError (List Diagnostic)

Section: Streaming Pipeline

  compile-streaming : Text -> Text -> [Console] Nothing
  compile-streaming (source) (chapter-name) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
   in let doc = parse-document st
     in let ast = desugar-document doc chapter-name
      in let check-result = check-chapter ast
       in let ctor-types = collect-ctor-bindings (ast.type-defs) 0 (list-length (ast.type-defs)) []
        in let all-types = ctor-types ++ check-result.types ++ builtin-type-env.bindings
         in let ctor-names = collect-ctor-names (ast.type-defs) 0
          in do
           print-line (emit-type-defs (ast.type-defs) 0)
           stream-defs (ast.defs) all-types (check-result.state) ctor-names 0 (list-length (ast.defs))
           print-line ""

  stream-defs : List ADef -> List TypeBinding -> UnificationState -> List Text -> Integer -> Integer -> [Console] Nothing
  stream-defs (defs) (types) (ust) (ctor-names) (i) (len) =
   if i == len then print-line ""
   else let def = list-at defs i
   in let ir-def = lower-def def types ust
   in if is-error-body (ir-def.body) then print-line ("COMPILE-ERROR: def '" ++ ir-def.name ++ "' has error body: " ++ error-message (ir-def.body))
      else let text = emit-def ir-def ctor-names
      in do
       print-line text
       stream-defs defs types ust ctor-names (i + 1) len

Section: Streaming Pipeline v2 (Phase 2 — token-retaining)

 Tokenizes once, scans headers without parsing bodies, builds type
 context from signatures, then processes each def one at a time:
 re-parse body from token position, desugar, check, lower, emit, discard.
 Only tokens (~1.4 MB) and type context (~350 KB) persist across defs.

  compile-streaming-v2 : Text -> Text -> [Console] Nothing
  compile-streaming-v2 (source) (chapter-name) =
   let tokens = tokenize source
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let type-defs = map-list desugar-type-def (scan.type-defs)
   in let headers = scan.def-headers
   in let assignments = build-all-assignments headers 0
   in let colliding = find-colliding-names assignments
   in do
    compile-with-scope tokens type-defs headers assignments colliding

  compile-with-scope : List Token -> List ATypeDef -> List DefHeader -> List ChapterAssignment -> List Text -> [Console] Nothing
  compile-with-scope (tokens) (type-defs) (headers) (assignments) (colliding) =
   let tdm = build-type-def-map type-defs 0 (list-length type-defs) []
   in let tenv = register-type-defs empty-unification-state builtin-type-env tdm type-defs 0 (list-length type-defs)
   in let env = register-def-headers (tenv.state) (tenv.env) tdm headers 0 (list-length headers)
   in let ctor-types = collect-ctor-bindings type-defs 0 (list-length type-defs) []
   in let all-types = ctor-types ++ env.env.bindings
   in let ctor-names = collect-ctor-names type-defs 0
   in do
    print-line (emit-type-defs type-defs 0)
    emit-defs-scoped tokens headers all-types (env.state) ctor-names colliding assignments 0 (list-length headers)
    print-line ""

  register-def-headers : UnificationState -> TypeEnv -> List TypeBinding -> List DefHeader -> Integer -> Integer -> LetBindResult
  register-def-headers (st) (env) (tdm) (headers) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let hdr = list-at headers i
   in let declared = desugar-annotations (hdr.ann)
   in let ty = if list-length declared == 0 then let fr = fresh-and-advance st
         in let env2 = env-bind env (hdr.name.text) (fr.var-type)
         in LetBindResult {
          state = fr.state,
          env = env2
         }
      else let resolved = resolve-type-expr tdm (list-at declared 0)
         in let pr = parameterize-type st resolved
         in LetBindResult {
          state = pr.state,
          env = env-bind env (hdr.name.text) (pr.parameterized)
         }
   in register-def-headers (ty.state) (ty.env) tdm headers (i + 1) len

  check-defs-streaming : List Token -> List DefHeader -> UnificationState -> TypeEnv -> Integer -> Integer -> List TypeBinding -> ChapterResult
  check-defs-streaming (tokens) (headers) (ust) (env) (i) (len) (acc) =
   if i == len then ChapterResult {
    types = acc,
    state = ust
   }
   else let hdr = list-at headers i
   in let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos
   }
   in let body-result = parse-expr body-st
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef = desugar-def def
   in let r = check-def ust env adef
   in let resolved = deep-resolve (r.state) (r.inferred-type)
   in let entry = TypeBinding {
    name = (adef.name.value),
    bound-type = resolved
   }
   in check-defs-streaming tokens headers (r.state) env (i + 1) len (list-snoc acc entry)

  emit-defs-streaming : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> Integer -> Integer -> [Console] Nothing
  emit-defs-streaming (tokens) (headers) (all-types) (ust) (ctor-names) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos
   }
   in let body-result = parse-expr body-st
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef = desugar-def def
   in let ir-def = lower-def adef all-types ust
   in if is-error-body (ir-def.body) then print-line ("COMPILE-ERROR: def '" ++ ir-def.name ++ "' has error body: " ++ error-message (ir-def.body))
      else let text = emit-def ir-def ctor-names
      in if text == "" then emit-defs-streaming tokens headers all-types ust ctor-names (i + 1) len
         else do
      print-line text
      emit-defs-streaming tokens headers all-types ust ctor-names (i + 1) len

  emit-defs-scoped : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> Integer -> Integer -> [Console] Nothing
  emit-defs-scoped (tokens) (headers) (all-types) (ust) (ctor-names) (colliding) (assignments) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in let rn = build-chapter-rename-map colliding assignments (hdr.chapter-slug)
   in emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn (hdr.chapter-slug) i len

  emit-defs-same-chapter : List Token -> List DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> List RenameEntry -> Text -> Integer -> Integer -> [Console] Nothing
  emit-defs-same-chapter (tokens) (headers) (all-types) (ust) (ctor-names) (colliding) (assignments) (rn) (cur-slug) (i) (len) =
   if i == len then print-line ""
   else let hdr = list-at headers i
   in if (hdr.chapter-slug) /= cur-slug
      then emit-defs-scoped tokens headers all-types ust ctor-names colliding assignments i len
      else emit-one-scoped-def tokens hdr all-types ust ctor-names colliding assignments rn headers i len

  emit-one-scoped-def : List Token -> DefHeader -> List TypeBinding -> UnificationState -> List Text -> List Text -> List ChapterAssignment -> List RenameEntry -> List DefHeader -> Integer -> Integer -> [Console] Nothing
  emit-one-scoped-def (tokens) (hdr) (all-types) (ust) (ctor-names) (colliding) (assignments) (rn) (headers) (i) (len) =
   let body-st = ParseState {
    tokens = tokens,
    pos = hdr.body-pos
   }
   in let body-result = parse-expr body-st
   in let def = Def {
    name = hdr.name,
    params = hdr.params,
    ann = hdr.ann,
    body = unwrap-body body-result,
    chapter-slug = hdr.chapter-slug
   }
   in let adef = desugar-def def
   in let ir-def = lower-def adef all-types ust
   in let scoped-name = scope-def-name colliding assignments (ir-def.name) (hdr.chapter-slug)
   in let scoped-body = rename-ir-expr rn (ir-def.body)
   in let scoped-def = IRDef {
    name = scoped-name,
    params = ir-def.params,
    type-val = ir-def.type-val,
    body = scoped-body,
    chapter-slug = hdr.chapter-slug
   }
   in if is-error-body (scoped-def.body) then print-line ("COMPILE-ERROR: def '" ++ scoped-def.name ++ "' has error body: " ++ error-message (scoped-def.body))
      else let text = emit-def scoped-def ctor-names
      in if text == "" then emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn (hdr.chapter-slug) (i + 1) len
         else do
      print-line text
      emit-defs-same-chapter tokens headers all-types ust ctor-names colliding assignments rn (hdr.chapter-slug) (i + 1) len

  unwrap-body : ParseExprResult -> Expr
  unwrap-body (r) =
   when r
    if ExprOk (e) (st) -> e

Section: Whitespace Normalization

  normalize-whitespace : Text -> Text
  normalize-whitespace (s) =
   let r = text-replace s "\n\n\n" "\n\n"
   in if text-length r == text-length s then s
      else normalize-whitespace r

Section: Entry Point

  main : [Console, FileSystem] Nothing
  main = do
   path <- read-line
   source <- read-file path
   let clean = normalize-whitespace source
   in compile-streaming-v2 clean "Program"

