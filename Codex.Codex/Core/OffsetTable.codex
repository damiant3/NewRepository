Chapter: OffsetTable

 Flat open-addressing hash table with linear probing — Text keys to
 Integer values. Used by the bare-metal codegen as a Text → offset
 lookup at link time. Not a HAMT; the name was previously misleading.

Section: Hash Function
  djb2-hash : Text -> Integer
  djb2-hash (s) = djb2-loop s 0 (text-length s) 5381

  djb2-loop : Text -> Integer -> Integer -> Integer -> Integer
  djb2-loop (s) (i) (len) (h) =
   if i == len then h
   else djb2-loop s (i + 1) len (int-mod (h * 33 + char-code-at s i) 2147483647)

Section: Table Construction
  offset-table-size : Integer = 8192

  offset-table-mask : Integer = 8191

  OffsetTable = record {
    keys : List Text,
    values : List Integer
  }

  fill-empty-keys : Integer -> Integer -> List Text -> List Text
  fill-empty-keys (n) (i) (acc) =
   if i >= n then acc
   else fill-empty-keys n (i + 1) (list-snoc acc "")

  fill-empty-values : Integer -> Integer -> List Integer -> List Integer
  fill-empty-values (n) (i) (acc) =
   if i >= n then acc
   else fill-empty-values n (i + 1) (list-snoc acc (0 - 1))

  offset-table-empty : OffsetTable = OffsetTable {
    keys = fill-empty-keys offset-table-size 0 (list-with-capacity offset-table-size),
    values = fill-empty-values offset-table-size 0 (list-with-capacity offset-table-size)
  }

Section: Insert (Linear Probing)
  offset-table-insert-at : List Text -> List Integer -> Integer -> Text -> Integer -> OffsetTable
  offset-table-insert-at (ks) (vs) (slot) (k) (v) =
   let existing = list-at ks slot
   in if existing == "" then OffsetTable {
        keys = offset-table-text-replace-at ks slot k,
        values = offset-table-int-replace-at vs slot v
      }
      else if existing == k then OffsetTable {
        keys = ks,
        values = offset-table-int-replace-at vs slot v
      }
      else offset-table-insert-at ks vs (bit-and (slot + 1) offset-table-mask) k v

  offset-table-set : OffsetTable -> Text -> Integer -> OffsetTable
  offset-table-set (m) (k) (v) =
   let h = djb2-hash k
   in let slot = bit-and h offset-table-mask
   in offset-table-insert-at (m.keys) (m.values) slot k v

Section: Lookup
  offset-table-lookup-probe : List Text -> List Integer -> Integer -> Text -> Integer -> Integer
  offset-table-lookup-probe (ks) (vs) (slot) (k) (steps) =
   if steps >= offset-table-size then 0 - 1
   else let existing = list-at ks slot
   in if existing == "" then 0 - 1
      else if existing == k then list-at vs slot
      else offset-table-lookup-probe ks vs (bit-and (slot + 1) offset-table-mask) k (steps + 1)

  offset-table-get : OffsetTable -> Text -> Integer
  offset-table-get (m) (k) =
   let h = djb2-hash k
   in let slot = bit-and h offset-table-mask
   in offset-table-lookup-probe (m.keys) (m.values) slot k 0

Section: List Replace Helpers
  offset-table-text-replace-at : List Text -> Integer -> Text -> List Text
  offset-table-text-replace-at (xs) (idx) (x) = list-set-at xs idx x

  offset-table-int-replace-at : List Integer -> Integer -> Integer -> List Integer
  offset-table-int-replace-at (xs) (idx) (x) = list-set-at xs idx x

Section: Build from Func Offsets
  build-offset-table : List FuncOffset -> OffsetTable
  build-offset-table (offsets) =
   build-offset-table-loop offsets 0 (list-length offsets) offset-table-empty

  build-offset-table-loop : List FuncOffset -> Integer -> Integer -> OffsetTable -> OffsetTable
  build-offset-table-loop (offsets) (i) (len) (m) =
   if i >= len then m
   else let fo = list-at offsets i
   in build-offset-table-loop offsets (i + 1) len (offset-table-set m (fo.name) (fo.offset))

  offset-table-lookup : OffsetTable -> Text -> Integer
  offset-table-lookup (m) (name) = offset-table-get m name

