Chapter: Phase

 Compilation phases as integer constants.

Section: Constants
  phase-infrastructure : Integer
  phase-infrastructure = 0

  phase-lexer : Integer
  phase-lexer = 1

  phase-parser : Integer
  phase-parser = 2

  phase-prose-validation : Integer
  phase-prose-validation = 3

  phase-name-resolver : Integer
  phase-name-resolver = 4

  phase-type-checker : Integer
  phase-type-checker = 5

  phase-linearity : Integer
  phase-linearity = 6

  phase-proof-checker : Integer
  phase-proof-checker = 7

  phase-capability-checker : Integer
  phase-capability-checker = 8

  phase-codegen : Integer
  phase-codegen = 9

Section: Display
  phase-label : Integer -> Text
  phase-label (p) =
   if p == phase-infrastructure then "Infrastructure"
   else if p == phase-lexer then "Lexer"
   else if p == phase-parser then "Parser"
   else if p == phase-prose-validation then "ProseValidation"
   else if p == phase-name-resolver then "NameResolver"
   else if p == phase-type-checker then "TypeChecker"
   else if p == phase-linearity then "Linearity"
   else if p == phase-proof-checker then "ProofChecker"
   else if p == phase-capability-checker then "CapabilityChecker"
   else if p == phase-codegen then "CodeGen"
   else "Unknown"

