Chapter: Source Text

 Source position and span types for error reporting.

Section: Types
  SourcePosition = record {
   line : Integer,
   column : Integer,
   offset : Integer
  }

  SourceSpan = record {
   start : SourcePosition,
   end : SourcePosition,
   file : Text
  }

Section: Functions
  make-position : Integer -> Integer -> Integer -> SourcePosition
  make-position (line) (col) (offset) =
   SourcePosition {
    line = line,
    column = col,
    offset = offset
   }

  make-span : SourcePosition -> SourcePosition -> Text -> SourceSpan
  make-span (s) (e) (f) =
   SourceSpan {
    start = s,
    end = e,
    file = f
   }

  span-length : SourceSpan -> Integer
  span-length (span) =
   span.end.offset - span.start.offset

  synthetic-span : SourceSpan
  synthetic-span =
   SourceSpan {
    start = make-position 0 0 0,
    end = make-position 0 0 0,
    file = ""
   }

  is-synthetic-span : SourceSpan -> Boolean
  is-synthetic-span (span) =
   span.file == "" & span.start.line == 0 & span.start.column == 0

  span-at : Integer -> Integer -> Integer -> Integer -> SourceSpan
  span-at (line) (col) (offset) (len) =
   let start = make-position line col offset
   in let end = make-position line (col + len) (offset + len)
   in make-span start end ""

  span-display : SourceSpan -> Text
  span-display (span) =
   if is-synthetic-span span then ""
   else (if span.file == "" then "" else span.file ++ ":")
        ++ integer-to-text (span.start.line) ++ ":" ++ integer-to-text (span.start.column)

