Chapter: Diagnostics

 Compiler diagnostic types. Code and severity are plain integers; their
 text forms are produced only at render time.

Section: Type
  Diagnostic = record {
   code : Integer,
   message : Text,
   severity : Integer
  }

Section: Constructors
  make-error : Integer -> Text -> Diagnostic
  make-error (code) (msg) =
   Diagnostic {
    code = code,
    message = msg,
    severity = sev-error
   }

  make-warning : Integer -> Text -> Diagnostic
  make-warning (code) (msg) =
   Diagnostic {
    code = code,
    message = msg,
    severity = sev-warning
   }

Section: Display
  format-cdx-code : Integer -> Text
  format-cdx-code (n) = "CDX" ++ integer-to-text-padded n 4

  diagnostic-display : Diagnostic -> Text
  diagnostic-display (d) =
   severity-label (d.severity) ++ " " ++ format-cdx-code (d.code) ++ ": " ++ d.message

