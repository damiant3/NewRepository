Chapter: Diagnostics

 Compiler diagnostic types. Code and severity are plain integers; their
 text forms are produced only at render time.

Section: Type
  Diagnostic = record {
   code : Integer,
   message : Text,
   severity : Integer,
   span : SourceSpan,
   related-spans : List SourceSpan
  }

Section: Constructors
  make-diagnostic : Integer -> Integer -> Text -> SourceSpan -> Diagnostic
  make-diagnostic (sev) (code) (msg) (span) =
   Diagnostic {
    code = code,
    message = msg,
    severity = sev,
    span = span,
    related-spans = []
   }

  make-error : Integer -> Text -> SourceSpan -> Diagnostic
  make-error (code) (msg) (span) = make-diagnostic sev-error code msg span

  make-warning : Integer -> Text -> SourceSpan -> Diagnostic
  make-warning (code) (msg) (span) = make-diagnostic sev-warning code msg span

  make-info : Integer -> Text -> SourceSpan -> Diagnostic
  make-info (code) (msg) (span) = make-diagnostic sev-info code msg span

  make-hint : Integer -> Text -> SourceSpan -> Diagnostic
  make-hint (code) (msg) (span) = make-diagnostic sev-hint code msg span

  make-error-related : Integer -> Text -> SourceSpan -> List SourceSpan -> Diagnostic
  make-error-related (code) (msg) (span) (related) =
   Diagnostic {
    code = code,
    message = msg,
    severity = sev-error,
    span = span,
    related-spans = related
   }

Section: Display
  format-cdx-code : Integer -> Text
  format-cdx-code (n) = "CDX" ++ integer-to-text-padded n 4

  diagnostic-display : Diagnostic -> FileTable -> Text
  diagnostic-display (d) (table) =
   let loc = span-display (d.span) table
   in let prefix = if loc == "" then "" else loc ++ ": "
   in prefix ++ severity-label (d.severity) ++ " " ++ format-cdx-code (d.code) ++ ": " ++ d.message

