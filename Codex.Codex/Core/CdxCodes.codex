Chapter: CdxCodes

 Central registry of diagnostic codes. Codes are plain integers; call
 sites use the named constants below.

 Ranges: 0xxx infrastructure and lexer; 1xxx parser; 2xxx type checker,
 unifier, codegen; 3xxx name resolver; 4xxx proof and capability;
 9xxx reserved for compiler-internal.

Section: Registry Type
  CdxCodeInfo = record {
    code : Integer,
    name : Text,
    severity : Integer,
    phase : Integer,
    summary : Text
  }

Section: Infrastructure
  cdx-too-many-errors : Integer = 1

Section: Parser
  cdx-expected-token-kind : Integer = 1000

Section: Type checker and Codegen
  cdx-ir-error : Integer = 2000

  cdx-type-mismatch : Integer = 2001

  cdx-unknown-name : Integer = 2002

  cdx-infinite-type : Integer = 2010

  cdx-let-binds-effectful-value : Integer = 2033

  cdx-unresolved-func-offset : Integer = 2040

  cdx-error-type-in-ir : Integer = 2041

Section: Name resolver
  cdx-duplicate-definition : Integer = 3001

  cdx-undefined-name : Integer = 3002

  cdx-duplicate-cite : Integer = 3003

Section: Registry entry constructor
  mk-cdx : Integer -> Text -> Integer -> Integer -> Text -> CdxCodeInfo
  mk-cdx (code) (name) (sev) (phase) (summary) =
   CdxCodeInfo {
    code = code,
    name = name,
    severity = sev,
    phase = phase,
    summary = summary
   }

Section: Registry
  cdx-registry : List CdxCodeInfo = [
    mk-cdx cdx-too-many-errors "TooManyErrors" sev-error phase-infrastructure "Error cap reached; further errors suppressed.",
    mk-cdx cdx-expected-token-kind "ExpectedTokenKind" sev-error phase-parser "A specific token kind was required but a different one was found.",
    mk-cdx cdx-ir-error "IrError" sev-error phase-codegen "Codegen encountered an IrError node, indicating an earlier phase silently failed.",
    mk-cdx cdx-type-mismatch "TypeMismatch" sev-error phase-type-checker "Two types could not be unified.",
    mk-cdx cdx-unknown-name "UnknownName" sev-error phase-type-checker "Name was not found in the type environment during checking.",
    mk-cdx cdx-infinite-type "InfiniteType" sev-error phase-type-checker "Occurs check failed - unification would produce an infinite type.",
    mk-cdx cdx-let-binds-effectful-value "LetBindsEffectfulValue" sev-error phase-type-checker "let-binding the result of an effectful call silently corrupts on bare metal; use do-bind (X <- expr) inside a do block.",
    mk-cdx cdx-unresolved-func-offset "UnresolvedFuncOffset" sev-error phase-codegen "A call or func-addr fixup refers to a function not present in the offset table; emission would produce wrong code.",
    mk-cdx cdx-error-type-in-ir "ErrorTypeInIR" sev-error phase-codegen "An IR node reached codegen with ErrorTy in its type; an earlier phase silently failed to resolve the type.",
    mk-cdx cdx-duplicate-definition "DuplicateDefinition" sev-error phase-name-resolver "The same name is introduced twice at chapter scope.",
    mk-cdx cdx-undefined-name "UndefinedName" sev-error phase-name-resolver "A name was referenced but is not in any visible scope.",
    mk-cdx cdx-duplicate-cite "DuplicateCite" sev-error phase-name-resolver "Two cite declarations in the same chapter select the same name; the later cite would silently shadow the earlier."
  ]

Section: Lookup
  cdx-lookup-loop : List CdxCodeInfo -> Integer -> Integer -> Integer -> CdxCodeInfo
  cdx-lookup-loop (reg) (code) (i) (len) =
   if i >= len then mk-cdx 0 "Unknown" sev-error phase-infrastructure "Unregistered CDX code."
   else let entry = list-at reg i
   in if entry.code == code then entry
      else cdx-lookup-loop reg code (i + 1) len

  cdx-lookup : Integer -> CdxCodeInfo
  cdx-lookup (code) = cdx-lookup-loop cdx-registry code 0 (list-length cdx-registry)

