Chapter: Collections

 Functional list operations and hash map used throughout the compiler.

Section: List Operations

  map-list : (a -> b) -> List a -> List b
  map-list (f) (xs) = map-list-loop f xs 0 (list-length xs) []

  map-list-loop : (a -> b) -> List a -> Integer -> Integer -> List b -> List b
  map-list-loop (f) (xs) (i) (len) (acc) =
   if i == len then acc
   else map-list-loop f xs (i + 1) len (acc ++ [f (list-at xs i)])

  fold-list : (b -> a -> b) -> b -> List a -> b
  fold-list (f) (z) (xs) = fold-list-loop f z xs 0 (list-length xs)

  fold-list-loop : (b -> a -> b) -> b -> List a -> Integer -> Integer -> b
  fold-list-loop (f) (z) (xs) (i) (len) =
   if i == len then z
   else fold-list-loop f (f z (list-at xs i)) xs (i + 1) len

  list-tail : List a -> List a
  list-tail (xs) = list-tail-loop xs 1 (list-length xs) []

  list-tail-loop : List a -> Integer -> Integer -> List a -> List a
  list-tail-loop (xs) (i) (len) (acc) =
   if i == len then acc
   else list-tail-loop xs (i + 1) len (acc ++ [list-at xs i])

Section: Maybe

  MaybeType =
   | JustType (CodexType)
   | MaybeNoneType

Section: Type Map (HAMT specialized for CodexType values)

 O(log32 n) lookup and insert. Monomorphized for CodexType values
 since the reference parser does not support polymorphic records.

  TypeMapEntry = record {
   key : Text,
   value : CodexType
  }

  TypeMapNode =
   | TmEmpty
   | TmLeaf (Integer) (Text) (CodexType)
   | TmCollision (Integer) (List TypeMapEntry)
   | TmBranch (Integer) (List TypeMapNode)

  TypeMap = record {
   root : TypeMapNode,
   tm-size : Integer
  }

  tm-empty : TypeMap
  tm-empty = TypeMap { root = TmEmpty, tm-size = 0 }

  djb2-hash : Text -> Integer
  djb2-hash (s) = djb2-loop s 0 (text-length s) 5381

  djb2-loop : Text -> Integer -> Integer -> Integer -> Integer
  djb2-loop (s) (i) (len) (h) =
   if i == len then tm-abs h
   else djb2-loop s (i + 1) len (h * 33 + char-code-at s i)

  tm-abs : Integer -> Integer
  tm-abs (n) = if n < 0 then 0 - n else n

  tm-pow32 : Integer -> Integer
  tm-pow32 (level) =
   if level == 0 then 1
   else 32 * tm-pow32 (level - 1)

  tm-extract-chunk : Integer -> Integer -> Integer
  tm-extract-chunk (hash) (level) =
   let d = tm-pow32 level
   in (hash / d) - ((hash / d) / 32) * 32

  tm-popcount : Integer -> Integer
  tm-popcount (n) = tm-popcount-loop n 0

  tm-popcount-loop : Integer -> Integer -> Integer
  tm-popcount-loop (n) (count) =
   if n == 0 then count
   else tm-popcount-loop (n / 2) (count + n - (n / 2) * 2)

  tm-bitmap-has : Integer -> Integer -> Boolean
  tm-bitmap-has (bitmap) (bit) =
   let mask = tm-pow32 bit
   in let shifted = bitmap / mask
   in shifted - (shifted / 2) * 2 == 1

  tm-bitmap-set : Integer -> Integer -> Integer
  tm-bitmap-set (bitmap) (bit) =
   if tm-bitmap-has bitmap bit then bitmap
   else bitmap + tm-pow32 bit

  tm-bitmap-index : Integer -> Integer -> Integer
  tm-bitmap-index (bitmap) (bit) =
   let below = bitmap - (bitmap / tm-pow32 bit) * tm-pow32 bit
   in tm-popcount below

  tm-list-insert-at : List TypeMapNode -> Integer -> TypeMapNode -> List TypeMapNode
  tm-list-insert-at (xs) (i) (x) =
   if i == 0 then [x] ++ xs
   else [list-at xs 0] ++ tm-list-insert-at (list-tail xs) (i - 1) x

  tm-list-replace-at : List TypeMapNode -> Integer -> TypeMapNode -> List TypeMapNode
  tm-list-replace-at (xs) (i) (x) =
   if i == 0 then [x] ++ list-tail xs
   else [list-at xs 0] ++ tm-list-replace-at (list-tail xs) (i - 1) x

  tm-get : TypeMap -> Text -> MaybeType
  tm-get (m) (key) =
   let hash = djb2-hash key
   in tm-node-get m.root hash key 0

  tm-node-get : TypeMapNode -> Integer -> Text -> Integer -> MaybeType
  tm-node-get (node) (hash) (key) (level) =
   when node
    if TmEmpty -> MaybeNoneType
    if TmLeaf (h) (k) (v) ->
     if k == key then JustType v else MaybeNoneType
    if TmCollision (h) (entries) ->
     if h == hash then tm-collision-find entries key else MaybeNoneType
    if TmBranch (bitmap) (children) ->
     let chunk = tm-extract-chunk hash level
     in if tm-bitmap-has bitmap chunk
      then let idx = tm-bitmap-index bitmap chunk
       in tm-node-get (list-at children idx) hash key (level + 1)
      else MaybeNoneType

  tm-collision-find : List TypeMapEntry -> Text -> MaybeType
  tm-collision-find (entries) (key) =
   if list-length entries == 0 then MaybeNoneType
   else let e = list-at entries 0
    in if e.key == key then JustType e.value
    else tm-collision-find (list-tail entries) key

  tm-set : TypeMap -> Text -> CodexType -> TypeMap
  tm-set (m) (key) (value) =
   let hash = djb2-hash key
   in let result = tm-node-set m.root hash key value 0
   in TypeMap { root = result.node, tm-size = m.tm-size + result.delta }

  TmSetResult = record {
   node : TypeMapNode,
   delta : Integer
  }

  tm-node-set : TypeMapNode -> Integer -> Text -> CodexType -> Integer -> TmSetResult
  tm-node-set (node) (hash) (key) (value) (level) =
   when node
    if TmEmpty ->
     TmSetResult { node = TmLeaf hash key value, delta = 1 }
    if TmLeaf (h) (k) (v) ->
     if k == key
      then TmSetResult { node = TmLeaf h key value, delta = 0 }
     else if h == hash
      then TmSetResult { node = TmCollision h [TypeMapEntry { key = k, value = v }, TypeMapEntry { key = key, value = value }], delta = 1 }
     else let new-node = tm-make-branch h k v hash key value level
      in TmSetResult { node = new-node, delta = 1 }
    if TmCollision (h) (entries) ->
     if h == hash
      then let updated = tm-collision-set entries key value
       in TmSetResult { node = TmCollision h updated.entries, delta = updated.delta }
     else let col-node = TmCollision h entries
      in tm-node-set (tm-make-single-branch col-node h level) hash key value level
    if TmBranch (bitmap) (children) ->
     let chunk = tm-extract-chunk hash level
     in if tm-bitmap-has bitmap chunk
      then let idx = tm-bitmap-index bitmap chunk
       in let child = list-at children idx
       in let result = tm-node-set child hash key value (level + 1)
       in TmSetResult { node = TmBranch bitmap (tm-list-replace-at children idx result.node), delta = result.delta }
      else let idx = tm-bitmap-index bitmap chunk
       in let new-leaf = TmLeaf hash key value
       in TmSetResult { node = TmBranch (tm-bitmap-set bitmap chunk) (tm-list-insert-at children idx new-leaf), delta = 1 }

  tm-make-single-branch : TypeMapNode -> Integer -> Integer -> TypeMapNode
  tm-make-single-branch (node) (hash) (level) =
   let chunk = tm-extract-chunk hash level
   in TmBranch (tm-pow32 chunk) [node]

  tm-make-branch : Integer -> Text -> CodexType -> Integer -> Text -> CodexType -> Integer -> TypeMapNode
  tm-make-branch (h1) (k1) (v1) (h2) (k2) (v2) (level) =
   if level > 6 then TmCollision h1 [TypeMapEntry { key = k1, value = v1 }, TypeMapEntry { key = k2, value = v2 }]
   else let c1 = tm-extract-chunk h1 level
    in let c2 = tm-extract-chunk h2 level
    in if c1 == c2
     then let child = tm-make-branch h1 k1 v1 h2 k2 v2 (level + 1)
      in TmBranch (tm-pow32 c1) [child]
     else if c1 < c2
      then TmBranch (tm-bitmap-set (tm-pow32 c1) c2) [TmLeaf h1 k1 v1, TmLeaf h2 k2 v2]
      else TmBranch (tm-bitmap-set (tm-pow32 c2) c1) [TmLeaf h2 k2 v2, TmLeaf h1 k1 v1]

  TmCollisionSetResult = record {
   entries : List TypeMapEntry,
   delta : Integer
  }

  tm-collision-set : List TypeMapEntry -> Text -> CodexType -> TmCollisionSetResult
  tm-collision-set (entries) (key) (value) =
   tm-collision-set-loop entries key value 0

  tm-collision-set-loop : List TypeMapEntry -> Text -> CodexType -> Integer -> TmCollisionSetResult
  tm-collision-set-loop (entries) (key) (value) (i) =
   if i == list-length entries
    then TmCollisionSetResult { entries = entries ++ [TypeMapEntry { key = key, value = value }], delta = 1 }
   else let e = list-at entries i
    in if e.key == key
     then TmCollisionSetResult { entries = tm-entry-replace-at entries i (TypeMapEntry { key = key, value = value }), delta = 0 }
     else tm-collision-set-loop entries key value (i + 1)

  tm-entry-replace-at : List TypeMapEntry -> Integer -> TypeMapEntry -> List TypeMapEntry
  tm-entry-replace-at (xs) (i) (x) =
   if i == 0 then [x] ++ list-tail xs
   else [list-at xs 0] ++ tm-entry-replace-at (list-tail xs) (i - 1) x

  tm-contains : TypeMap -> Text -> Boolean
  tm-contains (m) (key) =
   when tm-get m key
    if JustType (_) -> True
    if MaybeNoneType -> False

  tm-fold : (b -> Text -> CodexType -> b) -> b -> TypeMap -> b
  tm-fold (f) (z) (m) = tm-node-fold f z m.root

  tm-node-fold : (b -> Text -> CodexType -> b) -> b -> TypeMapNode -> b
  tm-node-fold (f) (z) (node) =
   when node
    if TmEmpty -> z
    if TmLeaf (h) (k) (v) -> f z k v
    if TmCollision (h) (entries) -> tm-fold-entries f z entries 0
    if TmBranch (bitmap) (children) -> tm-fold-children f z children 0

  tm-fold-entries : (b -> Text -> CodexType -> b) -> b -> List TypeMapEntry -> Integer -> b
  tm-fold-entries (f) (z) (entries) (i) =
   if i == list-length entries then z
   else let e = list-at entries i
    in tm-fold-entries f (f z e.key e.value) entries (i + 1)

  tm-fold-children : (b -> Text -> CodexType -> b) -> b -> List TypeMapNode -> Integer -> b
  tm-fold-children (f) (z) (children) (i) =
   if i == list-length children then z
   else let acc = tm-node-fold f z (list-at children i)
    in tm-fold-children f acc children (i + 1)

  tm-merge-from : TypeMap -> TypeMap -> TypeMap
  tm-merge-from (source) (target) =
   tm-fold (\acc k v -> tm-set acc k v) target source
