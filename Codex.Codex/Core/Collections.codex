Chapter: Collections

 Functional list operations used throughout the compiler.

Section: List Operations

  map-list : (a -> b) -> List a -> List b
  map-list (f) (xs) = map-list-loop f xs 0 (list-length xs) []

  map-list-loop : (a -> b) -> List a -> Integer -> Integer -> List b -> List b
  map-list-loop (f) (xs) (i) (len) (acc) =
   if i == len then acc
   else map-list-loop f xs (i + 1) len (list-snoc acc (f (list-at xs i)))

  fold-list : (b -> a -> b) -> b -> List a -> b
  fold-list (f) (z) (xs) = fold-list-loop f z xs 0 (list-length xs)

  fold-list-loop : (b -> a -> b) -> b -> List a -> Integer -> Integer -> b
  fold-list-loop (f) (z) (xs) (i) (len) =
   if i == len then z
   else fold-list-loop f (f z (list-at xs i)) xs (i + 1) len

Section: Binary Search — Text Keys (lower bound)

 Lower-bound binary search on a sorted List TypeBinding by name.
 Returns the leftmost index where the key is >= name. The caller
 checks list-at pos for an exact match to distinguish hit from miss.
 On insert, using the returned pos places new entries before any
 existing entry with the same key, so the newest binding wins on lookup.

  bsearch-text-pos : List TypeBinding -> Text -> Integer -> Integer -> Integer
  bsearch-text-pos (bindings) (name) (lo) (hi) =
   if lo >= hi then lo
   else let mid = lo + (hi - lo) / 2
    in let mid-name = (list-at bindings mid).name
    in if text-compare name mid-name <= 0
     then bsearch-text-pos bindings name lo mid
     else bsearch-text-pos bindings name (mid + 1) hi

Section: Binary Search — Integer Keys (lower bound)

  bsearch-int-pos : List SubstEntry -> Integer -> Integer -> Integer -> Integer
  bsearch-int-pos (entries) (key) (lo) (hi) =
   if lo >= hi then lo
   else let mid = lo + (hi - lo) / 2
    in if key <= (list-at entries mid).var-id
     then bsearch-int-pos entries key lo mid
     else bsearch-int-pos entries key (mid + 1) hi

Section: Binary Search — Text Set (lower bound)

  bsearch-text-set : List Text -> Text -> Integer -> Integer -> Integer
  bsearch-text-set (names) (name) (lo) (hi) =
   if lo >= hi then lo
   else let mid = lo + (hi - lo) / 2
    in if text-compare name (list-at names mid) <= 0
     then bsearch-text-set names name lo mid
     else bsearch-text-set names name (mid + 1) hi
