Chapter: Collections

 Functional list operations and hash map used throughout the compiler.

Section: List Operations

  map-list : (a -> b) -> List a -> List b
  map-list (f) (xs) = map-list-loop f xs 0 (list-length xs) []

  map-list-loop : (a -> b) -> List a -> Integer -> Integer -> List b -> List b
  map-list-loop (f) (xs) (i) (len) (acc) =
   if i == len then acc
   else map-list-loop f xs (i + 1) len (acc ++ [f (list-at xs i)])

  fold-list : (b -> a -> b) -> b -> List a -> b
  fold-list (f) (z) (xs) = fold-list-loop f z xs 0 (list-length xs)

  fold-list-loop : (b -> a -> b) -> b -> List a -> Integer -> Integer -> b
  fold-list-loop (f) (z) (xs) (i) (len) =
   if i == len then z
   else fold-list-loop f (f z (list-at xs i)) xs (i + 1) len

  list-tail : List a -> List a
  list-tail (xs) = list-tail-loop xs 1 (list-length xs) []

  list-tail-loop : List a -> Integer -> Integer -> List a -> List a
  list-tail-loop (xs) (i) (len) (acc) =
   if i == len then acc
   else list-tail-loop xs (i + 1) len (acc ++ [list-at xs i])

Section: Maybe

  Maybe a =
   | Just (a)
   | MaybeNone

Section: Hash-Array Mapped Trie (HAMT)

 O(log32 n) lookup and insert for Text-keyed maps.
 Inlined from prelude/Hamt.codex for use in the self-hosted compiler.

  HamtEntry a = record {
   key : Text,
   value : a
  }

  HamtNode a =
   | HamtEmpty
   | HamtLeaf (Integer) (Text) (a)
   | HamtCollision (Integer) (List HamtEntry a)
   | HamtBranch (Integer) (List HamtNode a)

  HamtMap a = record {
   root : HamtNode a,
   hamt-size : Integer
  }

  hamt-empty : HamtMap a
  hamt-empty = HamtMap { root = HamtEmpty, hamt-size = 0 }

  djb2-hash : Text -> Integer
  djb2-hash (s) = djb2-loop s 0 (text-length s) 5381

  djb2-loop : Text -> Integer -> Integer -> Integer -> Integer
  djb2-loop (s) (i) (len) (h) =
   if i == len then hamt-abs h
   else djb2-loop s (i + 1) len (h * 33 + char-code-at s i)

  hamt-abs : Integer -> Integer
  hamt-abs (n) = if n < 0 then 0 - n else n

  hamt-pow32 : Integer -> Integer
  hamt-pow32 (level) =
   if level == 0 then 1
   else 32 * hamt-pow32 (level - 1)

  hamt-extract-chunk : Integer -> Integer -> Integer
  hamt-extract-chunk (hash) (level) =
   let d = hamt-pow32 level
   in (hash / d) - ((hash / d) / 32) * 32

  hamt-popcount : Integer -> Integer
  hamt-popcount (n) = hamt-popcount-loop n 0

  hamt-popcount-loop : Integer -> Integer -> Integer
  hamt-popcount-loop (n) (count) =
   if n == 0 then count
   else hamt-popcount-loop (n / 2) (count + n - (n / 2) * 2)

  hamt-bitmap-has : Integer -> Integer -> Boolean
  hamt-bitmap-has (bitmap) (bit) =
   let mask = hamt-pow32 bit
   in let shifted = bitmap / mask
   in shifted - (shifted / 2) * 2 == 1

  hamt-bitmap-set : Integer -> Integer -> Integer
  hamt-bitmap-set (bitmap) (bit) =
   if hamt-bitmap-has bitmap bit then bitmap
   else bitmap + hamt-pow32 bit

  hamt-bitmap-index : Integer -> Integer -> Integer
  hamt-bitmap-index (bitmap) (bit) =
   let below = bitmap - (bitmap / hamt-pow32 bit) * hamt-pow32 bit
   in hamt-popcount below

  hamt-list-insert-at : List a -> Integer -> a -> List a
  hamt-list-insert-at (xs) (i) (x) =
   if i == 0 then [x] ++ xs
   else [list-at xs 0] ++ hamt-list-insert-at (list-tail xs) (i - 1) x

  hamt-list-replace-at : List a -> Integer -> a -> List a
  hamt-list-replace-at (xs) (i) (x) =
   if i == 0 then [x] ++ list-tail xs
   else [list-at xs 0] ++ hamt-list-replace-at (list-tail xs) (i - 1) x

  hamt-get : HamtMap a -> Text -> Maybe a
  hamt-get (m) (key) =
   let hash = djb2-hash key
   in hamt-node-get m.root hash key 0

  hamt-node-get : HamtNode a -> Integer -> Text -> Integer -> Maybe a
  hamt-node-get (node) (hash) (key) (level) =
   when node
    if HamtEmpty -> MaybeNone
    if HamtLeaf (h) (k) (v) ->
     if k == key then Just v else MaybeNone
    if HamtCollision (h) (entries) ->
     if h == hash then hamt-collision-find entries key else MaybeNone
    if HamtBranch (bitmap) (children) ->
     let chunk = hamt-extract-chunk hash level
     in if hamt-bitmap-has bitmap chunk
      then let idx = hamt-bitmap-index bitmap chunk
       in hamt-node-get (list-at children idx) hash key (level + 1)
      else MaybeNone

  hamt-collision-find : List HamtEntry a -> Text -> Maybe a
  hamt-collision-find (entries) (key) =
   if list-length entries == 0 then MaybeNone
   else let e = list-at entries 0
    in if e.key == key then Just e.value
    else hamt-collision-find (list-tail entries) key

  hamt-set : HamtMap a -> Text -> a -> HamtMap a
  hamt-set (m) (key) (value) =
   let hash = djb2-hash key
   in let result = hamt-node-set m.root hash key value 0
   in HamtMap { root = result.node, hamt-size = m.hamt-size + result.delta }

  HamtSetResult a = record {
   node : HamtNode a,
   delta : Integer
  }

  hamt-node-set : HamtNode a -> Integer -> Text -> a -> Integer -> HamtSetResult a
  hamt-node-set (node) (hash) (key) (value) (level) =
   when node
    if HamtEmpty ->
     HamtSetResult { node = HamtLeaf hash key value, delta = 1 }
    if HamtLeaf (h) (k) (v) ->
     if k == key
      then HamtSetResult { node = HamtLeaf h key value, delta = 0 }
     else if h == hash
      then HamtSetResult { node = HamtCollision h [HamtEntry { key = k, value = v }, HamtEntry { key = key, value = value }], delta = 1 }
     else let new-node = hamt-make-branch h k v hash key value level
      in HamtSetResult { node = new-node, delta = 1 }
    if HamtCollision (h) (entries) ->
     if h == hash
      then let updated = hamt-collision-set entries key value
       in HamtSetResult { node = HamtCollision h updated.entries, delta = updated.delta }
     else let col-node = HamtCollision h entries
      in hamt-node-set (hamt-make-single-branch col-node h level) hash key value level
    if HamtBranch (bitmap) (children) ->
     let chunk = hamt-extract-chunk hash level
     in if hamt-bitmap-has bitmap chunk
      then let idx = hamt-bitmap-index bitmap chunk
       in let child = list-at children idx
       in let result = hamt-node-set child hash key value (level + 1)
       in HamtSetResult { node = HamtBranch bitmap (hamt-list-replace-at children idx result.node), delta = result.delta }
      else let idx = hamt-bitmap-index bitmap chunk
       in let new-leaf = HamtLeaf hash key value
       in HamtSetResult { node = HamtBranch (hamt-bitmap-set bitmap chunk) (hamt-list-insert-at children idx new-leaf), delta = 1 }

  hamt-make-single-branch : HamtNode a -> Integer -> Integer -> HamtNode a
  hamt-make-single-branch (node) (hash) (level) =
   let chunk = hamt-extract-chunk hash level
   in HamtBranch (hamt-pow32 chunk) [node]

  hamt-make-branch : Integer -> Text -> a -> Integer -> Text -> a -> Integer -> HamtNode a
  hamt-make-branch (h1) (k1) (v1) (h2) (k2) (v2) (level) =
   if level > 6 then HamtCollision h1 [HamtEntry { key = k1, value = v1 }, HamtEntry { key = k2, value = v2 }]
   else let c1 = hamt-extract-chunk h1 level
    in let c2 = hamt-extract-chunk h2 level
    in if c1 == c2
     then let child = hamt-make-branch h1 k1 v1 h2 k2 v2 (level + 1)
      in HamtBranch (hamt-pow32 c1) [child]
     else if c1 < c2
      then HamtBranch (hamt-bitmap-set (hamt-pow32 c1) c2) [HamtLeaf h1 k1 v1, HamtLeaf h2 k2 v2]
      else HamtBranch (hamt-bitmap-set (hamt-pow32 c2) c1) [HamtLeaf h2 k2 v2, HamtLeaf h1 k1 v1]

  HamtCollisionSetResult a = record {
   entries : List HamtEntry a,
   delta : Integer
  }

  hamt-collision-set : List HamtEntry a -> Text -> a -> HamtCollisionSetResult a
  hamt-collision-set (entries) (key) (value) =
   hamt-collision-set-loop entries key value 0

  hamt-collision-set-loop : List HamtEntry a -> Text -> a -> Integer -> HamtCollisionSetResult a
  hamt-collision-set-loop (entries) (key) (value) (i) =
   if i == list-length entries
    then HamtCollisionSetResult { entries = entries ++ [HamtEntry { key = key, value = value }], delta = 1 }
   else let e = list-at entries i
    in if e.key == key
     then HamtCollisionSetResult { entries = hamt-list-replace-at entries i (HamtEntry { key = key, value = value }), delta = 0 }
     else hamt-collision-set-loop entries key value (i + 1)

  hamt-contains : HamtMap a -> Text -> Boolean
  hamt-contains (m) (key) =
   when hamt-get m key
    if Just (_) -> True
    if MaybeNone -> False

  hamt-fold : (b -> Text -> a -> b) -> b -> HamtMap a -> b
  hamt-fold (f) (z) (m) = hamt-node-fold f z m.root

  hamt-node-fold : (b -> Text -> a -> b) -> b -> HamtNode a -> b
  hamt-node-fold (f) (z) (node) =
   when node
    if HamtEmpty -> z
    if HamtLeaf (h) (k) (v) -> f z k v
    if HamtCollision (h) (entries) -> hamt-fold-entries f z entries 0
    if HamtBranch (bitmap) (children) -> hamt-fold-children f z children 0

  hamt-fold-entries : (b -> Text -> a -> b) -> b -> List HamtEntry a -> Integer -> b
  hamt-fold-entries (f) (z) (entries) (i) =
   if i == list-length entries then z
   else let e = list-at entries i
    in hamt-fold-entries f (f z e.key e.value) entries (i + 1)

  hamt-fold-children : (b -> Text -> a -> b) -> b -> List HamtNode a -> Integer -> b
  hamt-fold-children (f) (z) (children) (i) =
   if i == list-length children then z
   else let acc = hamt-node-fold f z (list-at children i)
    in hamt-fold-children f acc children (i + 1)

  hamt-merge-from : HamtMap a -> HamtMap a -> HamtMap a
  hamt-merge-from (source) (target) =
   hamt-fold (\acc k v -> hamt-set acc k v) target source
