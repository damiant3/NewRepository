Chapter: Set

 Sorted-list text set. O(log n) contains, O(n) insert.
 For small-to-medium sets where hash overhead isn't worth it.
 For large sets, use Hamt.codex directly.

Section: Type
  TextSet = record {
    items : List Text
  }

Section: Construction
  set-empty : TextSet
  set-empty = TextSet { items = [] }

  set-insert : TextSet -> Text -> TextSet
  set-insert (s) (x) =
   let items = s.items
   in let len = list-length items
   in let pos = bsearch-text-set items x 0 len
   in if pos < len & list-at items pos == x then s
      else TextSet { items = list-insert-at items pos x }

Section: Query
  set-contains : TextSet -> Text -> Boolean
  set-contains (s) (x) = text-set-has (s.items) x

  set-size : TextSet -> Integer
  set-size (s) = list-length (s.items)

  set-is-empty : TextSet -> Boolean
  set-is-empty (s) = list-length (s.items) == 0

Section: Iteration
  set-to-list : TextSet -> List Text
  set-to-list (s) = s.items

  set-from-list : List Text -> TextSet
  set-from-list (xs) = set-from-list-loop xs 0 (list-length xs) set-empty

  set-from-list-loop : List Text -> Integer -> Integer -> TextSet -> TextSet
  set-from-list-loop (xs) (i) (len) (acc) =
   if i >= len then acc
   else set-from-list-loop xs (i + 1) len (set-insert acc (list-at xs i))

