Chapter: TextFormat

 Shared text-formatting helpers.

Section: Zero-padded integers
  pad-zeros-loop : Integer -> Text -> Text
  pad-zeros-loop (remaining) (s) =
   if remaining <= 0 then s
   else pad-zeros-loop (remaining - 1) ("0" ++ s)

  integer-to-text-padded : Integer -> Integer -> Text
  integer-to-text-padded (n) (width) =
   let s = integer-to-text n
   in let len = text-length s
   in if len >= width then s
      else pad-zeros-loop (width - len) s

