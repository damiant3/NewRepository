Chapter: Name Resolution

 Checks that every name used in an expression resolves to a definition,
 builtin, constructor, type, or local binding.

Section: Scope
  Scope = record {
   names : List Text
  }

  empty-scope : Scope = Scope { names = [] }

  scope-has : Scope -> Text -> Boolean
  scope-has (sc) (name) =
   let len = list-length (sc.names)
   in if len == 0 then False
   else let pos = bsearch-text-set (sc.names) name 0 len
   in if pos >= len then False
      else list-at (sc.names) pos == name

  scope-add : Scope -> Text -> Scope
  scope-add (sc) (name) =
   let len = list-length (sc.names)
   in let pos = bsearch-text-set (sc.names) name 0 len
   in Scope { names = list-insert-at (sc.names) pos name }

Section: Built-in Names
  builtin-names : List Text
  builtin-names =
   ["show", "negate", "True", "False", "Nothing",
    "print-line", "read-line", "read-file",
    "write-file", "write-binary", "file-exists", "list-files",
    "open-file", "read-all", "close-file",
    "char-at", "char-to-text", "text-length", "substring",
    "is-letter", "is-digit", "is-whitespace",
    "text-to-integer", "integer-to-text", "text-replace",
    "text-split", "text-contains", "text-starts-with",
    "char-code", "char-code-at", "code-to-char",
    "list-length", "list-at", "list-insert-at", "list-set-at", "list-snoc",
    "text-compare",
    "get-args", "get-env", "current-dir",
    "map", "filter", "fold",
    "text-concat-list",
    "record-set",
    "linked-list-empty", "linked-list-push", "linked-list-to-list",
    "bit-and", "bit-or", "bit-xor", "bit-shl", "bit-shr", "bit-not"]

Section: Name Classification
  is-type-name : Text -> Boolean
  is-type-name (name) =
   if text-length name == 0 then False
   else is-letter (char-at name 0) & is-upper-char (char-at name 0)

  is-upper-char : Char -> Boolean
  is-upper-char (c) =
   let code = char-code c
   in code >= char-code 'E' & code <= char-code 'Z'

Section: Resolution Result
  ResolveResult = record {
   bag : DiagnosticBag,
   top-level-names : List Text,
   type-names : List Text,
   ctor-names : List Text
  }

Section: Collect Names
  collect-top-level-names : List ADef -> Integer -> Integer -> List Text -> List Diagnostic -> CollectResult
  collect-top-level-names (defs) (i) (len) (acc) (errs) =
   if i == len then CollectResult {
    names = acc,
    errors = errs
   }
   else let def = list-at defs i
   in let name = def.name.value
   in let acc-len = list-length acc
   in let pos = bsearch-text-set acc name 0 acc-len
   in if pos < acc-len then if list-at acc pos == name then collect-top-level-names defs (i + 1) len acc (errs ++ [make-error cdx-duplicate-definition ("Duplicate definition: " ++ name) (def.span)])
      else collect-top-level-names defs (i + 1) len (list-insert-at acc pos name) errs
      else collect-top-level-names defs (i + 1) len (list-insert-at acc pos name) errs

  CollectResult = record {
   names : List Text,
   errors : List Diagnostic
  }

  list-contains : List Text -> Text -> Boolean
  list-contains (xs) (name) =
   let len = list-length xs
   in if len == 0 then False
   else let pos = bsearch-text-set xs name 0 len
   in if pos >= len then False
      else list-at xs pos == name

  collect-ctor-names : List ATypeDef -> Integer -> Integer -> List Text -> List Text -> CtorCollectResult
  collect-ctor-names (type-defs) (i) (len) (type-acc) (ctor-acc) =
   if i == len then CtorCollectResult {
    type-names = type-acc,
    ctor-names = ctor-acc
   }
   else let td = list-at type-defs i
   in when td
     is AVariantTypeDef (name) (params) (ctors) (s) ->
      let new-type-acc = list-snoc type-acc (name.value)
   in let new-ctor-acc = collect-variant-ctors ctors 0 (list-length ctors) ctor-acc
   in collect-ctor-names type-defs (i + 1) len new-type-acc new-ctor-acc
     is ARecordTypeDef (name) (params) (fields) (s) ->
      collect-ctor-names type-defs (i + 1) len (list-snoc type-acc (name.value)) ctor-acc

  CtorCollectResult = record {
   type-names : List Text,
   ctor-names : List Text
  }

  collect-variant-ctors : List AVariantCtorDef -> Integer -> Integer -> List Text -> List Text
  collect-variant-ctors (ctors) (i) (len) (acc) =
   if i == len then acc
   else let ctor = list-at ctors i
   in collect-variant-ctors ctors (i + 1) len (list-snoc acc (ctor.name.value))

Section: Build Initial Scope
  build-all-names-scope : List Text -> List Text -> List Text -> Scope
  build-all-names-scope (top-names) (ctor-names) (builtins) =
   let sc = add-names-to-scope empty-scope top-names 0 (list-length top-names)
   in let sc2 = add-names-to-scope sc ctor-names 0 (list-length ctor-names)
   in add-names-to-scope sc2 builtins 0 (list-length builtins)

  add-names-to-scope : Scope -> List Text -> Integer -> Integer -> Scope
  add-names-to-scope (sc) (names) (i) (len) =
   if i == len then sc
   else add-names-to-scope (scope-add sc (list-at names i)) names (i + 1) len

Section: Resolve Expressions
  resolve-expr : Scope -> AExpr -> List Diagnostic
  resolve-expr (sc) (expr) =
   when expr
    is ALitExpr (val) (kind) (s) -> []
    is ANameExpr (name) (s) ->
     if scope-has sc (name.value) | is-type-name (name.value) then []
     else [make-error cdx-undefined-name ("Undefined name: " ++ name.value) s]
    is ABinaryExpr (left) (op) (right) (s) ->
     resolve-expr sc left ++ resolve-expr sc right
    is AUnaryExpr (operand) (s) -> resolve-expr sc operand
    is AApplyExpr (func) (arg) (s) ->
     resolve-expr sc func ++ resolve-expr sc arg
    is AIfExpr (cond) (then-e) (else-e) (s) ->
     resolve-expr sc cond ++ resolve-expr sc then-e ++ resolve-expr sc else-e
    is ALetExpr (bindings) (body) (s) ->
     resolve-let sc bindings body 0 (list-length bindings) []
    is ALambdaExpr (params) (body) (s) ->
     let sc2 = add-lambda-params sc params 0 (list-length params)
     in resolve-expr sc2 body
    is AMatchExpr (scrutinee) (arms) (s) ->
     resolve-expr sc scrutinee ++ resolve-match-arms sc arms 0 (list-length arms) []
    is AListExpr (elems) (s) ->
     resolve-list-elems sc elems 0 (list-length elems) []
    is ARecordExpr (name) (fields) (s) ->
     resolve-record-fields sc fields 0 (list-length fields) []
    is AFieldAccess (obj) (field) (s) -> resolve-expr sc obj
    is AActExpr (stmts) (s) -> resolve-act-stmts sc stmts 0 (list-length stmts) []
    is AErrorExpr (msg) (s) -> []

Section: Resolve Let
  resolve-let : Scope -> List ALetBind -> AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-let (sc) (bindings) (body) (i) (len) (errs) =
   if i == len then errs ++ resolve-expr sc body
   else let b = list-at bindings i
   in let bind-errs = resolve-expr sc (b.value)
   in let sc2 = scope-add sc (b.name.value)
   in resolve-let sc2 bindings body (i + 1) len (errs ++ bind-errs)

Section: Resolve Lambda Parameters
  add-lambda-params : Scope -> List Name -> Integer -> Integer -> Scope
  add-lambda-params (sc) (params) (i) (len) =
   if i == len then sc
   else let p = list-at params i
   in add-lambda-params (scope-add sc (p.value)) params (i + 1) len

Section: Resolve Match Arms
  resolve-match-arms : Scope -> List AMatchArm -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-match-arms (sc) (arms) (i) (len) (errs) =
   if i == len then errs
   else let arm = list-at arms i
   in let sc2 = collect-pattern-names sc (arm.pattern)
   in let arm-errs = resolve-expr sc2 (arm.body)
   in resolve-match-arms sc arms (i + 1) len (errs ++ arm-errs)

  collect-pattern-names : Scope -> APat -> Scope
  collect-pattern-names (sc) (pat) =
   when pat
    is AVarPat (name) (s) -> scope-add sc (name.value)
    is ACtorPat (name) (subs) (s) -> collect-ctor-pat-names sc subs 0 (list-length subs)
    is ALitPat (val) (kind) (s) -> sc
    is AWildPat (s) -> sc

  collect-ctor-pat-names : Scope -> List APat -> Integer -> Integer -> Scope
  collect-ctor-pat-names (sc) (subs) (i) (len) =
   if i == len then sc
   else let sub = list-at subs i
   in collect-ctor-pat-names (collect-pattern-names sc sub) subs (i + 1) len

Section: Resolve List Elements
  resolve-list-elems : Scope -> List AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-list-elems (sc) (elems) (i) (len) (errs) =
   if i == len then errs
   else let errs2 = resolve-expr sc (list-at elems i)
   in resolve-list-elems sc elems (i + 1) len (errs ++ errs2)

Section: Resolve Record Fields
  resolve-record-fields : Scope -> List AFieldExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-record-fields (sc) (fields) (i) (len) (errs) =
   if i == len then errs
   else let f = list-at fields i
   in let errs2 = resolve-expr sc (f.value)
   in resolve-record-fields sc fields (i + 1) len (errs ++ errs2)

Section: Resolve Act Statements
  resolve-act-stmts : Scope -> List AActStmt -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-act-stmts (sc) (stmts) (i) (len) (errs) =
   if i == len then errs
   else let stmt = list-at stmts i
   in when stmt
     is AActExprStmt (e) (s) ->
      let errs2 = resolve-expr sc e
   in resolve-act-stmts sc stmts (i + 1) len (errs ++ errs2)
     is AActBindStmt (name) (e) (s) ->
      let errs2 = resolve-expr sc e
   in let sc2 = scope-add sc (name.value)
   in resolve-act-stmts sc2 stmts (i + 1) len (errs ++ errs2)

Section: Resolve All Definitions
  resolve-all-defs : Scope -> List ADef -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-all-defs (sc) (defs) (i) (len) (errs) =
   if i == len then errs
   else let def = list-at defs i
   in let def-scope = add-def-params sc (def.params) 0 (list-length (def.params))
   in let errs2 = resolve-expr def-scope (def.body)
   in resolve-all-defs sc defs (i + 1) len (errs ++ errs2)

  add-def-params : Scope -> List AParam -> Integer -> Integer -> Scope
  add-def-params (sc) (params) (i) (len) =
   if i == len then sc
   else let p = list-at params i
   in add-def-params (scope-add sc (p.name.value)) params (i + 1) len

Section: Resolve Chapter
  resolve-chapter : AChapter -> ResolveResult
  resolve-chapter (mod) =
   resolve-chapter-with-citations mod []

  resolve-chapter-with-citations : AChapter -> List ResolveResult -> ResolveResult
  resolve-chapter-with-citations (mod) (imported) =
   let top = collect-top-level-names (mod.defs) 0 (list-length (mod.defs)) [] []
   in let ctors = collect-ctor-names (mod.type-defs) 0 (list-length (mod.type-defs)) [] []
   in let cited-names = collect-cited-names imported 0 (list-length imported) []
   in let all-top = top.names ++ cited-names
   in let sc = build-all-names-scope all-top (ctors.ctor-names) builtin-names
   in let expr-errs = resolve-all-defs sc (mod.defs) 0 (list-length (mod.defs)) []
   in ResolveResult {
     bag = bag-from-list (top.errors ++ expr-errs),
     top-level-names = top.names,
     type-names = ctors.type-names,
     ctor-names = ctors.ctor-names
    }

  collect-cited-names : List ResolveResult -> Integer -> Integer -> List Text -> List Text
  collect-cited-names (results) (i) (len) (acc) =
   if i == len then acc
   else let r = list-at results i
   in let names = r.top-level-names ++ r.ctor-names
   in collect-cited-names results (i + 1) len (acc ++ names)

Page 1

