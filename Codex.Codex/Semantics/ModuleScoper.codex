Chapter: Module Scoper

 Resolves name collisions across modules by prefixing duplicate
 definition names with their module slug. Only colliding names
 (defined in 2+ modules) are renamed. Non-colliding names pass
 through unchanged.

 The source format uses "module: slug-name" markers between file
 boundaries. The scoper reads these markers, tracks module membership,
 identifies collisions, and rewrites def names and body references.

Section: Module Assignment

  ModuleAssignment = record {
   def-name : Text,
   module-slug : Text
  }

  assign-modules : List DefHeader -> Text -> Integer -> List ModuleAssignment
  assign-modules (headers) (current-module) (i) =
   if i == list-length headers then []
   else let hdr = list-at headers i
   in [ModuleAssignment {
    def-name = (hdr.name.text),
    module-slug = current-module
   }] ++ assign-modules headers current-module (i + 1)

Section: Collision Detection

  find-colliding-names : List ModuleAssignment -> List Text
  find-colliding-names (assignments) =
   find-collisions-loop assignments 0 (list-length assignments) []

  find-collisions-loop : List ModuleAssignment -> Integer -> Integer -> List Text -> List Text
  find-collisions-loop (assignments) (i) (len) (acc) =
   if i == len then acc
   else let a = list-at assignments i
   in if appears-in-different-module assignments (a.def-name) (a.module-slug) 0 len then if list-contains acc (a.def-name) then find-collisions-loop assignments (i + 1) len acc
      else find-collisions-loop assignments (i + 1) len (list-snoc acc (a.def-name))
      else find-collisions-loop assignments (i + 1) len acc

  appears-in-different-module : List ModuleAssignment -> Text -> Text -> Integer -> Integer -> Boolean
  appears-in-different-module (assignments) (name) (module-slug) (i) (len) =
   if i == len then False
   else let a = list-at assignments i
   in if (a.def-name) == name then if (a.module-slug) /= module-slug then True
      else appears-in-different-module assignments name module-slug (i + 1) len
      else appears-in-different-module assignments name module-slug (i + 1) len

Section: Name Mangling

  mangle-name : Text -> Text -> Text
  mangle-name (module-slug) (def-name) =
   module-slug ++ "_" ++ def-name

  lookup-module : List ModuleAssignment -> Text -> Text
  lookup-module (assignments) (name) =
   lookup-module-loop assignments name 0 (list-length assignments)

  lookup-module-loop : List ModuleAssignment -> Text -> Integer -> Integer -> Text
  lookup-module-loop (assignments) (name) (i) (len) =
   if i == len then ""
   else let a = list-at assignments i
   in if (a.def-name) == name then a.module-slug
      else lookup-module-loop assignments name (i + 1) len

Section: Rename Map

  RenameEntry = record {
   original : Text,
   mangled : Text
  }

  build-rename-map : List Text -> List ModuleAssignment -> Text -> List RenameEntry
  build-rename-map (colliding) (assignments) (current-module) =
   build-rename-map-loop colliding assignments current-module 0 (list-length colliding) []

  build-rename-map-loop : List Text -> List ModuleAssignment -> Text -> Integer -> Integer -> List RenameEntry -> List RenameEntry
  build-rename-map-loop (colliding) (assignments) (current-module) (i) (len) (acc) =
   if i == len then acc
   else let name = list-at colliding i
   in let slug = lookup-module assignments name
   in let entry = RenameEntry {
    original = name,
    mangled = mangle-name slug name
   }
   in build-rename-map-loop colliding assignments current-module (i + 1) len (list-snoc acc entry)

Section: Apply Rename

  rename-lookup : List RenameEntry -> Text -> Text
  rename-lookup (entries) (name) =
   rename-lookup-loop entries name 0 (list-length entries)

  rename-lookup-loop : List RenameEntry -> Text -> Integer -> Integer -> Text
  rename-lookup-loop (entries) (name) (i) (len) =
   if i == len then name
   else let e = list-at entries i
   in if (e.original) == name then e.mangled
      else rename-lookup-loop entries name (i + 1) len

  is-colliding : List Text -> Text -> Boolean
  is-colliding (names) (name) =
   list-contains names name
