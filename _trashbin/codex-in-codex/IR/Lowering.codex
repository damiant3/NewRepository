Chapter: Lowering

  Transforms the typed AST into the intermediate representation.
  Each AST expression is lowered to an IR expression that carries
  its resolved type.

Section: Binary Op Lowering

    lower-bin-op : BinaryOp -> CodexType -> IRBinaryOp
    lower-bin-op (op) (ty) =
      when op
        if OpAdd -> IrAddInt
        if OpSub -> IrSubInt
        if OpMul -> IrMulInt
        if OpDiv -> IrDivInt
        if OpPow -> IrPowInt
        if OpEq -> IrEq
        if OpNotEq -> IrNotEq
        if OpLt -> IrLt
        if OpGt -> IrGt
        if OpLtEq -> IrLtEq
        if OpGtEq -> IrGtEq
        if OpDefEq -> IrEq
        if OpAppend -> IrAppendList
        if OpCons -> IrConsList
        if OpAnd -> IrAnd
        if OpOr -> IrOr

Section: Expression Lowering

    lower-expr : AExpr -> CodexType -> IRExpr
    lower-expr (e) (ty) =
      when e
        if ALitExpr (text) (kind) -> lower-literal text kind
        if ANameExpr (name) -> IrName name.value ty
        if AApplyExpr (f) (a) -> lower-apply f a ty
        if ABinaryExpr (l) (op) (r) -> IrBinary (lower-bin-op op ty) (lower-expr l ty) (lower-expr r ty) ty
        if AUnaryExpr (operand) -> IrNegate (lower-expr operand IntegerTy)
        if AIfExpr (c) (t) (e2) -> IrIf (lower-expr c BooleanTy) (lower-expr t ty) (lower-expr e2 ty) ty
        if ALetExpr (binds) (body) -> lower-let binds body ty
        if ALambdaExpr (params) (body) -> lower-lambda params body ty
        if AMatchExpr (scrut) (arms) -> lower-match scrut arms ty
        if AListExpr (elems) -> lower-list elems ty
        if ARecordExpr (name) (fields) -> lower-record name fields ty
        if AFieldAccess (rec) (field) -> IrFieldAccess (lower-expr rec ty) field.value ty
        if ADoExpr (stmts) -> lower-do stmts ty
        if AErrorExpr (msg) -> IrError msg ty

    lower-literal : Text -> LiteralKind -> IRExpr
    lower-literal (text) (kind) =
      when kind
        if IntLit -> IrIntLit (text-to-integer text)
        if NumLit -> IrIntLit (text-to-integer text)
        if TextLit -> IrTextLit text
        if BoolLit -> IrBoolLit (text == "True")

    lower-apply : AExpr -> AExpr -> CodexType -> IRExpr
    lower-apply (f) (a) (ty) =
      IrApply (lower-expr f ty) (lower-expr a ty) ty

    lower-let : List ALetBind -> AExpr -> CodexType -> IRExpr
    lower-let (binds) (body) (ty) =
      if list-length binds == 0 then lower-expr body ty
      else let b = list-at binds 0
        in IrLet b.name.value ty (lower-expr b.value ty) (lower-let-rest binds body ty 1)

    lower-let-rest : List ALetBind -> AExpr -> CodexType -> Integer -> IRExpr
    lower-let-rest (binds) (body) (ty) (i) =
      if i == list-length binds then lower-expr body ty
      else let b = list-at binds i
        in IrLet b.name.value ty (lower-expr b.value ty) (lower-let-rest binds body ty (i + 1))

    lower-lambda : List Name -> AExpr -> CodexType -> IRExpr
    lower-lambda (params) (body) (ty) =
      IrLambda (map-list lower-param params) (lower-expr body ty) ty

    lower-param : Name -> IRParam
    lower-param (n) = IRParam { name = n.value, type-val = ErrorTy }

    lower-match : AExpr -> List AMatchArm -> CodexType -> IRExpr
    lower-match (scrut) (arms) (ty) =
      IrMatch (lower-expr scrut ty) (map-list (lower-arm ty) arms) ty

    lower-arm : CodexType -> AMatchArm -> IRBranch
    lower-arm (ty) (arm) =
      IRBranch { pattern = lower-pattern arm.pattern, body = lower-expr arm.body ty }

    lower-pattern : APat -> IRPat
    lower-pattern (p) =
      when p
        if AVarPat (name) -> IrVarPat name.value ErrorTy
        if ALitPat (text) (kind) -> IrLitPat text ErrorTy
        if ACtorPat (name) (subs) -> IrCtorPat name.value (map-list lower-pattern subs) ErrorTy
        if AWildPat -> IrWildPat

    lower-list : List AExpr -> CodexType -> IRExpr
    lower-list (elems) (ty) =
      IrList (map-list (lower-elem ty) elems) ty

    lower-elem : CodexType -> AExpr -> IRExpr
    lower-elem (ty) (e) = lower-expr e ty

    lower-record : Name -> List AFieldExpr -> CodexType -> IRExpr
    lower-record (name) (fields) (ty) =
      IrRecord name.value (map-list (lower-field-val ty) fields) ty

    lower-field-val : CodexType -> AFieldExpr -> IRFieldVal
    lower-field-val (ty) (f) =
      IRFieldVal { name = f.name.value, value = lower-expr f.value ty }

    lower-do : List ADoStmt -> CodexType -> IRExpr
    lower-do (stmts) (ty) =
      IrDo (map-list (lower-do-stmt ty) stmts) ty

    lower-do-stmt : CodexType -> ADoStmt -> IRDoStmt
    lower-do-stmt (ty) (s) =
      when s
        if ADoBindStmt (name) (val) -> IrDoBind name.value ty (lower-expr val ty)
        if ADoExprStmt (e) -> IrDoExec (lower-expr e ty)

Section: Definition Lowering

    lower-def : ADef -> IRDef
    lower-def (d) =
      IRDef { name = d.name.value, params = map-list lower-def-param d.params, type-val = ErrorTy, body = lower-expr d.body ErrorTy }

    lower-def-param : AParam -> IRParam
    lower-def-param (p) = IRParam { name = p.name.value, type-val = ErrorTy }

    lower-module : AModule -> IRModule
    lower-module (m) =
      IRModule { name = m.name, defs = map-list lower-def m.defs }
