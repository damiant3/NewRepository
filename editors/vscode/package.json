{
  "name": "codex-lang",
  "displayName": "Codex Language",
  "description": "Language support for the Codex programming language",
  "version": "0.1.0",
  "publisher": "codex",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "activationEvents": [
    "onLanguage:codex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "codex",
        "extensions": [".codex"],
        "aliases": ["Codex", "codex"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "codex",
        "scopeName": "source.codex",
        "path": "./syntaxes/codex.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Codex",
      "properties": {
        "codex.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Codex LSP server executable. If empty, uses the bundled server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
