{
  "comments": {
    "lineComment": "-- "
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "=\\s*$|\\bact\\s*$|\\bthen\\s*$|\\belse\\s*$|\\bin\\s*$|\\{\\s*$",
    "decreaseIndentPattern": "^\\s*(in|else|\\})\\b"
  },
  "wordPattern": "[a-zA-Z][a-zA-Z0-9_-]*"
}
