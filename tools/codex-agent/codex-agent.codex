parse-int-or : Text -> Integer -> Integer
parse-int-or (s) (default-val) =
 if text-length s == 0 then default-val
 else text-to-integer s

pad-right : Text -> Integer -> Text
pad-right (s) (width) =
 if text-length s >= width then s
 else pad-right (s ++ " ") width

pad-left : Text -> Integer -> Text
pad-left (s) (width) =
 if text-length s >= width then s
 else pad-left (" " ++ s) width

count-lines : Text -> Integer
count-lines (content) =
 if text-length content == 0 then 0
 else list-length (text-split content "\n")

snap-path : Text -> Text
snap-path (file) = file ++ ".snap"

size-hint : Integer -> Text
size-hint (lines) =
 if lines > 300 then " !! LARGE"
 else if lines > 100 then " ~  medium"
 else ""

format-line : Integer -> Text -> Text
format-line (num) (line) =
 pad-left (integer-to-text num) 5 ++ "  " ++ line

format-lines-loop : List Text -> Integer -> Integer -> Text
format-lines-loop (lines) (current) (end-line) =
 if current > end-line then ""
 else if current > list-length lines then ""
 else let line = list-at lines (current - 1)
  in let formatted = format-line current line
   in let rest = format-lines-loop lines (current + 1) end-line
    in if text-length rest == 0 then formatted
     else formatted ++ "\n" ++ rest

do-peek : List Text -> [Console, FileSystem] Nothing
do-peek (args) =
 let argc = list-length args
 in if argc < 3 then print-line "Usage: codex-agent peek <file> [start] [end]"
  else let file = list-at args 2
   in if file-exists file then
    let content = read-file file
    in let all-lines = text-split content "\n"
     in let total = list-length all-lines
      in let raw-start = if argc > 3 then parse-int-or (list-at args 3) 1 else 1
       in let start = if raw-start < 1 then 1 else raw-start
        in let end-line = if argc > 4 then parse-int-or (list-at args 4) 0 else 0
         in let actual-end = if end-line == 0 then total else end-line
         in let header = "--- " ++ file ++ " lines " ++ integer-to-text start ++ ".." ++ integer-to-text actual-end ++ " of " ++ integer-to-text total ++ " ---"
          in print-line (header ++ "\n" ++ format-lines-loop all-lines start actual-end)
   else print-line ("File not found: " ++ file)

stat-loop : List Text -> Integer -> Integer -> Integer -> [FileSystem] Text
stat-loop (args) (idx) (total-lines) (total-chars) =
 if idx >= list-length args then
  if idx > 3 then
   "\n" ++ pad-right ("TOTAL (" ++ integer-to-text (idx - 2) ++ " files)") 50 ++ pad-left (integer-to-text total-lines) 7 ++ pad-left (integer-to-text total-chars) 9
  else ""
 else let file = list-at args idx
  in if file-exists file then
   let content = read-file file
   in let lines = count-lines content
    in let chars = text-length content
     in let row = pad-right file 50 ++ pad-left (integer-to-text lines) 7 ++ pad-left (integer-to-text chars) 9 ++ size-hint lines
      in let rest = stat-loop args (idx + 1) (total-lines + lines) (total-chars + chars)
       in row ++ "\n" ++ rest
  else let rest = stat-loop args (idx + 1) total-lines total-chars
   in "  (not found: " ++ file ++ ")\n" ++ rest

do-stat : List Text -> [Console, FileSystem] Nothing
do-stat (args) =
 let argc = list-length args
 in if argc < 3 then print-line "Usage: codex-agent stat <file> [file2] ..."
  else let header = pad-right "File" 50 ++ pad-left "Lines" 7 ++ pad-left "Chars" 9
   in let sep = "-------------------------------------------------- ------- --------"
    in print-line (header ++ "\n" ++ sep ++ "\n" ++ stat-loop args 2 0 0)

do-snap-save : Text -> [Console, FileSystem] Nothing
do-snap-save (file) =
 if file-exists file then
  let content = read-file file
  in let lines = count-lines content
   in let _ = write-file (snap-path file) content
    in print-line ("  Snapshot saved: " ++ file ++ " (" ++ integer-to-text lines ++ " lines)")
 else print-line ("  File not found: " ++ file)

do-snap-restore : Text -> [Console, FileSystem] Nothing
do-snap-restore (file) =
 let snap = snap-path file
 in if file-exists snap then
  let content = read-file snap
  in let lines = count-lines content
   in let _ = write-file file content
    in print-line ("  Restored: " ++ file ++ " (" ++ integer-to-text lines ++ " lines)")
 else print-line ("  No snapshot found for " ++ file ++ ". Run 'snap save' first.")

do-snap-diff : Text -> [Console, FileSystem] Nothing
do-snap-diff (file) =
 let snap = snap-path file
 in if file-exists snap then
  if file-exists file then
   let old-content = read-file snap
   in let new-content = read-file file
    in let old-lines = count-lines old-content
     in let new-lines = count-lines new-content
      in let delta = new-lines - old-lines
       in if old-content == new-content then
        print-line ("-- " ++ file ++ ": no changes (" ++ integer-to-text old-lines ++ " lines) --")
       else
        print-line ("-- " ++ file ++ " --\n  Before: " ++ integer-to-text old-lines ++ " lines   After: " ++ integer-to-text new-lines ++ " lines   Delta: " ++ integer-to-text delta ++ "\n  Use 'codex-agent peek " ++ file ++ "' to inspect.\n-- End diff --")
  else print-line ("  File not found: " ++ file)
 else print-line ("  No snapshot for " ++ file ++ ". Run 'codex-agent snap save " ++ file ++ "' first.")

do-snap : List Text -> [Console, FileSystem] Nothing
do-snap (args) =
 let argc = list-length args
 in if argc < 3 then print-line "Usage: codex-agent snap <save|diff|restore> <file>"
  else let action = list-at args 2
   in if action == "save" then
    if argc < 4 then print-line "Usage: codex-agent snap save <file>"
    else do-snap-save (list-at args 3)
   else if action == "diff" then
    if argc < 4 then print-line "Usage: codex-agent snap diff <file>"
    else do-snap-diff (list-at args 3)
   else if action == "restore" then
    if argc < 4 then print-line "Usage: codex-agent snap restore <file>"
    else do-snap-restore (list-at args 3)
   else print-line ("Unknown snap action: " ++ action ++ ". Use save, diff, or restore.")

check-file-status : Text -> Text -> Text
check-file-status (label) (path) =
 if file-exists path then label ++ ": found"
 else label ++ ": MISSING"

do-status : List Text -> [Console, FileSystem] Nothing
do-status (args) =
 print-line (
  "=== Codex Agent Status ===\n" ++
  check-file-status "  Solution     " "Codex.sln" ++ "\n" ++
  check-file-status "  Build props  " "Directory.Build.props" ++ "\n" ++
  check-file-status "  Contributing " "CONTRIBUTING.md" ++ "\n" ++
  check-file-status "  Lock doc     " "docs/REFERENCE-COMPILER-LOCK.md" ++ "\n" ++
  check-file-status "  Current plan " "docs/CurrentPlan.md" ++ "\n" ++
  check-file-status "  Agent rules  " ".github/copilot-instructions.md" ++ "\n" ++
  "=========================="
 )

plan-file : Text
plan-file = ".codex-agent/plan.txt"

log-file : Text
log-file = ".codex-agent/session.log"

build-log : Text
build-log = ".codex-agent/last-build.txt"

test-log : Text
test-log = ".codex-agent/last-test.txt"

known-conditions-file : Text
known-conditions-file = "docs/KNOWN-CONDITIONS.md"

handoff-file : Text
handoff-file = ".handoff"

collect-args : List Text -> Integer -> Integer -> Text
collect-args (args) (idx) (start) =
 if idx >= list-length args then ""
 else let word = list-at args idx
  in if idx == start then word ++ collect-args args (idx + 1) start
   else " " ++ word ++ collect-args args (idx + 1) start

kv-get : Text -> List Text -> Integer -> Text
kv-get (key) (lines) (idx) =
 if idx >= list-length lines then ""
 else let line = list-at lines idx
  in let prefix = key ++ "="
   in if text-starts-with line prefix then substring line (text-length prefix) (text-length line - text-length prefix)
    else kv-get key lines (idx + 1)

kv-set-loop : Text -> Text -> List Text -> Text -> Integer -> Integer -> Text
kv-set-loop (key) (value) (lines) (prefix) (idx) (found) =
 if idx >= list-length lines then
  if found == 0 then key ++ "=" ++ value ++ "\n"
  else ""
 else let line = list-at lines idx
  in let rest = kv-set-loop key value lines prefix (idx + 1) (if text-starts-with line prefix then 1 else found)
   in if text-starts-with line prefix then key ++ "=" ++ value ++ "\n" ++ rest
    else if text-length line == 0 then rest
     else line ++ "\n" ++ rest

kv-set : Text -> Text -> Text -> Text
kv-set (key) (value) (content) =
 let lines = text-split content "\n"
 in let prefix = key ++ "="
  in kv-set-loop key value lines prefix 0 0

valid-transition : Text -> Text -> Integer
valid-transition (from-state) (to-state) =
 if from-state == "draft" then if to-state == "awaiting-review" then 1 else 0
 else if from-state == "awaiting-review" then if to-state == "under-review" then 1 else if to-state == "abandoned" then 1 else 0
  else if from-state == "under-review" then if to-state == "approved" then 1 else if to-state == "changes-requested" then 1 else if to-state == "abandoned" then 1 else 0
   else if from-state == "changes-requested" then if to-state == "awaiting-review" then 1 else if to-state == "abandoned" then 1 else 0
    else if from-state == "approved" then if to-state == "merged" then 1 else if to-state == "abandoned" then 1 else 0
     else if from-state == "abandoned" then if to-state == "awaiting-review" then 1 else 0
      else if from-state == "merged" then if to-state == "awaiting-review" then 1 else 0
       else 0

next-action-hint : Text -> Text
next-action-hint (state) =
 if state == "draft" then "Author: run 'handoff push <summary>' to request review"
 else if state == "awaiting-review" then "Reviewer: run 'handoff review' to begin review"
  else if state == "under-review" then "Reviewer: run 'handoff approve' or 'handoff request-changes <reason>'"
   else if state == "changes-requested" then "Author: fix issues, then 'handoff push <summary>' to re-request review"
    else if state == "approved" then "Anyone: run 'handoff merge' to merge to master"
     else if state == "merged" then "Done. Branch can be deleted."
      else if state == "abandoned" then "Abandoned. No action needed."
       else "Unknown state."

detect-agent : [FileSystem] Text
detect-agent =
 let dir = current-dir
 in if text-contains dir "linux" then "linux-agent"
  else if text-contains dir "Linux" then "linux-agent"
   else "windows-agent"

get-current-branch : [FileSystem] Text
get-current-branch =
 let result = run-process "git" "rev-parse --abbrev-ref HEAD"
 in let lines = text-split result "\n"
  in if list-length lines > 0 then list-at lines 0 else "unknown"

do-handoff-show : [Console, FileSystem] Nothing
do-handoff-show =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let branch = kv-get "branch" lines 0
     in let author = kv-get "author" lines 0
      in let reviewer = kv-get "reviewer" lines 0
       in let summary = kv-get "summary" lines 0
        in let updated = kv-get "updated" lines 0
         in let notes = kv-get "notes" lines 0
          in print-line ("=== Handoff ===\n  State:    " ++ state ++ "\n  Branch:   " ++ branch ++ "\n  Author:   " ++ author ++ "\n  Reviewer: " ++ (if text-length reviewer == 0 then "(none yet)" else reviewer) ++ "\n  Summary:  " ++ summary ++ "\n  Updated:  " ++ updated ++ "\n  Notes:    " ++ notes ++ "\n  Next:     " ++ next-action-hint state ++ "\n===============")
 else print-line "  No active handoff. Use 'codex-agent handoff push <summary>' to create one."

make-handoff-content : Text -> Text -> Text -> Text -> Text
make-handoff-content (branch) (agent) (summary) (state) =
 "state=" ++ state ++ "\nbranch=" ++ branch ++ "\nauthor=" ++ agent ++ "\nreviewer=\nsummary=" ++ summary ++ "\nupdated=see-git-log\nnotes=\n"

do-handoff-push : List Text -> [Console, FileSystem] Nothing
do-handoff-push (args) =
 let argc = list-length args
 in if argc < 4 then print-line "Usage: codex-agent handoff push <summary>"
  else let summary = collect-args args 3 3
   in let branch = get-current-branch
    in let agent = detect-agent
     in let old-content = if file-exists handoff-file then read-file handoff-file else ""
      in let old-lines = text-split old-content "\n"
       in let old-state = kv-get "state" old-lines 0
        in let from-state = if text-length old-state == 0 then "draft" else old-state
         in let ok = valid-transition from-state "awaiting-review"
          in if ok == 0 then print-line ("  ERROR: cannot transition from '" ++ from-state ++ "' to 'awaiting-review'")
           else let new-content = make-handoff-content branch agent summary "awaiting-review"
            in let _ = write-file handoff-file new-content
             in let _ = run-process "git" ("add " ++ handoff-file)
              in let _ = run-process "git" ("commit -m \"handoff: " ++ summary ++ "\"")
               in print-line ("  Handoff created: awaiting-review\n  Branch:  " ++ branch ++ "\n  Author:  " ++ agent ++ "\n  Summary: " ++ summary ++ "\n  Next: push branch to origin, then another agent runs 'handoff review'")

do-handoff-review : List Text -> [Console, FileSystem] Nothing
do-handoff-review (args) =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let ok = valid-transition state "under-review"
     in if ok == 0 then print-line ("  ERROR: cannot review from state '" ++ state ++ "' (need awaiting-review)")
      else let agent = detect-agent
       in let new-content = kv-set "state" "under-review" (kv-set "reviewer" agent content)
        in let _ = write-file handoff-file new-content
         in let branch = kv-get "branch" lines 0
          in let summary = kv-get "summary" lines 0
           in print-line ("  Review started\n  Branch:   " ++ branch ++ "\n  Summary:  " ++ summary ++ "\n  Reviewer: " ++ agent ++ "\n  Next: build, test, review code, then 'handoff approve' or 'handoff request-changes <reason>'")
 else print-line "  No handoff found. Nothing to review."

do-handoff-approve : List Text -> [Console, FileSystem] Nothing
do-handoff-approve (args) =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let ok = valid-transition state "approved"
     in if ok == 0 then print-line ("  ERROR: cannot approve from state '" ++ state ++ "' (need under-review)")
      else let new-content = kv-set "state" "approved" content
       in let _ = write-file handoff-file new-content
        in let branch = kv-get "branch" lines 0
         in print-line ("  APPROVED\n  Branch: " ++ branch ++ "\n  Next: run 'handoff merge' to merge to master and clean up")
 else print-line "  No handoff found."

do-handoff-request-changes : List Text -> [Console, FileSystem] Nothing
do-handoff-request-changes (args) =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let ok = valid-transition state "changes-requested"
     in if ok == 0 then print-line ("  ERROR: cannot request changes from state '" ++ state ++ "' (need under-review)")
      else let reason = if list-length args > 3 then collect-args args 3 3 else "(no reason given)"
       in let new-content = kv-set "state" "changes-requested" (kv-set "notes" reason content)
        in let _ = write-file handoff-file new-content
         in let branch = kv-get "branch" lines 0
          in print-line ("  CHANGES REQUESTED\n  Branch: " ++ branch ++ "\n  Reason: " ++ reason ++ "\n  Next: author fixes issues, then 'handoff push <summary>'")
 else print-line "  No handoff found."

do-handoff-merge : List Text -> [Console, FileSystem] Nothing
do-handoff-merge (args) =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let ok = valid-transition state "merged"
     in if ok == 0 then print-line ("  ERROR: cannot merge from state '" ++ state ++ "' (need approved)")
      else let branch = kv-get "branch" lines 0
       in let summary = kv-get "summary" lines 0
        in let author = kv-get "author" lines 0
         in let reviewer = kv-get "reviewer" lines 0
          in let merge-msg = "merge: " ++ branch ++ " -- " ++ summary ++ " (author: " ++ author ++ ", reviewer: " ++ reviewer ++ ")"
           in let _ = write-file handoff-file (kv-set "state" "merged" content)
            in let _ = run-process "git" "checkout master"
             in let _ = run-process "git" ("merge " ++ branch ++ " --no-ff -m \"" ++ merge-msg ++ "\"")
              in print-line ("  MERGED to master\n  Commit: " ++ merge-msg ++ "\n  Next: push master, delete branch if done")
 else print-line "  No handoff found."

do-handoff-abandon : List Text -> [Console, FileSystem] Nothing
do-handoff-abandon (args) =
 if file-exists handoff-file then
  let content = read-file handoff-file
  in let lines = text-split content "\n"
   in let state = kv-get "state" lines 0
    in let new-content = kv-set "state" "abandoned" content
     in let _ = write-file handoff-file new-content
      in let branch = kv-get "branch" lines 0
       in print-line ("  ABANDONED\n  Branch: " ++ branch ++ "\n  Previous state: " ++ state)
 else print-line "  No handoff found."

do-handoff : List Text -> [Console, FileSystem] Nothing
do-handoff (args) =
 let argc = list-length args
 in if argc < 3 then do-handoff-show
  else let action = list-at args 2
   in if action == "show" then do-handoff-show
    else if action == "push" then do-handoff-push args
     else if action == "review" then do-handoff-review args
      else if action == "approve" then do-handoff-approve args
       else if action == "request-changes" then do-handoff-request-changes args
        else if action == "merge" then do-handoff-merge args
         else if action == "abandon" then do-handoff-abandon args
          else print-line ("Unknown handoff action: " ++ action ++ ". Use show, push, review, approve, request-changes, merge, or abandon.")

count-error-lines : List Text -> Integer -> Integer -> Integer
count-error-lines (lines) (idx) (acc) =
 if idx >= list-length lines then acc
 else let line = list-at lines idx
  in let has-error = text-contains line ": error "
   in count-error-lines lines (idx + 1) (if has-error then acc + 1 else acc)

count-warning-lines : List Text -> Integer -> Integer -> Integer
count-warning-lines (lines) (idx) (acc) =
 if idx >= list-length lines then acc
 else let line = list-at lines idx
  in let has-warn = text-contains line ": warning "
   in count-warning-lines lines (idx + 1) (if has-warn then acc + 1 else acc)

first-error-line : List Text -> Integer -> Text
first-error-line (lines) (idx) =
 if idx >= list-length lines then ""
 else let line = list-at lines idx
  in if text-contains line ": error " then line
   else first-error-line lines (idx + 1)

has-succeeded : List Text -> Integer -> Integer
has-succeeded (lines) (idx) =
 if idx >= list-length lines then 0
 else let line = list-at lines idx
  in if text-contains line "Build succeeded" then 1
   else if text-contains line "succeeded" then
    if text-contains line "0 failed" then 1 else has-succeeded lines (idx + 1)
   else has-succeeded lines (idx + 1)

has-test-failure : List Text -> Integer -> Integer
has-test-failure (lines) (idx) =
 if idx >= list-length lines then 0
 else let line = list-at lines idx
  in if text-contains line "Failed!" then 1
   else has-test-failure lines (idx + 1)

has-any-test-result : List Text -> Integer -> Integer
has-any-test-result (lines) (idx) =
 if idx >= list-length lines then 0
 else let line = list-at lines idx
  in if text-contains line "Passed!" then 1
   else if text-contains line "Failed!" then 1
    else has-any-test-result lines (idx + 1)

count-test-passed : List Text -> Integer -> Text
count-test-passed (lines) (idx) =
 if idx >= list-length lines then "?"
 else let line = list-at lines idx
  in if text-contains line "Passed" then line
   else if text-contains line "Failed" then line
    else count-test-passed lines (idx + 1)

count-condition-headers : List Text -> Integer -> Integer -> Integer
count-condition-headers (lines) (idx) (acc) =
 if idx >= list-length lines then acc
 else let line = list-at lines idx
  in let is-header = text-starts-with line "### "
   in count-condition-headers lines (idx + 1) (if is-header then acc + 1 else acc)

collect-condition-summaries : List Text -> Integer -> Text
collect-condition-summaries (lines) (idx) =
 if idx >= list-length lines then ""
 else let line = list-at lines idx
  in let rest = collect-condition-summaries lines (idx + 1)
   in if text-starts-with line "### " then
    "  * " ++ line ++ "\n" ++ rest
   else rest

do-doctor : List Text -> [Console, FileSystem] Nothing
do-doctor (args) =
 let kc-status = if file-exists known-conditions-file then "found" else "MISSING"
 in let kc-body = if file-exists known-conditions-file then read-file known-conditions-file else ""
  in let kc-lines = if text-length kc-body > 0 then text-split kc-body "\n" else text-split "" "\n"
   in let n-conditions = count-condition-headers kc-lines 0 0
    in let summaries = collect-condition-summaries kc-lines 0
     in let cs5001-check = if file-exists "Codex.Codex/Codex.Codex.csproj" then let csproj = read-file "Codex.Codex/Codex.Codex.csproj" in if text-contains csproj "<OutputType>Exe</OutputType>" then "  CS5001 trap: ACTIVE (Codex.Codex is Exe, will emit CS5001 -- this is expected)" else "  CS5001 trap: cleared" else "  CS5001 trap: n/a (no Codex.Codex project)"
      in let session-status = if file-exists log-file then let log-content = read-file log-file in let log-lines = count-lines log-content in "  Session log: " ++ integer-to-text log-lines ++ " entries" else "  Session log: (none -- new session)"
       in let last-build-status = if file-exists build-log then let bc = read-file build-log in let bl = text-split bc "\n" in let be = count-error-lines bl 0 0 in "  Last build: " ++ integer-to-text be ++ " errors (see " ++ build-log ++ ")" else "  Last build: (no record)"
        in let last-test-status = if file-exists test-log then let tc = read-file test-log in let tl = text-split tc "\n" in let tp = count-test-passed tl 0 in "  Last test: " ++ tp ++ " (see " ++ test-log ++ ")" else "  Last test: (no record)"
         in let handoff-status = if file-exists handoff-file then let hc = read-file handoff-file in let hl = text-split hc "\n" in let hs = kv-get "state" hl 0 in let hb = kv-get "branch" hl 0 in "  Handoff: " ++ hs ++ " on " ++ hb ++ " -- " ++ next-action-hint hs else "  Handoff: (none active)"
          in print-line ("=== Doctor -- Known Conditions & Diagnostics ===\n" ++ "  Conditions file: " ++ kc-status ++ " (" ++ integer-to-text n-conditions ++ " known)\n" ++ summaries ++ cs5001-check ++ "\n" ++ session-status ++ "\n" ++ last-build-status ++ "\n" ++ last-test-status ++ "\n" ++ handoff-status ++ "\n" ++ "  Advice: CS5001 in Codex.Codex is PRE-EXISTING. Do NOT investigate.\n" ++ "  Advice: Do NOT extract effectful helper functions in .codex -- inline instead.\n" ++ "  Advice: After editing .codex files, check for else->then corruption.\n" ++ "  Advice: ALWAYS snap save before editing. edit_file has deleted code from files in this repo. See TEF-009.\n" ++ "  See: docs/KNOWN-CONDITIONS.md for full details.\n" ++ "================================================")

do-log : List Text -> [Console, FileSystem] Nothing
do-log (args) =
 let argc = list-length args
 in if argc < 3 then print-line "Usage: codex-agent log <message>"
  else let msg = collect-args args 2 2
   in let existing = if file-exists log-file then read-file log-file else ""
    in let entry = "[LOG] " ++ msg
     in let _ = write-file log-file (existing ++ entry ++ "\n")
      in print-line ("  Logged: " ++ msg)

take-last-n : List Text -> Integer -> Integer -> Integer -> Text
take-last-n (lines) (idx) (start) (total) =
 if idx >= total then ""
 else if idx < start then take-last-n lines (idx + 1) start total
  else let line = list-at lines idx
   in let rest = take-last-n lines (idx + 1) start total
    in if text-length rest == 0 then line
     else line ++ "\n" ++ rest

do-recall : List Text -> [Console, FileSystem] Nothing
do-recall (args) =
 if file-exists log-file then
  let content = read-file log-file
  in if text-length content == 0 then print-line "  (session log is empty)"
   else let lines = text-split content "\n"
    in let raw-total = list-length lines
     in let total = if raw-total > 0 then raw-total - 1 else 0
      in let n = if list-length args > 2 then parse-int-or (list-at args 2) 10 else 10
       in let start = if total > n then total - n else 0
        in print-line ("=== Session Log (last " ++ integer-to-text n ++ ") ===\n" ++ take-last-n lines 0 start total ++ "\n===========================")
 else print-line "  (no session log yet. Use 'codex-agent log <msg>' or run build/test.)"

do-plan-show : [Console, FileSystem] Nothing
do-plan-show =
 if file-exists plan-file then
  let content = read-file plan-file
  in if text-length content == 0 then print-line "  (no tasks)"
   else print-line ("=== Agent Plan ===\n" ++ content ++ "==================")
 else print-line "  (no plan file yet. Use 'codex-agent plan add <task>' to start.)"

do-plan-add : List Text -> Integer -> Text
do-plan-add (args) (idx) =
 if idx >= list-length args then ""
 else if idx == 3 then list-at args idx ++ do-plan-add args (idx + 1)
  else " " ++ list-at args idx ++ do-plan-add args (idx + 1)

do-plan : List Text -> [Console, FileSystem] Nothing
do-plan (args) =
 let argc = list-length args
 in if argc < 3 then do-plan-show
  else let action = list-at args 2
   in if action == "show" then do-plan-show
    else if action == "clear" then
     let _ = write-file plan-file ""
     in print-line "  Plan cleared."
    else if action == "add" then
     if argc < 4 then print-line "Usage: codex-agent plan add <task description>"
     else let task = do-plan-add args 3
      in let existing = if file-exists plan-file then read-file plan-file else ""
       in let new-content = if text-length existing == 0 then "- " ++ task ++ "\n" else existing ++ "- " ++ task ++ "\n"
        in let _ = write-file plan-file new-content
         in print-line ("  Added: " ++ task)
    else print-line ("Unknown plan action: " ++ action ++ ". Use add, show, or clear.")

agent-budget : Text -> Integer
agent-budget (name) =
 if name == "cam" then 800000
 else if name == "windows" then 60000
  else if name == "linux" then 60000
   else 60000

agent-label : Text -> Text
agent-label (name) =
 if name == "cam" then "Cam (Claude Code CLI, 1M context)"
 else if name == "windows" then "Agent Windows (Copilot/VS)"
  else if name == "linux" then "Agent Linux (Claude sandbox)"
   else "unknown agent (using default 60K budget)"

check-level : Integer -> Text
check-level (pct) =
 if pct > 90 then "RED - overloaded, build and verify NOW"
 else if pct > 70 then "ORANGE - high load, finish current task then build"
  else if pct > 40 then "YELLOW - moderate, stay focused"
   else "GREEN - plenty of headroom"

do-check : List Text -> [Console, FileSystem] Nothing
do-check (args) =
 let argc = list-length args
 in let name = if argc > 2 then list-at args 2 else "unknown"
  in let budget = agent-budget name
   in let label = agent-label name
    in let pc = if file-exists "Codex.Codex/Syntax/Parser.codex" then read-file "Codex.Codex/Syntax/Parser.codex" else ""
     in let parser-chars = text-length pc
      in let tc = if file-exists "Codex.Codex/Types/TypeChecker.codex" then read-file "Codex.Codex/Types/TypeChecker.codex" else ""
       in let tc-chars = text-length tc
        in let ec = if file-exists "Codex.Codex/Emit/CSharpEmitter.codex" then read-file "Codex.Codex/Emit/CSharpEmitter.codex" else ""
         in let emitter-chars = text-length ec
          in let lc = if file-exists "Codex.Codex/IR/Lowering.codex" then read-file "Codex.Codex/IR/Lowering.codex" else ""
           in let lowering-chars = text-length lc
            in let uc = if file-exists "Codex.Codex/Types/Unifier.codex" then read-file "Codex.Codex/Types/Unifier.codex" else ""
             in let unifier-chars = text-length uc
              in let xc = if file-exists "Codex.Codex/Syntax/Lexer.codex" then read-file "Codex.Codex/Syntax/Lexer.codex" else ""
               in let lexer-chars = text-length xc
                in let total-hot = parser-chars + tc-chars + emitter-chars + lowering-chars + unifier-chars + lexer-chars
                 in let pct = (total-hot * 100) / budget
                  in let level = check-level pct
                   in let plan-status = if file-exists plan-file then let planc = read-file plan-file in if text-length planc == 0 then "  Plan: (empty)" else "  Plan: " ++ integer-to-text (list-length (text-split planc "\n") - 1) ++ " tasks" else "  Plan: (none)"
                    in print-line ("=== Cognitive Check ===\n" ++ "  Agent:  " ++ label ++ "\n" ++ "  Hot path files: " ++ integer-to-text total-hot ++ " chars / " ++ integer-to-text budget ++ " budget (" ++ integer-to-text pct ++ "%)\n" ++ "  Load: " ++ level ++ "\n" ++ "  Parser.codex:       " ++ pad-left (integer-to-text parser-chars) 6 ++ " chars\n" ++ "  TypeChecker.codex:  " ++ pad-left (integer-to-text tc-chars) 6 ++ " chars\n" ++ "  CSharpEmitter.codex:" ++ pad-left (integer-to-text emitter-chars) 6 ++ " chars\n" ++ "  Lowering.codex:     " ++ pad-left (integer-to-text lowering-chars) 6 ++ " chars\n" ++ "  Unifier.codex:      " ++ pad-left (integer-to-text unifier-chars) 6 ++ " chars\n" ++ "  Lexer.codex:        " ++ pad-left (integer-to-text lexer-chars) 6 ++ " chars\n" ++ plan-status ++ "\n" ++ "=======================")

do-build : List Text -> [Console, FileSystem] Nothing
do-build (args) =
 let output = run-process "dotnet" "build Codex.sln --verbosity quiet"
 in let _ = write-file build-log output
  in let lines = text-split output "\n"
   in let errs = count-error-lines lines 0 0
    in let warns = count-warning-lines lines 0 0
     in let ok = has-succeeded lines 0
      in let status = if ok == 1 then "PASS" else "FAIL"
       in let first-err = if errs > 0 then "\n  First error: " ++ first-error-line lines 0 else ""
        in let summary = "=== Build " ++ status ++ " === errors: " ++ integer-to-text errs ++ "  warnings: " ++ integer-to-text warns ++ first-err ++ "\n  Full log: " ++ build-log
         in let log-entry = "[BUILD] " ++ status ++ " errors=" ++ integer-to-text errs ++ " warnings=" ++ integer-to-text warns
          in let log-existing = if file-exists log-file then read-file log-file else ""
           in let _ = write-file log-file (log-existing ++ log-entry ++ "\n")
            in let verify-output = run-process "pwsh" "-File tools/codex-agent-verify.ps1 docs/CurrentPlan.md docs/ToDo/CSharpCleanup.md docs/TOOL-ERROR-REGISTRY.md docs/KNOWN-CONDITIONS.md .github/copilot-instructions.md"
             in print-line (summary ++ "\n" ++ verify-output)

do-test : List Text -> [Console, FileSystem] Nothing
do-test (args) =
 let argc = list-length args
 in let extra = if argc > 2 then " --filter " ++ list-at args 2 else ""
  in let output = run-process "dotnet" ("test Codex.sln --verbosity quiet" ++ extra)
   in let _ = write-file test-log output
    in let lines = text-split output "\n"
     in let errs = count-error-lines lines 0 0
      in let test-line = count-test-passed lines 0
       in let has-tests = has-any-test-result lines 0
        in let has-fail = has-test-failure lines 0
         in let status = if errs > 0 then "BUILD-FAIL" else if has-tests == 1 then if has-fail == 1 then "FAIL" else "PASS" else "FAIL"
         in let first-err = if errs > 0 then "\n  First error: " ++ first-error-line lines 0 else ""
          in let summary = "=== Test " ++ status ++ " === " ++ test-line ++ first-err ++ "\n  Full log: " ++ test-log
           in let log-entry = "[TEST] " ++ status ++ " " ++ test-line
            in let log-existing = if file-exists log-file then read-file log-file else ""
             in let _ = write-file log-file (log-existing ++ log-entry ++ "\n")
              in print-line summary

print-help : [Console] Nothing
print-help =
 print-line (
  "codex-agent - Codex compiler toolkit for AI agents\n" ++
  "\n" ++
  "Commands:\n" ++
  "  peek <file> [start] [end]          Read file lines safely\n" ++
  "  stat <file> [file2] ...            File statistics (lines, chars)\n" ++
  "  snap save <file>                   Snapshot before editing\n" ++
  "  snap diff <file>                   Compare file to snapshot\n" ++
  "  snap restore <file>                Restore from snapshot\n" ++
  "  status                             Project status check\n" ++
  "  plan [add <task>|show|clear]       Task list (survives context loss)\n" ++
  "  check [agent]                      Cognitive load estimate (cam|windows|linux)\n" ++
  "  doctor                             Known conditions & diagnostics briefing\n" ++
  "  handoff [show]                     Show current handoff state\n" ++
  "  handoff push <summary>             Create/update handoff, request review\n" ++
  "  handoff review                     Pick up handoff for review\n" ++
  "  handoff approve                    Approve after review\n" ++
  "  handoff request-changes <reason>   Request changes with reason\n" ++
  "  handoff merge                      Merge approved branch to master\n" ++
  "  handoff abandon                    Abandon handoff\n" ++
  "  log <message>                      Append to session log\n" ++
  "  recall [n]                         Show last N session log entries (default 10)\n" ++
  "  build                              Build + compact summary (full log stored)\n" ++
  "  test [filter]                      Test + compact summary (full log stored)\n" ++
  "  orient [topic]                      Project map (topics: syntax, pipeline, agents, style, git, tools, structure, pitfalls)\n" ++
  "  greet <name> [--context N] [...]    Register agent identity and capabilities\n" ++
  "  roster                              Show registered agents and capabilities\n" ++
  "  init                                Full session start (doctor+check+status+handoff+sweep+git)\n" ++
  "  help                                This message\n" ++
  "\n" ++
  "Handoff lifecycle: draft -> awaiting-review -> under-review -> approved -> merged\n" ++
  "                                             \\-> changes-requested -> awaiting-review\n" ++
  "\n" ++
  "Usage: codex-agent <command> [args]\n" ++
  "Built from codex-agent.codex via the Codex IL backend."
 )

agents-dir : Text
agents-dir = "docs/agents"

agent-file : Text -> Text
agent-file (name) = agents-dir ++ "/" ++ name ++ ".txt"

do-greet : List Text -> [Console, FileSystem] Nothing
do-greet (args) =
 let argc = list-length args
 in if argc < 3 then print-line "Usage: codex-agent greet <name> <context> <tools> <os> <workdir>"
  else let name = list-at args 2
   in let _ = if file-exists agents-dir then "" else run-process "pwsh" ("-Command New-Item -ItemType Directory -Force -Path " ++ agents-dir)
    in let ctx = if argc > 3 then list-at args 3 else ""
     in let tools-val = if argc > 4 then list-at args 4 else ""
      in let os-val = if argc > 5 then list-at args 5 else ""
       in let workdir-val = if argc > 6 then list-at args 6 else current-dir
        in let dotnet-ver = run-process "dotnet" "--version"
         in let content = "agent=" ++ name ++ "\ncontext=" ++ ctx ++ "\ntools=" ++ tools-val ++ "\nos=" ++ os-val ++ "\nworkdir=" ++ workdir-val ++ "\ndotnet=" ++ dotnet-ver ++ "last-seen=see-git-log\n"
          in let _ = write-file (agent-file name) content
           in print-line ("  Agent registered: " ++ name ++ "\n  Context: " ++ (if text-length ctx > 0 then ctx else "(default)") ++ "\n  Tools: " ++ (if text-length tools-val > 0 then tools-val else "(none)") ++ "\n  OS: " ++ (if text-length os-val > 0 then os-val else "(unknown)") ++ "\n  Workdir: " ++ workdir-val)

format-agent-entry : Text -> Text
format-agent-entry (content) =
 let lines = text-split content "\n"
 in let name = kv-get "agent" lines 0
  in let ctx = kv-get "context" lines 0
   in let tools-val = kv-get "tools" lines 0
    in let os-val = kv-get "os" lines 0
     in let workdir-val = kv-get "workdir" lines 0
      in "  " ++ pad-right name 10 ++ pad-right (if text-length ctx > 0 then ctx ++ " ctx" else "?") 12 ++ pad-right os-val 16 ++ pad-right tools-val 24 ++ workdir-val

format-roster-loop : List Text -> Integer -> [FileSystem] Text
format-roster-loop (files) (idx) =
 if idx >= list-length files then ""
 else let path = list-at files idx
  in let content = read-file path
   in let entry = format-agent-entry content
    in let rest = format-roster-loop files (idx + 1)
     in if text-length rest == 0 then entry
      else entry ++ "\n" ++ rest

do-roster : List Text -> [Console, FileSystem] Nothing
do-roster (args) =
 let files = list-files agents-dir "*.txt"
 in if list-length files == 0 then print-line "  No agents registered. Use 'codex-agent greet <name>' to register."
  else let header = "=== Agent Roster ==="
   in let entries = format-roster-loop files 0
    in print-line (header ++ "\n" ++ entries ++ "\n=====================")

orient-level0 : [Console, FileSystem] Nothing
orient-level0 =
 let lock-status = if file-exists "docs/REFERENCE-COMPILER-LOCK.md" then
   let lock-content = read-file "docs/REFERENCE-COMPILER-LOCK.md"
   in if text-contains lock-content "LIFTED" then "LIFTED — src/ is modifiable"
    else if text-contains lock-content "LOCKED" then "LOCKED — do not modify src/"
     else "see docs/REFERENCE-COMPILER-LOCK.md"
  else "unknown"
 in let roster-files = list-files agents-dir "*.txt"
 in let roster-info = if list-length roster-files > 0 then format-roster-loop roster-files 0
  else "  (none registered -- use 'codex-agent greet <name>')"
 in let plan-info = if file-exists "docs/CurrentPlan.md" then
   let pc = read-file "docs/CurrentPlan.md"
   in let pl = text-split pc "\n"
    in "  Current plan: docs/CurrentPlan.md (" ++ integer-to-text (list-length pl) ++ " lines)"
  else "  Current plan: (none)"
 in print-line (
  "=== Codex Project — Quick Orientation ===\n" ++
  "\n" ++
  "  Language:  Self-hosting compiler, .codex source, ML-family syntax\n" ++
  "  Pipeline:  Lexer -> Parser -> Desugarer -> NameResolver -> TypeChecker -> Lowering -> Emitter\n" ++
  "  Backends:  15 (C#, JS, Python, Rust, C++, Go, Java, Ada, Fortran, COBOL, IL, RISC-V, ARM64, x86-64, WASM)\n" ++
  "  Tests:     900+, run with: dotnet test Codex.sln\n" ++
  "  Build:     dotnet build Codex.sln (.NET 8, TreatWarningsAsErrors)\n" ++
  "  Self-host: 26 .codex files in Codex.Codex/\n" ++
  "\n" ++
  "  Ref compiler lock: " ++ lock-status ++ "\n" ++
  "\n" ++
  "  Agents:\n" ++ roster-info ++ "\n" ++
  "\n" ++
  plan-info ++ "\n" ++
  "\n" ++
  "  Key docs:\n" ++
  "    Overview:     docs/00-OVERVIEW.md\n" ++
  "    Principles:   docs/10-PRINCIPLES.md\n" ++
  "    Syntax:       docs/SYNTAX-QUICKREF.md\n" ++
  "    Pitfalls:     docs/KNOWN-CONDITIONS.md\n" ++
  "    Tool errors:  docs/TOOL-ERROR-REGISTRY.md\n" ++
  "    Code style:   .github/copilot-instructions.md\n" ++
  "    Route map:    docs/THE-LAST-PEAK.md\n" ++
  "\n" ++
  "  Project structure:\n" ++
  "    Core -> Syntax -> Ast -> Semantics -> Types -> IR -> Emit -> Emit.* -> Cli\n" ++
  "    Codex.Core has zero deps (root). Codex.Cli references everything.\n" ++
  "\n" ++
  "  Topics (use 'orient <topic>' for detail):\n" ++
  "    syntax, pipeline, agents, style, git, tools, structure, pitfalls\n" ++
  "\n" ++
  "=========================================")

orient-topic : Text -> [Console, FileSystem] Nothing
orient-topic (topic) =
 if topic == "syntax" then
  if file-exists "docs/SYNTAX-QUICKREF.md" then print-line (read-file "docs/SYNTAX-QUICKREF.md")
  else print-line "  docs/SYNTAX-QUICKREF.md not found"
 else if topic == "pitfalls" then
  if file-exists "docs/KNOWN-CONDITIONS.md" then print-line (read-file "docs/KNOWN-CONDITIONS.md")
  else print-line "  docs/KNOWN-CONDITIONS.md not found"
 else if topic == "style" then
  print-line (
   "=== Code Style Quick Reference ===\n" ++
   "\n" ++
   "  C#:\n" ++
   "    Private fields: m_ prefix (m_diagnostics)\n" ++
   "    Properties/types: PascalCase. Locals: camelCase.\n" ++
   "    sealed record for immutable ref. readonly record struct for values.\n" ++
   "    No XML doc comments (///). No var. No unused fields.\n" ++
   "    Prefer Map<K,V> (Codex.Core) over ImmutableDictionary.\n" ++
   "    4 spaces, UTF-8, max 120 chars/line. TreatWarningsAsErrors.\n" ++
   "\n" ++
   "  Codex (.codex):\n" ++
   "    Booleans: True / False (capital T/F)\n" ++
   "    Application: left-assoc, f x y = (f x) y\n" ++
   "    Pattern matching: when/if, not match/case\n" ++
   "    All functions curried. Effects in brackets: [Console] Nothing\n" ++
   "    Do NOT extract effectful helper functions — inline instead.\n" ++
   "\n" ++
   "  Full details: .github/copilot-instructions.md\n" ++
   "=================================")
 else if topic == "agents" then
  let agent-files = list-files agents-dir "*.txt"
  in if list-length agent-files > 0 then
   let entries = format-roster-loop agent-files 0
   in print-line ("=== Agent Roster (detailed) ===\n" ++ entries ++ "\n\n  Register: codex-agent greet <name> <context> <tools> <os> <workdir>\n" ++ "  Branch prefixes: windows/, linux/, cam/, nut/\n" ++ "  No agent merges own work to master without review.\n" ++ "==============================")
  else print-line "  No agents registered. Use 'codex-agent greet <name>'."
 else if topic == "git" then
  print-line (
   "=== Git Workflow ===\n" ++
   "  Branch naming: windows/<topic>, linux/<topic>, cam/<topic>, nut/<topic>\n" ++
   "  Conventional Commits: feat:, fix:, docs:, test:, chore:, refactor:\n" ++
   "  No agent merges own work to master without review.\n" ++
   "  Handoff: codex-agent handoff push/review/approve/merge\n" ++
   "===================")
 else if topic == "tools" then
  print-line (
   "=== Agent Toolkit ===\n" ++
   "  All tools run natively: tools/codex-agent/<tool>.exe <args>\n" ++
   "  Or via dotnet:          dotnet tools/codex-agent/<tool>.exe <args>\n" ++
   "\n" ++
   "  codex-agent  Main toolkit (init, build, test, doctor, handoff, etc.)\n" ++
   "  peek         Read file lines with line numbers\n" ++
   "  fstat        File statistics\n" ++
   "  sdiff        Side-by-side diff\n" ++
   "\n" ++
   "  Run 'codex-agent help' for full command list.\n" ++
   "====================")
 else if topic == "structure" then
  print-line (
   "=== Project Structure ===\n" ++
   "  Dependency flow (one way):\n" ++
   "    Core -> Syntax -> Ast -> Semantics -> Types -> IR -> Emit -> Emit.* -> Cli\n" ++
   "\n" ++
   "  Codex.Core      Zero deps (root). Map<K,V>, ValueMap, SourceSpan.\n" ++
   "  Codex.Syntax    Lexer + Parser. Token, SyntaxTree.\n" ++
   "  Codex.Ast       AST nodes. Expression, Declaration.\n" ++
   "  Codex.Semantics Name resolution. NameResolver, Scope.\n" ++
   "  Codex.Types     Type checking + inference. TypeChecker, Unifier.\n" ++
   "  Codex.IR        IR lowering. IRModule, IRNode.\n" ++
   "  Codex.Emit      Emitter interface. ICodeEmitter.\n" ++
   "  Codex.Emit.*    15 backend emitters (CSharp, IL, RiscV, Arm64, etc.)\n" ++
   "  Codex.Cli       Composition root. build/run/repl/bootstrap commands.\n" ++
   "\n" ++
   "  Self-hosted: 26 .codex files in Codex.Codex/\n" ++
   "  Bootstrap:   tools/Codex.Bootstrap/\n" ++
   "  Tests:       Codex.Core.Tests, Codex.Syntax.Tests, etc.\n" ++
   "========================")
 else if topic == "pipeline" then
  print-line (
   "=== Compiler Pipeline ===\n" ++
   "  Source (.codex)\n" ++
   "    |-> Lexer      tokenizes source text\n" ++
   "    |-> Parser     builds syntax tree\n" ++
   "    |-> Desugarer  expands syntactic sugar\n" ++
   "    |-> NameResolver  resolves identifiers to bindings\n" ++
   "    |-> TypeChecker   Hindley-Milner inference + effect tracking\n" ++
   "    |-> Lowering      AST -> IR (IRModule, IRNode)\n" ++
   "    |-> Emitter       IR -> target code\n" ++
   "\n" ++
   "  Hot path files (self-hosted):\n" ++
   "    Codex.Codex/Syntax/Lexer.codex\n" ++
   "    Codex.Codex/Syntax/Parser.codex\n" ++
   "    Codex.Codex/Types/TypeChecker.codex\n" ++
   "    Codex.Codex/Types/Unifier.codex\n" ++
   "    Codex.Codex/IR/Lowering.codex\n" ++
   "    Codex.Codex/Emit/CSharpEmitter.codex\n" ++
   "=========================")
 else print-line ("  Unknown topic: " ++ topic ++ ". Available: syntax, pipeline, agents, style, git, tools, structure, pitfalls")

do-orient : List Text -> [Console, FileSystem] Nothing
do-orient (args) =
 let argc = list-length args
 in if argc < 3 then orient-level0
  else orient-topic (list-at args 2)

do-init : List Text -> [Console, FileSystem] Nothing
do-init (args) =
 let agent = "tools/codex-agent/codex-agent.dll"
 in let doctor-out = run-process "dotnet" (agent ++ " doctor")
  in let check-out = run-process "dotnet" (agent ++ " check")
   in let status-out = run-process "dotnet" (agent ++ " status")
    in let handoff-out = run-process "dotnet" (agent ++ " handoff show")
     in let verify-out = run-process "pwsh" "-File tools/codex-agent-verify.ps1 docs/CurrentPlan.md docs/ToDo/CSharpCleanup.md docs/TOOL-ERROR-REGISTRY.md docs/KNOWN-CONDITIONS.md .github/copilot-instructions.md"
      in let git-log = run-process "git" "log --oneline -5"
       in let git-branches = run-process "git" "branch -r"
        in print-line (doctor-out ++ "\n" ++ check-out ++ "\n" ++ status-out ++ "\n" ++ handoff-out ++ "\n" ++ verify-out ++ "\n=== Recent Commits ===\n" ++ git-log ++ "\n=== Remote Branches ===\n" ++ git-branches)

main : [Console, FileSystem] Nothing
main = do
 let args = get-args
 in let argc = list-length args
  in if argc < 2 then print-help
   else let cmd = list-at args 1
    in if cmd == "peek" then do-peek args
     else if cmd == "stat" then do-stat args
      else if cmd == "snap" then do-snap args
       else if cmd == "init" then do-init args
        else if cmd == "status" then do-status args
         else if cmd == "plan" then do-plan args
          else if cmd == "check" then do-check args
           else if cmd == "doctor" then do-doctor args
            else if cmd == "handoff" then do-handoff args
             else if cmd == "log" then do-log args
              else if cmd == "recall" then do-recall args
               else if cmd == "build" then do-build args
                else if cmd == "test" then do-test args
                 else if cmd == "orient" then do-orient args
                  else if cmd == "greet" then do-greet args
                   else if cmd == "roster" then do-roster args
                    else if cmd == "help" then print-help
                     else print-line ("Unknown command: " ++ cmd ++ ". Run 'codex-agent help' for usage.")
