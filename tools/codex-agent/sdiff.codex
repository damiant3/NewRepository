snap-path : Text -> Text
snap-path (file) = file ++ ".snap"

count-lines : Text -> Integer
count-lines (content) =
 if text-length content == 0 then 0
 else list-length (text-split content "\n")

do-snap : Text -> [Console, FileSystem] Nothing
do-snap (file) =
 if file-exists file then
  let content = read-file file
  in let lines = count-lines content
   in let _ = write-file (snap-path file) content
    in print-line ("  Snapshot saved: " ++ file ++ " (" ++ integer-to-text lines ++ " lines)")
 else print-line ("  File not found: " ++ file)

do-restore : Text -> [Console, FileSystem] Nothing
do-restore (file) =
 let snap = snap-path file
 in if file-exists snap then
  let content = read-file snap
  in let lines = count-lines content
   in let _ = write-file file content
    in print-line ("  Restored: " ++ file ++ " (" ++ integer-to-text lines ++ " lines)")
 else print-line ("  No snapshot found for " ++ file ++ ". Run 'snap' first.")

diff-report : Text -> Integer -> Integer -> Integer -> Text
diff-report (file) (old-lines) (new-lines) (delta) =
 "-- Diff: " ++ file ++ " --\n" ++
 "  Before: " ++ integer-to-text old-lines ++ " lines   After: " ++ integer-to-text new-lines ++ " lines   Delta: " ++ integer-to-text delta ++ "\n" ++
 "  File has been modified. Use peek to inspect.\n" ++
 "-- End diff --"

unchanged-report : Text -> Integer -> Text
unchanged-report (file) (lines) =
 "-- Diff: " ++ file ++ " --\n" ++
 "  Before: " ++ integer-to-text lines ++ " lines   After: " ++ integer-to-text lines ++ " lines\n" ++
 "  No changes.\n" ++
 "-- End diff --"

do-diff : Text -> [Console, FileSystem] Nothing
do-diff (file) =
 let snap = snap-path file
 in if file-exists snap then
  if file-exists file then
   let old-content = read-file snap
   in let new-content = read-file file
    in let old-lines = count-lines old-content
     in let new-lines = count-lines new-content
      in let delta = new-lines - old-lines
       in if old-content == new-content then print-line (unchanged-report file old-lines)
        else print-line (diff-report file old-lines new-lines delta)
  else print-line ("  File not found: " ++ file)
 else print-line ("  No snapshot found for " ++ file ++ ". Run 'snap' first.")

main : [Console, FileSystem] Nothing
main = do
 let args = get-args
 in let argc = list-length args
  in if argc < 2 then print-line "Usage: codex-sdiff <snap|diff|restore> <file>"
   else let action = list-at args 1
    in if action == "snap" then
     if argc < 3 then print-line "Usage: codex-sdiff snap <file>"
      else do-snap (list-at args 2)
    else if action == "diff" then
     if argc < 3 then print-line "Usage: codex-sdiff diff <file>"
      else do-diff (list-at args 2)
    else if action == "restore" then
     if argc < 3 then print-line "Usage: codex-sdiff restore <file>"
      else do-restore (list-at args 2)
    else if action == "clean" then
     print-line "  clean: manually delete .snap files (needs delete-file builtin)"
    else print-line ("Unknown action: " ++ action ++ ". Use snap, diff, or restore.")
