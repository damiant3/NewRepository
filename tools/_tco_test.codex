State = record { subs : List Integer, next-id : Integer }
Ty = | IntT | VarT (Integer)

has-sub : Integer -> List Integer -> Boolean
has-sub (id) (subs) =
  if list-length subs == 0 then False
  else if list-at subs 0 == id then True
  else False

do-lookup : Integer -> List Integer -> Ty
do-lookup (id) (subs) =
  if list-length subs == 0 then VarT id
  else IntT

resolve : State -> Ty -> Ty
resolve (st) (ty) =
  when ty
    if VarT (id) ->
      let a = st.next-id + 1
      in let b = a + 2
      in let c = b + 3
      in let d = c + 4
      in let e = d + 5
      in let f = e + 6
      in let g = f + 7
      in let h = g + 8
      in let i = h + 9
      in let j = i + 10
      in let k = j + 11
      in if has-sub id st.subs
        then resolve st (do-lookup id st.subs)
        else ty
    if _ -> ty

main : Integer
main =
  let st = State { subs = [42], next-id = 10 }
  in let r = resolve st (VarT 42)
  in when r
    if IntT -> 1
    if _ -> 0
