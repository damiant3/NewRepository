{
  "$schema": "http://json.schemastore.org/template",
  "author": "Codex",
  "classifications": [ "Codex" ],
  "identity": "Codex.ProjectTemplate",
  "name": "Codex Project",
  "shortName": "codex",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "CodexProject",
  "preferNameDirectory": true,
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        { "choice": "net8.0", "description": ".NET 8" }
      ],
      "defaultValue": "net8.0"
    }
  },
  "sources": [
    {
      "modifiers": [
        { "exclude": [ ".template.config/**", "codex-icon.png" ] }
      ]
    }
  ]
}
