{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Codex",
  "scopeName": "source.codex",
  "fileTypes": [".codex"],
  "patterns": [
    { "include": "#prose-headers" },
    { "include": "#type-signatures" },
    { "include": "#annotations" },
    { "include": "#char-literals" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#proof-keywords" },
    { "include": "#effect-brackets" },
    { "include": "#operators" },
    { "include": "#boolean-constants" },
    { "include": "#types" },
    { "include": "#function-definition" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "prose-headers": {
      "patterns": [
        {
          "match": "^(Chapter|Section):\\s*(.*)$",
          "captures": {
            "1": { "name": "keyword.control.header.codex" },
            "2": { "name": "markup.heading.codex" }
          }
        }
      ]
    },
    "type-signatures": {
      "patterns": [
        {
          "match": "^(\\s*)((?:[a-z][a-z0-9]*(?:-[a-z][a-z0-9]*)*))(\\s*:)(\\s.+)$",
          "captures": {
            "2": { "name": "entity.name.function.codex" },
            "3": { "name": "keyword.operator.type-annotation.codex" },
            "4": {
              "patterns": [
                { "include": "#effect-brackets" },
                { "include": "#types" },
                { "include": "#operators" }
              ]
            }
          }
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "match": "^(\\s*)((?:[a-z][a-z0-9]*(?:-[a-z][a-z0-9]*)*))(\\s+\\(|\\s+=)",
          "captures": {
            "2": { "name": "entity.name.function.codex" }
          }
        }
      ]
    },
    "annotations": {
      "patterns": [
        {
          "match": "@[a-z][a-z0-9-]*",
          "name": "entity.name.tag.annotation.codex"
        }
      ]
    },
    "char-literals": {
      "patterns": [
        {
          "begin": "'(?=([^'\\\\]|\\\\.)')",
          "end": "'",
          "name": "string.quoted.single.char.codex",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.codex"
            },
            {
              "match": "[^'\\\\]",
              "name": "constant.character.codex"
            }
          ]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "name": "string.quoted.triple.codex",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.codex"
            }
          ]
        },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.codex",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.codex"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b[0-9][0-9_]*(\\.[0-9][0-9_]*)?\\b",
          "name": "constant.numeric.codex"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(let|in|if|then|else|when|where|such-that|act|end|qed|record|cites|effect|with|claim|proof|is|otherwise|linear)\\b",
          "name": "keyword.control.codex"
        }
      ]
    },
    "proof-keywords": {
      "patterns": [
        {
          "match": "\\b(claim|proof|forall|exists|induction|assume)\\b",
          "name": "keyword.other.proof.codex"
        }
      ]
    },
    "effect-brackets": {
      "patterns": [
        {
          "match": "\\[([A-Z][A-Za-z0-9]*)\\]",
          "captures": {
            "0": { "name": "storage.type.effect.codex" },
            "1": { "name": "entity.name.type.effect.codex" }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "→|←|≡|≠|≤|≥|⊢|⊗|∀|∃",
          "name": "keyword.operator.unicode.codex"
        },
        {
          "match": "->|<-|===|/=|<=|>=|==|\\+\\+|::|\\|-|\\(\\*\\*\\)",
          "name": "keyword.operator.ascii.codex"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.pipe.codex"
        },
        {
          "match": "[=+\\-*/^&<>]",
          "name": "keyword.operator.codex"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b[A-Z][A-Za-z0-9]*\\b",
          "name": "entity.name.type.codex"
        }
      ]
    },
    "boolean-constants": {
      "patterns": [
        {
          "match": "\\b(True|False)\\b",
          "name": "constant.language.boolean.codex"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "match": "\\b[a-z][a-z0-9]*(-[a-z][a-z0-9]*)*\\b",
          "name": "variable.other.codex"
        }
      ]
    }
  }
}
