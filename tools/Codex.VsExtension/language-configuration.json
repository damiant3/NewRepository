{
  "comments": {},
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^.*=\\s*$|^.*\\b(do|if|when|where|let)\\b.*$",
    "decreaseIndentPattern": "^\\s*(else|in)\\b"
  },
  "wordPattern": "[a-zA-Z][a-zA-Z0-9]*(-[a-z][a-zA-Z0-9]*)*"
}
