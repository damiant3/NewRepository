{
  "name": "codex-language",
  "displayName": "Codex Language Support",
  "description": "Syntax highlighting, project system, and build support for the Codex programming language",
  "version": "0.2.0",
  "publisher": "codex-lang",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "codex",
        "aliases": ["Codex", "codex"],
        "extensions": [".codex"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./codex-icon.png",
          "dark": "./codex-icon.png"
        }
      },
      {
        "id": "xml",
        "extensions": [".codexproj"]
      },
      {
        "id": "json",
        "filenames": ["codex.project.json"]
      }
    ],
    "grammars": [
      {
        "language": "codex",
        "scopeName": "source.codex",
        "path": "./codex.tmLanguage.json"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": "codex.project.json",
        "url": "./codex.project.schema.json"
      }
    ],
    "taskDefinitions": [
      {
        "type": "codex",
        "required": ["command"],
        "properties": {
          "command": {
            "type": "string",
            "description": "The codex CLI command to run (build, check, run)",
            "enum": ["build", "check", "run"]
          },
          "target": {
            "type": "string",
            "description": "Target backend for compilation"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "codex",
        "owner": "codex",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(error|warning|info|hint)\\s+(CDX\\d+):\\s+(.*)\\s+(.+):(\\d+):(\\d+)$",
          "severity": 1,
          "code": 2,
          "message": 3,
          "file": 4,
          "line": 5,
          "column": 6
        }
      }
    ]
  }
}
