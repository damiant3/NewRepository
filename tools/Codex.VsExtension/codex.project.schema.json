{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Codex Project",
  "description": "Configuration for a Codex language project",
  "type": "object",
  "required": ["name"],
  "properties": {
    "name": {
      "type": "string",
      "description": "The project name (used as the module name)"
    },
    "version": {
      "type": "string",
      "description": "Semantic version of the project",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.]+)?$"
    },
    "sources": {
      "type": "array",
      "description": "Glob patterns for .codex source files",
      "items": {
        "type": "string"
      },
      "default": ["**/*.codex"]
    },
    "target": {
      "type": "string",
      "description": "Default compilation target (used when a single target is needed)",
      "enum": [
        "csharp", "cs",
        "javascript", "js",
        "rust", "rs",
        "python", "py",
        "cpp", "c++",
        "go",
        "java",
        "ada",
        "fortran", "f90",
        "cobol", "cob",
        "babbage", "ae"
      ],
      "default": "csharp"
    },
    "targets": {
      "type": "array",
      "description": "Multiple compilation targets — emitted in parallel",
      "items": {
        "type": "string",
        "enum": [
          "csharp", "cs",
          "javascript", "js",
          "rust", "rs",
          "python", "py",
          "cpp", "c++",
          "go",
          "java",
          "ada",
          "fortran", "f90",
          "cobol", "cob",
          "babbage", "ae"
        ]
      }
    },
    "output": {
      "type": "string",
      "description": "Output directory for compiled files",
      "default": "out/"
    },
    "dependencies": {
      "type": "object",
      "description": "Project dependencies (name -> version)",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
