Chapter: CanonTest Original

Section: Definitions

  Color =
   | Red
   | Green
   | Blue

  Shape =
   | Circle (Integer)
   | Rect (Integer) (Integer)
   | Point

  Point2D = record {
   x : Integer,
   y : Integer
  }

  Line = record {
   start : Point2D,
   end : Point2D,
   label : Text
  }

  Tag = record {
   name : Text
  }

  origin : Point2D
  origin =
   Point2D {
    x = 0,
    y = 0
   }

  make-tag : Text -> Tag
  make-tag (s) =
   Tag { name = s }

  tag-name : Tag -> Text
  tag-name (t) =
   t.name

  color-name : Color -> Text
  color-name (c) =
   when c
    if Red -> "red"
    if Green -> "green"
    if Blue -> "blue"

  area : Shape -> Integer
  area (s) =
   when s
    if Circle (r) -> r * r * 3
    if Rect (w) (h) -> w * h
    if Point -> 0

  describe : Shape -> Text
  describe (s) =
   when s
    if Circle (r) -> "circle r=" ++ show r
    if Rect (w) (h) -> "rect " ++ show w ++ "x" ++ show h
    if _ -> "point"

  distance : Point2D -> Point2D -> Integer
  distance (a) (b) =
   let dx = b.x - a.x
   in let dy = b.y - a.y
   in dx * dx + dy * dy

  midpoint : Point2D -> Point2D -> Point2D
  midpoint (a) (b) =
   Point2D {
    x = (a.x + b.x) / 2,
    y = (a.y + b.y) / 2
   }

  line-length : Line -> Integer
  line-length (l) =
   distance (l.start) (l.end)

  make-line : Point2D -> Point2D -> Text -> Line
  make-line (s) (e) (lbl) =
   Line {
    start = s,
    end = e,
    label = lbl
   }

  classify : Integer -> Text
  classify (n) =
   if n < 0 then "negative"
   else if n == 0 then "zero"
        else "positive"

  clamp : Integer -> Integer -> Integer -> Integer
  clamp (lo) (hi) (x) =
   if x < lo then lo
   else if x > hi then hi
        else x

  abs : Integer -> Integer
  abs (n) =
   if n < 0 then 0 - n
   else n

  fibonacci : Integer -> Integer
  fibonacci (n) =
   if n <= 1 then n
   else fibonacci (n - 1) + fibonacci (n - 2)

  is-keyword : Text -> Boolean
  is-keyword (s) =
   if s == "let" then True
   else if s == "in" then True
   else if s == "if" then True
   else if s == "then" then True
   else if s == "else" then True
   else if s == "when" then True
   else if s == "do" then True
   else False

  format-point : Point2D -> Text
  format-point (p) =
   "(" ++ show (p.x) ++ ", " ++ show (p.y) ++ ")"

  format-line : Line -> Text
  format-line (l) =
   l.label ++ ": " ++ format-point (l.start) ++ " -> " ++ format-point (l.end)

  map-list : (a -> b) -> List a -> List b
  map-list (f) (xs) =
   if list-length xs == 0 then []
   else [f (list-at xs 0)] ++ map-list f (list-at-rest xs 1)

  list-at-rest : List a -> Integer -> List a
  list-at-rest (xs) (i) =
   if i == list-length xs then []
   else [list-at xs i] ++ list-at-rest xs (i + 1)

  filter-list : (a -> Boolean) -> List a -> List a
  filter-list (pred) (xs) =
   if list-length xs == 0 then []
   else let head = list-at xs 0
   in let rest = filter-list pred (list-at-rest xs 1)
   in if pred head then [head] ++ rest
      else rest

  sum-list : List Integer -> Integer -> Integer
  sum-list (xs) (acc) =
   if list-length xs == 0 then acc
   else sum-list (list-at-rest xs 1) (acc + list-at xs 0)

  count-positives : List Integer -> Integer
  count-positives (xs) =
   let positives = filter-list (\x -> x > 0) xs
   in list-length positives

  has-mixed-precedence : Integer -> Integer -> Boolean
  has-mixed-precedence (a) (b) =
   a + b * 2 == a * 3 - b

  check-bounds : Integer -> Integer -> Integer -> Boolean
  check-bounds (lo) (hi) (x) =
   x >= lo & x <= hi & hi - lo > 0

  scale-point : Integer -> Point2D -> Point2D
  scale-point (factor) (p) =
   Point2D {
    x = p.x * factor,
    y = p.y * factor
   }

  translate : Point2D -> Point2D -> Point2D
  translate (offset) (p) =
   Point2D {
    x = p.x + offset.x,
    y = p.y + offset.y
   }

  main : Integer
  main =
   let p = origin
   in let q = Point2D { x = 3, y = 4 }
   in let d = distance p q
   in let s = describe (Circle 5)
   in let k = is-keyword "let"
   in d + area (Rect 3 4)

