Chapter: Diagnostic

Section: Definitions

  DiagnosticSeverity =
   | Error
   | Warning
   | Info

  Diagnostic = record {
   code : Text,
   message : Text,
   severity : DiagnosticSeverity
  }

  make-error : Text -> Text -> Diagnostic
  make-error (code) (msg) =
   Diagnostic {
    code = code,
    message = msg,
    severity = Error
   }

  make-warning : Text -> Text -> Diagnostic
  make-warning (code) (msg) =
   Diagnostic {
    code = code,
    message = msg,
    severity = Warning
   }

  severity-label : DiagnosticSeverity -> Text
  severity-label (s) =
   when s
    is Error -> "error"
    is Warning -> "warning"
    is Info -> "info"

  diagnostic-display : Diagnostic -> Text
  diagnostic-display (d) =
   severity-label (d.severity) ++ " " ++ d.code ++ ": " ++ d.message

