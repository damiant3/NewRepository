hex-digit : Integer -> Text
hex-digit (n) =
 if n == 0
  then "0"
  else if n == 1
   then "1"
   else if n == 2
    then "2"
    else if n == 3
     then "3"
     else if n == 4
      then "4"
      else if n == 5
       then "5"
       else if n == 6
        then "6"
        else if n == 7
         then "7"
         else if n == 8
          then "8"
          else if n == 9
           then "9"
           else if n == 10
            then "A"
            else if n == 11
             then "B"
             else if n == 12
              then "C"
              else if n == 13
               then "D"
               else if n == 14
                then "E"
                else if n == 15 then "F" else "?"

hex4 : Integer -> Text
hex4 (n) =
 "00" ++ hex-digit (n / 16) ++ hex-digit (n - n / 16 * 16)












is-catch-all : IRPat -> Boolean
is-catch-all (p) = when p
 if IrWildPat -> True
 if IrVarPat (name) (ty) -> True
 if _ -> False

has-any-catch-all : List IRBranch -> Integer -> Boolean
has-any-catch-all (branches) (i) =
 if i == list-length branches
  then False
  else let b = list-at branches i
  in if is-catch-all (b.pattern)
   then True
   else has-any-catch-all branches (i + 1)












cdx-magic : List Integer
cdx-magic =
 [67, 68, 88, 49]

cdx-format-version : Integer
cdx-format-version =
 1

cdx-fixed-header-size : Integer
cdx-fixed-header-size =
 224

cdx-content-hash-size : Integer
cdx-content-hash-size =
 32

cdx-author-key-size : Integer
cdx-author-key-size =
 32

cdx-signature-size : Integer
cdx-signature-size =
 64

cdx-flag-bare-metal : Integer
cdx-flag-bare-metal =
 1

cdx-flag-needs-heap : Integer
cdx-flag-needs-heap =
 2

cdx-flag-needs-stack-guard : Integer
cdx-flag-needs-stack-guard =
 4

cdx-flag-has-proofs : Integer
cdx-flag-has-proofs =
 8

cdx-header-bytes : List Integer
cdx-header-bytes (flags) (cap-off) (cap-sz) (proof-off) (proof-sz) (text-off) (text-sz) (rodata-off) (rodata-sz) (entry) (stack-sz) (heap-sz) =
 cdx-magic

write-i16 : a1624
write-i16 =
 0 write-i16 flags

pad-zeros : a1627
pad-zeros =
 0 pad-zeros cdx-author-key-size

pad-zeros : a1627
pad-zeros =
 0 write-i64 cap-off

write-i64 : a1633
write-i64 =
 0 write-i64 proof-off

write-i64 : a1633
write-i64 =
 0 write-i64 text-off

write-i64 : a1633
write-i64 =
 0 write-i64 rodata-off

write-i64 : a1633
write-i64 =
 0 write-i64 entry

write-i32 : a1645
write-i32 =
 0 write-i32 heap-sz

write-i16 : a1624
write-i16 =
 0 write-i16 0

write-i32 : a1645
write-i32 =
 build-cdx





hdr : Integer
hdr =
 cdx-fixed-header-size


rodata-size : Integer
rodata-size =
 list-length rodata

cdx-header-bytes : List Integer
cdx-header-bytes =
 hdr 0 hdr 0 hdr text-size (hdr + text-size) rodata-size entry-offset stack-size heap-size


build-cdx-bare-metal : Integer -> Integer -> Integer -> List Integer -> List Integer -> List Integer
build-cdx-bare-metal (entry-offset) (stack-size) (heap-size) (text) (rodata) =
 build-cdx (cdx-flag-bare-metal + cdx-flag-needs-heap) entry-offset stack-size heap-size text rodata











wrap-fun-param : CodexType -> Text
wrap-fun-param (ty) = when ty
 if FunTy (p) (r) -> "(" ++ emit-type ty ++ ")"
 if _ -> emit-type ty

wrap-complex : CodexType -> Text
wrap-complex (ty) = when ty
 if FunTy (p) (r) -> "(" ++ emit-type ty ++ ")"
 if ListTy (elem) -> "(" ++ emit-type ty ++ ")"
 if _ -> emit-type ty



is-match-body : IRExpr -> Boolean
is-match-body (e) = when e
 if IrMatch (scrut) (branches) (ty) -> True
 if _ -> False

skip-def : IRDef -> List Text -> Boolean
skip-def (d) (ctor-names) =
 if list-contains ctor-names (d.name)
  then True
  else if text-length (d.name) == 0
   then True
   else let first = char-code-at (d.name) 0
   in let code-a = char-code-at "a" 0
   in let code-z = char-code-at "z" 0
   in if first < code-a | first > code-z then True else False

is-upper : Integer -> Boolean
is-upper (c) =
 let code = char-code-at "A" 0
 in let code-z = char-code-at "Z" 0
 in c >= code & c <= code-z

is-error-body : IRExpr -> Boolean
is-error-body (e) = when e
 if IrError (msg) (ty) -> True
 if _ -> False


is-lower-start : Text -> Boolean
is-lower-start (s) =
 if text-length s == 0
  then False
  else let c = char-code-at s 0
  in let code-a = char-code-at "a" 0
  in let code-z = char-code-at "z" 0
  in c >= code-a & c <= code-z




bin-op-text : IRBinaryOp -> Text
bin-op-text (op) = when op
 if IrAddInt -> "+"
 if IrSubInt -> "-"
 if IrMulInt -> "*"
 if IrDivInt -> "/"
 if IrPowInt -> "^"
 if IrAddNum -> "+"
 if IrSubNum -> "-"
 if IrMulNum -> "*"
 if IrDivNum -> "/"
 if IrEq -> "=="
 if IrNotEq -> "/="
 if IrLt -> "<"
 if IrGt -> ">"
 if IrLtEq -> "<="
 if IrGtEq -> ">="
 if IrAnd -> "&"
 if IrOr -> "|"
 if IrAppendText -> "++"
 if IrAppendList -> "++"
 if IrConsList -> "::"





wrap-arg : IRExpr -> List Text -> Integer -> Boolean -> Text
wrap-arg (e) (ctors) (indent) (is-ctor) =
 if needs-parens e is-ctor
  then "(" ++ emit-expr e ctors indent ++ ")"
  else emit-expr e ctors indent

is-ctor-name : IRExpr -> List Text -> Boolean
is-ctor-name (e) (ctors) = when e
 if IrName (n) (ty) -> list-contains ctors n
 if _ -> False

needs-parens : IRExpr -> Boolean -> Boolean
needs-parens (e) (is-ctor) = when e
 if IrApply (f) (a) (ty) -> True
 if IrBinary (op) (l) (r) (ty) -> True
 if IrIf (c) (t) (el) (ty) -> True
 if IrLet (name) (ty) (val) (body) -> True
 if IrMatch (scrut) (branches) (ty) -> True
 if IrNegate (operand) -> True
 if IrLambda (params) (body) (ty) -> True
 if IrFieldAccess (rec) (field) (ty) -> True
 if _ -> False

















collect-ctor-names : List ATypeDef -> Integer -> List Text
collect-ctor-names (type-defs) (i) =
 if i == list-length type-defs
  then []
  else let td = list-at type-defs i
  in let names = when td
    if AVariantTypeDef (name) (tparams) (ctors) -> collect-variant-ctor-names ctors 0
    if ARecordTypeDef (name) (tparams) (fields) -> [name.value]
  in names ++ collect-ctor-names type-defs (i + 1)

collect-variant-ctor-names : List AVariantCtorDef -> Integer -> List Text
collect-variant-ctor-names (ctors) (i) =
 if i == list-length ctors
  then []
  else let c = list-at ctors i
  in [c.name.value] ++ collect-variant-ctor-names ctors (i + 1)

is-simple : IRExpr -> Boolean
is-simple (e) = when e
 if IrIntLit (n) -> True
 if IrNumLit (n) -> True
 if IrTextLit (s) -> True
 if IrBoolLit (b) -> True
 if IrCharLit (n) -> True
 if IrName (n) (ty) -> True
 if IrFieldAccess (r) (f) (ty) -> True
 if _ -> False

make-indent : Integer -> Text
make-indent (n) =
 if n == 0
  then ""
  else " " ++ make-indent (n - 1)








filter-defs : List IRDef -> List Text -> Integer -> Integer -> List IRDef -> List IRDef
filter-defs (defs) (ctor-names) (i) (len) (acc) =
 if i == len
  then acc
  else let d = list-at defs i
  in if skip-def d ctor-names
   then filter-defs defs ctor-names (i + 1) len acc
   else if has-def-named acc (d.name) 0 (list-length acc)
    then if def-score d > def-score-named acc (d.name) 0 (list-length acc)
     then filter-defs defs ctor-names (i + 1) len (replace-def acc (d.name) d 0 (list-length acc))
     else filter-defs defs ctor-names (i + 1) len acc
    else filter-defs defs ctor-names (i + 1) len (list-snoc acc d)

def-score : IRDef -> Integer
def-score (d) =
 list-length (d.params) * 100 + body-depth (d.body)

def-score-named : List IRDef -> Text -> Integer -> Integer -> Integer
def-score-named (defs) (name) (i) (len) =
 if i == len
  then 0
  else if (list-at defs i).name == name
   then def-score (list-at defs i)
   else def-score-named defs name (i + 1) len

body-depth : IRExpr -> Integer
body-depth (e) = when e
 if IrName (n) (ty) -> 1
 if IrIntLit (n) -> 1
 if IrTextLit (s) -> 1
 if IrBoolLit (b) -> 1
 if IrFieldAccess (r) (f) (ty) -> 2
 if IrApply (f) (a) (ty) -> 3 + body-depth f
 if IrLet (name) (ty) (val) (body) -> 5 + body-depth body
 if IrIf (c) (t) (el) (ty) -> 5 + body-depth t
 if IrMatch (s) (bs) (ty) -> 10
 if IrLambda (ps) (b) (ty) -> 5
 if IrDo (stmts) (ty) -> 5
 if IrRecord (n) (fs) (ty) -> 3
 if _ -> 1

has-def-named : List IRDef -> Text -> Integer -> Integer -> Boolean
has-def-named (defs) (name) (i) (len) =
 if i == len
  then False
  else if (list-at defs i).name == name
   then True
   else has-def-named defs name (i + 1) len

replace-def : List IRDef -> Text -> IRDef -> Integer -> Integer -> List IRDef
replace-def (defs) (name) (new-def) (i) (len) =
 if i == len
  then defs
  else if (list-at defs i).name == name
   then list-set defs i new-def
   else replace-def defs name new-def (i + 1) len

list-set : List IRDef -> Integer -> IRDef -> List IRDef
list-set (xs) (idx) (val) =
 list-set-loop xs idx val 0 (list-length xs) []

list-set-loop : List IRDef -> Integer -> IRDef -> Integer -> Integer -> List IRDef -> List IRDef
list-set-loop (xs) (idx) (val) (i) (len) (acc) =
 if i == len
  then acc
  else if i == idx
   then list-set-loop xs idx val (i + 1) len (list-snoc acc val)
   else list-set-loop xs idx val (i + 1) len (list-snoc acc (list-at xs i))









