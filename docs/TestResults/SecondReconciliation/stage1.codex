LiteralKind =
 | IntLit
 | NumLit
 | TextLit
 | CharLit
 | BoolLit

BinaryOp =
 | OpAdd
 | OpSub
 | OpMul
 | OpDiv
 | OpPow
 | OpEq
 | OpNotEq
 | OpLt
 | OpGt
 | OpLtEq
 | OpGtEq
 | OpDefEq
 | OpAppend
 | OpCons
 | OpAnd
 | OpOr

AExpr =
 | ALitExpr (Text) (LiteralKind)
 | ANameExpr (Name)
 | AApplyExpr (AExpr) (AExpr)
 | ABinaryExpr (AExpr) (BinaryOp) (AExpr)
 | AUnaryExpr (AExpr)
 | AIfExpr (AExpr) (AExpr) (AExpr)
 | ALetExpr (List ALetBind) (AExpr)
 | ALambdaExpr (List Name) (AExpr)
 | AMatchExpr (AExpr) (List AMatchArm)
 | AListExpr (List AExpr)
 | ARecordExpr (Name) (List AFieldExpr)
 | AFieldAccess (AExpr) (Name)
 | ADoExpr (List ADoStmt)
 | AHandleExpr (Name) (AExpr) (List AHandleClause)
 | AErrorExpr (Text)

ALetBind = record {
  name : Name,
  value : AExpr
}

AMatchArm = record {
  pattern : APat,
  body : AExpr
}

AFieldExpr = record {
  name : Name,
  value : AExpr
}

ADoStmt =
 | ADoBindStmt (Name) (AExpr)
 | ADoExprStmt (AExpr)

AHandleClause = record {
  op-name : Name,
  resume-name : Name,
  body : AExpr
}

APat =
 | AVarPat (Name)
 | ALitPat (Text) (LiteralKind)
 | ACtorPat (Name) (List APat)
 | AWildPat

ATypeExpr =
 | ANamedType (Name)
 | AFunType (ATypeExpr) (ATypeExpr)
 | AAppType (ATypeExpr) (List ATypeExpr)
 | AEffectType (List Name) (ATypeExpr)

AParam = record {
  name : Name
}

ADef = record {
  name : Name,
  params : List AParam,
  declared-type : List ATypeExpr,
  body : AExpr
}

ARecordFieldDef = record {
  name : Name,
  type-expr : ATypeExpr
}

AVariantCtorDef = record {
  name : Name,
  fields : List ATypeExpr
}

ATypeDef =
 | ARecordTypeDef (Name) (List Name) (List ARecordFieldDef)
 | AVariantTypeDef (Name) (List Name) (List AVariantCtorDef)

AEffectOpDef = record {
  name : Name,
  type-expr : ATypeExpr
}

AEffectDef = record {
  name : Name,
  ops : List AEffectOpDef
}

AImportDecl = record {
  module-name : Name,
  selected-names : List Name
}

AModule = record {
  name : Name,
  defs : List ADef,
  type-defs : List ATypeDef,
  effect-defs : List AEffectDef,
  imports : List AImportDecl
}

DiagnosticSeverity =
 | Error
 | Warning
 | Info

Diagnostic = record {
  code : Text,
  message : Text,
  severity : DiagnosticSeverity
}

Name = record {
  value : Text
}

SourcePosition = record {
  line : Integer,
  column : Integer,
  offset : Integer
}

SourceSpan = record {
  start : SourcePosition,
  end : SourcePosition,
  file : Text
}

ArityEntry = record {
  name : Text,
  arity : Integer
}

ApplyChain = record {
  root : IRExpr,
  args : List IRExpr
}

FuncOffset = record {
  name : Text,
  offset : Integer
}

CallPatch = record {
  patch-offset : Integer,
  target : Text
}

LocalBinding = record {
  name : Text,
  slot : Integer
}

FuncAddrFixup = record {
  patch-offset : Integer,
  target : Text
}

TcoState = record {
  active : Boolean,
  in-tail-pos : Boolean,
  loop-top : Integer,
  param-locals : List Integer,
  temp-locals : List Integer,
  current-func : Text,
  saved-next-local : Integer,
  saved-next-temp : Integer
}

CodegenState = record {
  text : List Integer,
  rodata : List Integer,
  func-offsets : List FuncOffset,
  call-patches : List CallPatch,
  func-addr-fixups : List FuncAddrFixup,
  locals : List LocalBinding,
  next-temp : Integer,
  next-local : Integer,
  spill-count : Integer,
  load-local-toggle : Integer,
  tco : TcoState
}

EmitResult = record {
  state : CodegenState,
  reg : Integer
}

TrampolineResult = record {
  bytes : List Integer,
  far-jump-patch-pos : Integer
}

FlatApply = record {
  func-name : Text,
  args : List IRExpr
}

SavedArgs = record {
  state : CodegenState,
  locals : List Integer
}

FieldLocal = record {
  name : Text,
  slot : Integer
}

EvalFieldsResult = record {
  state : CodegenState,
  field-locals : List FieldLocal
}

MatchBranchState = record {
  cg-state : CodegenState,
  end-patches : List Integer
}

PatchEntry = record {
  pos : Integer,
  b0 : Integer,
  b1 : Integer,
  b2 : Integer,
  b3 : Integer
}

TcoAllocResult = record {
  alloc-state : CodegenState,
  alloc-locals : List Integer
}

EmitPatternResult = record {
  state : CodegenState,
  next-branch-patch : Integer
}

ItoaState = record {
  cg : CodegenState,
  jmp-done-zero-pos : Integer
}

StrEqHeadResult = record {
  cg : CodegenState,
  len-ne-pos : Integer
}

StrEqLoopResult = record {
  cg : CodegenState,
  loop-done-pos : Integer,
  byte-ne-pos : Integer
}

ItoaZeroResult = record {
  cg : CodegenState,
  skip-digits-pos : Integer
}

StrConcatCheckResult = record {
  cg : CodegenState,
  slow-path-pos : Integer
}

StrConcatFastResult = record {
  cg : CodegenState,
  fast-done-pos : Integer
}

HelpResult1 = record {
  cg : CodegenState,
  p1 : Integer
}

HelpResult2 = record {
  cg : CodegenState,
  p1 : Integer,
  p2 : Integer
}

HelpResult3 = record {
  cg : CodegenState,
  p1 : Integer,
  p2 : Integer,
  p3 : Integer
}

HelpResult4 = record {
  cg : CodegenState,
  p1 : Integer,
  p2 : Integer,
  p3 : Integer,
  p4 : Integer
}

IRBinaryOp =
 | IrAddInt
 | IrSubInt
 | IrMulInt
 | IrDivInt
 | IrPowInt
 | IrAddNum
 | IrSubNum
 | IrMulNum
 | IrDivNum
 | IrEq
 | IrNotEq
 | IrLt
 | IrGt
 | IrLtEq
 | IrGtEq
 | IrAnd
 | IrOr
 | IrAppendText
 | IrAppendList
 | IrConsList

IRExpr =
 | IrIntLit (Integer)
 | IrNumLit (Integer)
 | IrTextLit (Text)
 | IrBoolLit (Boolean)
 | IrCharLit (Integer)
 | IrName (Text) (CodexType)
 | IrBinary (IRBinaryOp) (IRExpr) (IRExpr) (CodexType)
 | IrNegate (IRExpr)
 | IrIf (IRExpr) (IRExpr) (IRExpr) (CodexType)
 | IrLet (Text) (CodexType) (IRExpr) (IRExpr)
 | IrApply (IRExpr) (IRExpr) (CodexType)
 | IrLambda (List IRParam) (IRExpr) (CodexType)
 | IrList (List IRExpr) (CodexType)
 | IrMatch (IRExpr) (List IRBranch) (CodexType)
 | IrDo (List IRDoStmt) (CodexType)
 | IrHandle (Text) (IRExpr) (List IRHandleClause) (CodexType)
 | IrRecord (Text) (List IRFieldVal) (CodexType)
 | IrFieldAccess (IRExpr) (Text) (CodexType)
 | IrFork (IRExpr) (CodexType)
 | IrAwait (IRExpr) (CodexType)
 | IrError (Text) (CodexType)

IRParam = record {
  name : Text,
  type-val : CodexType
}

IRBranch = record {
  pattern : IRPat,
  body : IRExpr
}

IRPat =
 | IrVarPat (Text) (CodexType)
 | IrLitPat (Text) (CodexType)
 | IrCtorPat (Text) (List IRPat) (CodexType)
 | IrWildPat

IRDoStmt =
 | IrDoBind (Text) (CodexType) (IRExpr)
 | IrDoExec (IRExpr)

IRHandleClause = record {
  op-name : Text,
  resume-name : Text,
  body : IRExpr
}

IRFieldVal = record {
  name : Text,
  value : IRExpr
}

