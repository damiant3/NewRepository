ir-expr-type : IRExpr -> CodexType
ir-expr-type (e) = when e
 if IrIntLit (v) -> IntegerTy
 if IrNumLit (v) -> IntegerTy
 if IrTextLit (v) -> TextTy
 if IrBoolLit (v) -> BooleanTy
 if IrCharLit (v) -> CharTy
 if IrName (n) (t) -> t
 if IrBinary (op) (l) (r) (t) -> t
 if IrNegate (x) -> IntegerTy
 if IrIf (c) (th) (el) (t) -> t
 if IrLet (n) (t) (v) (b) -> ir-expr-type b
 if IrApply (f) (a) (t) -> t
 if IrLambda (ps) (b) (t) -> t
 if IrList (es) (t) -> ListTy t
 if IrMatch (s) (bs) (t) -> t
 if IrDo (ss) (t) -> t
 if IrHandle (eff) (h) (cs) (t) -> t
 if IrRecord (n) (fs) (t) -> t
 if IrFieldAccess (r) (f) (t) -> t
 if IrFork (body) (t) -> t
 if IrAwait (task) (t) -> t
 if IrError (m) (t) -> t

lower-expr : AExpr -> CodexType -> LowerCtx -> IRExpr
lower-expr (e) (ty) (ctx) = when e
 if ALitExpr (text) (kind) -> lower-literal text kind
 if ANameExpr (name) -> lower-name (name.value) ty ctx
 if AApplyExpr (f) (a) -> lower-apply f a ty ctx
 if ABinaryExpr (l) (op) (r) -> let left-ir = lower-expr l ty ctx
 in let left-ty = ir-expr-type left-ir
 in let right-ir = lower-expr r ty ctx
 in IrBinary (lower-bin-op op left-ty) left-ir right-ir (binary-result-type op left-ty ty)
 if AUnaryExpr (operand) -> IrNegate (lower-expr operand IntegerTy ctx)
 if AIfExpr (c) (t) (e2) -> let resolved = deep-resolve (ctx.ust) ty
 in let then-ir = lower-expr t resolved ctx
 in let then-ty = ir-expr-type then-ir
 in let result-ty = when resolved
   if ErrorTy -> then-ty
   if _ -> resolved
 in let else-ir = lower-expr e2 result-ty ctx
 in IrIf (lower-expr c BooleanTy ctx) then-ir else-ir result-ty
 if ALetExpr (binds) (body) -> lower-let binds body ty ctx
 if ALambdaExpr (params) (body) -> lower-lambda params body ty ctx
 if AMatchExpr (scrut) (arms) -> lower-match scrut arms ty ctx
 if AListExpr (elems) -> lower-list elems ty ctx
 if ARecordExpr (name) (fields) -> lower-record name fields ty ctx
 if AFieldAccess (rec) (field) -> let rec-ir = lower-expr rec ErrorTy ctx
 in let rec-ty = deep-resolve (ctx.ust) (ir-expr-type rec-ir)
 in let field-ty = when rec-ty
   if RecordTy (rname) (rfields) -> lookup-record-field rfields (field.value)
   if ConstructedTy (cname) (cargs) -> let ctor-raw = lookup-type (ctx.types) (cname.value)
   in let resolved-record = when ctor-raw
     if ErrorTy -> ErrorTy
     if _ -> strip-fun-args-lower (deep-resolve (ctx.ust) ctor-raw)
   in when resolved-record
    if RecordTy (rn) (rf) -> lookup-record-field rf (field.value)
    if _ -> ty
   if _ -> ty
 in let actual-field-ty = when field-ty
   if ErrorTy -> ty
   if _ -> field-ty
 in IrFieldAccess rec-ir (field.value) actual-field-ty
 if ADoExpr (stmts) -> lower-do stmts ty ctx
 if AHandleExpr (eff) (body) (clauses) -> lower-handle eff body clauses ty ctx
 if AErrorExpr (msg) -> IrError msg ty

lower-name : Text -> CodexType -> LowerCtx -> IRExpr
lower-name (name) (ty) (ctx) =
 let raw = lookup-type (ctx.types) name
 in when raw
  if ErrorTy -> IrName name ty
  if _ -> let resolved = deep-resolve (ctx.ust) raw
  in let stripped = strip-forall-ty resolved
  in IrName name stripped

lower-literal : Text -> LiteralKind -> IRExpr
lower-literal (text) (kind) = when kind
 if IntLit -> IrIntLit (text-to-integer text)
 if NumLit -> IrIntLit (text-to-integer text)
 if TextLit -> IrTextLit text
 if CharLit -> IrCharLit (text-to-integer text)
 if BoolLit -> IrBoolLit (text == "True")

lower-apply : AExpr -> AExpr -> CodexType -> LowerCtx -> IRExpr
lower-apply (f) (a) (ty) (ctx) =
 let func-ir = lower-expr f ErrorTy ctx
 in let func-ty = deep-resolve (ctx.ust) (ir-expr-type func-ir)
 in let arg-ty = peel-fun-param func-ty
 in let ret-ty = peel-fun-return func-ty
 in let arg-ir = lower-expr a arg-ty ctx
 in let resolved-ret = subst-type-vars-from-arg arg-ty (ir-expr-type arg-ir) ret-ty
 in let actual-ret = when resolved-ret
   if ErrorTy -> ty
   if _ -> resolved-ret
 in lower-apply-dispatch func-ir arg-ir actual-ret

lower-apply-dispatch : IRExpr -> IRExpr -> CodexType -> IRExpr
lower-apply-dispatch (func-ir) (arg-ir) (ret-ty) = when func-ir
 if IrName (n) (fty) -> if n == "fork"
  then IrFork arg-ir ret-ty
  else if n == "await"
   then IrAwait arg-ir ret-ty
   else IrApply func-ir arg-ir ret-ty
 if _ -> IrApply func-ir arg-ir ret-ty

lower-let : List ALetBind -> AExpr -> CodexType -> LowerCtx -> IRExpr
lower-let (binds) (body) (ty) (ctx) =
 if list-length binds == 0
  then lower-expr body ty ctx
  else let b = list-at binds 0
  in let val-ir = lower-expr (b.value) ErrorTy ctx
  in let val-ty = deep-resolve (ctx.ust) (ir-expr-type val-ir)
  in let ctx2 = LowerCtx { types = [TypeBinding { name = b.name.value, bound-type = val-ty }] ++ ctx.types, ust = ctx.ust }
  in IrLet (b.name.value) val-ty val-ir (lower-let-rest binds body ty ctx2 1)

lower-let-rest : List ALetBind -> AExpr -> CodexType -> LowerCtx -> Integer -> IRExpr
lower-let-rest (binds) (body) (ty) (ctx) (i) =
 if i == list-length binds
  then lower-expr body ty ctx
  else let b = list-at binds i
  in let val-ir = lower-expr (b.value) ErrorTy ctx
  in let val-ty = deep-resolve (ctx.ust) (ir-expr-type val-ir)
  in let ctx2 = LowerCtx { types = [TypeBinding { name = b.name.value, bound-type = val-ty }] ++ ctx.types, ust = ctx.ust }
  in IrLet (b.name.value) val-ty val-ir (lower-let-rest binds body ty ctx2 (i + 1))

lower-lambda : List Name -> AExpr -> CodexType -> LowerCtx -> IRExpr
lower-lambda (params) (body) (ty) (ctx) =
 let stripped = strip-forall-ty ty
 in let lparams = lower-lambda-params params stripped 0
 in let lctx = bind-lambda-to-ctx ctx params stripped 0
 in IrLambda lparams (lower-expr body (get-lambda-return stripped (list-length params)) lctx) ty

bind-lambda-to-ctx : LowerCtx -> List Name -> CodexType -> Integer -> LowerCtx
bind-lambda-to-ctx (ctx) (params) (ty) (i) =
 if i == list-length params
  then ctx
  else let p = list-at params i
  in let param-ty = peel-fun-param ty
  in let rest-ty = peel-fun-return ty
  in let ctx2 = LowerCtx { types = [TypeBinding { name = p.value, bound-type = param-ty }] ++ ctx.types, ust = ctx.ust }
  in bind-lambda-to-ctx ctx2 params rest-ty (i + 1)

lower-lambda-params : List Name -> CodexType -> Integer -> List IRParam
lower-lambda-params (params) (ty) (i) =
 lower-lambda-params-acc params ty i []

lower-lambda-params-acc : List Name -> CodexType -> Integer -> List IRParam -> List IRParam
lower-lambda-params-acc (params) (ty) (i) (acc) =
 if i == list-length params
  then acc
  else let p = list-at params i
  in let param-ty = peel-fun-param ty
  in let rest-ty = peel-fun-return ty
  in lower-lambda-params-acc params rest-ty (i + 1) (list-snoc acc IRParam { name = p.value, type-val = param-ty })

get-lambda-return : CodexType -> Integer -> CodexType
get-lambda-return (ty) (n) =
 if n == 0
  then ty
  else when ty
   if FunTy (p) (r) -> get-lambda-return r (n - 1)
   if _ -> ErrorTy

lower-match : AExpr -> List AMatchArm -> CodexType -> LowerCtx -> IRExpr
lower-match (scrut) (arms) (ty) (ctx) =
 let scrut-ir = lower-expr scrut ErrorTy ctx
 in let scrut-ty = ir-expr-type scrut-ir
 in let branches = lower-match-arms-loop arms ty scrut-ty ctx 0 (list-length arms)
 in let result-ty = when ty
   if ErrorTy -> infer-match-type branches 0 (list-length branches)
   if _ -> ty
 in IrMatch scrut-ir branches result-ty

infer-match-type : List IRBranch -> Integer -> Integer -> CodexType
infer-match-type (branches) (i) (len) =
 if i == len
  then ErrorTy
  else let b = list-at branches i
  in let body-ty = ir-expr-type (b.body)
  in when body-ty
   if ErrorTy -> infer-match-type branches (i + 1) len
   if _ -> body-ty

lower-match-arms-loop : List AMatchArm -> CodexType -> CodexType -> LowerCtx -> Integer -> Integer -> List IRBranch
lower-match-arms-loop (arms) (ty) (scrut-ty) (ctx) (i) (len) =
 lower-match-arms-acc arms ty scrut-ty ctx i len []

lower-match-arms-acc : List AMatchArm -> CodexType -> CodexType -> LowerCtx -> Integer -> Integer -> List IRBranch -> List IRBranch
lower-match-arms-acc (arms) (ty) (scrut-ty) (ctx) (i) (len) (acc) =
 if i == len
  then acc
  else let arm = list-at arms i
  in let arm-ctx = bind-pattern-to-ctx ctx (arm.pattern) scrut-ty
  in lower-match-arms-acc arms ty scrut-ty ctx (i + 1) len (list-snoc acc IRBranch { pattern = lower-pattern (arm.pattern), body = lower-expr (arm.body) ty arm-ctx })

bind-pattern-to-ctx : LowerCtx -> APat -> CodexType -> LowerCtx
bind-pattern-to-ctx (ctx) (pat) (ty) = when pat
 if AVarPat (name) -> LowerCtx { types = [TypeBinding { name = name.value, bound-type = ty }] ++ ctx.types, ust = ctx.ust }
 if ACtorPat (ctor-name) (sub-pats) -> let ctor-raw = lookup-type (ctx.types) (ctor-name.value)
 in let ctor-ty = deep-resolve (ctx.ust) ctor-raw
 in let ctor-stripped = strip-forall-ty ctor-ty
 in bind-ctor-pattern-fields ctx sub-pats ctor-stripped 0 (list-length sub-pats)
 if AWildPat -> ctx
 if ALitPat (text) (kind) -> ctx

bind-ctor-pattern-fields : LowerCtx -> List APat -> CodexType -> Integer -> Integer -> LowerCtx
bind-ctor-pattern-fields (ctx) (sub-pats) (ctor-ty) (i) (len) =
 if i == len
  then ctx
  else when ctor-ty
   if FunTy (param-ty) (ret-ty) -> let ctx2 = bind-pattern-to-ctx ctx (list-at sub-pats i) param-ty
   in bind-ctor-pattern-fields ctx2 sub-pats ret-ty (i + 1) len
   if _ -> let ctx2 = bind-pattern-to-ctx ctx (list-at sub-pats i) ErrorTy
   in bind-ctor-pattern-fields ctx2 sub-pats ctor-ty (i + 1) len

lower-pattern : APat -> IRPat
lower-pattern (p) = when p
 if AVarPat (name) -> IrVarPat (name.value) ErrorTy
 if ALitPat (text) (kind) -> IrLitPat text ErrorTy
 if ACtorPat (name) (subs) -> IrCtorPat (name.value) (map-list lower-pattern subs) ErrorTy
 if AWildPat -> IrWildPat

lower-list : List AExpr -> CodexType -> LowerCtx -> IRExpr
lower-list (elems) (ty) (ctx) =
 let resolved = deep-resolve (ctx.ust) ty
 in let elem-ty = when resolved
   if ListTy (e) -> e
   if _ -> if list-length elems == 0
    then ErrorTy
    else ir-expr-type (lower-expr (list-at elems 0) ErrorTy ctx)
 in IrList (lower-list-elems-loop elems elem-ty ctx 0 (list-length elems)) elem-ty

lower-list-elems-loop : List AExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRExpr
lower-list-elems-loop (elems) (elem-ty) (ctx) (i) (len) =
 lower-list-elems-acc elems elem-ty ctx i len []

lower-list-elems-acc : List AExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRExpr -> List IRExpr
lower-list-elems-acc (elems) (elem-ty) (ctx) (i) (len) (acc) =
 if i == len
  then acc
  else lower-list-elems-acc elems elem-ty ctx (i + 1) len (list-snoc acc (lower-expr (list-at elems i) elem-ty ctx))

lower-record : Name -> List AFieldExpr -> CodexType -> LowerCtx -> IRExpr
lower-record (name) (fields) (ty) (ctx) =
 let ctor-raw = lookup-type (ctx.types) (name.value)
 in let record-ty = when ctor-raw
   if ErrorTy -> ty
   if _ -> strip-fun-args-lower (deep-resolve (ctx.ust) ctor-raw)
 in let actual-ty = when record-ty
   if ErrorTy -> ty
   if _ -> record-ty
 in IrRecord (name.value) (lower-record-fields-typed fields actual-ty ctx 0 (list-length fields)) actual-ty

lower-record-fields-typed : List AFieldExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRFieldVal
lower-record-fields-typed (fields) (record-ty) (ctx) (i) (len) =
 lower-record-fields-acc fields record-ty ctx i len []

lower-record-fields-acc : List AFieldExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRFieldVal -> List IRFieldVal
lower-record-fields-acc (fields) (record-ty) (ctx) (i) (len) (acc) =
 if i == len
  then acc
  else let f = list-at fields i
  in let field-expected = when record-ty
    if RecordTy (rname) (rfields) -> lookup-record-field rfields (f.name.value)
    if _ -> ErrorTy
  in lower-record-fields-acc fields record-ty ctx (i + 1) len (list-snoc acc IRFieldVal { name = f.name.value, value = lower-expr (f.value) field-expected ctx })

lower-do : List ADoStmt -> CodexType -> LowerCtx -> IRExpr
lower-do (stmts) (ty) (ctx) =
 IrDo (lower-do-stmts-loop stmts ty ctx 0 (list-length stmts)) ty

lower-do-stmts-loop : List ADoStmt -> CodexType -> LowerCtx -> Integer -> Integer -> List IRDoStmt
lower-do-stmts-loop (stmts) (ty) (ctx) (i) (len) =
 lower-do-stmts-acc stmts ty ctx i len []

lower-do-stmts-acc : List ADoStmt -> CodexType -> LowerCtx -> Integer -> Integer -> List IRDoStmt -> List IRDoStmt
lower-do-stmts-acc (stmts) (ty) (ctx) (i) (len) (acc) =
 if i == len
  then acc
  else let s = list-at stmts i
  in when s
   if ADoBindStmt (name) (val) -> let val-ir = lower-expr val ty ctx
   in let val-ty = ir-expr-type val-ir
   in let ctx2 = LowerCtx { types = [TypeBinding { name = name.value, bound-type = val-ty }] ++ ctx.types, ust = ctx.ust }
   in lower-do-stmts-acc stmts ty ctx2 (i + 1) len (list-snoc acc (IrDoBind (name.value) val-ty val-ir))
   if ADoExprStmt (e) -> lower-do-stmts-acc stmts ty ctx (i + 1) len (list-snoc acc (IrDoExec (lower-expr e ty ctx)))

lower-handle : Name -> AExpr -> List AHandleClause -> CodexType -> LowerCtx -> IRExpr
lower-handle (eff) (body) (clauses) (ty) (ctx) =
 let body-ir = lower-expr body ty ctx
 in IrHandle (eff.value) body-ir (lower-handle-clauses clauses ty ctx) ty

lower-handle-clauses : List AHandleClause -> CodexType -> LowerCtx -> List IRHandleClause
lower-handle-clauses (clauses) (ty) (ctx) =
 lower-handle-clauses-loop clauses ty ctx 0

lower-handle-clauses-loop : List AHandleClause -> CodexType -> LowerCtx -> Integer -> List IRHandleClause
lower-handle-clauses-loop (clauses) (ty) (ctx) (i) =
 lower-handle-clauses-acc clauses ty ctx i []

lower-handle-clauses-acc : List AHandleClause -> CodexType -> LowerCtx -> Integer -> List IRHandleClause -> List IRHandleClause
lower-handle-clauses-acc (clauses) (ty) (ctx) (i) (acc) =
 if i == list-length clauses
  then acc
  else let c = list-at clauses i
  in let body-ir = lower-expr (c.body) ty ctx
  in lower-handle-clauses-acc clauses ty ctx (i + 1) (list-snoc acc IRHandleClause { op-name = c.op-name.value, resume-name = c.resume-name.value, body = body-ir })

lower-def : ADef -> List TypeBinding -> UnificationState -> IRDef
lower-def (d) (types) (ust) =
 let raw-type = lookup-type types (d.name.value)
 in let full-type = deep-resolve ust raw-type
 in let stripped = strip-forall-ty full-type
 in let params = lower-def-params (d.params) stripped 0
 in let ret-type = get-return-type-n stripped (list-length (d.params))
 in let ctx = build-def-ctx types ust (d.params) stripped
 in IRDef { name = d.name.value, params = params, type-val = full-type, body = lower-expr (d.body) ret-type ctx }

build-def-ctx : List TypeBinding -> UnificationState -> List AParam -> CodexType -> LowerCtx
build-def-ctx (types) (ust) (params) (ty) =
 let base-ctx = LowerCtx { types = types, ust = ust }
 in bind-params-to-ctx base-ctx params ty 0

bind-params-to-ctx : LowerCtx -> List AParam -> CodexType -> Integer -> LowerCtx
bind-params-to-ctx (ctx) (params) (ty) (i) =
 if i == list-length params
  then ctx
  else let p = list-at params i
  in let param-ty = peel-fun-param ty
  in let rest-ty = peel-fun-return ty
  in let ctx2 = LowerCtx { types = [TypeBinding { name = p.name.value, bound-type = param-ty }] ++ ctx.types, ust = ctx.ust }
  in bind-params-to-ctx ctx2 params rest-ty (i + 1)

lower-def-params : List AParam -> CodexType -> Integer -> List IRParam
lower-def-params (params) (ty) (i) =
 lower-def-params-acc params ty i []

lower-def-params-acc : List AParam -> CodexType -> Integer -> List IRParam -> List IRParam
lower-def-params-acc (params) (ty) (i) (acc) =
 if i == list-length params
  then acc
  else let p = list-at params i
  in let param-ty = peel-fun-param ty
  in let rest-ty = peel-fun-return ty
  in lower-def-params-acc params rest-ty (i + 1) (list-snoc acc IRParam { name = p.name.value, type-val = param-ty })

get-return-type-n : CodexType -> Integer -> CodexType
get-return-type-n (ty) (n) =
 if n == 0
  then ty
  else when ty
   if FunTy (p) (r) -> get-return-type-n r (n - 1)
   if _ -> ErrorTy

lower-module : AModule -> List TypeBinding -> UnificationState -> IRModule
lower-module (m) (types) (ust) =
 let ctor-types = collect-ctor-bindings (m.type-defs) 0 (list-length (m.type-defs)) []
 in let all-types = ctor-types ++ types ++ builtin-type-env.bindings
 in IRModule { name = m.name, defs = lower-defs (m.defs) all-types ust 0 }

lower-defs : List ADef -> List TypeBinding -> UnificationState -> Integer -> List IRDef
lower-defs (defs) (types) (ust) (i) =
 lower-defs-acc defs types ust i []

lower-defs-acc : List ADef -> List TypeBinding -> UnificationState -> Integer -> List IRDef -> List IRDef
lower-defs-acc (defs) (types) (ust) (i) (acc) =
 if i == list-length defs
  then acc
  else lower-defs-acc defs types ust (i + 1) (list-snoc acc (lower-def (list-at defs i) types ust))

lookup-type : List TypeBinding -> Text -> CodexType
lookup-type (bindings) (name) =
 lookup-type-loop bindings name 0 (list-length bindings)

lookup-type-loop : List TypeBinding -> Text -> Integer -> Integer -> CodexType
lookup-type-loop (bindings) (name) (i) (len) =
 if i == len
  then ErrorTy
  else let b = list-at bindings i
  in if b.name == name
   then b.bound-type
   else lookup-type-loop bindings name (i + 1) len

peel-fun-param : CodexType -> CodexType
peel-fun-param (ty) = when ty
 if FunTy (p) (r) -> p
 if ForAllTy (id) (body) -> peel-fun-param body
 if _ -> ErrorTy

peel-fun-return : CodexType -> CodexType
peel-fun-return (ty) = when ty
 if FunTy (p) (r) -> r
 if ForAllTy (id) (body) -> peel-fun-return body
 if _ -> ErrorTy

strip-forall-ty : CodexType -> CodexType
strip-forall-ty (ty) = when ty
 if ForAllTy (id) (body) -> strip-forall-ty body
 if _ -> ty

subst-type-vars-from-arg : CodexType -> CodexType -> CodexType -> CodexType
subst-type-vars-from-arg (param-ty) (arg-ty) (target) = when param-ty
 if TypeVar (id) -> subst-type-var-in-target target id arg-ty
 if ListTy (pe) -> subst-from-list pe arg-ty target
 if FunTy (pp) (pr) -> subst-from-fun pp pr arg-ty target
 if _ -> target

subst-from-list : CodexType -> CodexType -> CodexType -> CodexType
subst-from-list (pe) (arg-ty) (target) = when arg-ty
 if ListTy (ae) -> subst-type-vars-from-arg pe ae target
 if _ -> target

subst-from-fun : CodexType -> CodexType -> CodexType -> CodexType -> CodexType
subst-from-fun (pp) (pr) (arg-ty) (target) = when arg-ty
 if FunTy (ap) (ar) -> let t2 = subst-type-vars-from-arg pp ap target
 in subst-type-vars-from-arg pr ar t2
 if _ -> target

subst-type-var-in-target : CodexType -> Integer -> CodexType -> CodexType
subst-type-var-in-target (ty) (var-id) (replacement) = when ty
 if TypeVar (id) -> if id == var-id then replacement else ty
 if FunTy (p) (r) -> FunTy (subst-type-var-in-target p var-id replacement) (subst-type-var-in-target r var-id replacement)
 if ListTy (elem) -> ListTy (subst-type-var-in-target elem var-id replacement)
 if ForAllTy (fid) (body) -> if fid == var-id
  then ty
  else ForAllTy fid (subst-type-var-in-target body var-id replacement)
 if _ -> ty

strip-fun-args-lower : CodexType -> CodexType
strip-fun-args-lower (ty) = when ty
 if FunTy (p) (r) -> strip-fun-args-lower r
 if ForAllTy (id) (body) -> strip-fun-args-lower body
 if _ -> ty

is-text-type : CodexType -> Boolean
is-text-type (ty) = when ty
 if TextTy -> True
 if _ -> False

collect-ctor-bindings : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
collect-ctor-bindings (tdefs) (i) (len) (acc) =
 if i == len
  then acc
  else let td = list-at tdefs i
  in let bindings = ctor-bindings-for-typedef td
  in collect-ctor-bindings tdefs (i + 1) len (acc ++ bindings)

ctor-bindings-for-typedef : ATypeDef -> List TypeBinding
ctor-bindings-for-typedef (td) = when td
 if AVariantTypeDef (name) (type-params) (ctors) -> let result-ty = ConstructedTy name []
 in collect-variant-ctor-bindings ctors result-ty 0 (list-length ctors) []
 if ARecordTypeDef (name) (type-params) (fields) -> let resolved-fields = build-record-fields fields 0 (list-length fields) []
 in let result-ty = RecordTy name resolved-fields
 in let ctor-ty = build-record-ctor-type fields result-ty 0 (list-length fields)
 in [TypeBinding { name = name.value, bound-type = ctor-ty }]

collect-variant-ctor-bindings : List AVariantCtorDef -> CodexType -> Integer -> Integer -> List TypeBinding -> List TypeBinding
collect-variant-ctor-bindings (ctors) (result-ty) (i) (len) (acc) =
 if i == len
  then acc
  else let ctor = list-at ctors i
  in let ctor-ty = build-ctor-type (ctor.fields) result-ty 0 (list-length (ctor.fields))
  in collect-variant-ctor-bindings ctors result-ty (i + 1) len (list-snoc acc TypeBinding { name = ctor.name.value, bound-type = ctor-ty })

build-ctor-type : List TypeBinding -> List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
build-ctor-type (fields) (result) (i) (len) =
 if i == len
  then result
  else let rest = build-ctor-type fields result (i + 1) len
  in FunTy (resolve-type-expr (list-at fields i)) rest

build-record-fields : List TypeBinding -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
build-record-fields (fields) (i) (len) (acc) =
 if i == len
  then acc
  else let f = list-at fields i
  in let rfield = RecordField { name = f.name, type-val = resolve-type-expr (f.type-expr) }
  in build-record-fields fields (i + 1) len (list-snoc acc rfield)

build-record-ctor-type : List TypeBinding -> List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
build-record-ctor-type (fields) (result) (i) (len) =
 if i == len
  then result
  else let f = list-at fields i
  in let rest = build-record-ctor-type fields result (i + 1) len
  in FunTy (resolve-type-expr (f.type-expr)) rest

resolve-type-expr : List TypeBinding -> ATypeExpr -> CodexType
resolve-type-expr (texpr) = when texpr
 if ANamedType (name) -> if name.value == "Integer"
  then IntegerTy
  else if name.value == "Number"
   then NumberTy
   else if name.value == "Text"
    then TextTy
    else if name.value == "Boolean"
     then BooleanTy
     else if name.value == "Nothing"
      then NothingTy
      else ConstructedTy name []
 if AFunType (param) (ret) -> FunTy (resolve-type-expr param) (resolve-type-expr ret)
 if AAppType (ctor) (args) -> when ctor
  if ANamedType (cname) -> if cname.value == "List"
   then if list-length args == 1
    then ListTy (resolve-type-expr (list-at args 0))
    else ListTy ErrorTy
   else ConstructedTy cname []
  if _ -> ErrorTy

lower-bin-op : BinaryOp -> CodexType -> IRBinaryOp
lower-bin-op (op) (ty) = when op
 if OpAdd -> IrAddInt
 if OpSub -> IrSubInt
 if OpMul -> IrMulInt
 if OpDiv -> IrDivInt
 if OpPow -> IrPowInt
 if OpEq -> IrEq
 if OpNotEq -> IrNotEq
 if OpLt -> IrLt
 if OpGt -> IrGt
 if OpLtEq -> IrLtEq
 if OpGtEq -> IrGtEq
 if OpDefEq -> IrEq
 if OpAppend -> if is-text-type ty then IrAppendText else IrAppendList
 if OpCons -> IrConsList
 if OpAnd -> IrAnd
 if OpOr -> IrOr

binary-result-type : BinaryOp -> CodexType -> CodexType -> CodexType
binary-result-type (op) (left-ty) (expected-ty) = when op
 if OpEq -> BooleanTy
 if OpNotEq -> BooleanTy
 if OpLt -> BooleanTy
 if OpGt -> BooleanTy
 if OpLtEq -> BooleanTy
 if OpGtEq -> BooleanTy
 if OpDefEq -> BooleanTy
 if OpAnd -> BooleanTy
 if OpOr -> BooleanTy
 if OpAppend -> if is-text-type left-ty
  then TextTy
  else if is-text-type expected-ty then TextTy else left-ty
 if _ -> left-ty


scope-has : Scope -> Text -> Boolean
scope-has (sc) (name) =
 let len = list-length (sc.names)
 in if len == 0
  then False
  else let pos = bsearch-text-set (sc.names) name 0 len
  in if pos >= len
   then False
   else list-at (sc.names) pos == name

scope-add : Scope -> Text -> Scope
scope-add (sc) (name) =
 let len = list-length (sc.names)
 in let pos = bsearch-text-set (sc.names) name 0 len
 in Scope { names = list-insert-at (sc.names) pos name }

builtin-names : List Text
builtin-names =
 ["show", "negate", "True", "False", "Nothing", "print-line", "read-line", "read-file", "write-file", "file-exists", "list-files", "open-file", "read-all", "close-file", "char-at", "char-to-text", "text-length", "substring", "is-letter", "is-digit", "is-whitespace", "text-to-integer", "integer-to-text", "text-replace", "text-split", "text-contains", "text-starts-with", "char-code", "char-code-at", "code-to-char", "list-length", "list-at", "list-insert-at", "list-snoc", "text-compare", "get-args", "get-env", "current-dir", "map", "filter", "fold", "text-concat-list"]

is-type-name : Text -> Boolean
is-type-name (name) =
 if text-length name == 0
  then False
  else is-letter (char-at name 0) & is-upper-char (char-at name 0)

is-upper-char : Char -> Boolean
is-upper-char (c) =
 let code = char-code c
 in code >= char-code 'E' & code <= char-code 'Z'

collect-top-level-names : List ADef -> Integer -> Integer -> List Text -> List Diagnostic -> CollectResult
collect-top-level-names (defs) (i) (len) (acc) (errs) =
 if i == len
  then CollectResult { names = acc, errors = errs }
  else let def = list-at defs i
  in let name = def.name.value
  in if list-contains acc name
   then collect-top-level-names defs (i + 1) len acc (errs ++ [make-error "CDX3001" ("Duplicate definition: " ++ name)])
   else let pos = bsearch-text-set acc name 0 (list-length acc)
   in collect-top-level-names defs (i + 1) len (list-insert-at acc pos name) errs

list-contains : List Text -> Text -> Boolean
list-contains (xs) (name) =
 let len = list-length xs
 in if len == 0
  then False
  else let pos = bsearch-text-set xs name 0 len
  in if pos >= len
   then False
   else list-at xs pos == name

collect-ctor-names : List ATypeDef -> Integer -> List Text
collect-ctor-names (type-defs) (i) (len) (type-acc) (ctor-acc) =
 if i == len
  then CtorCollectResult { type-names = type-acc, ctor-names = ctor-acc }
  else let td = list-at type-defs i
  in when td
   if AVariantTypeDef (name) (params) (ctors) -> let new-type-acc = list-snoc type-acc (name.value)
   in let new-ctor-acc = collect-variant-ctors ctors 0 (list-length ctors) ctor-acc
   in collect-ctor-names type-defs (i + 1) len new-type-acc new-ctor-acc
   if ARecordTypeDef (name) (params) (fields) -> collect-ctor-names type-defs (i + 1) len (list-snoc type-acc (name.value)) ctor-acc

collect-variant-ctors : List AVariantCtorDef -> Integer -> Integer -> List Text -> List Text
collect-variant-ctors (ctors) (i) (len) (acc) =
 if i == len
  then acc
  else let ctor = list-at ctors i
  in collect-variant-ctors ctors (i + 1) len (list-snoc acc (ctor.name.value))

build-all-names-scope : List Text -> List Text -> List Text -> Scope
build-all-names-scope (top-names) (ctor-names) (builtins) =
 let sc = add-names-to-scope empty-scope top-names 0 (list-length top-names)
 in let sc2 = add-names-to-scope sc ctor-names 0 (list-length ctor-names)
 in add-names-to-scope sc2 builtins 0 (list-length builtins)

add-names-to-scope : Scope -> List Text -> Integer -> Integer -> Scope
add-names-to-scope (sc) (names) (i) (len) =
 if i == len
  then sc
  else add-names-to-scope (scope-add sc (list-at names i)) names (i + 1) len

resolve-expr : Scope -> AExpr -> List Diagnostic
resolve-expr (sc) (expr) = when expr
 if ALitExpr (val) (kind) -> []
 if ANameExpr (name) -> if scope-has sc (name.value) | is-type-name (name.value)
  then []
  else [make-error "CDX3002" ("Undefined name: " ++ name.value)]
 if ABinaryExpr (left) (op) (right) -> resolve-expr sc left ++ resolve-expr sc right
 if AUnaryExpr (operand) -> resolve-expr sc operand
 if AApplyExpr (func) (arg) -> resolve-expr sc func ++ resolve-expr sc arg
 if AIfExpr (cond) (then-e) (else-e) -> resolve-expr sc cond ++ resolve-expr sc then-e ++ resolve-expr sc else-e
 if ALetExpr (bindings) (body) -> resolve-let sc bindings body 0 (list-length bindings) []
 if ALambdaExpr (params) (body) -> let sc2 = add-lambda-params sc params 0 (list-length params)
 in resolve-expr sc2 body
 if AMatchExpr (scrutinee) (arms) -> resolve-expr sc scrutinee ++ resolve-match-arms sc arms 0 (list-length arms) []
 if AListExpr (elems) -> resolve-list-elems sc elems 0 (list-length elems) []
 if ARecordExpr (name) (fields) -> resolve-record-fields sc fields 0 (list-length fields) []
 if AFieldAccess (obj) (field) -> resolve-expr sc obj
 if ADoExpr (stmts) -> resolve-do-stmts sc stmts 0 (list-length stmts) []
 if AErrorExpr (msg) -> []

resolve-let : Scope -> List ALetBind -> AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-let (sc) (bindings) (body) (i) (len) (errs) =
 if i == len
  then errs ++ resolve-expr sc body
  else let b = list-at bindings i
  in let bind-errs = resolve-expr sc (b.value)
  in let sc2 = scope-add sc (b.name.value)
  in resolve-let sc2 bindings body (i + 1) len (errs ++ bind-errs)

add-lambda-params : Scope -> List Name -> Integer -> Integer -> Scope
add-lambda-params (sc) (params) (i) (len) =
 if i == len
  then sc
  else let p = list-at params i
  in add-lambda-params (scope-add sc (p.value)) params (i + 1) len

resolve-match-arms : Scope -> List AMatchArm -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-match-arms (sc) (arms) (i) (len) (errs) =
 if i == len
  then errs
  else let arm = list-at arms i
  in let sc2 = collect-pattern-names sc (arm.pattern)
  in let arm-errs = resolve-expr sc2 (arm.body)
  in resolve-match-arms sc arms (i + 1) len (errs ++ arm-errs)

collect-pattern-names : Scope -> APat -> Scope
collect-pattern-names (sc) (pat) = when pat
 if AVarPat (name) -> scope-add sc (name.value)
 if ACtorPat (name) (subs) -> collect-ctor-pat-names sc subs 0 (list-length subs)
 if ALitPat (val) (kind) -> sc
 if AWildPat -> sc

collect-ctor-pat-names : Scope -> List APat -> Integer -> Integer -> Scope
collect-ctor-pat-names (sc) (subs) (i) (len) =
 if i == len
  then sc
  else let sub = list-at subs i
  in collect-ctor-pat-names (collect-pattern-names sc sub) subs (i + 1) len

resolve-list-elems : Scope -> List AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-list-elems (sc) (elems) (i) (len) (errs) =
 if i == len
  then errs
  else let errs2 = resolve-expr sc (list-at elems i)
  in resolve-list-elems sc elems (i + 1) len (errs ++ errs2)

resolve-record-fields : Scope -> List AFieldExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-record-fields (sc) (fields) (i) (len) (errs) =
 if i == len
  then errs
  else let f = list-at fields i
  in let errs2 = resolve-expr sc (f.value)
  in resolve-record-fields sc fields (i + 1) len (errs ++ errs2)

resolve-do-stmts : Scope -> List ADoStmt -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-do-stmts (sc) (stmts) (i) (len) (errs) =
 if i == len
  then errs
  else let stmt = list-at stmts i
  in when stmt
   if ADoExprStmt (e) -> let errs2 = resolve-expr sc e
   in resolve-do-stmts sc stmts (i + 1) len (errs ++ errs2)
   if ADoBindStmt (name) (e) -> let errs2 = resolve-expr sc e
   in let sc2 = scope-add sc (name.value)
   in resolve-do-stmts sc2 stmts (i + 1) len (errs ++ errs2)

resolve-all-defs : Scope -> List ADef -> Integer -> Integer -> List Diagnostic -> List Diagnostic
resolve-all-defs (sc) (defs) (i) (len) (errs) =
 if i == len
  then errs
  else let def = list-at defs i
  in let def-scope = add-def-params sc (def.params) 0 (list-length (def.params))
  in let errs2 = resolve-expr def-scope (def.body)
  in resolve-all-defs sc defs (i + 1) len (errs ++ errs2)

add-def-params : Scope -> List AParam -> Integer -> Integer -> Scope
add-def-params (sc) (params) (i) (len) =
 if i == len
  then sc
  else let p = list-at params i
  in add-def-params (scope-add sc (p.name.value)) params (i + 1) len

resolve-module : AModule -> ResolveResult
resolve-module (mod) =
 resolve-module-with-imports mod []

resolve-module-with-imports : AModule -> List ResolveResult -> ResolveResult
resolve-module-with-imports (mod) (imported) =
 let top = collect-top-level-names (mod.defs) 0 (list-length (mod.defs)) [] []
 in let ctors = collect-ctor-names (mod.type-defs) 0 (list-length (mod.type-defs)) [] []
 in let imported-names = collect-imported-names imported 0 (list-length imported) []
 in let all-top = top.names ++ imported-names
 in let sc = build-all-names-scope all-top (ctors.ctor-names) builtin-names
 in let expr-errs = resolve-all-defs sc (mod.defs) 0 (list-length (mod.defs)) []
 in ResolveResult { errors = top.errors ++ expr-errs, top-level-names = top.names, type-names = ctors.type-names, ctor-names = ctors.ctor-names }

collect-imported-names : List ResolveResult -> Integer -> Integer -> List Text -> List Text
collect-imported-names (results) (i) (len) (acc) =
 if i == len
  then acc
  else let r = list-at results i
  in let names = r.top-level-names ++ r.ctor-names
  in collect-imported-names results (i + 1) len (acc ++ names)

cc-newline : Integer
cc-newline =
 char-code '7'

cc-cr : Integer
cc-cr =
 0 - 1

cc-space : Integer
cc-space =
 char-code ' '

cc-double-quote : Integer
cc-double-quote =
 char-code '"'

cc-single-quote : Integer
cc-single-quote =
 char-code '\''

cc-ampersand : Integer
cc-ampersand =
 char-code '&'

cc-left-paren : Integer
cc-left-paren =
 char-code '('

cc-right-paren : Integer
cc-right-paren =
 char-code ')'

cc-star : Integer
cc-star =
 char-code '*'

cc-plus : Integer
cc-plus =
 char-code '+'

cc-comma : Integer
cc-comma =
 char-code ','

cc-minus : Integer
cc-minus =
 char-code '-'

cc-dot : Integer
cc-dot =
 char-code '.'

cc-slash : Integer
cc-slash =
 char-code '/'

cc-zero : Integer
cc-zero =
 char-code '0'

cc-nine : Integer
cc-nine =
 char-code '9'

cc-colon : Integer
cc-colon =
 char-code ':'

cc-less : Integer
cc-less =
 char-code '<'

cc-equals : Integer
cc-equals =
 char-code '='

cc-greater : Integer
cc-greater =
 char-code '>'

cc-upper-a : Integer
cc-upper-a =
 char-code 'E'

cc-upper-z : Integer
cc-upper-z =
 char-code 'Z'

cc-left-bracket : Integer
cc-left-bracket =
 char-code '['

cc-backslash : Integer
cc-backslash =
 char-code '\\'

cc-right-bracket : Integer
cc-right-bracket =
 char-code ']'

cc-caret : Integer
cc-caret =
 char-code 'ǁ
cc-underscore : Integer
cc-underscore =
 char-code '_'

cc-lower-a : Integer
cc-lower-a =
 char-code 'a'

cc-lower-n : Integer
cc-lower-n =
 char-code 'n'

cc-lower-r : Integer
cc-lower-r =
 char-code 'r'

cc-lower-t : Integer
cc-lower-t =
 char-code 't'

cc-lower-z : Integer
cc-lower-z =
 char-code 'z'

cc-left-brace : Integer
cc-left-brace =
 char-code '{'

cc-pipe : Integer
cc-pipe =
 char-code '|'

cc-right-brace : Integer
cc-right-brace =
 char-code '}'

is-letter-code : Integer -> Boolean
is-letter-code (c) =
 is-letter (code-to-char c)

is-digit-code : Integer -> Boolean
is-digit-code (c) =
 is-digit (code-to-char c)

make-lex-state : Text -> LexState
make-lex-state (src) =
 LexState { source = src, offset = 0, line = 1, column = 1 }

is-at-end : LexState -> Boolean
is-at-end (st) =
 st.offset >= text-length (st.source)

peek-code : LexState -> Integer
peek-code (st) =
 if is-at-end st
  then 0
  else char-code-at (st.source) (st.offset)

advance-char : LexState -> LexState
advance-char (st) =
 if peek-code st == cc-newline
  then LexState { source = st.source, offset = st.offset + 1, line = st.line + 1, column = 1 }
  else LexState { source = st.source, offset = st.offset + 1, line = st.line, column = st.column + 1 }

skip-spaces-end : Text -> Integer -> Integer -> Integer
skip-spaces-end (source) (offset) (len) =
 if offset >= len
  then offset
  else if char-code-at source offset == cc-space
   then skip-spaces-end source (offset + 1) len
   else offset

skip-spaces : LexState -> LexState
skip-spaces (st) =
 let len = text-length (st.source)
 in let end = skip-spaces-end (st.source) (st.offset) len
 in if end == st.offset
  then st
  else LexState { source = st.source, offset = end, line = st.line, column = st.column + end - st.offset }

scan-ident-end : Text -> Integer -> Integer -> Integer
scan-ident-end (source) (offset) (len) =
 if offset >= len
  then offset
  else let c = char-code-at source offset
  in if is-letter-code c
   then scan-ident-end source (offset + 1) len
   else if is-digit-code c
    then scan-ident-end source (offset + 1) len
    else if c == cc-underscore
     then scan-ident-end source (offset + 1) len
     else if c == cc-minus
      then if offset + 1 >= len
       then offset
       else let nc = char-code-at source (offset + 1)
       in if is-letter-code nc | is-digit-code nc
        then scan-ident-end source (offset + 1) len
        else offset
      else offset

scan-ident-rest : LexState -> LexState
scan-ident-rest (st) =
 let len = text-length (st.source)
 in let end = scan-ident-end (st.source) (st.offset) len
 in if end == st.offset
  then st
  else LexState { source = st.source, offset = end, line = st.line, column = st.column + end - st.offset }

scan-digits-end : Text -> Integer -> Integer -> Integer
scan-digits-end (source) (offset) (len) =
 if offset >= len
  then offset
  else let c = char-code-at source offset
  in if is-digit-code c
   then scan-digits-end source (offset + 1) len
   else if c == cc-underscore
    then scan-digits-end source (offset + 1) len
    else offset

scan-digits : LexState -> LexState
scan-digits (st) =
 let len = text-length (st.source)
 in let end = scan-digits-end (st.source) (st.offset) len
 in if end == st.offset
  then st
  else LexState { source = st.source, offset = end, line = st.line, column = st.column + end - st.offset }

scan-string-end : Text -> Integer -> Integer -> Integer
scan-string-end (source) (offset) (len) =
 if offset >= len
  then offset
  else let c = char-code-at source offset
  in if c == cc-double-quote
   then offset + 1
   else if c == cc-newline
    then offset
    else if c == cc-backslash
     then scan-string-end source (offset + 2) len
     else scan-string-end source (offset + 1) len

scan-string-body : LexState -> LexState
scan-string-body (st) =
 let len = text-length (st.source)
 in let end = scan-string-end (st.source) (st.offset) len
 in if end == st.offset
  then st
  else LexState { source = st.source, offset = end, line = st.line, column = st.column + end - st.offset }

process-escapes : Text -> Integer -> Integer -> Text -> Text
process-escapes (s) (i) (len) (acc) =
 if i >= len
  then acc
  else let c = char-code-at s i
  in if c == cc-backslash
   then if i + 1 < len
    then let nc = char-code-at s (i + 1)
    in if nc == cc-lower-n
     then process-escapes s (i + 2) len (acc ++ char-to-text '7')
     else if nc == cc-lower-t
      then process-escapes s (i + 2) len (acc ++ "  ")
      else if nc == cc-lower-r
       then process-escapes s (i + 2) len acc
       else if nc == cc-backslash
        then process-escapes s (i + 2) len (acc ++ "\\")
        else if nc == cc-double-quote
         then process-escapes s (i + 2) len (acc ++ "\"")
         else process-escapes s (i + 2) len (acc ++ char-to-text (char-at s (i + 1)))
    else acc ++ char-to-text (char-at s i)
   else process-escapes s (i + 1) len (acc ++ char-to-text (char-at s i))

classify-word : Text -> TokenKind
classify-word (w) =
 if w == "let"
  then LetKeyword
  else if w == "in"
   then InKeyword
   else if w == "if"
    then IfKeyword
    else if w == "then"
     then ThenKeyword
     else if w == "else"
      then ElseKeyword
      else if w == "when"
       then WhenKeyword
       else if w == "where"
        then WhereKeyword
        else if w == "do"
         then DoKeyword
         else if w == "record"
          then RecordKeyword
          else if w == "import"
           then ImportKeyword
           else if w == "export"
            then ExportKeyword
            else if w == "claim"
             then ClaimKeyword
             else if w == "proof"
              then ProofKeyword
              else if w == "forall"
               then ForAllKeyword
               else if w == "exists"
                then ThereExistsKeyword
                else if w == "linear"
                 then LinearKeyword
                 else if w == "effect"
                  then EffectKeyword
                  else if w == "with"
                   then WithKeyword
                   else if w == "True"
                    then TrueKeyword
                    else if w == "False"
                     then FalseKeyword
                     else let first-code = char-code-at w 0
                     in if first-code >= cc-upper-a
                      then if first-code <= cc-upper-z then TypeIdentifier else Identifier
                      else Identifier

make-token : TokenKind -> Text -> LexState -> Token
make-token (kind) (text) (st) =
 Token { kind = kind, text = text, offset = st.offset, line = st.line, column = st.column }


scan-token : LexState -> LexResult
scan-token (st) =
 let s = skip-spaces st
 in if is-at-end s
  then LexEnd
  else let c = peek-code s
  in if c == cc-cr
   then scan-token (advance-char s)
   else if c == cc-newline
    then LexToken (make-token Newline "\n" s) (advance-char s)
    else if c == cc-double-quote
     then let start = s.offset + 1
     in let after = scan-string-body (advance-char s)
     in let text-len = after.offset - start - 1
     in let raw = substring (s.source) start text-len
     in LexToken (make-token TextLiteral (process-escapes raw 0 (text-length raw) "") s) after
     else if c == cc-single-quote
      then scan-char-literal s
      else if is-letter-code c
       then let start = s.offset
       in let after = scan-ident-rest (advance-char s)
       in let word = extract-text s start after
       in LexToken (make-token (classify-word word) word s) after
       else if c == cc-underscore
        then let start = s.offset
        in let after = scan-ident-rest (advance-char s)
        in let word = extract-text s start after
        in if text-length word == 1
         then LexToken (make-token Underscore "_" s) after
         else LexToken (make-token (classify-word word) word s) after
        else if is-digit-code c
         then let start = s.offset
         in let after = scan-digits (advance-char s)
         in if is-at-end after
          then LexToken (make-token IntegerLiteral (extract-text s start after) s) after
          else if peek-code after == cc-dot
           then let after2 = scan-digits (advance-char after)
           in LexToken (make-token NumberLiteral (extract-text s start after2) s) after2
           else LexToken (make-token IntegerLiteral (extract-text s start after) s) after
         else scan-operator s

scan-operator : LexState -> LexResult
scan-operator (s) =
 let c = peek-code s
 in let next = advance-char s
 in if c == cc-left-paren
  then LexToken (make-token LeftParen "(" s) next
  else if c == cc-right-paren
   then LexToken (make-token RightParen ")" s) next
   else if c == cc-left-bracket
    then LexToken (make-token LeftBracket "[" s) next
    else if c == cc-right-bracket
     then LexToken (make-token RightBracket "]" s) next
     else if c == cc-left-brace
      then LexToken (make-token LeftBrace "{" s) next
      else if c == cc-right-brace
       then LexToken (make-token RightBrace "}" s) next
       else if c == cc-comma
        then LexToken (make-token Comma "," s) next
        else if c == cc-dot
         then LexToken (make-token Dot "." s) next
         else if c == cc-caret
          then LexToken (make-token Caret "^" s) next
          else if c == cc-ampersand
           then LexToken (make-token Ampersand "&" s) next
           else if c == cc-backslash
            then LexToken (make-token Backslash "\\" s) next
            else scan-multi-char-operator s

scan-multi-char-operator : LexState -> LexResult
scan-multi-char-operator (s) =
 let c = peek-code s
 in let next = advance-char s
 in let nc = if is-at-end next
   then 0
   else peek-code next
 in if c == cc-plus
  then if nc == cc-plus
   then LexToken (make-token PlusPlus "++" s) (advance-char next)
   else LexToken (make-token Plus "+" s) next
  else if c == cc-minus
   then if nc == cc-greater
    then LexToken (make-token Arrow "->" s) (advance-char next)
    else LexToken (make-token Minus "-" s) next
   else if c == cc-star
    then LexToken (make-token Star "*" s) next
    else if c == cc-slash
     then if nc == cc-equals
      then LexToken (make-token NotEquals "/=" s) (advance-char next)
      else LexToken (make-token Slash "/" s) next
     else if c == cc-equals
      then if nc == cc-equals
       then let next2 = advance-char next
       in let nc2 = if is-at-end next2
         then 0
         else peek-code next2
       in if nc2 == cc-equals
        then LexToken (make-token TripleEquals "===" s) (advance-char next2)
        else LexToken (make-token DoubleEquals "==" s) next2
       else LexToken (make-token Equals "=" s) next
      else if c == cc-colon
       then if nc == cc-colon
        then LexToken (make-token ColonColon "::" s) (advance-char next)
        else LexToken (make-token Colon ":" s) next
       else if c == cc-pipe
        then if nc == cc-minus
         then LexToken (make-token Turnstile "|-" s) (advance-char next)
         else LexToken (make-token Pipe "|" s) next
        else if c == cc-less
         then if nc == cc-equals
          then LexToken (make-token LessOrEqual "<=" s) (advance-char next)
          else if nc == cc-minus
           then LexToken (make-token LeftArrow "<-" s) (advance-char next)
           else LexToken (make-token LessThan "<" s) next
         else if c == cc-greater
          then if nc == cc-equals
           then LexToken (make-token GreaterOrEqual ">=" s) (advance-char next)
           else LexToken (make-token GreaterThan ">" s) next
          else LexToken (make-token ErrorToken (char-to-text (char-at (s.source) (s.offset))) s) next

scan-char-literal : LexState -> LexResult
scan-char-literal (s) =
 let s1 = advance-char s
 in if is-at-end s1
  then LexToken (make-token ErrorToken "'" s) s1
  else if peek-code s1 == cc-backslash
   then let s2 = advance-char s1
   in if is-at-end s2
    then LexToken (make-token ErrorToken "'\\" s) s2
    else let esc-code = peek-code s2
    in let char-val = if esc-code == cc-lower-n
      then 10
      else if esc-code == cc-lower-t
       then 32
       else if esc-code == cc-lower-r
        then 10
        else if esc-code == cc-backslash
         then cc-backslash
         else if esc-code == cc-single-quote then cc-single-quote else esc-code
    in let s3 = advance-char s2
    in let s4 = if is-at-end s3
      then s3
      else if peek-code s3 == cc-single-quote
       then advance-char s3
       else s3
    in LexToken (make-token CharLiteral (integer-to-text char-val) s) s4
   else let char-val = peek-code s1
   in let s2 = advance-char s1
   in let s3 = if is-at-end s2
     then s2
     else if peek-code s2 == cc-single-quote
      then advance-char s2
      else s2
   in LexToken (make-token CharLiteral (integer-to-text char-val) s) s3



parse-type : ParseState -> ParseTypeResult
parse-type (st) =
 let result = parse-type-atom st
 in unwrap-type-ok result parse-type-continue

parse-type-continue : TypeExpr -> ParseState -> ParseTypeResult
parse-type-continue (left) (st) =
 if is-arrow (current-kind st)
  then let st2 = advance st
  in let right-result = parse-type st2
  in unwrap-type-ok right-result (make-fun-type left)
  else TypeOk left st

make-fun-type : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
make-fun-type (left) (right) (st) =
 TypeOk (FunType left right) st

unwrap-type-ok : ParseTypeResult -> (TypeExpr -> ParseState -> ParseTypeResult) -> ParseTypeResult
unwrap-type-ok (r) (f) = when r
 if TypeOk (t) (st) -> f t st

parse-type-atom : ParseState -> ParseTypeResult
parse-type-atom (st) =
 if is-ident (current-kind st)
  then let tok = current st
  in parse-type-args (NamedType tok) (advance st)
  else if is-type-ident (current-kind st)
   then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-left-paren (current-kind st)
    then parse-paren-type (advance st)
    else if is-left-bracket (current-kind st)
     then parse-effect-type (advance st)
     else let tok = current st
     in TypeOk (NamedType tok) (advance st)

parse-paren-type : ParseState -> ParseTypeResult
parse-paren-type (st) =
 let inner = parse-type st
 in unwrap-type-ok inner finish-paren-type

finish-paren-type : TypeExpr -> ParseState -> ParseTypeResult
finish-paren-type (t) (st) =
 let st2 = expect RightParen st
 in TypeOk (ParenType t) st2

parse-effect-type : ParseState -> ParseTypeResult
parse-effect-type (st) =
 let st2 = skip-effect-contents st
 in parse-type st2

skip-effect-contents : ParseState -> ParseState
skip-effect-contents (st) =
 if is-done st
  then st
  else if is-right-bracket (current-kind st)
   then advance st
   else skip-effect-contents (advance st)

parse-type-args : TypeExpr -> ParseState -> ParseTypeResult
parse-type-args (base-type) (st) =
 if is-done st
  then TypeOk base-type st
  else if is-type-arg-start (current-kind st)
   then parse-type-arg-next base-type st
   else TypeOk base-type st

parse-type-arg-next : TypeExpr -> ParseState -> ParseTypeResult
parse-type-arg-next (base-type) (st) =
 let arg-result = parse-type-atom st
 in unwrap-type-ok arg-result (continue-type-args base-type)

continue-type-args : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
continue-type-args (base-type) (arg) (st) =
 parse-type-args (AppType base-type [arg]) st

parse-pattern : ParseState -> ParsePatResult
parse-pattern (st) =
 if is-underscore (current-kind st)
  then PatOk (WildPat (current st)) (advance st)
  else if is-literal (current-kind st)
   then PatOk (LitPat (current st)) (advance st)
   else if is-type-ident (current-kind st)
    then let tok = current st
    in parse-ctor-pattern-fields tok [] (advance st)
    else if is-ident (current-kind st)
     then PatOk (VarPat (current st)) (advance st)
     else PatOk (WildPat (current st)) (advance st)

parse-ctor-pattern-fields : Token -> List Pat -> ParseState -> ParsePatResult
parse-ctor-pattern-fields (ctor) (acc) (st) =
 if is-left-paren (current-kind st)
  then let st2 = advance st
  in let sub = parse-pattern st2
  in unwrap-pat-ok sub (continue-ctor-fields ctor acc)
  else PatOk (CtorPat ctor acc) st

continue-ctor-fields : Token -> List Pat -> Pat -> ParseState -> ParsePatResult
continue-ctor-fields (ctor) (acc) (p) (st) =
 let st2 = expect RightParen st
 in parse-ctor-pattern-fields ctor (list-snoc acc p) st2

unwrap-pat-ok : ParsePatResult -> (Pat -> ParseState -> ParsePatResult) -> ParsePatResult
unwrap-pat-ok (r) (f) = when r
 if PatOk (p) (st) -> f p st

parse-type-annotation : ParseState -> ParseTypeResult
parse-type-annotation (st) =
 let st2 = advance st
 in let st3 = expect Colon st2
 in parse-type st3

parse-definition : ParseState -> ParseDefResult
parse-definition (st) =
 if is-done st
  then DefNone st
  else if is-ident (current-kind st)
   then try-parse-def st
   else if is-type-ident (current-kind st)
    then try-parse-def st
    else DefNone st


unwrap-type-for-def : ParseTypeResult -> ParseDefResult
unwrap-type-for-def (r) = when r
 if TypeOk (ann-type) (st) -> let name-tok = Token { kind = Identifier, text = "", offset = 0, line = 0, column = 0 }
 in let ann = [TypeAnn { name = name-tok, type-expr = ann-type }]
 in let st2 = skip-newlines st
 in parse-def-body-with-ann ann st2

parse-def-body-with-ann : List TypeAnn -> ParseState -> ParseDefResult
parse-def-body-with-ann (ann) (st) =
 let name-tok = current st
 in let st2 = advance st
 in parse-def-params-then ann name-tok [] st2

parse-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
parse-def-params-then (ann) (name-tok) (acc) (st) =
 if is-left-paren (current-kind st)
  then let st2 = advance st
  in if is-ident (current-kind st2)
   then let param = current st2
   in let st3 = advance st2
   in let st4 = expect RightParen st3
   in parse-def-params-then ann name-tok (list-snoc acc param) st4
   else finish-def ann name-tok acc st
  else finish-def ann name-tok acc st

finish-def : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
finish-def (ann) (name-tok) (params) (st) =
 let st2 = expect Equals st
 in let st3 = skip-newlines st2
 in let body-result = parse-expr st3
 in unwrap-def-body body-result ann name-tok params

unwrap-def-body : ParseExprResult -> List TypeAnn -> Token -> List Token -> ParseDefResult
unwrap-def-body (r) (ann) (name-tok) (params) = when r
 if ExprOk (b) (st) -> DefOk Def { name = name-tok, params = params, ann = ann, body = b } st

is-paren-type-param : ParseState -> Boolean
is-paren-type-param (st) =
 if is-left-paren (current-kind st)
  then let k1 = peek-kind st 1
  in if is-ident k1
   then is-right-paren (peek-kind st 2)
   else if is-type-ident k1
    then is-right-paren (peek-kind st 2)
    else False
  else False

is-type-param-pattern : ParseState -> Boolean
is-type-param-pattern (st) =
 if is-paren-type-param st
  then True
  else is-ident (current-kind st)

parse-type-params : ParseState -> List Token -> ParseState
parse-type-params (st) (acc) =
 if is-paren-type-param st
  then parse-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
  else if is-ident (current-kind st)
   then parse-type-params (advance st) (list-snoc acc (current st))
   else st

collect-type-params : ParseState -> List Token -> List Token
collect-type-params (st) (acc) =
 if is-paren-type-param st
  then collect-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
  else if is-ident (current-kind st)
   then collect-type-params (advance st) (list-snoc acc (current st))
   else acc

parse-type-def : ParseState -> ParseTypeDefResult
parse-type-def (st) =
 if is-type-ident (current-kind st)
  then let name-tok = current st
  in let st2 = advance st
  in let tparams = collect-type-params st2 []
  in let st3 = parse-type-params st2 []
  in if is-equals (current-kind st3)
   then let st4 = skip-newlines (advance st3)
   in if is-record-keyword (current-kind st4)
    then parse-record-type name-tok tparams st4
    else if is-pipe (current-kind st4)
     then parse-variant-type name-tok tparams st4
     else if is-type-ident (current-kind st4) & looks-like-variant st4
      then parse-variant-type name-tok tparams st4
      else TypeDefNone st
   else TypeDefNone st
  else TypeDefNone st

parse-record-type : Token -> List Token -> ParseState -> ParseTypeDefResult
parse-record-type (name-tok) (tparams) (st) =
 let st2 = advance st
 in let st3 = expect LeftBrace st2
 in let st4 = skip-newlines st3
 in parse-record-fields-loop name-tok tparams [] st4

parse-record-fields-loop : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
parse-record-fields-loop (name-tok) (tparams) (acc) (st) =
 if is-right-brace (current-kind st)
  then TypeDefOk TypeDef { name = name-tok, type-params = tparams, body = RecordBody acc } (advance st)
  else if is-ident (current-kind st)
   then parse-one-record-field name-tok tparams acc st
   else TypeDefOk TypeDef { name = name-tok, type-params = tparams, body = RecordBody acc } st

parse-one-record-field : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
parse-one-record-field (name-tok) (tparams) (acc) (st) =
 let field-name = current st
 in let st2 = advance st
 in let st3 = expect Colon st2
 in let field-type-result = parse-type st3
 in unwrap-record-field-type name-tok tparams acc field-name field-type-result

unwrap-record-field-type : Token -> List Token -> List RecordFieldDef -> Token -> ParseTypeResult -> ParseTypeDefResult
unwrap-record-field-type (name-tok) (tparams) (acc) (field-name) (r) = when r
 if TypeOk (ft) (st) -> let field = RecordFieldDef { name = field-name, type-expr = ft }
 in let st2 = skip-newlines st
 in if is-comma (current-kind st2)
  then parse-record-fields-loop name-tok tparams (list-snoc acc field) (skip-newlines (advance st2))
  else parse-record-fields-loop name-tok tparams (list-snoc acc field) st2

looks-like-variant : ParseState -> Boolean
looks-like-variant (st) =
 looks-like-variant-scan (st.tokens) (st.pos + 1) (list-length (st.tokens))

looks-like-variant-scan : List Token -> Integer -> Integer -> Boolean
looks-like-variant-scan (tokens) (i) (len) =
 if i >= len
  then False
  else let k = (list-at tokens i).kind
  in if is-pipe k
   then True
   else when k
    if Newline -> False
    if EndOfFile -> False
    if _ -> looks-like-variant-scan tokens (i + 1) len

parse-variant-type : Token -> List Token -> ParseState -> ParseTypeDefResult
parse-variant-type (name-tok) (tparams) (st) =
 if is-type-ident (current-kind st)
  then let ctor-name = current st
  in let st2 = advance st
  in parse-ctor-fields ctor-name [] st2 name-tok tparams []
  else parse-variant-ctors name-tok tparams [] st

parse-variant-ctors : Token -> List Token -> List VariantCtorDef -> ParseState -> ParseTypeDefResult
parse-variant-ctors (name-tok) (tparams) (acc) (st) =
 if is-pipe (current-kind st)
  then let st2 = skip-newlines (advance st)
  in let ctor-name = current st2
  in let st3 = advance st2
  in parse-ctor-fields ctor-name [] st3 name-tok tparams acc
  else TypeDefOk TypeDef { name = name-tok, type-params = tparams, body = VariantBody acc } st

parse-ctor-fields : Token -> List TypeExpr -> ParseState -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
parse-ctor-fields (ctor-name) (fields) (st) (name-tok) (tparams) (acc) =
 if is-left-paren (current-kind st)
  then let field-result = parse-type (advance st)
  in unwrap-ctor-field field-result ctor-name fields name-tok tparams acc
  else let st2 = skip-newlines st
  in let ctor = VariantCtorDef { name = ctor-name, fields = fields }
  in parse-variant-ctors name-tok tparams (list-snoc acc ctor) st2

unwrap-ctor-field : ParseTypeResult -> Token -> List TypeExpr -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
unwrap-ctor-field (r) (ctor-name) (fields) (name-tok) (tparams) (acc) = when r
 if TypeOk (ty) (st) -> let st2 = expect RightParen st
 in parse-ctor-fields ctor-name (fields ++ [ty]) st2 name-tok tparams acc

parse-document : ParseState -> Document
parse-document (st) =
 let st2 = skip-newlines st
 in let imp-result = parse-imports st2 []
 in parse-top-level [] [] [] (imp-result.imports) (imp-result.state)

parse-imports : ParseState -> List ImportDecl -> ImportParseResult
parse-imports (st) (acc) =
 if is-import-keyword (current-kind st)
  then let st2 = advance st
  in let name-tok = current st2
  in let st3 = advance st2
  in if is-left-paren (current-kind st3)
   then let sel = parse-selected-names (advance st3) []
   in let st4 = skip-newlines (sel.state)
   in parse-imports st4 (list-snoc acc ImportDecl { module-name = name-tok, selected-names = sel.names })
   else let st4 = skip-newlines st3
   in parse-imports st4 (list-snoc acc ImportDecl { module-name = name-tok, selected-names = [] })
  else ImportParseResult { imports = acc, state = st }

parse-selected-names : ParseState -> List Token -> SelectedNamesResult
parse-selected-names (st) (acc) =
 if is-ident (current-kind st)
  then let tok = current st
  in let st2 = advance st
  in if is-comma (current-kind st2)
   then parse-selected-names (skip-newlines (advance st2)) (list-snoc acc tok)
   else SelectedNamesResult { names = list-snoc acc tok, state = st2 }
  else if is-right-paren (current-kind st)
   then SelectedNamesResult { names = acc, state = advance st }
   else SelectedNamesResult { names = acc, state = st }

parse-top-level : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
parse-top-level (defs) (type-defs) (effect-defs) (imports) (st) =
 if is-done st
  then Document { defs = defs, type-defs = type-defs, effect-defs = effect-defs, imports = imports }
  else if is-effect-keyword (current-kind st)
   then parse-top-level-effect defs type-defs effect-defs imports st
   else try-top-level-type-def defs type-defs effect-defs imports st

parse-top-level-effect : List Def -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> Document
parse-top-level-effect (defs) (type-defs) (effect-defs) (imports) (st) =
 let st1 = advance st
 in let name-tok = current st1
 in let st2 = advance st1
 in let st3 = if is-where-keyword (current-kind st2)
   then skip-newlines (advance st2)
   else st2
 in let ops = parse-effect-ops st3 []
 in let ed = EffectDef { name = name-tok, ops = ops.ops }
 in parse-top-level defs type-defs (effect-defs ++ [ed]) imports (skip-newlines (ops.state))

parse-effect-ops : ParseState -> List EffectOpDef -> EffectOpsResult
parse-effect-ops (st) (acc) =
 if is-ident (current-kind st)
  then if is-colon (peek-kind st 1)
   then let op-tok = current st
   in let st2 = advance (advance st)
   in let type-result = parse-type st2
   in when type-result
    if TypeOk (ty) (st3) -> let op = EffectOpDef { name = op-tok, type-expr = ty }
    in parse-effect-ops (skip-newlines st3) (list-snoc acc op)
   else EffectOpsResult { ops = acc, state = st }
  else EffectOpsResult { ops = acc, state = st }



scan-document : ParseState -> ScanResult
scan-document (st) =
 let st2 = skip-newlines st
 in let imp-result = parse-imports st2 []
 in scan-top-level [] [] [] (imp-result.imports) (imp-result.state)

scan-top-level : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
scan-top-level (headers) (type-defs) (effect-defs) (imports) (st) =
 if is-done st
  then ScanResult { type-defs = type-defs, effect-defs = effect-defs, def-headers = headers, imports = imports }
  else if is-effect-keyword (current-kind st)
   then scan-top-level-effect headers type-defs effect-defs imports st
   else try-scan-type-def headers type-defs effect-defs imports st

scan-top-level-effect : List DefHeader -> List TypeDef -> List EffectDef -> List ImportDecl -> ParseState -> ScanResult
scan-top-level-effect (headers) (type-defs) (effect-defs) (imports) (st) =
 let st1 = advance st
 in let name-tok = current st1
 in let st2 = advance st1
 in let st3 = if is-where-keyword (current-kind st2)
   then skip-newlines (advance st2)
   else st2
 in let ops = parse-effect-ops st3 []
 in let ed = EffectDef { name = name-tok, ops = ops.ops }
 in scan-top-level headers type-defs (effect-defs ++ [ed]) imports (skip-newlines (ops.state))



scan-definition : ParseState -> ScanDefResult
scan-definition (st) =
 if is-done st
  then DefHeaderNone st
  else if is-ident (current-kind st)
   then try-scan-def st
   else if is-type-ident (current-kind st)
    then try-scan-def st
    else DefHeaderNone st


unwrap-type-for-scan : ParseTypeResult -> ScanDefResult
unwrap-type-for-scan (r) = when r
 if TypeOk (ann-type) (st) -> let name-tok = Token { kind = Identifier, text = "", offset = 0, line = 0, column = 0 }
 in let ann = [TypeAnn { name = name-tok, type-expr = ann-type }]
 in let st2 = skip-newlines st
 in scan-def-body-with-ann ann st2

scan-def-body-with-ann : List TypeAnn -> ParseState -> ScanDefResult
scan-def-body-with-ann (ann) (st) =
 let name-tok = current st
 in let st2 = advance st
 in scan-def-params-then ann name-tok [] st2

scan-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
scan-def-params-then (ann) (name-tok) (acc) (st) =
 if is-left-paren (current-kind st)
  then let st2 = advance st
  in if is-ident (current-kind st2)
   then let param = current st2
   in let st3 = advance st2
   in let st4 = expect RightParen st3
   in scan-def-params-then ann name-tok (list-snoc acc param) st4
   else finish-def-scan ann name-tok acc st
  else finish-def-scan ann name-tok acc st

finish-def-scan : List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
finish-def-scan (ann) (name-tok) (params) (st) =
 let st2 = expect Equals st
 in let st3 = skip-newlines st2
 in let body-pos = st3.pos
 in let st4 = skip-body-tokens st3 (name-tok.column)
 in DefHeaderOk DefHeader { name = name-tok, params = params, ann = ann, body-pos = body-pos } st4

skip-body-tokens : ParseState -> Integer -> ParseState
skip-body-tokens (st) (name-col) =
 if is-done st
  then st
  else let tok = current st
  in when tok.kind
   if Newline -> skip-body-tokens (advance st) name-col
   if Indent -> skip-body-tokens (advance st) name-col
   if Dedent -> skip-body-tokens (advance st) name-col
   if _ -> if tok.column <= name-col
    then st
    else skip-body-tokens (advance st) name-col

make-parse-state : List Token -> ParseState
make-parse-state (toks) =
 ParseState { tokens = toks, pos = 0 }

current : ParseState -> Token
current (st) =
 list-at (st.tokens) (st.pos)

current-kind : ParseState -> TokenKind
current-kind (st) =
 (current st).kind

advance : ParseState -> ParseState
advance (st) =
 if st.pos >= list-length (st.tokens) - 1
  then st
  else ParseState { tokens = st.tokens, pos = st.pos + 1 }

is-done : ParseState -> Boolean
is-done (st) = when current-kind st
 if EndOfFile -> True
 if _ -> False

peek-kind : ParseState -> Integer -> TokenKind
peek-kind (st) (offset) =
 let idx = st.pos + offset
 in if idx >= list-length (st.tokens) then EndOfFile else (list-at (st.tokens) idx).kind

is-ident : TokenKind -> Boolean
is-ident (k) = when k
 if Identifier -> True
 if _ -> False

is-type-ident : TokenKind -> Boolean
is-type-ident (k) = when k
 if TypeIdentifier -> True
 if _ -> False

is-arrow : TokenKind -> Boolean
is-arrow (k) = when k
 if Arrow -> True
 if _ -> False

is-equals : TokenKind -> Boolean
is-equals (k) = when k
 if Equals -> True
 if _ -> False

is-colon : TokenKind -> Boolean
is-colon (k) = when k
 if Colon -> True
 if _ -> False

is-comma : TokenKind -> Boolean
is-comma (k) = when k
 if Comma -> True
 if _ -> False

is-pipe : TokenKind -> Boolean
is-pipe (k) = when k
 if Pipe -> True
 if _ -> False

is-dot : TokenKind -> Boolean
is-dot (k) = when k
 if Dot -> True
 if _ -> False

is-left-paren : TokenKind -> Boolean
is-left-paren (k) = when k
 if LeftParen -> True
 if _ -> False

is-left-brace : TokenKind -> Boolean
is-left-brace (k) = when k
 if LeftBrace -> True
 if _ -> False

is-left-bracket : TokenKind -> Boolean
is-left-bracket (k) = when k
 if LeftBracket -> True
 if _ -> False

is-right-brace : TokenKind -> Boolean
is-right-brace (k) = when k
 if RightBrace -> True
 if _ -> False

is-right-bracket : TokenKind -> Boolean
is-right-bracket (k) = when k
 if RightBracket -> True
 if _ -> False

is-right-paren : TokenKind -> Boolean
is-right-paren (k) = when k
 if RightParen -> True
 if _ -> False

is-if-keyword : TokenKind -> Boolean
is-if-keyword (k) = when k
 if IfKeyword -> True
 if _ -> False

is-let-keyword : TokenKind -> Boolean
is-let-keyword (k) = when k
 if LetKeyword -> True
 if _ -> False

is-when-keyword : TokenKind -> Boolean
is-when-keyword (k) = when k
 if WhenKeyword -> True
 if _ -> False

is-do-keyword : TokenKind -> Boolean
is-do-keyword (k) = when k
 if DoKeyword -> True
 if _ -> False

is-with-keyword : TokenKind -> Boolean
is-with-keyword (k) = when k
 if WithKeyword -> True
 if _ -> False

is-effect-keyword : TokenKind -> Boolean
is-effect-keyword (k) = when k
 if EffectKeyword -> True
 if _ -> False

is-import-keyword : TokenKind -> Boolean
is-import-keyword (k) = when k
 if ImportKeyword -> True
 if _ -> False

is-where-keyword : TokenKind -> Boolean
is-where-keyword (k) = when k
 if WhereKeyword -> True
 if _ -> False

is-in-keyword : TokenKind -> Boolean
is-in-keyword (k) = when k
 if InKeyword -> True
 if _ -> False

is-minus : TokenKind -> Boolean
is-minus (k) = when k
 if Minus -> True
 if _ -> False

is-dedent : TokenKind -> Boolean
is-dedent (k) = when k
 if Dedent -> True
 if _ -> False

is-left-arrow : TokenKind -> Boolean
is-left-arrow (k) = when k
 if LeftArrow -> True
 if _ -> False

is-record-keyword : TokenKind -> Boolean
is-record-keyword (k) = when k
 if RecordKeyword -> True
 if _ -> False

is-underscore : TokenKind -> Boolean
is-underscore (k) = when k
 if Underscore -> True
 if _ -> False

is-backslash : TokenKind -> Boolean
is-backslash (k) = when k
 if Backslash -> True
 if _ -> False

is-literal : TokenKind -> Boolean
is-literal (k) = when k
 if IntegerLiteral -> True
 if NumberLiteral -> True
 if TextLiteral -> True
 if CharLiteral -> True
 if TrueKeyword -> True
 if FalseKeyword -> True
 if _ -> False

is-app-start : TokenKind -> Boolean
is-app-start (k) = when k
 if Identifier -> True
 if TypeIdentifier -> True
 if IntegerLiteral -> True
 if NumberLiteral -> True
 if TextLiteral -> True
 if CharLiteral -> True
 if TrueKeyword -> True
 if FalseKeyword -> True
 if LeftParen -> True
 if LeftBracket -> True
 if _ -> False

is-compound : Expr -> Boolean
is-compound (e) = when e
 if MatchExpr (s) (arms) -> True
 if IfExpr (c) (t) (el) -> True
 if LetExpr (binds) (body) -> True
 if DoExpr (stmts) -> True
 if _ -> False

is-type-arg-start : TokenKind -> Boolean
is-type-arg-start (k) = when k
 if TypeIdentifier -> True
 if Identifier -> True
 if LeftParen -> True
 if _ -> False

operator-precedence : TokenKind -> Integer
operator-precedence (k) = when k
 if PlusPlus -> 5
 if ColonColon -> 5
 if Plus -> 6
 if Minus -> 6
 if Star -> 7
 if Slash -> 7
 if Caret -> 8
 if DoubleEquals -> 4
 if NotEquals -> 4
 if LessThan -> 4
 if GreaterThan -> 4
 if LessOrEqual -> 4
 if GreaterOrEqual -> 4
 if TripleEquals -> 4
 if Ampersand -> 3
 if Pipe -> 2
 if _ -> 0 - 1

is-right-assoc : TokenKind -> Boolean
is-right-assoc (k) = when k
 if PlusPlus -> True
 if ColonColon -> True
 if Caret -> True
 if Arrow -> True
 if _ -> False


skip-newlines-pos : List Token -> Integer -> Integer -> Integer
skip-newlines-pos (tokens) (pos) (len) =
 if pos >= len - 1
  then pos
  else let kind = (list-at tokens pos).kind
  in when kind
   if Newline -> skip-newlines-pos tokens (pos + 1) len
   if Indent -> skip-newlines-pos tokens (pos + 1) len
   if Dedent -> skip-newlines-pos tokens (pos + 1) len
   if _ -> pos

skip-newlines : ParseState -> ParseState
skip-newlines (st) =
 let end-pos = skip-newlines-pos (st.tokens) (st.pos) (list-length (st.tokens))
 in if end-pos == st.pos
  then st
  else ParseState { tokens = st.tokens, pos = end-pos }

parse-expr : ParseState -> ParseExprResult
parse-expr (st) =
 parse-binary st 0

unwrap-expr-ok : ParseExprResult -> (Expr -> ParseState -> ParseExprResult) -> ParseExprResult
unwrap-expr-ok (r) (f) = when r
 if ExprOk (e) (st) -> f e st

parse-binary : ParseState -> Integer -> ParseExprResult
parse-binary (st) (min-prec) =
 let left-result = parse-unary st
 in unwrap-expr-ok left-result (start-binary-loop min-prec)

start-binary-loop : Integer -> Expr -> ParseState -> ParseExprResult
start-binary-loop (min-prec) (left) (st) =
 parse-binary-loop left st min-prec

parse-binary-loop : Expr -> ParseState -> Integer -> ParseExprResult
parse-binary-loop (left) (st) (min-prec) =
 if is-done st
  then ExprOk left st
  else let prec = operator-precedence (current-kind st)
  in if prec < min-prec
   then ExprOk left st
   else let op = current st
   in let st2 = skip-newlines (advance st)
   in let next-min = if is-right-assoc (op.kind)
     then prec
     else prec + 1
   in let right-result = parse-binary st2 next-min
   in unwrap-expr-ok right-result (continue-binary left op min-prec)

continue-binary : Expr -> Token -> Integer -> Expr -> ParseState -> ParseExprResult
continue-binary (left) (op) (min-prec) (right) (st) =
 parse-binary-loop (BinExpr left op right) st min-prec

parse-unary : ParseState -> ParseExprResult
parse-unary (st) =
 if is-minus (current-kind st)
  then let op = current st
  in let result = parse-unary (advance st)
  in unwrap-expr-ok result (finish-unary op)
  else parse-application st

finish-unary : Token -> Expr -> ParseState -> ParseExprResult
finish-unary (op) (operand) (st) =
 ExprOk (UnaryExpr op operand) st

parse-application : ParseState -> ParseExprResult
parse-application (st) =
 let func-result = parse-atom st
 in unwrap-expr-ok func-result parse-app-loop

parse-app-loop : Expr -> ParseState -> ParseExprResult
parse-app-loop (func) (st) =
 if is-compound func
  then parse-dot-only func st
  else if is-done st
   then ExprOk func st
   else if is-app-start (current-kind st)
    then let arg-result = parse-atom st
    in unwrap-expr-ok arg-result (continue-app func)
    else parse-field-access func st

continue-app : Expr -> Expr -> ParseState -> ParseExprResult
continue-app (func) (arg) (st) =
 parse-app-loop (AppExpr func arg) st

parse-atom : ParseState -> ParseExprResult
parse-atom (st) =
 if is-literal (current-kind st)
  then ExprOk (LitExpr (current st)) (advance st)
  else if is-ident (current-kind st)
   then parse-field-access (NameExpr (current st)) (advance st)
   else if is-type-ident (current-kind st)
    then parse-atom-type-ident st
    else if is-left-paren (current-kind st)
     then parse-paren-expr (advance st)
     else if is-left-bracket (current-kind st)
      then parse-list-expr st
      else if is-if-keyword (current-kind st)
       then parse-if-expr st
       else if is-let-keyword (current-kind st)
        then parse-let-expr st
        else if is-when-keyword (current-kind st)
         then parse-match-expr st
         else if is-do-keyword (current-kind st)
          then parse-do-expr st
          else if is-with-keyword (current-kind st)
           then parse-handle-expr st
           else if is-backslash (current-kind st)
            then parse-lambda-expr st
            else ExprOk (ErrExpr (current st)) (advance st)

parse-field-access : Expr -> ParseState -> ParseExprResult
parse-field-access (node) (st) =
 if is-dot (current-kind st)
  then let st2 = advance st
  in let field = current st2
  in let st3 = advance st2
  in parse-field-access (FieldExpr node field) st3
  else ExprOk node st

parse-dot-only : Expr -> ParseState -> ParseExprResult
parse-dot-only (node) (st) =
 if is-dot (current-kind st)
  then let st2 = advance st
  in let field = current st2
  in let st3 = advance st2
  in parse-dot-only (FieldExpr node field) st3
  else ExprOk node st

parse-atom-type-ident : ParseState -> ParseExprResult
parse-atom-type-ident (st) =
 let tok = current st
 in let st2 = advance st
 in if is-left-brace (current-kind st2)
  then parse-record-expr tok st2
  else ExprOk (NameExpr tok) st2

parse-paren-expr : ParseState -> ParseExprResult
parse-paren-expr (st) =
 let st2 = skip-newlines st
 in let inner = parse-expr st2
 in unwrap-expr-ok inner finish-paren-expr

finish-paren-expr : Expr -> ParseState -> ParseExprResult
finish-paren-expr (e) (st) =
 let st2 = skip-newlines st
 in let st3 = expect RightParen st2
 in ExprOk (ParenExpr e) st3

parse-record-expr : Token -> ParseState -> ParseExprResult
parse-record-expr (type-name) (st) =
 let st2 = advance st
 in let st3 = skip-newlines st2
 in parse-record-expr-fields type-name [] st3

parse-record-expr-fields : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
parse-record-expr-fields (type-name) (acc) (st) =
 if is-right-brace (current-kind st)
  then ExprOk (RecordExpr type-name acc) (advance st)
  else if is-ident (current-kind st)
   then parse-record-field type-name acc st
   else ExprOk (RecordExpr type-name acc) st

parse-record-field : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
parse-record-field (type-name) (acc) (st) =
 let field-name = current st
 in let st2 = advance st
 in let st3 = expect Equals st2
 in let val-result = parse-expr st3
 in unwrap-expr-ok val-result (finish-record-field type-name acc field-name)

finish-record-field : Token -> List RecordFieldExpr -> Token -> Expr -> ParseState -> ParseExprResult
finish-record-field (type-name) (acc) (field-name) (v) (st) =
 let field = RecordFieldExpr { name = field-name, value = v }
 in let st2 = skip-newlines st
 in if is-comma (current-kind st2)
  then parse-record-expr-fields type-name (list-snoc acc field) (skip-newlines (advance st2))
  else parse-record-expr-fields type-name (list-snoc acc field) st2

parse-list-expr : ParseState -> ParseExprResult
parse-list-expr (st) =
 let st2 = advance st
 in let st3 = skip-newlines st2
 in parse-list-elements [] st3

parse-list-elements : List Expr -> ParseState -> ParseExprResult
parse-list-elements (acc) (st) =
 if is-right-bracket (current-kind st)
  then ExprOk (ListExpr acc) (advance st)
  else let elem = parse-expr st
  in unwrap-expr-ok elem (finish-list-element acc)

finish-list-element : List Expr -> Expr -> ParseState -> ParseExprResult
finish-list-element (acc) (e) (st) =
 let st2 = skip-newlines st
 in if is-comma (current-kind st2)
  then parse-list-elements (list-snoc acc e) (skip-newlines (advance st2))
  else parse-list-elements (list-snoc acc e) st2

parse-if-expr : ParseState -> ParseExprResult
parse-if-expr (st) =
 let st2 = skip-newlines (advance st)
 in let cond = parse-expr st2
 in unwrap-expr-ok cond parse-if-then

parse-if-then : Expr -> ParseState -> ParseExprResult
parse-if-then (c) (st) =
 let st2 = skip-newlines st
 in let st3 = expect ThenKeyword st2
 in let st4 = skip-newlines st3
 in let then-result = parse-expr st4
 in unwrap-expr-ok then-result (parse-if-else c)

parse-if-else : Expr -> Expr -> ParseState -> ParseExprResult
parse-if-else (c) (t) (st) =
 let st2 = skip-newlines st
 in let st3 = expect ElseKeyword st2
 in let st4 = skip-newlines st3
 in let else-result = parse-expr st4
 in unwrap-expr-ok else-result (finish-if c t)

finish-if : Expr -> Expr -> Expr -> ParseState -> ParseExprResult
finish-if (c) (t) (e) (st) =
 ExprOk (IfExpr c t e) st

parse-let-expr : ParseState -> ParseExprResult
parse-let-expr (st) =
 let st2 = skip-newlines (advance st)
 in parse-let-bindings [] st2

parse-let-bindings : List LetBind -> ParseState -> ParseExprResult
parse-let-bindings (acc) (st) =
 if is-ident (current-kind st)
  then parse-let-binding acc st
  else if is-in-keyword (current-kind st)
   then let st2 = skip-newlines (advance st)
   in let body = parse-expr st2
   in unwrap-expr-ok body (finish-let acc)
   else let body = parse-expr st
   in unwrap-expr-ok body (finish-let acc)

finish-let : List LetBind -> Expr -> ParseState -> ParseExprResult
finish-let (acc) (b) (st) =
 ExprOk (LetExpr acc b) st

parse-let-binding : List LetBind -> ParseState -> ParseExprResult
parse-let-binding (acc) (st) =
 let name-tok = current st
 in let st2 = advance st
 in let st3 = expect Equals st2
 in let val-result = parse-expr st3
 in unwrap-expr-ok val-result (finish-let-binding acc name-tok)

finish-let-binding : List LetBind -> Token -> Expr -> ParseState -> ParseExprResult
finish-let-binding (acc) (name-tok) (v) (st) =
 let binding = LetBind { name = name-tok, value = v }
 in let st2 = skip-newlines st
 in if is-comma (current-kind st2)
  then parse-let-bindings (list-snoc acc binding) (skip-newlines (advance st2))
  else parse-let-bindings (list-snoc acc binding) st2

parse-match-expr : ParseState -> ParseExprResult
parse-match-expr (st) =
 let st2 = advance st
 in let scrut = parse-expr st2
 in unwrap-expr-ok scrut start-match-branches

start-match-branches : Expr -> ParseState -> ParseExprResult
start-match-branches (s) (st) =
 let st2 = skip-newlines st
 in let tok = current st2
 in parse-match-branches s [] (tok.column) (tok.line) st2

parse-match-branches : Expr -> List MatchArm -> Integer -> Integer -> ParseState -> ParseExprResult
parse-match-branches (scrut) (acc) (col) (ln) (st) =
 if is-if-keyword (current-kind st)
  then let tok = current st
  in if tok.line == ln
   then parse-one-match-branch scrut acc col ln st
   else if tok.column == col
    then parse-one-match-branch scrut acc col ln st
    else ExprOk (MatchExpr scrut acc) st
  else ExprOk (MatchExpr scrut acc) st

unwrap-pat-for-expr : ParsePatResult -> (Pat -> ParseState -> ParseExprResult) -> ParseExprResult
unwrap-pat-for-expr (r) (f) = when r
 if PatOk (p) (st) -> f p st

parse-one-match-branch : Expr -> List MatchArm -> Integer -> Integer -> ParseState -> ParseExprResult
parse-one-match-branch (scrut) (acc) (col) (ln) (st) =
 let st2 = advance st
 in let pat = parse-pattern st2
 in unwrap-pat-for-expr pat (parse-match-branch-body scrut acc col ln)

parse-match-branch-body : Expr -> List MatchArm -> Integer -> Integer -> Pat -> ParseState -> ParseExprResult
parse-match-branch-body (scrut) (acc) (col) (ln) (p) (st) =
 let st2 = expect Arrow st
 in let st3 = skip-newlines st2
 in let body = parse-expr st3
 in unwrap-expr-ok body (finish-match-branch scrut acc col ln p)

finish-match-branch : Expr -> List MatchArm -> Integer -> Integer -> Pat -> Expr -> ParseState -> ParseExprResult
finish-match-branch (scrut) (acc) (col) (ln) (p) (b) (st) =
 let arm = MatchArm { pattern = p, body = b }
 in let st2 = skip-newlines st
 in parse-match-branches scrut (list-snoc acc arm) col ln st2

parse-do-expr : ParseState -> ParseExprResult
parse-do-expr (st) =
 let st2 = skip-newlines (advance st)
 in parse-do-stmts [] st2

parse-do-stmts : List DoStmt -> ParseState -> ParseExprResult
parse-do-stmts (acc) (st) =
 if is-done st
  then ExprOk (DoExpr acc) st
  else if is-dedent (current-kind st)
   then ExprOk (DoExpr acc) st
   else if looks-like-top-level-def st
    then ExprOk (DoExpr acc) st
    else if is-do-bind st
     then parse-do-bind-stmt acc st
     else parse-do-expr-stmt acc st

looks-like-top-level-def : ParseState -> Boolean
looks-like-top-level-def (st) =
 if is-ident (current-kind st) | is-type-ident (current-kind st)
  then is-colon (peek-kind st 1)
  else False

is-do-bind : ParseState -> Boolean
is-do-bind (st) =
 if is-ident (current-kind st)
  then is-left-arrow (peek-kind st 1)
  else False

parse-do-bind-stmt : List DoStmt -> ParseState -> ParseExprResult
parse-do-bind-stmt (acc) (st) =
 let name-tok = current st
 in let st2 = advance (advance st)
 in let val-result = parse-expr st2
 in unwrap-expr-ok val-result (finish-do-bind acc name-tok)

finish-do-bind : List DoStmt -> Token -> Expr -> ParseState -> ParseExprResult
finish-do-bind (acc) (name-tok) (v) (st) =
 let st2 = skip-newlines st
 in parse-do-stmts (list-snoc acc (DoBindStmt name-tok v)) st2

parse-do-expr-stmt : List DoStmt -> ParseState -> ParseExprResult
parse-do-expr-stmt (acc) (st) =
 let expr-result = parse-expr st
 in unwrap-expr-ok expr-result (finish-do-expr acc)

finish-do-expr : List DoStmt -> Expr -> ParseState -> ParseExprResult
finish-do-expr (acc) (e) (st) =
 let st2 = skip-newlines st
 in parse-do-stmts (list-snoc acc (DoExprStmt e)) st2

parse-handle-expr : ParseState -> ParseExprResult
parse-handle-expr (st) =
 let st1 = advance st
 in let eff-tok = current st1
 in let st2 = advance st1
 in let body-result = parse-expr st2
 in unwrap-expr-ok body-result (finish-handle-body eff-tok)

finish-handle-body : Token -> Expr -> ParseState -> ParseExprResult
finish-handle-body (eff-tok) (body) (st) =
 let st2 = skip-newlines st
 in let clauses = parse-handle-clauses st2 []
 in ExprOk (HandleExpr eff-tok body (clauses.clauses)) (clauses.state)

parse-handle-clauses : ParseState -> List HandleClause -> HandleParseResult
parse-handle-clauses (st) (acc) =
 if is-ident (current-kind st)
  then let op-tok = current st
  in let st1 = advance st
  in let params = parse-handle-params st1 []
  in if list-length (params.toks) > 0
   then let resume-tok = list-at (params.toks) (list-length (params.toks) - 1)
   in let st5 = expect Equals (params.state)
   in let st6 = skip-newlines st5
   in let body-result = parse-expr st6
   in unwrap-handle-clause-body op-tok resume-tok body-result acc
   else HandleParseResult { clauses = acc, state = st }
  else HandleParseResult { clauses = acc, state = st }

parse-handle-params : ParseState -> List Token -> HandleParamsResult
parse-handle-params (st) (acc) =
 if is-left-paren (current-kind st)
  then let st1 = advance st
  in let tok = current st1
  in let st2 = advance st1
  in let st3 = expect RightParen st2
  in parse-handle-params st3 (list-snoc acc tok)
  else HandleParamsResult { toks = acc, state = st }

unwrap-handle-clause-body : Token -> Token -> ParseExprResult -> List HandleClause -> HandleParseResult
unwrap-handle-clause-body (op-tok) (resume-tok) (result) (acc) = when result
 if ExprOk (body) (st) -> let clause = HandleClause { op-name = op-tok, resume-name = resume-tok, body = body }
 in let st2 = skip-newlines st
 in parse-handle-clauses st2 (list-snoc acc clause)

parse-lambda-expr : ParseState -> ParseExprResult
parse-lambda-expr (st) =
 let st2 = advance st
 in let params-result = collect-lambda-params st2 []
 in let st3 = expect Arrow (params-result.state)
 in let st4 = skip-newlines st3
 in let body = parse-expr st4
 in unwrap-expr-ok body (finish-lambda (params-result.toks))

collect-lambda-params : ParseState -> List Token -> LambdaParamsResult
collect-lambda-params (st) (acc) =
 if is-ident (current-kind st)
  then let tok = current st
  in collect-lambda-params (advance st) (list-snoc acc tok)
  else LambdaParamsResult { toks = acc, state = st }

finish-lambda : List Token -> Expr -> ParseState -> ParseExprResult
finish-lambda (params) (body) (st) =
 ExprOk (LambdaExpr params body) st


resolve-type-expr : List TypeBinding -> ATypeExpr -> CodexType
resolve-type-expr (tdm) (texpr) = when texpr
 if ANamedType (name) -> resolve-type-name tdm (name.value)
 if AFunType (param) (ret) -> FunTy (resolve-type-expr tdm param) (resolve-type-expr tdm ret)
 if AAppType (ctor) (args) -> resolve-applied-type tdm ctor args
 if AEffectType (effs) (ret) -> resolve-type-expr tdm ret

resolve-applied-type : List TypeBinding -> ATypeExpr -> List ATypeExpr -> CodexType
resolve-applied-type (tdm) (ctor) (args) = when ctor
 if ANamedType (name) -> if name.value == "List"
  then if list-length args == 1
   then ListTy (resolve-type-expr tdm (list-at args 0))
   else ListTy ErrorTy
  else ConstructedTy name (resolve-type-expr-list tdm args 0 (list-length args) [])
 if _ -> resolve-type-expr tdm ctor

resolve-type-expr-list : List TypeBinding -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List CodexType
resolve-type-expr-list (tdm) (args) (i) (len) (acc) =
 if i == len
  then acc
  else resolve-type-expr-list tdm args (i + 1) len (list-snoc acc (resolve-type-expr tdm (list-at args i)))

resolve-type-name : List TypeBinding -> Text -> CodexType
resolve-type-name (tdm) (name) =
 if name == "Integer"
  then IntegerTy
  else if name == "Number"
   then NumberTy
   else if name == "Text"
    then TextTy
    else if name == "Boolean"
     then BooleanTy
     else if name == "Char"
      then CharTy
      else if name == "Nothing"
       then NothingTy
       else lookup-type-def tdm name

lookup-type-def : List TypeBinding -> Text -> CodexType
lookup-type-def (tdm) (name) =
 let len = list-length tdm
 in if len == 0
  then ConstructedTy Name { value = name } []
  else let pos = bsearch-text-pos tdm name 0 len
  in if pos >= len
   then ConstructedTy Name { value = name } []
   else let b = list-at tdm pos
   in if b.name == name
    then b.bound-type
    else ConstructedTy Name { value = name } []

is-value-name : Text -> Boolean
is-value-name (name) =
 if text-length name == 0
  then False
  else let code = char-code (char-at name 0)
  in code >= char-code 'e' & code <= char-code 'z'

parameterize-type : UnificationState -> CodexType -> ParamResult
parameterize-type (st) (ty) =
 let r = parameterize-walk st [] ty
 in let wrapped = wrap-forall-from-entries (r.walked) (r.entries) 0 (list-length (r.entries))
 in ParamResult { parameterized = wrapped, entries = r.entries, state = r.state }

wrap-forall-from-entries : CodexType -> List ParamEntry -> Integer -> Integer -> CodexType
wrap-forall-from-entries (ty) (entries) (i) (len) =
 if i == len
  then ty
  else let e = list-at entries i
  in ForAllTy (e.var-id) (wrap-forall-from-entries ty entries (i + 1) len)

parameterize-walk : UnificationState -> List ParamEntry -> CodexType -> WalkResult
parameterize-walk (st) (entries) (ty) = when ty
 if ConstructedTy (name) (args) -> if list-length args == 0 & is-value-name (name.value)
  then let looked = find-param-entry entries (name.value) 0 (list-length entries)
  in if looked >= 0
   then WalkResult { walked = TypeVar looked, entries = entries, state = st }
   else let fr = fresh-and-advance st
   in when fr.var-type
    if TypeVar (new-id) -> let new-entry = ParamEntry { param-name = name.value, var-id = new-id }
    in WalkResult { walked = fr.var-type, entries = entries ++ [new-entry], state = fr.state }
    if _ -> WalkResult { walked = ty, entries = entries, state = fr.state }
  else let args-r = parameterize-walk-list st entries args 0 (list-length args) []
  in WalkResult { walked = ConstructedTy name (args-r.walked-list), entries = args-r.entries, state = args-r.state }
 if FunTy (param) (ret) -> let pr = parameterize-walk st entries param
 in let rr = parameterize-walk (pr.state) (pr.entries) ret
 in WalkResult { walked = FunTy (pr.walked) (rr.walked), entries = rr.entries, state = rr.state }
 if ListTy (elem) -> let er = parameterize-walk st entries elem
 in WalkResult { walked = ListTy (er.walked), entries = er.entries, state = er.state }
 if ForAllTy (id) (body) -> let br = parameterize-walk st entries body
 in WalkResult { walked = ForAllTy id (br.walked), entries = br.entries, state = br.state }
 if _ -> WalkResult { walked = ty, entries = entries, state = st }

find-param-entry : List ParamEntry -> Text -> Integer -> Integer -> Integer
find-param-entry (entries) (name) (i) (len) =
 if i == len
  then 0 - 1
  else let e = list-at entries i
  in if e.param-name == name
   then e.var-id
   else find-param-entry entries name (i + 1) len

parameterize-walk-list : UnificationState -> List ParamEntry -> List CodexType -> Integer -> Integer -> List CodexType -> WalkListResult
parameterize-walk-list (st) (entries) (args) (i) (len) (acc) =
 if i == len
  then WalkListResult { walked-list = acc, entries = entries, state = st }
  else let r = parameterize-walk st entries (list-at args i)
  in parameterize-walk-list (r.state) (r.entries) args (i + 1) len (list-snoc acc (r.walked))

check-def : UnificationState -> TypeEnv -> ADef -> CheckResult
check-def (st) (env) (def) =
 let declared = resolve-declared-type st env def
 in let env2 = bind-def-params (declared.state) (declared.env) (def.params) (declared.expected-type) 0 (list-length (def.params))
 in let body-r = infer-expr (env2.state) (env2.env) (def.body)
 in let u = unify (body-r.state) (env2.remaining-type) (body-r.inferred-type)
 in CheckResult { inferred-type = declared.expected-type, state = u.state }

resolve-declared-type : UnificationState -> TypeEnv -> ADef -> DefSetup
resolve-declared-type (st) (env) (def) =
 if list-length (def.declared-type) == 0
  then let fr = fresh-and-advance st
  in DefSetup { expected-type = fr.var-type, remaining-type = fr.var-type, state = fr.state, env = env }
  else let env-type = env-lookup env (def.name.value)
  in let inst = instantiate-type st env-type
  in DefSetup { expected-type = inst.var-type, remaining-type = inst.var-type, state = inst.state, env = env }

bind-def-params : UnificationState -> TypeEnv -> List AParam -> CodexType -> Integer -> Integer -> DefParamResult
bind-def-params (st) (env) (params) (remaining) (i) (len) =
 if i == len
  then DefParamResult { state = st, env = env, remaining-type = remaining }
  else let p = list-at params i
  in when remaining
   if FunTy (param-ty) (ret-ty) -> let env2 = env-bind env (p.name.value) param-ty
   in bind-def-params st env2 params ret-ty (i + 1) len
   if _ -> let fr = fresh-and-advance st
   in let env2 = env-bind env (p.name.value) (fr.var-type)
   in bind-def-params (fr.state) env2 params remaining (i + 1) len

check-module : AModule -> ModuleResult
check-module (mod) =
 let tdm = build-type-def-map (mod.type-defs) 0 (list-length (mod.type-defs)) []
 in let tenv = register-type-defs empty-unification-state builtin-type-env tdm (mod.type-defs) 0 (list-length (mod.type-defs))
 in let env = register-all-defs (tenv.state) (tenv.env) tdm (mod.defs) 0 (list-length (mod.defs))
 in check-all-defs (env.state) (env.env) (mod.defs) 0 (list-length (mod.defs)) []

register-all-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ADef -> Integer -> Integer -> LetBindResult
register-all-defs (st) (env) (tdm) (defs) (i) (len) =
 if i == len
  then LetBindResult { state = st, env = env }
  else let def = list-at defs i
  in let ty = if list-length (def.declared-type) == 0
    then let fr = fresh-and-advance st
    in let env2 = env-bind env (def.name.value) (fr.var-type)
    in LetBindResult { state = fr.state, env = env2 }
    else let resolved = resolve-type-expr tdm (list-at (def.declared-type) 0)
    in let pr = parameterize-type st resolved
    in LetBindResult { state = pr.state, env = env-bind env (def.name.value) (pr.parameterized) }
  in register-all-defs (ty.state) (ty.env) tdm defs (i + 1) len

check-all-defs : UnificationState -> TypeEnv -> List ADef -> Integer -> Integer -> List TypeBinding -> ModuleResult
check-all-defs (st) (env) (defs) (i) (len) (acc) =
 if i == len
  then ModuleResult { types = acc, state = st }
  else let def = list-at defs i
  in let r = check-def st env def
  in let resolved = deep-resolve (r.state) (r.inferred-type)
  in let entry = TypeBinding { name = def.name.value, bound-type = resolved }
  in check-all-defs (r.state) env defs (i + 1) len (list-snoc acc entry)

build-type-def-map : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
build-type-def-map (tdefs) (i) (len) (acc) =
 if i == len
  then acc
  else let td = list-at tdefs i
  in let entry = when td
    if AVariantTypeDef (name) (type-params) (ctors) -> let sum-ctors = build-sum-ctors tdefs ctors 0 (list-length ctors) [] acc
    in TypeBinding { name = name.value, bound-type = SumTy name sum-ctors }
    if ARecordTypeDef (name) (type-params) (fields) -> let rec-fields = build-record-fields-for-map tdefs fields 0 (list-length fields) [] acc
    in TypeBinding { name = name.value, bound-type = RecordTy name rec-fields }
  in build-type-def-map tdefs (i + 1) len (list-insert-at acc (bsearch-text-pos acc (entry.name) 0 (list-length acc)) entry)

build-sum-ctors : List ATypeDef -> List AVariantCtorDef -> Integer -> Integer -> List SumCtor -> List TypeBinding -> List SumCtor
build-sum-ctors (tdefs) (ctors) (i) (len) (acc) (partial-tdm) =
 if i == len
  then acc
  else let c = list-at ctors i
  in let field-types = resolve-type-expr-list-for-map tdefs (c.fields) 0 (list-length (c.fields)) [] partial-tdm
  in let sc = SumCtor { name = c.name, fields = field-types }
  in build-sum-ctors tdefs ctors (i + 1) len (list-snoc acc sc) partial-tdm

build-record-fields-for-map : List ATypeDef -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List TypeBinding -> List RecordField
build-record-fields-for-map (tdefs) (fields) (i) (len) (acc) (partial-tdm) =
 if i == len
  then acc
  else let f = list-at fields i
  in let rfield = RecordField { name = f.name, type-val = resolve-type-expr partial-tdm (f.type-expr) }
  in build-record-fields-for-map tdefs fields (i + 1) len (list-snoc acc rfield) partial-tdm

resolve-type-expr-list-for-map : List ATypeDef -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List TypeBinding -> List CodexType
resolve-type-expr-list-for-map (tdefs) (args) (i) (len) (acc) (partial-tdm) =
 if i == len
  then acc
  else resolve-type-expr-list-for-map tdefs args (i + 1) len (list-snoc acc (resolve-type-expr partial-tdm (list-at args i))) partial-tdm

register-type-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ATypeDef -> Integer -> Integer -> LetBindResult
register-type-defs (st) (env) (tdm) (tdefs) (i) (len) =
 if i == len
  then LetBindResult { state = st, env = env }
  else let td = list-at tdefs i
  in let r = register-one-type-def st env tdm td
  in register-type-defs (r.state) (r.env) tdm tdefs (i + 1) len

register-one-type-def : UnificationState -> TypeEnv -> List TypeBinding -> ATypeDef -> LetBindResult
register-one-type-def (st) (env) (tdm) (td) = when td
 if AVariantTypeDef (name) (type-params) (ctors) -> let result-ty = lookup-type-def tdm (name.value)
 in register-variant-ctors st env tdm ctors result-ty 0 (list-length ctors)
 if ARecordTypeDef (name) (type-params) (fields) -> let resolved-fields = build-record-fields tdm fields 0 (list-length fields) []
 in let result-ty = RecordTy name resolved-fields
 in let ctor-ty = build-record-ctor-type tdm fields result-ty 0 (list-length fields)
 in LetBindResult { state = st, env = env-bind env (name.value) ctor-ty }

build-record-fields : List TypeBinding -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
build-record-fields (tdm) (fields) (i) (len) (acc) =
 if i == len
  then acc
  else let f = list-at fields i
  in let rfield = RecordField { name = f.name, type-val = resolve-type-expr tdm (f.type-expr) }
  in build-record-fields tdm fields (i + 1) len (list-snoc acc rfield)

lookup-record-field : List RecordField -> Text -> CodexType
lookup-record-field (fields) (name) =
 if list-length fields == 0
  then ErrorTy
  else let f = list-at fields 0
  in if f.name.value == name
   then f.type-val
   else lookup-record-field-loop fields name 1 (list-length fields)

lookup-record-field-loop : List RecordField -> Text -> Integer -> Integer -> CodexType
lookup-record-field-loop (fields) (name) (i) (len) =
 if i == len
  then ErrorTy
  else let f = list-at fields i
  in if f.name.value == name
   then f.type-val
   else lookup-record-field-loop fields name (i + 1) len

register-variant-ctors : UnificationState -> TypeEnv -> List TypeBinding -> List AVariantCtorDef -> CodexType -> Integer -> Integer -> LetBindResult
register-variant-ctors (st) (env) (tdm) (ctors) (result-ty) (i) (len) =
 if i == len
  then LetBindResult { state = st, env = env }
  else let ctor = list-at ctors i
  in let ctor-ty = build-ctor-type tdm (ctor.fields) result-ty 0 (list-length (ctor.fields))
  in let env2 = env-bind env (ctor.name.value) ctor-ty
  in register-variant-ctors st env2 tdm ctors result-ty (i + 1) len

build-ctor-type : List TypeBinding -> List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
build-ctor-type (tdm) (fields) (result) (i) (len) =
 if i == len
  then result
  else let rest = build-ctor-type tdm fields result (i + 1) len
  in FunTy (resolve-type-expr tdm (list-at fields i)) rest

build-record-ctor-type : List TypeBinding -> List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
build-record-ctor-type (tdm) (fields) (result) (i) (len) =
 if i == len
  then result
  else let f = list-at fields i
  in let rest = build-record-ctor-type tdm fields result (i + 1) len
  in FunTy (resolve-type-expr tdm (f.type-expr)) rest

infer-literal : UnificationState -> LiteralKind -> CheckResult
infer-literal (st) (kind) = when kind
 if IntLit -> CheckResult { inferred-type = IntegerTy, state = st }
 if NumLit -> CheckResult { inferred-type = NumberTy, state = st }
 if TextLit -> CheckResult { inferred-type = TextTy, state = st }
 if CharLit -> CheckResult { inferred-type = CharTy, state = st }
 if BoolLit -> CheckResult { inferred-type = BooleanTy, state = st }

infer-name : UnificationState -> TypeEnv -> Text -> CheckResult
infer-name (st) (env) (name) =
 if env-has env name
  then let raw = env-lookup env name
  in let inst = instantiate-type st raw
  in CheckResult { inferred-type = inst.var-type, state = inst.state }
  else CheckResult { inferred-type = ErrorTy, state = add-unify-error st "CDX2002" ("Unknown name: " ++ name) }

instantiate-type : UnificationState -> CodexType -> FreshResult
instantiate-type (st) (ty) = when ty
 if ForAllTy (var-id) (body) -> let fr = fresh-and-advance st
 in let substituted = subst-type-var body var-id (fr.var-type)
 in instantiate-type (fr.state) substituted
 if _ -> FreshResult { var-type = ty, state = st }

subst-type-var : CodexType -> Integer -> CodexType -> CodexType
subst-type-var (ty) (var-id) (replacement) = when ty
 if TypeVar (id) -> if id == var-id then replacement else ty
 if FunTy (param) (ret) -> FunTy (subst-type-var param var-id replacement) (subst-type-var ret var-id replacement)
 if ListTy (elem) -> ListTy (subst-type-var elem var-id replacement)
 if ForAllTy (inner-id) (body) -> if inner-id == var-id
  then ty
  else ForAllTy inner-id (subst-type-var body var-id replacement)
 if ConstructedTy (name) (args) -> ConstructedTy name (map-subst-type-var args var-id replacement 0 (list-length args) [])
 if SumTy (name) (ctors) -> ty
 if RecordTy (name) (fields) -> ty
 if _ -> ty

map-subst-type-var : List CodexType -> Integer -> CodexType -> Integer -> Integer -> List CodexType -> List CodexType
map-subst-type-var (args) (var-id) (replacement) (i) (len) (acc) =
 if i == len
  then acc
  else map-subst-type-var args var-id replacement (i + 1) len (list-snoc acc (subst-type-var (list-at args i) var-id replacement))

infer-binary : UnificationState -> TypeEnv -> AExpr -> BinaryOp -> AExpr -> CheckResult
infer-binary (st) (env) (left) (op) (right) =
 let lr = infer-expr st env left
 in let rr = infer-expr (lr.state) env right
 in infer-binary-op (rr.state) (lr.inferred-type) (rr.inferred-type) op

infer-binary-op : UnificationState -> CodexType -> CodexType -> BinaryOp -> CheckResult
infer-binary-op (st) (lt) (rt) (op) = when op
 if OpAdd -> infer-arithmetic st lt rt
 if OpSub -> infer-arithmetic st lt rt
 if OpMul -> infer-arithmetic st lt rt
 if OpDiv -> infer-arithmetic st lt rt
 if OpPow -> infer-arithmetic st lt rt
 if OpEq -> infer-comparison st lt rt
 if OpNotEq -> infer-comparison st lt rt
 if OpLt -> infer-comparison st lt rt
 if OpGt -> infer-comparison st lt rt
 if OpLtEq -> infer-comparison st lt rt
 if OpGtEq -> infer-comparison st lt rt
 if OpAnd -> infer-logical st lt rt
 if OpOr -> infer-logical st lt rt
 if OpAppend -> infer-append st lt rt
 if OpCons -> infer-cons st lt rt
 if OpDefEq -> infer-comparison st lt rt

infer-arithmetic : UnificationState -> CodexType -> CodexType -> CheckResult
infer-arithmetic (st) (lt) (rt) =
 let r = unify st lt rt
 in CheckResult { inferred-type = lt, state = r.state }

infer-comparison : UnificationState -> CodexType -> CodexType -> CheckResult
infer-comparison (st) (lt) (rt) =
 let r = unify st lt rt
 in CheckResult { inferred-type = BooleanTy, state = r.state }

infer-logical : UnificationState -> CodexType -> CodexType -> CheckResult
infer-logical (st) (lt) (rt) =
 let r1 = unify st lt BooleanTy
 in let r2 = unify (r1.state) rt BooleanTy
 in CheckResult { inferred-type = BooleanTy, state = r2.state }

infer-append : UnificationState -> CodexType -> CodexType -> CheckResult
infer-append (st) (lt) (rt) =
 let resolved = resolve st lt
 in when resolved
  if TextTy -> let r = unify st rt TextTy
  in CheckResult { inferred-type = TextTy, state = r.state }
  if _ -> let r = unify st lt rt
  in CheckResult { inferred-type = lt, state = r.state }

infer-cons : UnificationState -> CodexType -> CodexType -> CheckResult
infer-cons (st) (lt) (rt) =
 let list-ty = ListTy lt
 in let r = unify st rt list-ty
 in CheckResult { inferred-type = list-ty, state = r.state }

infer-if : UnificationState -> TypeEnv -> AExpr -> AExpr -> AExpr -> CheckResult
infer-if (st) (env) (cond) (then-e) (else-e) =
 let cr = infer-expr st env cond
 in let r1 = unify (cr.state) (cr.inferred-type) BooleanTy
 in let tr = infer-expr (r1.state) env then-e
 in let er = infer-expr (tr.state) env else-e
 in let r2 = unify (er.state) (tr.inferred-type) (er.inferred-type)
 in CheckResult { inferred-type = tr.inferred-type, state = r2.state }

infer-let : UnificationState -> TypeEnv -> List ALetBind -> AExpr -> CheckResult
infer-let (st) (env) (bindings) (body) =
 let env2 = infer-let-bindings st env bindings 0 (list-length bindings)
 in infer-expr (env2.state) (env2.env) body

infer-let-bindings : UnificationState -> TypeEnv -> List ALetBind -> Integer -> Integer -> LetBindResult
infer-let-bindings (st) (env) (bindings) (i) (len) =
 if i == len
  then LetBindResult { state = st, env = env }
  else let b = list-at bindings i
  in let vr = infer-expr st env (b.value)
  in let env2 = env-bind env (b.name.value) (vr.inferred-type)
  in infer-let-bindings (vr.state) env2 bindings (i + 1) len

infer-lambda : UnificationState -> TypeEnv -> List Name -> AExpr -> CheckResult
infer-lambda (st) (env) (params) (body) =
 let pr = bind-lambda-params st env params 0 (list-length params) []
 in let br = infer-expr (pr.state) (pr.env) body
 in let fun-ty = wrap-fun-type (pr.param-types) (br.inferred-type)
 in CheckResult { inferred-type = fun-ty, state = br.state }

bind-lambda-params : UnificationState -> TypeEnv -> List Name -> Integer -> Integer -> List CodexType -> LambdaBindResult
bind-lambda-params (st) (env) (params) (i) (len) (acc) =
 if i == len
  then LambdaBindResult { state = st, env = env, param-types = acc }
  else let p = list-at params i
  in let fr = fresh-and-advance st
  in let env2 = env-bind env (p.value) (fr.var-type)
  in bind-lambda-params (fr.state) env2 params (i + 1) len (list-snoc acc (fr.var-type))

wrap-fun-type : List CodexType -> CodexType -> CodexType
wrap-fun-type (param-types) (result) =
 wrap-fun-type-loop param-types result (list-length param-types - 1)

wrap-fun-type-loop : List CodexType -> CodexType -> Integer -> CodexType
wrap-fun-type-loop (param-types) (result) (i) =
 if i < 0
  then result
  else wrap-fun-type-loop param-types (FunTy (list-at param-types i) result) (i - 1)

infer-application : UnificationState -> TypeEnv -> AExpr -> AExpr -> CheckResult
infer-application (st) (env) (func) (arg) =
 let fr = infer-expr st env func
 in let ar = infer-expr (fr.state) env arg
 in let ret = fresh-and-advance (ar.state)
 in let r = unify (ret.state) (fr.inferred-type) (FunTy (ar.inferred-type) (ret.var-type))
 in CheckResult { inferred-type = ret.var-type, state = r.state }

infer-list : UnificationState -> TypeEnv -> List AExpr -> CheckResult
infer-list (st) (env) (elems) =
 if list-length elems == 0
  then let fr = fresh-and-advance st
  in CheckResult { inferred-type = ListTy (fr.var-type), state = fr.state }
  else let first = infer-expr st env (list-at elems 0)
  in let st2 = unify-list-elems (first.state) env elems (first.inferred-type) 1 (list-length elems)
  in CheckResult { inferred-type = ListTy (first.inferred-type), state = st2 }

unify-list-elems : UnificationState -> TypeEnv -> List AExpr -> CodexType -> Integer -> Integer -> UnificationState
unify-list-elems (st) (env) (elems) (elem-ty) (i) (len) =
 if i == len
  then st
  else let er = infer-expr st env (list-at elems i)
  in let r = unify (er.state) (er.inferred-type) elem-ty
  in unify-list-elems (r.state) env elems elem-ty (i + 1) len

infer-match : UnificationState -> TypeEnv -> AExpr -> List AMatchArm -> CheckResult
infer-match (st) (env) (scrutinee) (arms) =
 let sr = infer-expr st env scrutinee
 in let fr = fresh-and-advance (sr.state)
 in let st2 = infer-match-arms (fr.state) env (sr.inferred-type) (fr.var-type) arms 0 (list-length arms)
 in CheckResult { inferred-type = fr.var-type, state = st2 }

infer-match-arms : UnificationState -> TypeEnv -> CodexType -> CodexType -> List AMatchArm -> Integer -> Integer -> UnificationState
infer-match-arms (st) (env) (scrut-ty) (result-ty) (arms) (i) (len) =
 if i == len
  then st
  else let arm = list-at arms i
  in let pr = bind-pattern st env (arm.pattern) scrut-ty
  in let br = infer-expr (pr.state) (pr.env) (arm.body)
  in let r = unify (br.state) (br.inferred-type) result-ty
  in infer-match-arms (r.state) env scrut-ty result-ty arms (i + 1) len

bind-pattern : UnificationState -> TypeEnv -> APat -> CodexType -> PatBindResult
bind-pattern (st) (env) (pat) (ty) = when pat
 if AVarPat (name) -> PatBindResult { state = st, env = env-bind env (name.value) ty }
 if AWildPat -> PatBindResult { state = st, env = env }
 if ALitPat (val) (kind) -> PatBindResult { state = st, env = env }
 if ACtorPat (ctor-name) (sub-pats) -> let ctor-lookup = instantiate-type st (env-lookup env (ctor-name.value))
 in bind-ctor-sub-patterns (ctor-lookup.state) env sub-pats (ctor-lookup.var-type) 0 (list-length sub-pats)

bind-ctor-sub-patterns : UnificationState -> TypeEnv -> List APat -> CodexType -> Integer -> Integer -> PatBindResult
bind-ctor-sub-patterns (st) (env) (sub-pats) (ctor-ty) (i) (len) =
 if i == len
  then PatBindResult { state = st, env = env }
  else when ctor-ty
   if FunTy (param-ty) (ret-ty) -> let pr = bind-pattern st env (list-at sub-pats i) param-ty
   in bind-ctor-sub-patterns (pr.state) (pr.env) sub-pats ret-ty (i + 1) len
   if _ -> let fr = fresh-and-advance st
   in let pr = bind-pattern (fr.state) env (list-at sub-pats i) (fr.var-type)
   in bind-ctor-sub-patterns (pr.state) (pr.env) sub-pats ctor-ty (i + 1) len

infer-do : UnificationState -> TypeEnv -> List ADoStmt -> CheckResult
infer-do (st) (env) (stmts) =
 infer-do-loop st env stmts 0 (list-length stmts) NothingTy

infer-do-loop : UnificationState -> TypeEnv -> List ADoStmt -> Integer -> Integer -> CodexType -> CheckResult
infer-do-loop (st) (env) (stmts) (i) (len) (last-ty) =
 if i == len
  then CheckResult { inferred-type = last-ty, state = st }
  else let stmt = list-at stmts i
  in when stmt
   if ADoExprStmt (e) -> let er = infer-expr st env e
   in infer-do-loop (er.state) env stmts (i + 1) len (er.inferred-type)
   if ADoBindStmt (name) (e) -> let er = infer-expr st env e
   in let env2 = env-bind env (name.value) (er.inferred-type)
   in infer-do-loop (er.state) env2 stmts (i + 1) len (er.inferred-type)

infer-expr : UnificationState -> TypeEnv -> AExpr -> CheckResult
infer-expr (st) (env) (expr) = when expr
 if ALitExpr (val) (kind) -> infer-literal st kind
 if ANameExpr (name) -> infer-name st env (name.value)
 if ABinaryExpr (left) (op) (right) -> infer-binary st env left op right
 if AUnaryExpr (operand) -> let r = infer-expr st env operand
 in let u = unify (r.state) (r.inferred-type) IntegerTy
 in CheckResult { inferred-type = IntegerTy, state = u.state }
 if AApplyExpr (func) (arg) -> infer-application st env func arg
 if AIfExpr (cond) (then-e) (else-e) -> infer-if st env cond then-e else-e
 if ALetExpr (bindings) (body) -> infer-let st env bindings body
 if ALambdaExpr (params) (body) -> infer-lambda st env params body
 if AMatchExpr (scrutinee) (arms) -> infer-match st env scrutinee arms
 if AListExpr (elems) -> infer-list st env elems
 if ADoExpr (stmts) -> infer-do st env stmts
 if AFieldAccess (obj) (field) -> let r = infer-expr st env obj
 in let resolved = deep-resolve (r.state) (r.inferred-type)
 in when resolved
  if RecordTy (rname) (rfields) -> let ftype = lookup-record-field rfields (field.value)
  in CheckResult { inferred-type = ftype, state = r.state }
  if ConstructedTy (cname) (cargs) -> let record-type = resolve-constructed-to-record env (cname.value)
  in when record-type
   if RecordTy (rname) (rfields) -> let ftype = lookup-record-field rfields (field.value)
   in CheckResult { inferred-type = ftype, state = r.state }
   if _ -> let fr = fresh-and-advance (r.state)
   in CheckResult { inferred-type = fr.var-type, state = fr.state }
  if _ -> let fr = fresh-and-advance (r.state)
  in CheckResult { inferred-type = fr.var-type, state = fr.state }
 if ARecordExpr (name) (fields) -> let st2 = infer-record-fields st env fields 0 (list-length fields)
 in let ctor-type = if env-has env (name.value)
   then env-lookup env (name.value)
   else ErrorTy
 in let result-type = strip-fun-args ctor-type
 in CheckResult { inferred-type = result-type, state = st2 }
 if AErrorExpr (msg) -> CheckResult { inferred-type = ErrorTy, state = st }

resolve-constructed-to-record : TypeEnv -> Text -> CodexType
resolve-constructed-to-record (env) (name) =
 if env-has env name
  then strip-fun-args (env-lookup env name)
  else ErrorTy

infer-record-fields : UnificationState -> TypeEnv -> List AFieldExpr -> Integer -> Integer -> UnificationState
infer-record-fields (st) (env) (fields) (i) (len) =
 if i == len
  then st
  else let f = list-at fields i
  in let r = infer-expr st env (f.value)
  in infer-record-fields (r.state) env fields (i + 1) len

strip-fun-args : CodexType -> CodexType
strip-fun-args (ty) = when ty
 if FunTy (p) (r) -> strip-fun-args r
 if _ -> ty





builtin-type-env : TypeEnv
builtin-type-env =
 let e = empty-type-env
 in let e2 = env-bind e "negate" (FunTy IntegerTy IntegerTy)
 in let e3 = env-bind e2 "text-length" (FunTy TextTy IntegerTy)
 in let e4 = env-bind e3 "integer-to-text" (FunTy IntegerTy TextTy)
 in let e5 = env-bind e4 "char-at" (FunTy TextTy (FunTy IntegerTy CharTy))
 in let e5b = env-bind e5 "char-to-text" (FunTy CharTy TextTy)
 in let e6 = env-bind e5b "substring" (FunTy TextTy (FunTy IntegerTy (FunTy IntegerTy TextTy)))
 in let e7 = env-bind e6 "is-letter" (FunTy CharTy BooleanTy)
 in let e8 = env-bind e7 "is-digit" (FunTy CharTy BooleanTy)
 in let e9 = env-bind e8 "is-whitespace" (FunTy CharTy BooleanTy)
 in let e10 = env-bind e9 "char-code" (FunTy CharTy IntegerTy)
 in let e10b = env-bind e10 "char-code-at" (FunTy TextTy (FunTy IntegerTy IntegerTy))
 in let e11 = env-bind e10b "code-to-char" (FunTy IntegerTy CharTy)
 in let e12 = env-bind e11 "text-replace" (FunTy TextTy (FunTy TextTy (FunTy TextTy TextTy)))
 in let e13 = env-bind e12 "text-to-integer" (FunTy TextTy IntegerTy)
 in let e14 = env-bind e13 "show" (ForAllTy 0 (FunTy (TypeVar 0) TextTy))
 in let e15 = env-bind e14 "print-line" (FunTy TextTy NothingTy)
 in let e16 = env-bind e15 "list-length" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) IntegerTy))
 in let e16b = env-bind e16 "list-insert-at" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy IntegerTy (FunTy (TypeVar 0) (ListTy (TypeVar 0))))))
 in let e16c = env-bind e16b "text-compare" (FunTy TextTy (FunTy TextTy IntegerTy))
 in let e16d = env-bind e16c "list-snoc" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy (TypeVar 0) (ListTy (TypeVar 0)))))
 in let e17 = env-bind e16d "list-at" (ForAllTy 0 (FunTy (ListTy (TypeVar 0)) (FunTy IntegerTy (TypeVar 0))))
 in let e18 = env-bind e17 "map" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 0) (TypeVar 1)) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 1))))))
 in let e19 = env-bind e18 "filter" (ForAllTy 0 (FunTy (FunTy (TypeVar 0) BooleanTy) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 0)))))
 in let e20 = env-bind e19 "fold" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 1) (FunTy (TypeVar 0) (TypeVar 1))) (FunTy (TypeVar 1) (FunTy (ListTy (TypeVar 0)) (TypeVar 1))))))
 in let e21 = env-bind e20 "read-line" TextTy
 in let e22 = env-bind e21 "read-file" (FunTy TextTy TextTy)
 in let e23 = env-bind e22 "write-file" (FunTy TextTy (FunTy TextTy NothingTy))
 in let e24 = env-bind e23 "file-exists" (FunTy TextTy BooleanTy)
 in let e25 = env-bind e24 "list-files" (FunTy TextTy (FunTy TextTy (ListTy TextTy)))
 in let e26 = env-bind e25 "text-split" (FunTy TextTy (FunTy TextTy (ListTy TextTy)))
 in let e27 = env-bind e26 "text-contains" (FunTy TextTy (FunTy TextTy BooleanTy))
 in let e28 = env-bind e27 "text-starts-with" (FunTy TextTy (FunTy TextTy BooleanTy))
 in let e29 = env-bind e28 "get-args" (ListTy TextTy)
 in let e30 = env-bind e29 "get-env" (FunTy TextTy TextTy)
 in let e31 = env-bind e30 "current-dir" TextTy
 in let e32 = env-bind e31 "fork" (ForAllTy 0 (FunTy (FunTy NothingTy (TypeVar 0)) (ConstructedTy Name { value = "Task" } [TypeVar 0])))
 in let e33 = env-bind e32 "await" (ForAllTy 0 (FunTy (ConstructedTy Name { value = "Task" } [TypeVar 0]) (TypeVar 0)))
 in let e34 = env-bind e33 "par" (ForAllTy 0 (ForAllTy 1 (FunTy (FunTy (TypeVar 0) (TypeVar 1)) (FunTy (ListTy (TypeVar 0)) (ListTy (TypeVar 1))))))
 in let e35 = env-bind e34 "race" (ForAllTy 0 (FunTy (ListTy (FunTy NothingTy (TypeVar 0))) (TypeVar 0)))
 in let e36 = env-bind e35 "text-concat-list" (FunTy (ListTy TextTy) TextTy)
 in e36


fresh-var : UnificationState -> CodexType
fresh-var (st) =
 TypeVar (st.next-id)

advance-id : UnificationState -> UnificationState
advance-id (st) =
 UnificationState { substitutions = st.substitutions, next-id = st.next-id + 1, errors = st.errors }

fresh-and-advance : UnificationState -> FreshResult
fresh-and-advance (st) =
 FreshResult { var-type = TypeVar (st.next-id), state = advance-id st }

subst-lookup : Integer -> List SubstEntry -> CodexType
subst-lookup (var-id) (entries) =
 let len = list-length entries
 in if len == 0
  then ErrorTy
  else let pos = bsearch-int-pos entries var-id 0 len
  in if pos >= len
   then ErrorTy
   else let entry = list-at entries pos
   in if entry.var-id == var-id then entry.resolved-type else ErrorTy

has-subst : Integer -> List SubstEntry -> Boolean
has-subst (var-id) (entries) =
 let len = list-length entries
 in if len == 0
  then False
  else let pos = bsearch-int-pos entries var-id 0 len
  in if pos >= len
   then False
   else (list-at entries pos).var-id == var-id

resolve : UnificationState -> CodexType -> CodexType
resolve (st) (ty) = when ty
 if TypeVar (id) -> if has-subst id (st.substitutions)
  then resolve st (subst-lookup id (st.substitutions))
  else ty
 if _ -> ty

add-subst : UnificationState -> Integer -> CodexType -> UnificationState
add-subst (st) (var-id) (ty) =
 let entry = SubstEntry { var-id = var-id, resolved-type = ty }
 in let pos = bsearch-int-pos (st.substitutions) var-id 0 (list-length (st.substitutions))
 in UnificationState { substitutions = list-insert-at (st.substitutions) pos entry, next-id = st.next-id, errors = st.errors }

add-unify-error : UnificationState -> Text -> Text -> UnificationState
add-unify-error (st) (code) (msg) =
 UnificationState { substitutions = st.substitutions, next-id = st.next-id, errors = st.errors ++ [make-error code msg] }

occurs-in : UnificationState -> Integer -> CodexType -> Boolean
occurs-in (st) (var-id) (ty) =
 let resolved = resolve st ty
 in when resolved
  if TypeVar (id) -> id == var-id
  if FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
  if ListTy (elem) -> occurs-in st var-id elem
  if _ -> False

unify : UnificationState -> CodexType -> CodexType -> UnifyResult
unify (st) (a) (b) =
 let ra = resolve st a
 in let rb = resolve st b
 in unify-resolved st ra rb

unify-resolved : UnificationState -> CodexType -> CodexType -> UnifyResult
unify-resolved (st) (a) (b) =
 if types-equal a b
  then UnifyResult { success = True, state = st }
  else when a
   if TypeVar (id-a) -> if occurs-in st id-a b
    then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
    else UnifyResult { success = True, state = add-subst st id-a b }
   if _ -> unify-rhs st a b


unify-rhs : UnificationState -> CodexType -> CodexType -> UnifyResult
unify-rhs (st) (a) (b) = when b
 if TypeVar (id-b) -> if occurs-in st id-b a
  then UnifyResult { success = False, state = add-unify-error st "CDX2010" "Infinite type" }
  else UnifyResult { success = True, state = add-subst st id-b a }
 if _ -> unify-structural st a b

unify-structural : UnificationState -> CodexType -> CodexType -> UnifyResult
unify-structural (st) (a) (b) = when a
 if IntegerTy -> when b
  if IntegerTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if NumberTy -> when b
  if NumberTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if TextTy -> when b
  if TextTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if BooleanTy -> when b
  if BooleanTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if NothingTy -> when b
  if NothingTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if VoidTy -> when b
  if VoidTy -> UnifyResult { success = True, state = st }
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if ErrorTy -> UnifyResult { success = True, state = st }
 if FunTy (pa) (ra) -> when b
  if FunTy (pb) (rb) -> unify-fun st pa ra pb rb
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if ListTy (ea) -> when b
  if ListTy (eb) -> unify st ea eb
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if ConstructedTy (na) (args-a) -> when b
  if ConstructedTy (nb) (args-b) -> if na.value == nb.value
   then unify-constructed-args st args-a args-b 0 (list-length args-a)
   else unify-mismatch st a b
  if SumTy (sb-name) (sb-ctors) -> if na.value == sb-name.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if RecordTy (rb-name) (rb-fields) -> if na.value == rb-name.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if SumTy (sa-name) (sa-ctors) -> when b
  if SumTy (sb-name) (sb-ctors) -> if sa-name.value == sb-name.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if ConstructedTy (nb) (args-b) -> if sa-name.value == nb.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if RecordTy (ra-name) (ra-fields) -> when b
  if RecordTy (rb-name) (rb-fields) -> if ra-name.value == rb-name.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if ConstructedTy (nb) (args-b) -> if ra-name.value == nb.value
   then UnifyResult { success = True, state = st }
   else unify-mismatch st a b
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b
 if ForAllTy (id) (body) -> unify st body b
 if _ -> when b
  if ErrorTy -> UnifyResult { success = True, state = st }
  if _ -> unify-mismatch st a b

unify-constructed-args : UnificationState -> List CodexType -> List CodexType -> Integer -> Integer -> UnifyResult
unify-constructed-args (st) (args-a) (args-b) (i) (len) =
 if i == len
  then UnifyResult { success = True, state = st }
  else if i >= list-length args-b
   then UnifyResult { success = True, state = st }
   else let r = unify st (list-at args-a i) (list-at args-b i)
   in if r.success
    then unify-constructed-args (r.state) args-a args-b (i + 1) len
    else r

unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> UnifyResult
unify-fun (st) (pa) (ra) (pb) (rb) =
 let r1 = unify st pa pb
 in if r1.success
  then unify (r1.state) ra rb
  else r1

unify-mismatch : UnificationState -> CodexType -> CodexType -> UnifyResult
unify-mismatch (st) (a) (b) =
 UnifyResult { success = False, state = add-unify-error st "CDX2001" ("Type mismatch: " ++ type-tag a ++ " vs " ++ type-tag b) }


deep-resolve : UnificationState -> CodexType -> CodexType
deep-resolve (st) (ty) =
 let resolved = resolve st ty
 in when resolved
  if FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
  if ListTy (elem) -> ListTy (deep-resolve st elem)
  if ConstructedTy (name) (args) -> ConstructedTy name (deep-resolve-list st args 0 (list-length args) [])
  if ForAllTy (id) (body) -> ForAllTy id (deep-resolve st body)
  if SumTy (name) (ctors) -> resolved
  if RecordTy (name) (fields) -> resolved
  if _ -> resolved

deep-resolve-list : UnificationState -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
deep-resolve-list (st) (args) (i) (len) (acc) =
 if i == len
  then acc
  else deep-resolve-list st args (i + 1) len (list-snoc acc (deep-resolve st (list-at args i)))


collect-ctor-names : List ATypeDef -> Integer -> List Text
collect-ctor-names =
 0 TypeChecker resolve-type-expr

compile : Text -> Text -> Text
compile (source) (module-name) =
 let tokens = tokenize source
 in let st = make-parse-state tokens
 in let doc = parse-document st
 in let ast = desugar-document doc module-name
 in let check-result = check-module ast
 in let ir = lower-module ast (check-result.types) (check-result.state)
 in emit-full-module ir (ast.type-defs)

compile-checked : Text -> Text -> CompileResult
compile-checked (source) (module-name) =
 compile-with-imports source module-name []

compile-with-imports : Text -> Text -> List ResolveResult -> CompileResult
compile-with-imports (source) (module-name) (imported) =
 let tokens = tokenize source
 in let st = make-parse-state tokens
 in let doc = parse-document st
 in let ast = desugar-document doc module-name
 in let resolve-result = resolve-module-with-imports ast imported
 in if list-length (resolve-result.errors) > 0
  then CompileError (resolve-result.errors)
  else let check-result = check-module ast
  in let ir = lower-module ast (check-result.types) (check-result.state)
  in CompileOk (emit-full-module ir (ast.type-defs)) check-result

compile-streaming : Text -> Text -> Nothing
compile-streaming (source) (module-name) =
 let tokens = tokenize source
 in let st = make-parse-state tokens
 in let doc = parse-document st
 in let ast = desugar-document doc module-name
 in let check-result = check-module ast
 in let ctor-types = collect-ctor-bindings (ast.type-defs) 0 (list-length (ast.type-defs)) []
 in let all-types = ctor-types ++ check-result.types ++ builtin-type-env.bindings
 in let ctor-names = collect-ctor-names (ast.type-defs) 0
 in do
  print-line (emit-type-defs (ast.type-defs) 0)
  stream-defs (ast.defs) all-types (check-result.state) ctor-names 0 (list-length (ast.defs))
  print-line ""

stream-defs : List ADef -> List TypeBinding -> UnificationState -> List Text -> Integer -> Integer -> Nothing
stream-defs (defs) (types) (ust) (ctor-names) (i) (len) =
 if i == len
  then print-line ""
  else let def = list-at defs i
  in let ir-def = lower-def def types ust
  in if is-error-body (ir-def.body)
   then print-line ("COMPILE-ERROR: def '" ++ ir-def.name ++ "' has error body: " ++ error-message (ir-def.body))
   else let text = emit-def ir-def ctor-names
   in do
    print-line text
    stream-defs defs types ust ctor-names (i + 1) len

compile-streaming-v2 : Text -> Text -> Nothing
compile-streaming-v2 (source) (module-name) =
 let tokens = tokenize source
 in let st = make-parse-state tokens
 in let scan = scan-document st
 in let type-defs = map-list desugar-type-def (scan.type-defs)
 in let headers = scan.def-headers
 in let tdm = build-type-def-map type-defs 0 (list-length type-defs) []
 in let tenv = register-type-defs empty-unification-state builtin-type-env tdm type-defs 0 (list-length type-defs)
 in let env = register-def-headers (tenv.state) (tenv.env) tdm headers 0 (list-length headers)
 in let ctor-types = collect-ctor-bindings type-defs 0 (list-length type-defs) []
 in let all-types = ctor-types ++ env.env.bindings
 in let ctor-names = collect-ctor-names type-defs 0
 in do
  print-line (emit-type-defs type-defs 0)
  emit-defs-streaming tokens headers all-types (env.state) ctor-names 0 (list-length headers)
  print-line ""

register-def-headers : UnificationState -> TypeEnv -> List TypeBinding -> List DefHeader -> Integer -> Integer -> LetBindResult
register-def-headers (st) (env) (tdm) (headers) (i) (len) =
 if i == len
  then LetBindResult { state = st, env = env }
  else let hdr = list-at headers i
  in let declared = desugar-annotations (hdr.ann)
  in let ty = if list-length declared == 0
    then let fr = fresh-and-advance st
    in let env2 = env-bind env (hdr.name.text) (fr.var-type)
    in LetBindResult { state = fr.state, env = env2 }
    else let resolved = resolve-type-expr tdm (list-at declared 0)
    in let pr = parameterize-type st resolved
    in LetBindResult { state = pr.state, env = env-bind env (hdr.name.text) (pr.parameterized) }
  in register-def-headers (ty.state) (ty.env) tdm headers (i + 1) len

check-defs-streaming : List Token -> List DefHeader -> UnificationState -> TypeEnv -> Integer -> Integer -> List TypeBinding -> ModuleResult
check-defs-streaming (tokens) (headers) (ust) (env) (i) (len) (acc) =
 if i == len
  then ModuleResult { types = acc, state = ust }
  else let hdr = list-at headers i
  in let body-st = ParseState { tokens = tokens, pos = hdr.body-pos }
  in let body-result = parse-expr body-st
  in let def = Def { name = hdr.name, params = hdr.params, ann = hdr.ann, body = unwrap-body body-result }
  in let adef = desugar-def def
  in let r = check-def ust env adef
  in let resolved = deep-resolve (r.state) (r.inferred-type)
  in let entry = TypeBinding { name = adef.name.value, bound-type = resolved }
  in check-defs-streaming tokens headers (r.state) env (i + 1) len (list-snoc acc entry)


unwrap-body : ParseExprResult -> Expr
unwrap-body (r) = when r
 if ExprOk (e) (st) -> e

normalize-whitespace : Text -> Text
normalize-whitespace (s) =
 let r = text-replace s "\n\n\n" "\n\n"
 in if text-length r == text-length s
  then s
  else normalize-whitespace r

main : Nothing
main =
 do
  path <- read-line
  source <- read-file path
  let clean = normalize-whitespace source
  in compile-streaming-v2 clean "Program"

