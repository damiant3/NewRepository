 | TypeDefNone (ParseState)

HandleParseResult = record {
  clauses : List HandleClause,
  state : ParseState
}

HandleParamsResult = record {
  toks : List Token,
  state : ParseState
}

LambdaParamsResult = record {
  toks : List Token,
  state : ParseState
}

Expr =
 | LitExpr (Token)
 | NameExpr (Token)
 | AppExpr (Expr) (Expr)
 | BinExpr (Expr) (Token) (Expr)
 | UnaryExpr (Token) (Expr)
 | IfExpr (Expr) (Expr) (Expr)
 | LetExpr (List LetBind) (Expr)
 | MatchExpr (Expr) (List MatchArm)
 | ListExpr (List Expr)
 | RecordExpr (Token) (List RecordFieldExpr)
 | FieldExpr (Expr) (Token)
 | ParenExpr (Expr)
 | DoExpr (List DoStmt)
 | HandleExpr (Token) (Expr) (List HandleClause)
 | LambdaExpr (List Token) (Expr)
 | ErrExpr (Token)

LetBind = record {
  name : Token,
  value : Expr
}

MatchArm = record {
  pattern : Pat,
  body : Expr
}

RecordFieldExpr = record {
  name : Token,
  value : Expr
}

DoStmt =
 | DoBindStmt (Token) (Expr)
 | DoExprStmt (Expr)

HandleClause = record {
  op-name : Token,
  resume-name : Token,
  body : Expr
}

Pat =
 | VarPat (Token)
 | LitPat (Token)
 | CtorPat (Token) (List Pat)
 | WildPat (Token)

TypeExpr =
 | NamedType (Token)
 | FunType (TypeExpr) (TypeExpr)
 | AppType (TypeExpr) (List TypeExpr)
 | ParenType (TypeExpr)
 | ListType (TypeExpr)
 | LinearTypeExpr (TypeExpr)
 | EffectTypeExpr (List Token) (TypeExpr)

TypeAnn = record {
  name : Token,
  type-expr : TypeExpr
}

Def = record {
  name : Token,
  params : List Token,
  ann : List TypeAnn,
  body : Expr
}

RecordFieldDef = record {
  name : Token,
  type-expr : TypeExpr
}

VariantCtorDef = record {
  name : Token,
  fields : List TypeExpr
}

EffectOpDef = record {
  name : Token,
  type-expr : TypeExpr
}

EffectDef = record {
  name : Token,
  ops : List EffectOpDef
}

TypeBody =
 | RecordBody (List RecordFieldDef)
 | VariantBody (List VariantCtorDef)

TypeDef = record {
  name : Token,
  type-params : List Token,
  body : TypeBody
}

ImportDecl = record {
  module-name : Token,
  selected-names : List Token
}

Document = record {
  defs : List Def,
  type-defs : List TypeDef,
  effect-defs : List EffectDef,
  imports : List ImportDecl
}

DefHeader = record {
  name : Token,
  params : List Token,
  ann : List TypeAnn,
  body-pos : Integer
}

ScanDefResult =
 | DefHeaderOk (DefHeader) (ParseState)
 | DefHeaderNone (ParseState)

ScanResult = record {
  type-defs : List TypeDef,
  effect-defs : List EffectDef,
  def-headers : List DefHeader,
  imports : List ImportDecl
}

Token = record {
  kind : TokenKind,
  text : Text,
  offset : Integer,
  line : Integer,
  column : Integer
}

TokenKind =
 | EndOfFile
 | Newline
 | Indent
 | Dedent
 | IntegerLiteral
 | NumberLiteral
 | TextLiteral
 | CharLiteral
 | TrueKeyword
 | FalseKeyword
 | Identifier
 | TypeIdentifier
 | ProseText
 | ChapterHeader
 | SectionHeader
 | LetKeyword
 | InKeyword
 | IfKeyword
 | ThenKeyword
 | ElseKeyword
 | WhenKeyword
 | WhereKeyword
 | SuchThatKeyword
 | DoKeyword
 | RecordKeyword
 | ImportKeyword
 | ExportKeyword
 | ClaimKeyword
 | ProofKeyword
 | ForAllKeyword
 | ThereExistsKeyword
 | LinearKeyword
 | EffectKeyword
 | WithKeyword
 | Equals
 | Colon
 | Arrow
 | LeftArrow
 | Pipe
 | Ampersand
 | Plus
 | Minus
 | Star
 | Slash
 | Caret
 | PlusPlus
 | ColonColon
 | DoubleEquals
 | NotEquals
 | LessThan
 | GreaterThan
 | LessOrEqual
 | GreaterOrEqual
 | TripleEquals
 | Turnstile
 | LinearProduct
 | ForAllSymbol
 | ExistsSymbol
 | LeftParen
 | RightParen
 | LeftBracket
 | RightBracket
 | LeftBrace
 | RightBrace
 | Comma
 | Dot
 | DashGreater
 | Underscore
 | Backslash
 | ErrorToken

CodexType =
 | IntegerTy
 | NumberTy
 | TextTy
 | BooleanTy
 | CharTy
 | VoidTy
 | NothingTy
 | ErrorTy
 | FunTy (CodexType) (CodexType)
 | ListTy (CodexType)
 | TypeVar (Integer)
 | ForAllTy (Integer) (CodexType)
 | SumTy (Name) (List SumCtor)
 | RecordTy (Name) (List RecordField)
 | ConstructedTy (Name) (List CodexType)
 | EffectfulTy (List Name) (CodexType)

SumCtor = record {
  name : Name,
  fields : List CodexType
}

RecordField = record {
  name : Name,
  type-val : CodexType
}

ParamEntry = record {
  param-name : Text,
  var-id : Integer
}

ParamResult = record {
  parameterized : CodexType,
  entries : List ParamEntry,
  state : UnificationState
}

WalkResult = record {
  walked : CodexType,
  entries : List ParamEntry,
  state : UnificationState
}

WalkListResult = record {
  walked-list : List CodexType,
  entries : List ParamEntry,
  state : UnificationState
}

DefSetup = record {
  expected-type : CodexType,
  remaining-type : CodexType,
  state : UnificationState,
  env : TypeEnv
}

DefParamResult = record {
  state : UnificationState,
  env : TypeEnv,
  remaining-type : CodexType
}

ModuleResult = record {
  types : List TypeBinding,
  state : UnificationState
}

CheckResult = record {
  inferred-type : CodexType,
  state : UnificationState
}

LetBindResult = record {
  state : UnificationState,
  env : TypeEnv
}

LambdaBindResult = record {
  state : UnificationState,
  env : TypeEnv,
  param-types : List CodexType
}

PatBindResult = record {
  state : UnificationState,
  env : TypeEnv
}

TypeEnv = record {
  bindings : List TypeBinding
}

TypeBinding = record {
  name : Text,
  bound-type : CodexType
}

UnificationState = record {
  substitutions : List SubstEntry,
  next-id : Integer,
  errors : List Diagnostic
}

SubstEntry = record {
  var-id : Integer,
  resolved-type : CodexType
}

UnifyResult = record {
  success : Boolean,
