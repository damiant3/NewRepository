write-i16 : a1624
write-i16 (v) =
 write-bytes v 2

pad-zeros : a1627
pad-zeros (n) =
 pad-zeros-acc n []

pad-zeros-acc : Integer -> List Integer -> List Integer
pad-zeros-acc (n) (acc) =
 if n <= 0
  then acc
  else pad-zeros-acc (n - 1) (list-snoc acc 0)


