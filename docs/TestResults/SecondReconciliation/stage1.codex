}

FreshResult = record {
  var-type : CodexType,
  state : UnificationState
}

CompileResult =
 | CompileOk (Text) (ModuleResult)
 | CompileError (List Diagnostic)

desugar-expr : Expr -> AExpr
desugar-expr (node) = when node
 if LitExpr (tok) -> desugar-literal tok
 if NameExpr (tok) -> ANameExpr (make-name (tok.text))
 if AppExpr (f) (a) -> AApplyExpr (desugar-expr f) (desugar-expr a)
 if BinExpr (l) (op) (r) -> ABinaryExpr (desugar-expr l) (desugar-bin-op (op.kind)) (desugar-expr r)
 if UnaryExpr (op) (operand) -> AUnaryExpr (desugar-expr operand)
 if IfExpr (c) (t) (e) -> AIfExpr (desugar-expr c) (desugar-expr t) (desugar-expr e)
 if LetExpr (bindings) (body) -> ALetExpr (map-list desugar-let-bind bindings) (desugar-expr body)
 if MatchExpr (scrut) (arms) -> AMatchExpr (desugar-expr scrut) (map-list desugar-match-arm arms)
 if ListExpr (elems) -> AListExpr (map-list desugar-expr elems)
 if RecordExpr (type-tok) (fields) -> ARecordExpr (make-name (type-tok.text)) (map-list desugar-field-expr fields)
 if FieldExpr (rec) (field-tok) -> AFieldAccess (desugar-expr rec) (make-name (field-tok.text))
 if ParenExpr (inner) -> desugar-expr inner
 if DoExpr (stmts) -> ADoExpr (map-list desugar-do-stmt stmts)
 if HandleExpr (eff-tok) (body) (clauses) -> AHandleExpr (make-name (eff-tok.text)) (desugar-expr body) (map-list desugar-handle-clause clauses)
 if LambdaExpr (params) (body) -> ALambdaExpr (map-list desugar-lambda-param params) (desugar-expr body)
 if ErrExpr (tok) -> AErrorExpr (tok.text)

desugar-literal : Token -> AExpr
desugar-literal (tok) =
 if is-literal (tok.kind)
  then ALitExpr (tok.text) (classify-literal (tok.kind))
  else AErrorExpr (tok.text)

classify-literal : TokenKind -> LiteralKind
classify-literal (k) = when k
 if IntegerLiteral -> IntLit
 if NumberLiteral -> NumLit
 if TextLiteral -> TextLit
 if CharLiteral -> CharLit
 if TrueKeyword -> BoolLit
 if FalseKeyword -> BoolLit
 if _ -> TextLit

desugar-let-bind : LetBind -> ALetBind
desugar-let-bind (b) =
 ALetBind { name = make-name (b.name.text), value = desugar-expr (b.value) }

desugar-match-arm : MatchArm -> AMatchArm
desugar-match-arm (arm) =
 AMatchArm { pattern = desugar-pattern (arm.pattern), body = desugar-expr (arm.body) }

desugar-field-expr : RecordFieldExpr -> AFieldExpr
desugar-field-expr (f) =
 AFieldExpr { name = make-name (f.name.text), value = desugar-expr (f.value) }

desugar-do-stmt : DoStmt -> ADoStmt
desugar-do-stmt (s) = when s
 if DoBindStmt (tok) (val) -> ADoBindStmt (make-name (tok.text)) (desugar-expr val)
 if DoExprStmt (e) -> ADoExprStmt (desugar-expr e)

desugar-handle-clause : HandleClause -> AHandleClause
desugar-handle-clause (c) =
 AHandleClause { op-name = make-name (c.op-name.text), resume-name = make-name (c.resume-name.text), body = desugar-expr (c.body) }

desugar-lambda-param : Token -> Name
desugar-lambda-param (tok) =
 make-name (tok.text)

desugar-bin-op : TokenKind -> BinaryOp
desugar-bin-op (k) = when k
 if Plus -> OpAdd
 if Minus -> OpSub
 if Star -> OpMul
 if Slash -> OpDiv
 if Caret -> OpPow
 if DoubleEquals -> OpEq
 if NotEquals -> OpNotEq
 if LessThan -> OpLt
 if GreaterThan -> OpGt
 if LessOrEqual -> OpLtEq
 if GreaterOrEqual -> OpGtEq
 if TripleEquals -> OpDefEq
 if PlusPlus -> OpAppend
 if ColonColon -> OpCons
 if Ampersand -> OpAnd
 if Pipe -> OpOr
 if _ -> OpAdd

desugar-pattern : Pat -> APat
desugar-pattern (p) = when p
 if VarPat (tok) -> AVarPat (make-name (tok.text))
 if LitPat (tok) -> ALitPat (tok.text) (classify-literal (tok.kind))
 if CtorPat (tok) (subs) -> ACtorPat (make-name (tok.text)) (map-list desugar-pattern subs)
 if WildPat (tok) -> AWildPat

desugar-type-expr : TypeExpr -> ATypeExpr
desugar-type-expr (t) = when t
 if NamedType (tok) -> ANamedType (make-name (tok.text))
 if FunType (param) (ret) -> AFunType (desugar-type-expr param) (desugar-type-expr ret)
 if AppType (ctor) (args) -> AAppType (desugar-type-expr ctor) (map-list desugar-type-expr args)
 if ParenType (inner) -> desugar-type-expr inner
 if ListType (elem) -> AAppType (ANamedType (make-name "List")) [desugar-type-expr elem]
 if LinearTypeExpr (inner) -> desugar-type-expr inner
 if EffectTypeExpr (effs) (ret) -> AEffectType (map-list make-type-param-name effs) (desugar-type-expr ret)

desugar-def : Def -> ADef
desugar-def (d) =
 let ann-types = desugar-annotations (d.ann)
 in ADef { name = make-name (d.name.text), params = map-list desugar-param (d.params), declared-type = ann-types, body = desugar-expr (d.body) }

desugar-annotations : List TypeAnn -> List ATypeExpr
desugar-annotations (anns) =
 if list-length anns == 0
  then []
  else let a = list-at anns 0
  in [desugar-type-expr (a.type-expr)]

desugar-param : Token -> AParam
desugar-param (tok) =
 AParam { name = make-name (tok.text) }

desugar-type-def : TypeDef -> ATypeDef
desugar-type-def (td) = when td.body
 if RecordBody (fields) -> ARecordTypeDef (make-name (td.name.text)) (map-list make-type-param-name (td.type-params)) (map-list desugar-record-field-def fields)
 if VariantBody (ctors) -> AVariantTypeDef (make-name (td.name.text)) (map-list make-type-param-name (td.type-params)) (map-list desugar-variant-ctor-def ctors)

make-type-param-name : Token -> Name
make-type-param-name (tok) =
 make-name (tok.text)

desugar-record-field-def : RecordFieldDef -> ARecordFieldDef
desugar-record-field-def (f) =
 ARecordFieldDef { name = make-name (f.name.text), type-expr = desugar-type-expr (f.type-expr) }

desugar-variant-ctor-def : VariantCtorDef -> AVariantCtorDef
desugar-variant-ctor-def (c) =
 AVariantCtorDef { name = make-name (c.name.text), fields = map-list desugar-type-expr (c.fields) }

desugar-document : Document -> Text -> AModule
desugar-document (doc) (module-name) =
 AModule { name = make-name module-name, defs = map-list desugar-def (doc.defs), type-defs = map-list desugar-type-def (doc.type-defs), effect-defs = map-list desugar-effect-def (doc.effect-defs), imports = map-list desugar-import (doc.imports) }

desugar-import : ImportDecl -> AImportDecl
desugar-import (imp) =
 AImportDecl { module-name = make-name (imp.module-name.text), selected-names = map-list desugar-import-name (imp.selected-names) }

desugar-import-name : Token -> Name
desugar-import-name (tok) =
 make-name (tok.text)

desugar-effect-def : EffectDef -> AEffectDef
desugar-effect-def (ed) =
 AEffectDef { name = make-name (ed.name.text), ops = map-list desugar-effect-op (ed.ops) }

desugar-effect-op : EffectOpDef -> AEffectOpDef
desugar-effect-op (op) =
 AEffectOpDef { name = make-name (op.name.text), type-expr = desugar-type-expr (op.type-expr) }

map-list : (a320 -> a330) -> List a320 -> List a330
map-list (f) (xs) =
 map-list-loop f xs 0 (list-length xs) []

map-list-loop : (a344 -> a345) -> List a344 -> Integer -> Integer -> List a345 -> List a345
map-list-loop (f) (xs) (i) (len) (acc) =
 if i == len
  then acc
  else map-list-loop f xs (i + 1) len (list-snoc acc (f (list-at xs i)))

fold-list : (a358 -> a349 -> a358) -> a358 -> List a349 -> a358
fold-list (f) (z) (xs) =
 fold-list-loop f z xs 0 (list-length xs)

fold-list-loop : (a372 -> a367 -> a372) -> a372 -> List a367 -> Integer -> Integer -> a372
fold-list-loop (f) (z) (xs) (i) (len) =
 if i == len
  then z
  else fold-list-loop f (f z (list-at xs i)) xs (i + 1) len

bsearch-text-pos : List TypeBinding -> Text -> Integer -> Integer -> Integer
bsearch-text-pos (bindings) (name) (lo) (hi) =
 if lo >= hi
  then lo
  else let mid = lo + hi - lo / 2
  in let mid-name = (list-at bindings mid).name
  in if text-compare name mid-name <= 0
   then bsearch-text-pos bindings name lo mid
   else bsearch-text-pos bindings name (mid + 1) hi

bsearch-int-pos : List SubstEntry -> Integer -> Integer -> Integer -> Integer
bsearch-int-pos (entries) (key) (lo) (hi) =
 if lo >= hi
  then lo
  else let mid = lo + hi - lo / 2
  in if key <= (list-at entries mid).var-id
   then bsearch-int-pos entries key lo mid
   else bsearch-int-pos entries key (mid + 1) hi

bsearch-text-set : List Text -> Text -> Integer -> Integer -> Integer
bsearch-text-set (names) (name) (lo) (hi) =
 if lo >= hi
  then lo
  else let mid = lo + hi - lo / 2
  in if text-compare name (list-at names mid) <= 0
   then bsearch-text-set names name lo mid
   else bsearch-text-set names name (mid + 1) hi

make-error : Text -> Text -> Diagnostic
make-error (code) (msg) =
 Diagnostic { code = code, message = msg, severity = Error }

make-warning : Text -> Text -> Diagnostic
make-warning (code) (msg) =
 Diagnostic { code = code, message = msg, severity = Warning }

severity-label : DiagnosticSeverity -> Text
severity-label (s) = when s
 if Error -> "error"
 if Warning -> "warning"
 if Info -> "info"

diagnostic-display : Diagnostic -> Text
diagnostic-display (d) =
 severity-label (d.severity) ++ " " ++ d.code ++ ": " ++ d.message

make-name : Text -> Name
make-name (s) =
 Name { value = s }

name-value : Name -> Text
name-value (n) =
 n.value

make-position : Integer -> Integer -> Integer -> SourcePosition
make-position (line) (col) (offset) =
 SourcePosition { line = line, column = col, offset = offset }

make-span : SourcePosition -> SourcePosition -> Text -> SourceSpan
make-span (s) (e) (f) =
 SourceSpan { start = s, end = e, file = f }

span-length : SourceSpan -> Integer
span-length (span) =
 span.end.offset - span.start.offset




i : Integer
i =
 list-length tds











find-tparam-index : List Name -> Text -> Integer -> Integer
find-tparam-index (tparams) (name) (i) =
 if i == list-length tparams
  then 0 - 1
  else if (list-at tparams i).value == name
   then i
   else find-tparam-index tparams name (i + 1)

when-type-name : Text -> Text
when-type-name (n) =
 if n == "Integer"
  then "long"
  else if n == "Number"
   then "decimal"
   else if n == "Text"
    then "string"
    else if n == "Boolean"
     then "bool"
     else if n == "List"
      then "List"
      else sanitize n



collect-type-var-ids : CodexType -> List Integer -> List Integer
collect-type-var-ids (ty) (acc) = when ty
 if TypeVar (id) -> if list-contains-int acc id
  then acc
  else list-append-int acc id
 if FunTy (p) (r) -> collect-type-var-ids r (collect-type-var-ids p acc)
 if ListTy (elem) -> collect-type-var-ids elem acc
 if ForAllTy (id) (body) -> collect-type-var-ids body acc
 if ConstructedTy (name) (args) -> collect-type-var-ids-list args acc
 if _ -> acc

collect-type-var-ids-list : List CodexType -> List Integer -> List Integer
collect-type-var-ids-list (types) (acc) =
 collect-type-var-ids-list-loop types acc 0 (list-length types)

collect-type-var-ids-list-loop : List CodexType -> List Integer -> Integer -> Integer -> List Integer
collect-type-var-ids-list-loop (types) (acc) (i) (len) =
 if i == len
  then acc
  else collect-type-var-ids-list-loop types (collect-type-var-ids (list-at types i) acc) (i + 1) len

list-contains-int : List Integer -> Integer -> Boolean
list-contains-int (xs) (n) =
 list-contains-int-loop xs n 0 (list-length xs)

list-contains-int-loop : List Integer -> Integer -> Integer -> Integer -> Boolean
list-contains-int-loop (xs) (n) (i) (len) =
 if i == len
  then False
  else if list-at xs i == n
   then True
   else list-contains-int-loop xs n (i + 1) len

list-append-int : List Integer -> Integer -> List Integer
list-append-int (xs) (n) =
 xs ++ [n]

generic-suffix : CodexType -> Text
generic-suffix (ty) =
 let ids = collect-type-var-ids ty []
 in if list-length ids == 0
  then ""
  else "<" ++ emit-type-params ids 0 ++ ">"



is-self-call : IRExpr -> Text -> Boolean
is-self-call (e) (func-name) =
 let chain = collect-apply-chain e []
 in is-self-call-root (chain.root) func-name

is-self-call-root : IRExpr -> Text -> Boolean
is-self-call-root (e) (func-name) = when e
 if IrName (n) (ty) -> n == func-name
 if _ -> False

has-tail-call : IRExpr -> Text -> Boolean
has-tail-call (e) (func-name) = when e
 if IrIf (c) (t) (el) (ty) -> has-tail-call t func-name | has-tail-call el func-name
 if IrLet (name) (ty) (val) (body) -> has-tail-call body func-name
 if IrMatch (scrut) (branches) (ty) -> has-tail-call-branches branches func-name 0
 if IrApply (f) (a) (ty) -> is-self-call e func-name
 if _ -> False

has-tail-call-branches : List IRBranch -> Text -> Integer -> Boolean
has-tail-call-branches (branches) (func-name) (i) =
 if i == list-length branches
  then False
  else let b = list-at branches i
  in if has-tail-call (b.body) func-name
   then True
   else has-tail-call-branches branches func-name (i + 1)

should-tco : IRDef -> Boolean
should-tco (d) =
 if list-length (d.params) == 0
  then False
  else has-tail-call (d.body) (d.name)















get-return-type : CodexType -> Integer -> CodexType
get-return-type (ty) (n) =
 if n == 0
  then strip-forall ty
  else when strip-forall ty
   if FunTy (p) (r) -> get-return-type r (n - 1)
   if _ -> ty

strip-forall : CodexType -> CodexType
strip-forall (ty) = when ty
 if ForAllTy (id) (body) -> strip-forall body
 if _ -> ty







is-cs-keyword : Text -> Boolean
is-cs-keyword (n) =
 if n == "class"
  then True
  else if n == "static"
   then True
   else if n == "void"
    then True
    else if n == "return"
     then True
     else if n == "if"
      then True
      else if n == "else"
       then True
       else if n == "for"
        then True
        else if n == "while"
         then True
         else if n == "do"
          then True
          else if n == "switch"
           then True
           else if n == "case"
            then True
            else if n == "break"
             then True
             else if n == "continue"
              then True
              else if n == "new"
               then True
               else if n == "this"
                then True
                else if n == "base"
                 then True
                 else if n == "null"
                  then True
                  else if n == "true"
                   then True
                   else if n == "false"
                    then True
                    else if n == "int"
                     then True
                     else if n == "long"
                      then True
                      else if n == "string"
                       then True
                       else if n == "bool"
                        then True
                        else if n == "double"
                         then True
                         else if n == "decimal"
                          then True
                          else if n == "object"
                           then True
                           else if n == "in"
                            then True
                            else if n == "is"
                             then True
                             else if n == "as"
                              then True
                              else if n == "typeof"
                               then True
                               else if n == "default"
                                then True
                                else if n == "throw"
                                 then True
                                 else if n == "try"
                                  then True
                                  else if n == "catch"
                                   then True
                                   else if n == "finally"
                                    then True
                                    else if n == "using"
                                     then True
                                     else if n == "namespace"
                                      then True
                                      else if n == "public"
                                       then True
                                       else if n == "private"
                                        then True
                                        else if n == "protected"
                                         then True
                                         else if n == "internal"
                                          then True
                                          else if n == "abstract"
                                           then True
                                           else if n == "sealed"
                                            then True
                                            else if n == "override"
                                             then True
                                             else if n == "virtual"
                                              then True
                                              else if n == "event"
                                               then True
                                               else if n == "delegate"
                                                then True
                                                else if n == "out"
                                                 then True
                                                 else if n == "ref"
                                                  then True
                                                  else if n == "params" then True else False

sanitize : Text -> Text
sanitize (name) =
 let s = text-replace name "-" "_"
 in if is-cs-keyword s
  then "@" ++ s
  else if is-cs-member-name s
   then s ++ "_"
   else s

is-cs-member-name : Text -> Boolean
is-cs-member-name (n) =
 if n == "Equals"
  then True
  else if n == "GetHashCode"
   then True
   else if n == "ToString"
    then True
    else if n == "GetType"
     then True
     else if n == "MemberwiseClone" then True else False

cs-type : CodexType -> Text
cs-type (ty) = when ty
 if IntegerTy -> "long"
 if NumberTy -> "decimal"
 if TextTy -> "string"
 if BooleanTy -> "bool"
 if CharTy -> "long"
 if VoidTy -> "void"
 if NothingTy -> "object"
 if ErrorTy -> "object"
 if FunTy (p) (r) -> "Func<" ++ cs-type p ++ ", " ++ cs-type r ++ ">"
 if ListTy (elem) -> "List<" ++ cs-type elem ++ ">"
 if TypeVar (id) -> "T" ++ integer-to-text id
 if ForAllTy (id) (body) -> cs-type body
 if SumTy (name) (ctors) -> sanitize (name.value)
 if RecordTy (name) (fields) -> sanitize (name.value)
 if ConstructedTy (name) (args) -> if list-length args == 0
  then sanitize (name.value)
  else sanitize (name.value) ++ "<" ++ emit-cs-type-args args 0 ++ ">"
 if EffectfulTy (effects) (ret) -> cs-type ret


build-arity-map : List IRDef -> Integer -> List ArityEntry
build-arity-map (defs) (i) =
 if i == list-length defs
  then []
  else let d = list-at defs i
  in [ArityEntry { name = d.name, arity = list-length (d.params) }] ++ build-arity-map defs (i + 1)

build-arity-map-from-ast : List ADef -> Integer -> List ArityEntry
build-arity-map-from-ast (defs) (i) =
 if i == list-length defs
  then []
  else let d = list-at defs i
  in [ArityEntry { name = d.name.value, arity = list-length (d.params) }] ++ build-arity-map-from-ast defs (i + 1)

lookup-arity : List ArityEntry -> Text -> Integer
lookup-arity (entries) (name) =
 lookup-arity-loop entries name 0 (list-length entries)

lookup-arity-loop : List ArityEntry -> Text -> Integer -> Integer -> Integer
lookup-arity-loop (entries) (name) (i) (len) =
 if i == len
  then 0 - 1
  else let e = list-at entries i
  in if e.name == name
   then e.arity
   else lookup-arity-loop entries name (i + 1) len

collect-apply-chain : IRExpr -> List IRExpr -> ApplyChain
collect-apply-chain (e) (acc) = when e
 if IrApply (f) (a) (ty) -> collect-apply-chain f ([a] ++ acc)
 if _ -> ApplyChain { root = e, args = acc }

is-upper-letter : Char -> Boolean
is-upper-letter (c) =
 let code = char-code c
 in code >= char-code 'E' & code <= char-code 'Z'




