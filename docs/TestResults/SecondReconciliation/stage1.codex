       else if n == "is-whitespace"
        then True
        else if n == "text-to-integer"
         then True
         else if n == "integer-to-text"
          then True
          else if n == "char-code"
           then True
           else if n == "char-code-at"
            then True
            else if n == "code-to-char"
             then True
             else if n == "char-to-text"
              then True
              else if n == "list-length"
               then True
               else if n == "char-at"
                then True
                else if n == "substring"
                 then True
                 else if n == "list-at"
                  then True
                  else if n == "list-insert-at"
                   then True
                   else if n == "list-snoc"
                    then True
                    else if n == "text-compare"
                     then True
                     else if n == "text-replace"
                      then True
                      else if n == "open-file"
                       then True
                       else if n == "read-all"
                        then True
                        else if n == "close-file"
                         then True
                         else if n == "read-line"
                          then True
                          else if n == "read-file"
                           then True
                           else if n == "write-file"
                            then True
                            else if n == "file-exists"
                             then True
                             else if n == "list-files"
                              then True
                              else if n == "text-concat-list"
                               then True
                               else if n == "text-split"
                                then True
                                else if n == "text-contains"
                                 then True
                                 else if n == "text-starts-with"
                                  then True
                                  else if n == "get-args"
                                   then True
                                   else if n == "get-env"
                                    then True
                                    else if n == "current-dir"
                                     then True
                                     else if n == "run-process"
                                      then True
