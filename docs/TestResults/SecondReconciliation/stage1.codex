mov-load : List Integer
mov-load (rd) (rs) (offset) =
 [rex-w rd rs, 139] ++ emit-mem-operand rd rs offset

mov-store : Integer -> Integer -> Integer -> List Integer
mov-store (rd) (rs) (offset) =
 [rex-w rs rd, 137] ++ emit-mem-operand rs rd offset

mov-load-rip-rel : Integer -> Integer -> List Integer
mov-load-rip-rel (rd) (disp32) =
 [rex True (rd >= 8) False False, 139, modrm 0 rd 5] ++ write-i32 disp32

mov-store-rip-rel : Integer -> Integer -> List Integer
mov-store-rip-rel (rs) (disp32) =
 [rex True (rs >= 8) False False, 137, modrm 0 rs 5] ++ write-i32 disp32

movzx-byte : Integer -> Integer -> Integer -> List Integer
movzx-byte (rd) (rs) (offset) =
 [rex-w rd rs, 15, 182] ++ emit-mem-operand rd rs offset

mov-store-byte : Integer -> Integer -> Integer -> List Integer
mov-store-byte (rd) (rs) (offset) =
 let rex-byte = rex False (rs >= 8) False (rd >= 8)
 in let pfx = if rex-byte /= 64 | rs >= 4
   then [rex-byte]
   else []
 in pfx ++ [136] ++ emit-mem-operand rs rd offset

alu-ri : Integer -> Integer -> Integer -> List Integer
alu-ri (ext) (rd) (imm) =
 if imm >= 0 - 128 & imm <= 127
  then [rex-w 0 rd, 131, modrm 3 ext rd] ++ write-i8 imm
  else [rex-w 0 rd, 129, modrm 3 ext rd] ++ write-i32 imm

add-rr : Integer -> Integer -> List Integer
add-rr (rd) (rs) =
 [rex-w rs rd, 1, modrm 3 rs rd]

add-ri : Integer -> Integer -> List Integer
add-ri (rd) (imm) =
 alu-ri 0 rd imm

sub-rr : Integer -> Integer -> List Integer
sub-rr (rd) (rs) =
 [rex-w rs rd, 41, modrm 3 rs rd]

sub-ri : Integer -> Integer -> List Integer
sub-ri (rd) (imm) =
 alu-ri 5 rd imm

imul-rr : Integer -> Integer -> List Integer
imul-rr (rd) (rs) =
 [rex-w rd rs, 15, 175, modrm 3 rd rs]

neg-r : Integer -> List Integer
neg-r (rd) =
 [rex-w 0 rd, 247, modrm 3 3 rd]

cqo : List Integer
cqo =
 [rex True False False False, 153]

idiv-r : Integer -> List Integer
idiv-r (rs) =
 [rex-w 0 rs, 247, modrm 3 7 rs]

and-rr : Integer -> Integer -> List Integer
and-rr (rd) (rs) =
