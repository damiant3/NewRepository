build-elf-64-linux : List Integer -> List Integer -> Integer -> List Integer
build-elf-64-linux (text) (rodata) (entry-offset) =
 let base-addr = elf-linux-base-addr
 in let headers-size = elf64-header-size + elf64-phdr-size * 2
 in let text-file-offset = elf-align headers-size 16
 in let text-vaddr = base-addr + text-file-offset
 in let entry-point = text-vaddr + entry-offset
 in let text-size = list-length text
 in let text-region-end = text-file-offset + text-size
 in let rodata-file-offset = elf-align text-region-end elf-page-size
 in let rodata-vaddr = base-addr + rodata-file-offset
 in let rodata-size = list-length rodata
 in elf64-header-bytes entry-point elf64-header-size 2

phdr-64 : a2469
phdr-64 =
 pf-rwx 0 base-addr base-addr text-region-end text-region-end elf-page-size

phdr-64 : a2469
phdr-64 =
 pf-rw rodata-file-offset rodata-vaddr rodata-vaddr rodata-size rodata-size elf-page-size

