Page 3 of 3



Chapter: IR--IR Chapter
 The intermediate representation sits between the typed AST and code
 emission. Every node carries its resolved type and a SourceSpan
 inherited from the AST node it was lowered from.

Section: IR Expressions
  IRBinaryOp =
   | IrAddInt | IrSubInt | IrMulInt | IrDivInt | IrPowInt
   | IrAddNum | IrSubNum | IrMulNum | IrDivNum
   | IrEq | IrNotEq | IrLt | IrGt | IrLtEq | IrGtEq
   | IrAnd | IrOr
   | IrAppendText | IrAppendList
   | IrConsList

  IRExpr =
   | IrIntLit (Integer) (SourceSpan)
   | IrNumLit (Integer) (SourceSpan)
   | IrTextLit (Text) (SourceSpan)
   | IrBoolLit (Boolean) (SourceSpan)
   | IrCharLit (Integer) (SourceSpan)
   | IrName (Text) (CodexType) (SourceSpan)
   | IrBinary (IRBinaryOp) (IRExpr) (IRExpr) (CodexType) (SourceSpan)
   | IrNegate (IRExpr) (SourceSpan)
   | IrIf (IRExpr) (IRExpr) (IRExpr) (CodexType) (SourceSpan)
   | IrLet (Text) (CodexType) (IRExpr) (IRExpr) (SourceSpan)
   | IrApply (IRExpr) (IRExpr) (CodexType) (SourceSpan)
   | IrLambda (List IRParam) (IRExpr) (CodexType) (SourceSpan)
   | IrList (List IRExpr) (CodexType) (SourceSpan)
   | IrMatch (IRExpr) (List IRBranch) (CodexType) (SourceSpan)
   | IrAct (List IRActStmt) (CodexType) (SourceSpan)
   | IrHandle (Text) (IRExpr) (List IRHandleClause) (CodexType) (SourceSpan)
   | IrRecord (Text) (List IRFieldVal) (CodexType) (SourceSpan)
   | IrFieldAccess (IRExpr) (Text) (CodexType) (SourceSpan)
   | IrFork (IRExpr) (CodexType) (SourceSpan)
   | IrAwait (IRExpr) (CodexType) (SourceSpan)
   | IrError (Text) (CodexType) (SourceSpan)

  IRParam = record {
   name : Text,
   type-val : CodexType,
   span : SourceSpan
  }

  IRBranch = record {
   pattern : IRPat,
   body : IRExpr,
   span : SourceSpan
  }

  IRPat =
   | IrVarPat (Text) (CodexType) (SourceSpan)
   | IrLitPat (Text) (CodexType) (SourceSpan)
   | IrCtorPat (Text) (List IRPat) (CodexType) (SourceSpan)
   | IrWildPat (SourceSpan)

  IRActStmt =
   | IrDoBind (Text) (CodexType) (IRExpr) (SourceSpan)
   | IrDoExec (IRExpr) (SourceSpan)

  IRHandleClause = record {
   op-name : Text,
   resume-name : Text,
   body : IRExpr,
   span : SourceSpan
  }

  IRFieldVal = record {
   name : Text,
   value : IRExpr,
   span : SourceSpan
  }

Section: IR Definitions
  IRDef = record {
   name : Text,
   params : List IRParam,
   type-val : CodexType,
   body : IRExpr,
   chapter-slug : Text,
   span : SourceSpan
  }

  IRChapter = record {
   name : Name,
   defs : List IRDef,
   chapter-title : Text,
   prose : Text,
   section-titles : List Text,
   span : SourceSpan
  }

Section: IR Expression Type
  ir-expr-type : IRExpr -> CodexType
  ir-expr-type (e) =
   when e
    is IrIntLit (v) (s) -> IntegerTy
    is IrNumLit (v) (s) -> NumberTy
    is IrTextLit (v) (s) -> TextTy
    is IrBoolLit (v) (s) -> BooleanTy
    is IrCharLit (v) (s) -> CharTy
    is IrName (n) (t) (s) -> t
    is IrBinary (op) (l) (r) (t) (s) -> t
    is IrNegate (x) (s) -> IntegerTy
    is IrIf (c) (th) (el) (t) (s) -> t
    is IrLet (n) (t) (v) (b) (s) -> ir-expr-type b
    is IrApply (f) (a) (t) (s) -> t
    is IrLambda (ps) (b) (t) (s) -> t
    is IrList (es) (t) (s) -> ListTy t
    is IrMatch (sc) (bs) (t) (s) -> t
    is IrAct (ss) (t) (s) -> t
    is IrHandle (eff) (h) (cs) (t) (s) -> t
    is IrRecord (n) (fs) (t) (s) -> t
    is IrFieldAccess (r) (f) (t) (s) -> t
    is IrFork (body) (t) (s) -> t
    is IrAwait (task) (t) (s) -> t
    is IrError (m) (t) (s) -> t

  set-ir-expr-type : IRExpr -> CodexType -> IRExpr
  set-ir-expr-type (e) (new-ty) =
   when e
    is IrName (n) (t) (s) -> IrName n new-ty s
    is IrApply (f) (a) (t) (s) -> IrApply f a new-ty s
    is IrLet (n) (t) (v) (b) (s) -> IrLet n new-ty v b s
    is IrIf (c) (th) (el) (t) (s) -> IrIf c th el new-ty s
    is IrMatch (sc) (bs) (t) (s) -> IrMatch sc bs new-ty s
    is IrAct (ss) (t) (s) -> IrAct ss new-ty s
    is IrRecord (n) (fs) (t) (s) -> IrRecord n fs new-ty s
    is IrFieldAccess (r) (f) (t) (s) -> IrFieldAccess r f new-ty s
    is otherwise -> e

  ir-expr-span : IRExpr -> SourceSpan
  ir-expr-span (e) =
   when e
    is IrIntLit (v) (s) -> s
    is IrNumLit (v) (s) -> s
    is IrTextLit (v) (s) -> s
    is IrBoolLit (v) (s) -> s
    is IrCharLit (v) (s) -> s
    is IrName (n) (t) (s) -> s
    is IrBinary (op) (l) (r) (t) (s) -> s
    is IrNegate (x) (s) -> s
    is IrIf (c) (th) (el) (t) (s) -> s
    is IrLet (n) (t) (v) (b) (s) -> s
    is IrApply (f) (a) (t) (s) -> s
    is IrLambda (ps) (b) (t) (s) -> s
    is IrList (es) (t) (s) -> s
    is IrMatch (sc) (bs) (t) (s) -> s
    is IrAct (ss) (t) (s) -> s
    is IrHandle (eff) (h) (cs) (t) (s) -> s
    is IrRecord (n) (fs) (t) (s) -> s
    is IrFieldAccess (r) (f) (t) (s) -> s
    is IrFork (body) (t) (s) -> s
    is IrAwait (task) (t) (s) -> s
    is IrError (m) (t) (s) -> s

Page 1


Chapter: IR--Lowering
 Transforms the typed AST into the intermediate representation.
 Every IR node inherits the SourceSpan of the AST node it was
 lowered from, retagged ProvLowered.

Section: Lower Context
  LowerCtx = record {
   overlay : List TypeBinding,
   base : List TypeBinding,
   ust : UnificationState
  }

Section: Span Helper
  lowered-span : SourceSpan -> SourceSpan
  lowered-span (s) =
   span-with-provenance s ProvLowered

Section: Expression Lowering
  lower-expr : AExpr -> CodexType -> LowerCtx -> IRExpr
  lower-expr (e) (ty) (ctx) =
   when e
    is ALitExpr (text) (kind) (s) -> lower-literal text kind (lowered-span s)
    is ANameExpr (name) (s) -> lower-name (name.value) ty ctx (lowered-span s)
    is AApplyExpr (f) (a) (s) -> lower-apply f a ty ctx (lowered-span s)
    is ABinaryExpr (l) (op) (r) (s) ->
     let left-ir = lower-expr l ty ctx
     in let left-ty = ir-expr-type left-ir
     in let right-ir = lower-expr r ty ctx
     in IrBinary (lower-bin-op op left-ty) left-ir right-ir (binary-result-type op left-ty ty) (lowered-span s)
    is AUnaryExpr (operand) (s) -> IrNegate (lower-expr operand IntegerTy ctx) (lowered-span s)
    is AIfExpr (c) (t) (e2) (s) ->
     let resolved = deep-resolve (ctx.ust) ty
     in let then-ir = lower-expr t resolved ctx
     in let then-ty = ir-expr-type then-ir
     in let result-ty = when resolved
        is ErrorTy -> then-ty
        is otherwise -> resolved
     in let else-ir = lower-expr e2 result-ty ctx
     in IrIf (lower-expr c BooleanTy ctx) then-ir else-ir result-ty (lowered-span s)
    is ALetExpr (binds) (body) (s) -> lower-let binds body ty ctx (lowered-span s)
    is ALambdaExpr (params) (body) (s) -> lower-lambda params body ty ctx (lowered-span s)
    is AMatchExpr (scrut) (arms) (s) -> lower-match scrut arms ty ctx (lowered-span s)
    is AListExpr (elems) (s) -> lower-list elems ty ctx (lowered-span s)
    is ARecordExpr (name) (fields) (s) -> lower-record name fields ty ctx (lowered-span s)
    is AFieldAccess (rec) (field) (s) ->
     let rec-ir = lower-expr rec ErrorTy ctx
     in let rec-ty = deep-resolve (ctx.ust) (ir-expr-type rec-ir)
     in let stripped-rec-ty = when rec-ty
        is EffectfulTy (effs) (ret) -> deep-resolve (ctx.ust) ret
        is ForAllTy (id) (body) -> deep-resolve (ctx.ust) body
        is otherwise -> rec-ty
     in let resolved-rec-ty = when stripped-rec-ty
        is RecordTy (rn) (rf) -> stripped-rec-ty
        is ConstructedTy (cname) (cargs) ->
         let ctor-raw = lookup-type-split (ctx.overlay) (ctx.base) (cname.value)
     in let resolved-record = when ctor-raw
            is ErrorTy -> stripped-rec-ty
            is otherwise -> strip-fun-args-lower (deep-resolve (ctx.ust) ctor-raw)
     in when resolved-record
          is RecordTy (rn) (rf) -> resolved-record
          is otherwise -> stripped-rec-ty
        is otherwise -> stripped-rec-ty
     in let field-ty = when resolved-rec-ty
        is RecordTy (rname) (rfields) -> lookup-record-field rfields (field.value)
        is otherwise -> ty
     in let actual-field-ty = when field-ty
        is ErrorTy -> ty
        is otherwise -> field-ty
     in let fixed-rec = when rec-ty
        is RecordTy (rn) (rf) -> rec-ir
        is otherwise -> set-ir-expr-type rec-ir resolved-rec-ty
     in IrFieldAccess fixed-rec (field.value) actual-field-ty (lowered-span s)
    is AActExpr (stmts) (s) -> lower-act stmts ty ctx (lowered-span s)
    is AHandleExpr (eff) (body) (clauses) (s) -> lower-handle eff body clauses ty ctx (lowered-span s)
    is AErrorExpr (msg) (s) -> IrError msg ty (lowered-span s)

  lower-name : Text -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-name (name) (ty) (ctx) (sp) =
   let raw = lookup-type-split (ctx.overlay) (ctx.base) name
   in when raw
    is ErrorTy -> IrName name ty sp
    is otherwise ->
     let resolved = deep-resolve (ctx.ust) raw
   in let stripped = strip-forall-ty resolved
   in IrName name (prefer-applied-ty ty stripped) sp

  peel-effectful-ty : CodexType -> CodexType
  peel-effectful-ty (ty) =
   when ty
    is EffectfulTy (effs) (ret) -> peel-effectful-ty ret
    is otherwise -> ty

  prefer-applied-ty : CodexType -> CodexType -> CodexType
  prefer-applied-ty (expected) (stripped) =
   let peeled = peel-effectful-ty expected
   in when peeled
    is ConstructedTy (en) (eargs) ->
     if list-length eargs == 0 then stripped
     else when stripped
      is SumTy (sn) (sc) -> if en.value == sn.value then peeled else stripped
      is RecordTy (rn) (rf) -> if en.value == rn.value then peeled else stripped
      is ConstructedTy (cn) (cargs) -> if en.value == cn.value & list-length cargs == 0 then peeled else stripped
      is otherwise -> stripped
    is otherwise -> stripped

  lower-literal : Text -> LiteralKind -> SourceSpan -> IRExpr
  lower-literal (text) (kind) (sp) =
   when kind
    is IntLit -> IrIntLit (text-to-integer text) sp
    is NumLit -> IrNumLit (text-to-double-bits text) sp
    is TextLit -> IrTextLit text sp
    is CharLit -> IrCharLit (text-to-integer text) sp
    is BoolLit -> IrBoolLit (text == "True") sp

  lower-apply : AExpr -> AExpr -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-apply (f) (a) (ty) (ctx) (sp) =
   let func-ir = lower-expr f ErrorTy ctx
   in let func-ty = deep-resolve (ctx.ust) (ir-expr-type func-ir)
   in let arg-ty = peel-fun-param func-ty
   in let ret-ty = peel-fun-return func-ty
   in let arg-ir = lower-expr a arg-ty ctx
   in let resolved-ret = subst-type-vars-from-arg arg-ty (ir-expr-type arg-ir) ret-ty
   in let actual-ret = when resolved-ret
      is ErrorTy -> ty
      is otherwise -> resolved-ret
   in let preferred-ret = prefer-applied-ty ty actual-ret
   in lower-apply-dispatch func-ir arg-ir preferred-ret sp

  lower-apply-dispatch : IRExpr -> IRExpr -> CodexType -> SourceSpan -> IRExpr
  lower-apply-dispatch (func-ir) (arg-ir) (ret-ty) (sp) =
   when func-ir
    is IrName (n) (fty) (ns) ->
     if n == "fork" then IrFork arg-ir ret-ty sp
     else if n == "await" then IrAwait arg-ir ret-ty sp
     else IrApply func-ir arg-ir ret-ty sp
    is otherwise -> IrApply func-ir arg-ir ret-ty sp

Section: Let and Lambda
  lower-let : List ALetBind -> AExpr -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-let (binds) (body) (ty) (ctx) (sp) =
   if list-length binds == 0 then lower-expr body ty ctx
   else let b = list-at binds 0
   in let val-ir = lower-expr (b.value) ErrorTy ctx
   in let val-ty = deep-resolve (ctx.ust) (ir-expr-type val-ir)
   in let ctx2 = LowerCtx {
    overlay = [TypeBinding {
     name = b.name.value,
     bound-type = val-ty
    }] ++ ctx.overlay,
    base = ctx.base,
    ust = ctx.ust
   }
   in IrLet (b.name.value) val-ty val-ir (lower-let-rest binds body ty ctx2 1 sp) sp

  lower-let-rest : List ALetBind -> AExpr -> CodexType -> LowerCtx -> Integer -> SourceSpan -> IRExpr
  lower-let-rest (binds) (body) (ty) (ctx) (i) (sp) =
   if i == list-length binds then lower-expr body ty ctx
   else let b = list-at binds i
   in let val-ir = lower-expr (b.value) ErrorTy ctx
   in let val-ty = deep-resolve (ctx.ust) (ir-expr-type val-ir)
   in let ctx2 = LowerCtx {
    overlay = [TypeBinding {
     name = b.name.value,
     bound-type = val-ty
    }] ++ ctx.overlay,
    base = ctx.base,
    ust = ctx.ust
   }
   in IrLet (b.name.value) val-ty val-ir (lower-let-rest binds body ty ctx2 (i + 1) sp) sp

  lower-lambda : List Name -> AExpr -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-lambda (params) (body) (ty) (ctx) (sp) =
   let stripped = strip-forall-ty ty
   in let lparams = lower-lambda-params params stripped 0 sp
   in let lctx = bind-lambda-to-ctx ctx params stripped 0
   in IrLambda lparams (lower-expr body (get-lambda-return stripped (list-length params)) lctx) ty sp

  bind-lambda-to-ctx : LowerCtx -> List Name -> CodexType -> Integer -> LowerCtx
  bind-lambda-to-ctx (ctx) (params) (ty) (i) =
   if i == list-length params then ctx
   else let p = list-at params i
   in let param-ty = peel-fun-param ty
   in let rest-ty = peel-fun-return ty
   in let ctx2 = LowerCtx {
    overlay = [TypeBinding {
     name = p.value,
     bound-type = param-ty
    }] ++ ctx.overlay,
    base = ctx.base,
    ust = ctx.ust
   }
   in bind-lambda-to-ctx ctx2 params rest-ty (i + 1)

  lower-lambda-params : List Name -> CodexType -> Integer -> SourceSpan -> List IRParam
  lower-lambda-params (params) (ty) (i) (sp) =
   lower-lambda-params-acc params ty i sp []

  lower-lambda-params-acc : List Name -> CodexType -> Integer -> SourceSpan -> List IRParam -> List IRParam
  lower-lambda-params-acc (params) (ty) (i) (sp) (acc) =
   if i == list-length params then acc
   else let p = list-at params i
   in let param-ty = peel-fun-param ty
   in let rest-ty = peel-fun-return ty
   in lower-lambda-params-acc params rest-ty (i + 1) sp (list-snoc acc (IRParam {
    name = p.value,
    type-val = param-ty,
    span = sp
   }))

  get-lambda-return : CodexType -> Integer -> CodexType
  get-lambda-return (ty) (n) =
   if n == 0 then ty
   else when ty
    is FunTy (p) (r) -> get-lambda-return r (n - 1)
    is otherwise -> ErrorTy

Section: Match Lowering
  lower-match : AExpr -> List AMatchArm -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-match (scrut) (arms) (ty) (ctx) (sp) =
   let scrut-ir = lower-expr scrut ErrorTy ctx
   in let scrut-ty = ir-expr-type scrut-ir
   in let branches = lower-match-arms-loop arms ty scrut-ty ctx 0 (list-length arms)
   in let result-ty = when ty
      is ErrorTy -> infer-match-type branches 0 (list-length branches)
      is otherwise -> ty
   in IrMatch scrut-ir branches result-ty sp

  infer-match-type : List IRBranch -> Integer -> Integer -> CodexType
  infer-match-type (branches) (i) (len) =
   if i == len then ErrorTy
   else let b = list-at branches i
   in let body-ty = ir-expr-type (b.body)
   in when body-ty
     is ErrorTy -> infer-match-type branches (i + 1) len
     is otherwise -> body-ty

  lower-match-arms-loop : List AMatchArm -> CodexType -> CodexType -> LowerCtx -> Integer -> Integer -> List IRBranch
  lower-match-arms-loop (arms) (ty) (scrut-ty) (ctx) (i) (len) =
   lower-match-arms-acc arms ty scrut-ty ctx i len []

  lower-match-arms-acc : List AMatchArm -> CodexType -> CodexType -> LowerCtx -> Integer -> Integer -> List IRBranch -> List IRBranch
  lower-match-arms-acc (arms) (ty) (scrut-ty) (ctx) (i) (len) (acc) =
   if i == len then acc
   else let arm = list-at arms i
   in let arm-ctx = bind-pattern-to-ctx ctx (arm.pattern) scrut-ty
   in lower-match-arms-acc arms ty scrut-ty ctx (i + 1) len (list-snoc acc (IRBranch {
    pattern = lower-pattern (arm.pattern) scrut-ty,
    body = lower-expr (arm.body) ty arm-ctx,
    span = arm.span
   }))

  bind-pattern-to-ctx : LowerCtx -> APat -> CodexType -> LowerCtx
  bind-pattern-to-ctx (ctx) (pat) (ty) =
   when pat
    is AVarPat (name) (s) ->
     LowerCtx {
      overlay = [TypeBinding {
       name = name.value,
       bound-type = ty
      }] ++ ctx.overlay,
      base = ctx.base,
      ust = ctx.ust
     }
    is ACtorPat (ctor-name) (sub-pats) (s) ->
     let ctor-raw = lookup-type-split (ctx.overlay) (ctx.base) (ctor-name.value)
     in let ctor-ty = deep-resolve (ctx.ust) ctor-raw
     in let ctor-stripped = strip-forall-ty ctor-ty
     in bind-ctor-pattern-fields ctx sub-pats ctor-stripped 0 (list-length sub-pats)
    is AWildPat (s) -> ctx
    is ALitPat (text) (kind) (s) -> ctx

  bind-ctor-pattern-fields : LowerCtx -> List APat -> CodexType -> Integer -> Integer -> LowerCtx
  bind-ctor-pattern-fields (ctx) (sub-pats) (ctor-ty) (i) (len) =
   if i == len then ctx
   else when ctor-ty
     is FunTy (param-ty) (ret-ty) ->
      let ctx2 = bind-pattern-to-ctx ctx (list-at sub-pats i) param-ty
      in bind-ctor-pattern-fields ctx2 sub-pats ret-ty (i + 1) len
     is otherwise ->
      let ctx2 = bind-pattern-to-ctx ctx (list-at sub-pats i) ErrorTy
      in bind-ctor-pattern-fields ctx2 sub-pats ctor-ty (i + 1) len

  lower-pattern : APat -> CodexType -> IRPat
  lower-pattern (p) (scrut-ty) =
   when p
    is AVarPat (name) (s) -> IrVarPat (name.value) scrut-ty (lowered-span s)
    is ALitPat (text) (kind) (s) -> IrLitPat text scrut-ty (lowered-span s)
    is ACtorPat (name) (subs) (s) -> IrCtorPat (name.value) (lower-ctor-sub-patterns subs scrut-ty (name.value) 0) scrut-ty (lowered-span s)
    is AWildPat (s) -> IrWildPat (lowered-span s)

  lower-ctor-sub-patterns : List APat -> CodexType -> Text -> Integer -> List IRPat
  lower-ctor-sub-patterns (subs) (scrut-ty) (ctor-name) (i) =
   if i == list-length subs then []
   else let field-ty = lookup-ctor-field-type scrut-ty ctor-name i
   in [lower-pattern (list-at subs i) field-ty] ++ lower-ctor-sub-patterns subs scrut-ty ctor-name (i + 1)

  lookup-ctor-field-type : CodexType -> Text -> Integer -> CodexType
  lookup-ctor-field-type (ty) (ctor-name) (field-idx) =
   when ty
    is SumTy (sname) (ctors) -> find-ctor-field-type ctors ctor-name field-idx 0
    is otherwise -> ErrorTy

  find-ctor-field-type : List SumCtor -> Text -> Integer -> Integer -> CodexType
  find-ctor-field-type (ctors) (ctor-name) (field-idx) (i) =
   if i == list-length ctors then ErrorTy
   else let c = list-at ctors i
   in if c.name.value == ctor-name then if field-idx < list-length (c.fields) then list-at (c.fields) field-idx else ErrorTy
      else find-ctor-field-type ctors ctor-name field-idx (i + 1)

Section: Collections and Act
  lower-list : List AExpr -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-list (elems) (ty) (ctx) (sp) =
   let resolved = deep-resolve (ctx.ust) ty
   in let elem-ty = when resolved
      is ListTy (e) -> e
      is otherwise ->
       if list-length elems == 0 then ErrorTy
       else ir-expr-type (lower-expr (list-at elems 0) ErrorTy ctx)
   in IrList (lower-list-elems-loop elems elem-ty ctx 0 (list-length elems)) elem-ty sp

  lower-list-elems-loop : List AExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRExpr
  lower-list-elems-loop (elems) (elem-ty) (ctx) (i) (len) =
   lower-list-elems-acc elems elem-ty ctx i len []

  lower-list-elems-acc : List AExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRExpr -> List IRExpr
  lower-list-elems-acc (elems) (elem-ty) (ctx) (i) (len) (acc) =
   if i == len then acc
   else lower-list-elems-acc elems elem-ty ctx (i + 1) len (list-snoc acc (lower-expr (list-at elems i) elem-ty ctx))

  lower-record : Name -> List AFieldExpr -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-record (name) (fields) (ty) (ctx) (sp) =
   let ctor-raw = lookup-type-split (ctx.overlay) (ctx.base) (name.value)
   in let record-ty = when ctor-raw
      is ErrorTy -> ty
      is otherwise -> strip-fun-args-lower (deep-resolve (ctx.ust) ctor-raw)
   in let actual-ty = when record-ty
      is ErrorTy -> ty
      is otherwise -> record-ty
   in IrRecord (name.value) (lower-record-fields-typed fields actual-ty ctx 0 (list-length fields)) actual-ty sp

  lower-record-fields-typed : List AFieldExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRFieldVal
  lower-record-fields-typed (fields) (record-ty) (ctx) (i) (len) =
   lower-record-fields-acc fields record-ty ctx i len []

  lower-record-fields-acc : List AFieldExpr -> CodexType -> LowerCtx -> Integer -> Integer -> List IRFieldVal -> List IRFieldVal
  lower-record-fields-acc (fields) (record-ty) (ctx) (i) (len) (acc) =
   if i == len then acc
   else let f = list-at fields i
   in let field-expected = when record-ty
       is RecordTy (rname) (rfields) -> lookup-record-field rfields (f.name.value)
       is otherwise -> ErrorTy
   in lower-record-fields-acc fields record-ty ctx (i + 1) len (list-snoc acc (IRFieldVal {
    name = f.name.value,
    value = lower-expr (f.value) field-expected ctx,
    span = f.span
   }))

  lower-act : List AActStmt -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-act (stmts) (ty) (ctx) (sp) =
   let lowered = lower-act-stmts-loop stmts ty ctx 0 (list-length stmts)
   in let act-ty = act-block-type lowered ty
   in IrAct lowered act-ty sp

  act-block-type : List IRActStmt -> CodexType -> CodexType
  act-block-type (stmts) (fallback) =
   if list-length stmts == 0 then fallback
   else let last = list-at stmts (list-length stmts - 1)
   in when last
     is IrDoExec (e) (sp) -> ir-expr-type e
     is IrDoBind (nm) (bty) (e) (sp) -> bty

  lower-act-stmts-loop : List AActStmt -> CodexType -> LowerCtx -> Integer -> Integer -> List IRActStmt
  lower-act-stmts-loop (stmts) (ty) (ctx) (i) (len) =
   lower-act-stmts-acc stmts ty ctx i len []

  lower-act-stmts-acc : List AActStmt -> CodexType -> LowerCtx -> Integer -> Integer -> List IRActStmt -> List IRActStmt
  lower-act-stmts-acc (stmts) (ty) (ctx) (i) (len) (acc) =
   if i == len then acc
   else let s = list-at stmts i
   in when s
     is AActBindStmt (name) (val) (sp) ->
      let val-ir = lower-expr val ty ctx
   in let val-ty = ir-expr-type val-ir
   in let ctx2 = LowerCtx {
       overlay = [TypeBinding {
        name = name.value,
        bound-type = val-ty
       }] ++ ctx.overlay,
       base = ctx.base,
       ust = ctx.ust
      }
   in lower-act-stmts-acc stmts ty ctx2 (i + 1) len (list-snoc acc (IrDoBind (name.value) val-ty val-ir (lowered-span sp)))
     is AActExprStmt (e) (sp) ->
      lower-act-stmts-acc stmts ty ctx (i + 1) len (list-snoc acc (IrDoExec (lower-expr e ty ctx) (lowered-span sp)))

  lower-handle : Name -> AExpr -> List AHandleClause -> CodexType -> LowerCtx -> SourceSpan -> IRExpr
  lower-handle (eff) (body) (clauses) (ty) (ctx) (sp) =
   let body-ir = lower-expr body ty ctx
   in IrHandle (eff.value) body-ir (lower-handle-clauses clauses ty ctx) ty sp

  lower-handle-clauses : List AHandleClause -> CodexType -> LowerCtx -> List IRHandleClause
  lower-handle-clauses (clauses) (ty) (ctx) =
   lower-handle-clauses-loop clauses ty ctx 0

  lower-handle-clauses-loop : List AHandleClause -> CodexType -> LowerCtx -> Integer -> List IRHandleClause
  lower-handle-clauses-loop (clauses) (ty) (ctx) (i) =
   lower-handle-clauses-acc clauses ty ctx i []

  lower-handle-clauses-acc : List AHandleClause -> CodexType -> LowerCtx -> Integer -> List IRHandleClause -> List IRHandleClause
  lower-handle-clauses-acc (clauses) (ty) (ctx) (i) (acc) =
   if i == list-length clauses then acc
   else let c = list-at clauses i
   in let body-ir = lower-expr (c.body) ty ctx
   in lower-handle-clauses-acc clauses ty ctx (i + 1) (list-snoc acc (IRHandleClause {
    op-name = c.op-name.value,
    resume-name = c.resume-name.value,
    body = body-ir,
    span = c.span
   }))

Section: Definition Lowering
  lower-def : ADef -> List TypeBinding -> UnificationState -> IRDef
  lower-def (d) (types) (ust) =
   let raw-type = lookup-type-bsearch types (d.name.value)
   in let full-type = deep-resolve ust raw-type
   in let stripped = strip-forall-ty full-type
   in let params = lower-def-params (d.params) stripped 0
   in let ret-type = get-return-type-n stripped (list-length (d.params))
   in let ctx = build-def-ctx types ust (d.params) stripped
   in IRDef {
    name = d.name.value,
    params = params,
    type-val = full-type,
    body = lower-expr (d.body) ret-type ctx,
    chapter-slug = d.chapter-slug,
    span = d.span
   }

  build-def-ctx : List TypeBinding -> UnificationState -> List AParam -> CodexType -> LowerCtx
  build-def-ctx (types) (ust) (params) (ty) =
   let base-ctx = LowerCtx {
    overlay = [],
    base = types,
    ust = ust
   }
   in bind-params-to-ctx base-ctx params ty 0

  bind-params-to-ctx : LowerCtx -> List AParam -> CodexType -> Integer -> LowerCtx
  bind-params-to-ctx (ctx) (params) (ty) (i) =
   if i == list-length params then ctx
   else let p = list-at params i
   in let param-ty = peel-fun-param ty
   in let rest-ty = peel-fun-return ty
   in let ctx2 = LowerCtx {
    overlay = [TypeBinding {
     name = p.name.value,
     bound-type = param-ty
    }] ++ ctx.overlay,
    base = ctx.base,
    ust = ctx.ust
   }
   in bind-params-to-ctx ctx2 params rest-ty (i + 1)

  lower-def-params : List AParam -> CodexType -> Integer -> List IRParam
  lower-def-params (params) (ty) (i) =
   lower-def-params-acc params ty i []

  lower-def-params-acc : List AParam -> CodexType -> Integer -> List IRParam -> List IRParam
  lower-def-params-acc (params) (ty) (i) (acc) =
   if i == list-length params then acc
   else let p = list-at params i
   in let param-ty = peel-fun-param ty
   in let rest-ty = peel-fun-return ty
   in lower-def-params-acc params rest-ty (i + 1) (list-snoc acc (IRParam {
    name = p.name.value,
    type-val = param-ty,
    span = p.span
   }))

  get-return-type-n : CodexType -> Integer -> CodexType
  get-return-type-n (ty) (n) =
   if n == 0 then ty
   else when ty
    is FunTy (p) (r) -> get-return-type-n r (n - 1)
    is otherwise -> ErrorTy

  lower-chapter : AChapter -> List TypeBinding -> UnificationState -> IRChapter
  lower-chapter (m) (types) (ust) =
   let ctor-types = collect-ctor-bindings (m.type-defs) 0 (list-length (m.type-defs)) []
   in let all-types = sort-bindings (ctor-types ++ types ++ builtin-type-env.bindings)
   in IRChapter {
    name = m.name,
    defs = lower-defs (m.defs) all-types ust 0,
    chapter-title = m.chapter-title,
    prose = m.prose,
    section-titles = m.section-titles,
    span = m.span
   }

  lower-defs : List ADef -> List TypeBinding -> UnificationState -> Integer -> List IRDef
  lower-defs (defs) (types) (ust) (i) =
   lower-defs-acc defs types ust i []

  lower-defs-acc : List ADef -> List TypeBinding -> UnificationState -> Integer -> List IRDef -> List IRDef
  lower-defs-acc (defs) (types) (ust) (i) (acc) =
   if i == list-length defs then acc
   else lower-defs-acc defs types ust (i + 1) (list-snoc acc (lower-def (list-at defs i) types ust))

Page 1 of 2


Chapter: IR--Lowering
 Type lookup, substitution, and constructor binding utilities
 used by the main lowering pass.

Section: Type Lookup
  lookup-type : List TypeBinding -> Text -> CodexType
  lookup-type (bindings) (name) =
   lookup-type-loop bindings name 0 (list-length bindings)

  lookup-type-loop : List TypeBinding -> Text -> Integer -> Integer -> CodexType
  lookup-type-loop (bindings) (name) (i) (len) =
   if i == len then ErrorTy
   else let b = list-at bindings i
   in if b.name == name then b.bound-type
      else lookup-type-loop bindings name (i + 1) len

  lookup-type-bsearch : List TypeBinding -> Text -> CodexType
  lookup-type-bsearch (bindings) (name) =
   let len = list-length bindings
   in if len == 0 then ErrorTy
   else let pos = bsearch-text-pos bindings name 0 len
   in if pos >= len then ErrorTy
   else let b = list-at bindings pos
   in if b.name == name then b.bound-type else ErrorTy

  lookup-type-split : List TypeBinding -> List TypeBinding -> Text -> CodexType
  lookup-type-split (overlay) (base) (name) =
   let overlay-hit = lookup-type-loop overlay name 0 (list-length overlay)
   in when overlay-hit
    is ErrorTy -> lookup-type-bsearch base name
    is otherwise -> overlay-hit

  sort-bindings-loop : List TypeBinding -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  sort-bindings-loop (xs) (i) (len) (acc) =
   if i == len then acc
   else let b = list-at xs i
   in let acc-len = list-length acc
   in let pos = bsearch-text-pos acc (b.name) 0 acc-len
   in if pos < acc-len then if (list-at acc pos).name == b.name then sort-bindings-loop xs (i + 1) len acc
      else sort-bindings-loop xs (i + 1) len (list-insert-at acc pos b)
      else sort-bindings-loop xs (i + 1) len (list-insert-at acc pos b)

  sort-bindings : List TypeBinding -> List TypeBinding
  sort-bindings (xs) = sort-bindings-loop xs 0 (list-length xs) []

  peel-fun-param : CodexType -> CodexType
  peel-fun-param (ty) =
   when ty
    is FunTy (p) (r) -> p
    is ForAllTy (id) (body) -> peel-fun-param body
    is otherwise -> ErrorTy

  peel-fun-return : CodexType -> CodexType
  peel-fun-return (ty) =
   when ty
    is FunTy (p) (r) -> r
    is ForAllTy (id) (body) -> peel-fun-return body
    is otherwise -> ErrorTy

  strip-forall-ty : CodexType -> CodexType
  strip-forall-ty (ty) =
   when ty
    is ForAllTy (id) (body) -> strip-forall-ty body
    is otherwise -> ty

Section: Type Substitution
  subst-type-vars-from-arg : CodexType -> CodexType -> CodexType -> CodexType
  subst-type-vars-from-arg (param-ty) (arg-ty) (target) =
   when param-ty
    is TypeVar (id) -> subst-type-var-in-target target id arg-ty
    is ListTy (pe) -> subst-from-list pe arg-ty target
    is FunTy (pp) (pr) -> subst-from-fun pp pr arg-ty target
    is otherwise -> target

  subst-from-list : CodexType -> CodexType -> CodexType -> CodexType
  subst-from-list (pe) (arg-ty) (target) =
   when arg-ty
    is ListTy (ae) -> subst-type-vars-from-arg pe ae target
    is otherwise -> target

  subst-from-fun : CodexType -> CodexType -> CodexType -> CodexType -> CodexType
  subst-from-fun (pp) (pr) (arg-ty) (target) =
   when arg-ty
    is FunTy (ap) (ar) ->
     let t2 = subst-type-vars-from-arg pp ap target
     in subst-type-vars-from-arg pr ar t2
    is otherwise -> target

  subst-type-var-in-target : CodexType -> Integer -> CodexType -> CodexType
  subst-type-var-in-target (ty) (var-id) (replacement) =
   when ty
    is TypeVar (id) -> if id == var-id then replacement else ty
    is FunTy (p) (r) -> FunTy (subst-type-var-in-target p var-id replacement) (subst-type-var-in-target r var-id replacement)
    is ListTy (elem) -> ListTy (subst-type-var-in-target elem var-id replacement)
    is ForAllTy (fid) (body) ->
     if fid == var-id then ty
     else ForAllTy fid (subst-type-var-in-target body var-id replacement)
    is otherwise -> ty

  strip-fun-args-lower : CodexType -> CodexType
  strip-fun-args-lower (ty) =
   when ty
    is FunTy (p) (r) -> strip-fun-args-lower r
    is ForAllTy (id) (body) -> strip-fun-args-lower body
    is otherwise -> ty

  is-text-type : CodexType -> Boolean
  is-text-type (ty) =
   when ty
    is TextTy -> True
    is otherwise -> False

Section: Constructor Bindings
  collect-ctor-bindings : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  collect-ctor-bindings (tdefs) (i) (len) (acc) =
   if i == len then acc
   else let td = list-at tdefs i
   in let bindings = ctor-bindings-for-typedef td
   in collect-ctor-bindings tdefs (i + 1) len (acc ++ bindings)

  ctor-bindings-for-typedef : ATypeDef -> List TypeBinding
  ctor-bindings-for-typedef (td) =
   when td
    is AVariantTypeDef (name) (type-params) (ctors) (s) ->
     let sum-ctors = build-sum-ctors ctors 0 (list-length ctors) []
     in let result-ty = SumTy name sum-ctors
     in [TypeBinding { name = name.value, bound-type = result-ty }] ++ collect-variant-ctor-bindings ctors result-ty 0 (list-length ctors) []
    is ARecordTypeDef (name) (type-params) (fields) (s) ->
     let resolved-fields = build-record-fields fields 0 (list-length fields) []
     in let result-ty = RecordTy name resolved-fields
     in let ctor-ty = build-record-ctor-type fields result-ty 0 (list-length fields)
     in [TypeBinding {
      name = name.value,
      bound-type = ctor-ty
     }]

  build-sum-ctors : List AVariantCtorDef -> Integer -> Integer -> List SumCtor -> List SumCtor
  build-sum-ctors (ctors) (i) (len) (acc) =
   if i == len then acc
   else let c = list-at ctors i
   in build-sum-ctors ctors (i + 1) len (list-snoc acc (SumCtor {
    name = c.name,
    fields = []
   }))

  collect-variant-ctor-bindings : List AVariantCtorDef -> CodexType -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  collect-variant-ctor-bindings (ctors) (result-ty) (i) (len) (acc) =
   if i == len then acc
   else let ctor = list-at ctors i
   in let ctor-ty = build-ctor-type (ctor.fields) result-ty 0 (list-length (ctor.fields))
   in collect-variant-ctor-bindings ctors result-ty (i + 1) len (list-snoc acc (TypeBinding {
    name = ctor.name.value,
    bound-type = ctor-ty
   }))

  build-ctor-type : List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
  build-ctor-type (fields) (result) (i) (len) =
   if i == len then result
   else let rest = build-ctor-type fields result (i + 1) len
   in FunTy (resolve-type-expr (list-at fields i)) rest

  build-record-fields : List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
  build-record-fields (fields) (i) (len) (acc) =
   if i == len then acc
   else let f = list-at fields i
   in let rfield = RecordField {
    name = f.name,
    type-val = resolve-type-expr (f.type-expr)
   }
   in build-record-fields fields (i + 1) len (list-snoc acc rfield)

  build-record-ctor-type : List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
  build-record-ctor-type (fields) (result) (i) (len) =
   if i == len then result
   else let f = list-at fields i
   in let rest = build-record-ctor-type fields result (i + 1) len
   in FunTy (resolve-type-expr (f.type-expr)) rest

  resolve-type-expr-list : List ATypeExpr -> Integer -> Integer -> List CodexType -> List CodexType
  resolve-type-expr-list (args) (i) (len) (acc) =
   if i == len then acc
   else resolve-type-expr-list args (i + 1) len (list-snoc acc (resolve-type-expr (list-at args i)))

  resolve-type-expr : ATypeExpr -> CodexType
  resolve-type-expr (texpr) =
   when texpr
    is ANamedType (name) (s) ->
     if name.value == "Integer" then IntegerTy
     else if name.value == "Number" then NumberTy
     else if name.value == "Text" then TextTy
     else if name.value == "Boolean" then BooleanTy
     else if name.value == "Nothing" then NothingTy
     else ConstructedTy name []
    is AFunType (param) (ret) (s) -> FunTy (resolve-type-expr param) (resolve-type-expr ret)
    is AAppType (ctor) (args) (s) ->
     when ctor
      is ANamedType (cname) (s2) ->
       if cname.value == "List" then if list-length args == 1 then ListTy (resolve-type-expr (list-at args 0))
         else ListTy ErrorTy
        else ConstructedTy cname (resolve-type-expr-list args 0 (list-length args) [])
      is otherwise -> ErrorTy
    is AEffectType (effs) (ret) (s) -> EffectfulTy effs (resolve-type-expr ret)

Section: Binary Op Lowering
  is-number-type : CodexType -> Boolean
  is-number-type (ty) =
   when ty
    is NumberTy -> True
    is otherwise -> False

  lower-bin-op : BinaryOp -> CodexType -> IRBinaryOp
  lower-bin-op (op) (ty) =
   when op
    is OpAdd -> if is-number-type ty then IrAddNum else IrAddInt
    is OpSub -> if is-number-type ty then IrSubNum else IrSubInt
    is OpMul -> if is-number-type ty then IrMulNum else IrMulInt
    is OpDiv -> if is-number-type ty then IrDivNum else IrDivInt
    is OpPow -> IrPowInt
    is OpEq -> IrEq
    is OpNotEq -> IrNotEq
    is OpLt -> IrLt
    is OpGt -> IrGt
    is OpLtEq -> IrLtEq
    is OpGtEq -> IrGtEq
    is OpDefEq -> IrEq
    is OpAppend -> if is-text-type ty then IrAppendText else IrAppendList
    is OpCons -> IrConsList
    is OpAnd -> IrAnd
    is OpOr -> IrOr

  binary-result-type : BinaryOp -> CodexType -> CodexType -> CodexType
  binary-result-type (op) (left-ty) (expected-ty) =
   when op
    is OpEq -> BooleanTy
    is OpNotEq -> BooleanTy
    is OpLt -> BooleanTy
    is OpGt -> BooleanTy
    is OpLtEq -> BooleanTy
    is OpGtEq -> BooleanTy
    is OpDefEq -> BooleanTy
    is OpAnd -> BooleanTy
    is OpOr -> BooleanTy
    is OpAppend -> if is-text-type left-ty then TextTy
           else if is-text-type expected-ty then TextTy
           else left-ty
    is otherwise -> left-ty

Page 2 of 2



Chapter: Semantics--Chapter Scoper
 Resolves name collisions across chapters by prefixing duplicate
 definition names with their chapter slug. Only colliding names
 (defined in 2+ chapters) are renamed. Non-colliding names pass
 through unchanged.

Section: Chapter Assignment
  ChapterAssignment = record {
   def-name : Text,
   chapter-slug : Text
  }

  assign-chapters : List DefHeader -> Text -> Integer -> List ChapterAssignment -> List ChapterAssignment
  assign-chapters (headers) (current-chapter) (i) (acc) =
   if i == list-length headers then acc
   else let hdr = list-at headers i
   in assign-chapters headers current-chapter (i + 1) (list-snoc acc (ChapterAssignment {
    def-name = hdr.name.text,
    chapter-slug = current-chapter
   }))

Section: Collision Detection
  find-colliding-names : List ChapterAssignment -> List Text
  find-colliding-names (assignments) =
   find-collisions-loop assignments 0 (list-length assignments) []

  find-collisions-loop : List ChapterAssignment -> Integer -> Integer -> List Text -> List Text
  find-collisions-loop (assignments) (i) (len) (acc) =
   if i == len then acc
   else let a = list-at assignments i
   in if list-contains acc (a.def-name) then find-collisions-loop assignments (i + 1) len acc
      else if appears-in-different-chapter assignments (a.def-name) (a.chapter-slug) 0 len then find-collisions-loop assignments (i + 1) len (list-snoc acc (a.def-name))
      else find-collisions-loop assignments (i + 1) len acc

  appears-in-different-chapter : List ChapterAssignment -> Text -> Text -> Integer -> Integer -> Boolean
  appears-in-different-chapter (assignments) (name) (chapter-slug) (i) (len) =
   if i == len then False
   else let a = list-at assignments i
   in if a.def-name == name then if a.chapter-slug /= chapter-slug then True
      else appears-in-different-chapter assignments name chapter-slug (i + 1) len
      else appears-in-different-chapter assignments name chapter-slug (i + 1) len

Section: Name Mangling
  mangle-name : Text -> Text -> Text
  mangle-name (chapter-slug) (def-name) =
   slugify chapter-slug ++ "_" ++ def-name

  slugify-loop : Text -> Integer -> Integer -> List Text -> List Text
  slugify-loop (s) (i) (len) (acc) =
   if i == len then acc
   else let c = char-code-at s i
   in if c == char-code-at " " 0 then slugify-loop s (i + 1) len (list-snoc acc "-")
      else if c >= cc-first-upper then if c <= cc-upper-z then slugify-loop s (i + 1) len (list-snoc acc (char-to-text (code-to-char (c - 26))))
      else slugify-loop s (i + 1) len (list-snoc acc (char-to-text (code-to-char c)))
      else slugify-loop s (i + 1) len (list-snoc acc (char-to-text (code-to-char c)))

  slugify : Text -> Text
  slugify (s) = text-concat-list (slugify-loop s 0 (text-length s) [])

  lookup-chapter : List ChapterAssignment -> Text -> Text
  lookup-chapter (assignments) (name) =
   lookup-chapter-loop assignments name 0 (list-length assignments)

  lookup-chapter-loop : List ChapterAssignment -> Text -> Integer -> Integer -> Text
  lookup-chapter-loop (assignments) (name) (i) (len) =
   if i == len then ""
   else let a = list-at assignments i
   in if a.def-name == name then a.chapter-slug
      else lookup-chapter-loop assignments name (i + 1) len

Section: Rename Map
  RenameEntry = record {
   original : Text,
   mangled : Text
  }

  build-rename-map : List Text -> List ChapterAssignment -> Text -> List RenameEntry
  build-rename-map (colliding) (assignments) (current-chapter) =
   build-rename-map-loop colliding assignments current-chapter 0 (list-length colliding) []

  build-rename-map-loop : List Text -> List ChapterAssignment -> Text -> Integer -> Integer -> List RenameEntry -> List RenameEntry
  build-rename-map-loop (colliding) (assignments) (current-chapter) (i) (len) (acc) =
   if i == len then acc
   else let name = list-at colliding i
   in let slug = lookup-chapter assignments name
   in let entry = RenameEntry {
    original = name,
    mangled = mangle-name slug name
   }
   in build-rename-map-loop colliding assignments current-chapter (i + 1) len (list-snoc acc entry)

Section: Apply Rename
  rename-lookup : List RenameEntry -> Text -> Text
  rename-lookup (entries) (name) =
   rename-lookup-loop entries name 0 (list-length entries)

  rename-lookup-loop : List RenameEntry -> Text -> Integer -> Integer -> Text
  rename-lookup-loop (entries) (name) (i) (len) =
   if i == len then name
   else let e = list-at entries i
   in if e.original == name then e.mangled
      else rename-lookup-loop entries name (i + 1) len

  is-colliding : List Text -> Text -> Boolean
  is-colliding (names) (name) =
   list-contains names name

Section: IR Expression Renaming
  remove-rename : List RenameEntry -> Text -> List RenameEntry
  remove-rename (entries) (name) =
   remove-rename-loop entries name 0 (list-length entries) []

  remove-rename-loop : List RenameEntry -> Text -> Integer -> Integer -> List RenameEntry -> List RenameEntry
  remove-rename-loop (entries) (name) (i) (len) (acc) =
   if i == len then acc
   else let e = list-at entries i
   in if e.original == name then remove-rename-loop entries name (i + 1) len acc
      else remove-rename-loop entries name (i + 1) len (list-snoc acc e)

  remove-renames-for-params : List RenameEntry -> List IRParam -> Integer -> List RenameEntry
  remove-renames-for-params (entries) (params) (i) =
   if i == list-length params then entries
   else let p = list-at params i
   in remove-renames-for-params (remove-rename entries (p.name)) params (i + 1)

  rename-ir-expr : List RenameEntry -> IRExpr -> IRExpr
  rename-ir-expr (rn) (e) =
   when e
    is IrIntLit (v) (sp) -> e
    is IrNumLit (v) (sp) -> e
    is IrTextLit (v) (sp) -> e
    is IrBoolLit (v) (sp) -> e
    is IrCharLit (v) (sp) -> e
    is IrError (msg) (ty) (sp) -> e
    is IrFork (x) (ty) (sp) -> IrFork (rename-ir-expr rn x) ty sp
    is IrAwait (x) (ty) (sp) -> IrAwait (rename-ir-expr rn x) ty sp
    is IrNegate (x) (sp) -> IrNegate (rename-ir-expr rn x) sp
    is IrName (n) (ty) (sp) -> IrName (rename-lookup rn n) ty sp
    is IrBinary (op) (l) (r) (ty) (sp) -> IrBinary op (rename-ir-expr rn l) (rename-ir-expr rn r) ty sp
    is IrApply (f) (a) (ty) (sp) -> IrApply (rename-ir-expr rn f) (rename-ir-expr rn a) ty sp
    is IrIf (c) (t) (el) (ty) (sp) -> IrIf (rename-ir-expr rn c) (rename-ir-expr rn t) (rename-ir-expr rn el) ty sp
    is IrFieldAccess (rec) (field) (ty) (sp) -> IrFieldAccess (rename-ir-expr rn rec) field ty sp
    is IrLet (nm) (ty) (val) (body) (sp) -> rename-ir-let rn nm ty val body sp
    is IrLambda (params) (body) (ty) (sp) -> rename-ir-lambda rn params body ty sp
    is IrMatch (scrut) (branches) (ty) (sp) -> IrMatch (rename-ir-expr rn scrut) (rename-ir-branches rn branches 0 []) ty sp
    is IrList (elems) (ty) (sp) -> IrList (rename-ir-exprs rn elems 0 []) ty sp
    is IrRecord (nm) (fields) (ty) (sp) -> IrRecord nm (rename-ir-fields rn fields 0 []) ty sp
    is IrAct (stmts) (ty) (sp) -> IrAct (rename-ir-act-stmts rn stmts 0 []) ty sp
    is IrHandle (eff) (body) (clauses) (ty) (sp) -> IrHandle eff (rename-ir-expr rn body) (rename-ir-handle-clauses rn clauses 0 []) ty sp

  rename-ir-let : List RenameEntry -> Text -> CodexType -> IRExpr -> IRExpr -> SourceSpan -> IRExpr
  rename-ir-let (rn) (nm) (ty) (val) (body) (sp) =
   let rn2 = remove-rename rn nm
   in IrLet nm ty (rename-ir-expr rn val) (rename-ir-expr rn2 body) sp

  rename-ir-lambda : List RenameEntry -> List IRParam -> IRExpr -> CodexType -> SourceSpan -> IRExpr
  rename-ir-lambda (rn) (params) (body) (ty) (sp) =
   let rn2 = remove-renames-for-params rn params 0
   in IrLambda params (rename-ir-expr rn2 body) ty sp

Section: IR Collection Renaming
  rename-ir-exprs : List RenameEntry -> List IRExpr -> Integer -> List IRExpr -> List IRExpr
  rename-ir-exprs (rn) (elems) (i) (acc) =
   if i == list-length elems then acc
   else rename-ir-exprs rn elems (i + 1) (list-snoc acc (rename-ir-expr rn (list-at elems i)))

  rename-ir-fields : List RenameEntry -> List IRFieldVal -> Integer -> List IRFieldVal -> List IRFieldVal
  rename-ir-fields (rn) (fields) (i) (acc) =
   if i == list-length fields then acc
   else let f = list-at fields i
   in rename-ir-fields rn fields (i + 1) (list-snoc acc (IRFieldVal {
    name = f.name,
    value = rename-ir-expr rn (f.value),
    span = f.span
   }))

  rename-ir-branches : List RenameEntry -> List IRBranch -> Integer -> List IRBranch -> List IRBranch
  rename-ir-branches (rn) (branches) (i) (acc) =
   if i == list-length branches then acc
   else let b = list-at branches i
   in let rn2 = remove-renames-for-pat rn (b.pattern)
   in rename-ir-branches rn branches (i + 1) (list-snoc acc (IRBranch {
    pattern = b.pattern,
    body = rename-ir-expr rn2 (b.body),
    span = b.span
   }))

  remove-renames-for-pat : List RenameEntry -> IRPat -> List RenameEntry
  remove-renames-for-pat (rn) (p) =
   when p
    is IrVarPat (nm) (ty) (sp) -> remove-rename rn nm
    is IrCtorPat (nm) (subs) (ty) (sp) -> remove-renames-for-pats rn subs 0
    is IrLitPat (v) (ty) (sp) -> rn
    is IrWildPat (sp) -> rn

  remove-renames-for-pats : List RenameEntry -> List IRPat -> Integer -> List RenameEntry
  remove-renames-for-pats (rn) (pats) (i) =
   if i == list-length pats then rn
   else remove-renames-for-pats (remove-renames-for-pat rn (list-at pats i)) pats (i + 1)

  rename-ir-act-stmts : List RenameEntry -> List IRActStmt -> Integer -> List IRActStmt -> List IRActStmt
  rename-ir-act-stmts (rn) (stmts) (i) (acc) =
   if i == list-length stmts then acc
   else let stmt = list-at stmts i
   in when stmt
    is IrDoBind (nm) (ty) (expr) (sp) ->
     let rn2 = remove-rename rn nm
   in rename-ir-act-stmts rn2 stmts (i + 1) (list-snoc acc (IrDoBind nm ty (rename-ir-expr rn expr) sp))
    is IrDoExec (expr) (sp) ->
     rename-ir-act-stmts rn stmts (i + 1) (list-snoc acc (IrDoExec (rename-ir-expr rn expr) sp))

  rename-ir-handle-clauses : List RenameEntry -> List IRHandleClause -> Integer -> List IRHandleClause -> List IRHandleClause
  rename-ir-handle-clauses (rn) (clauses) (i) (acc) =
   if i == list-length clauses then acc
   else let c = list-at clauses i
   in let rn2 = remove-rename rn (c.resume-name)
   in rename-ir-handle-clauses rn clauses (i + 1) (list-snoc acc (IRHandleClause {
    op-name = c.op-name,
    resume-name = c.resume-name,
    body = rename-ir-expr rn2 (c.body),
    span = c.span
   }))

Section: Chapter Scoping Pipeline
  build-all-assignments : List DefHeader -> Integer -> List ChapterAssignment -> List ChapterAssignment
  build-all-assignments (headers) (i) (acc) =
   if i == list-length headers then acc
   else let hdr = list-at headers i
   in build-all-assignments headers (i + 1) (list-snoc acc (ChapterAssignment {
    def-name = hdr.name.text,
    chapter-slug = hdr.chapter-slug
   }))

  scope-def-name : List Text -> List ChapterAssignment -> Text -> Text -> Text
  scope-def-name (colliding) (assignments) (name) (cur-chap) =
   if is-colliding colliding name then mangle-name cur-chap name
    else name

  build-chapter-rename-map : List Text -> List ChapterAssignment -> Text -> List RenameEntry
  build-chapter-rename-map (colliding) (assignments) (cur-chap) =
   build-mod-renames colliding assignments cur-chap 0 (list-length assignments) []

  build-mod-renames : List Text -> List ChapterAssignment -> Text -> Integer -> Integer -> List RenameEntry -> List RenameEntry
  build-mod-renames (colliding) (assignments) (cur-chap) (i) (len) (acc) =
   if i == len then acc
   else let a = list-at assignments i
   in if is-colliding colliding (a.def-name)
      then if a.chapter-slug == cur-chap
           then let cleaned = remove-rename acc (a.def-name)
   in build-mod-renames colliding assignments cur-chap (i + 1) len (list-snoc cleaned (RenameEntry {
                 original = a.def-name,
                 mangled = mangle-name cur-chap (a.def-name)
                }))
           else if has-rename acc (a.def-name)
                then build-mod-renames colliding assignments cur-chap (i + 1) len acc
                else build-mod-renames colliding assignments cur-chap (i + 1) len (list-snoc acc (RenameEntry {
                 original = a.def-name,
                 mangled = mangle-name (a.chapter-slug) (a.def-name)
                }))
      else build-mod-renames colliding assignments cur-chap (i + 1) len acc

  has-rename : List RenameEntry -> Text -> Boolean
  has-rename (entries) (name) =
   has-rename-loop entries name 0 (list-length entries)

  has-rename-loop : List RenameEntry -> Text -> Integer -> Integer -> Boolean
  has-rename-loop (entries) (name) (i) (len) =
   if i == len then False
   else if (list-at entries i).original == name then True
        else has-rename-loop entries name (i + 1) len

Section: Global Scope (non-streaming)
  scope-ir-chapter : IRChapter -> List Text -> List ChapterAssignment -> IRChapter
  scope-ir-chapter (ir) (colliding) (assignments) =
   IRChapter {
    name = ir.name,
    defs = scope-ir-defs (ir.defs) colliding assignments "" [] 0 [],
    chapter-title = ir.chapter-title,
    prose = ir.prose,
    section-titles = ir.section-titles,
    span = ir.span
   }

  scope-ir-defs : List IRDef -> List Text -> List ChapterAssignment -> Text -> List RenameEntry -> Integer -> List IRDef -> List IRDef
  scope-ir-defs (defs) (colliding) (assignments) (cur-slug) (cur-rn) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in let rn = if d.chapter-slug == cur-slug then cur-rn
      else build-chapter-rename-map colliding assignments (d.chapter-slug)
   in let new-name = rename-lookup rn (d.name)
   in let new-body = rename-ir-expr rn (d.body)
   in scope-ir-defs defs colliding assignments (d.chapter-slug) rn (i + 1) (list-snoc acc (IRDef {
    name = new-name,
    params = d.params,
    type-val = d.type-val,
    body = new-body,
    chapter-slug = d.chapter-slug,
    span = d.span
   }))

Section: AST Expression Renaming
  rename-aexpr : List RenameEntry -> AExpr -> AExpr
  rename-aexpr (rn) (e) =
   when e
    is ALitExpr (v) (k) (s) -> e
    is AErrorExpr (msg) (s) -> e
    is ANameExpr (n) (s) -> ANameExpr (make-name (rename-lookup rn (n.value))) s
    is ABinaryExpr (l) (op) (r) (s) -> ABinaryExpr (rename-aexpr rn l) op (rename-aexpr rn r) s
    is AUnaryExpr (x) (s) -> AUnaryExpr (rename-aexpr rn x) s
    is AApplyExpr (f) (a) (s) -> AApplyExpr (rename-aexpr rn f) (rename-aexpr rn a) s
    is AIfExpr (c) (t) (el) (s) -> AIfExpr (rename-aexpr rn c) (rename-aexpr rn t) (rename-aexpr rn el) s
    is ALetExpr (binds) (body) (s) -> rename-alet rn binds body s
    is ALambdaExpr (params) (body) (s) -> rename-alambda rn params body s
    is AMatchExpr (scrut) (arms) (s) -> AMatchExpr (rename-aexpr rn scrut) (rename-amatch-arms rn arms 0 []) s
    is AListExpr (elems) (s) -> AListExpr (rename-aexprs rn elems 0 []) s
    is ARecordExpr (name) (fields) (s) -> ARecordExpr name (rename-afields rn fields 0 []) s
    is AFieldAccess (rec) (field) (s) -> AFieldAccess (rename-aexpr rn rec) field s
    is AActExpr (stmts) (s) -> AActExpr (rename-act-stmts rn stmts 0 []) s
    is AHandleExpr (eff) (body) (clauses) (s) -> AHandleExpr eff (rename-aexpr rn body) (rename-ahandle-clauses rn clauses 0 []) s

  rename-alet : List RenameEntry -> List ALetBind -> AExpr -> SourceSpan -> AExpr
  rename-alet (rn) (binds) (body) (s) =
   let new-binds = rename-alet-binds rn binds 0 []
   in let rn2 = remove-renames-for-let-binds rn binds 0
   in ALetExpr new-binds (rename-aexpr rn2 body) s

  rename-alet-binds : List RenameEntry -> List ALetBind -> Integer -> List ALetBind -> List ALetBind
  rename-alet-binds (rn) (binds) (i) (acc) =
   if i == list-length binds then acc
   else let b = list-at binds i
   in rename-alet-binds rn binds (i + 1) (list-snoc acc (ALetBind {
    name = b.name,
    value = rename-aexpr rn (b.value),
    span = b.span
   }))

  remove-renames-for-let-binds : List RenameEntry -> List ALetBind -> Integer -> List RenameEntry
  remove-renames-for-let-binds (rn) (binds) (i) =
   if i == list-length binds then rn
   else remove-renames-for-let-binds (remove-rename rn ((list-at binds i).name.value)) binds (i + 1)

  rename-alambda : List RenameEntry -> List Name -> AExpr -> SourceSpan -> AExpr
  rename-alambda (rn) (params) (body) (s) =
   let rn2 = remove-renames-for-names rn params 0
   in ALambdaExpr params (rename-aexpr rn2 body) s

  remove-renames-for-names : List RenameEntry -> List Name -> Integer -> List RenameEntry
  remove-renames-for-names (rn) (names) (i) =
   if i == list-length names then rn
   else remove-renames-for-names (remove-rename rn ((list-at names i).value)) names (i + 1)

  rename-aexprs : List RenameEntry -> List AExpr -> Integer -> List AExpr -> List AExpr
  rename-aexprs (rn) (elems) (i) (acc) =
   if i == list-length elems then acc
   else rename-aexprs rn elems (i + 1) (list-snoc acc (rename-aexpr rn (list-at elems i)))

  rename-afields : List RenameEntry -> List AFieldExpr -> Integer -> List AFieldExpr -> List AFieldExpr
  rename-afields (rn) (fields) (i) (acc) =
   if i == list-length fields then acc
   else let f = list-at fields i
   in rename-afields rn fields (i + 1) (list-snoc acc (AFieldExpr {
    name = f.name,
    value = rename-aexpr rn (f.value),
    span = f.span
   }))

  rename-amatch-arms : List RenameEntry -> List AMatchArm -> Integer -> List AMatchArm -> List AMatchArm
  rename-amatch-arms (rn) (arms) (i) (acc) =
   if i == list-length arms then acc
   else let a = list-at arms i
   in let rn2 = remove-renames-for-apat rn (a.pattern)
   in rename-amatch-arms rn arms (i + 1) (list-snoc acc (AMatchArm {
    pattern = a.pattern,
    body = rename-aexpr rn2 (a.body),
    span = a.span
   }))

  remove-renames-for-apat : List RenameEntry -> APat -> List RenameEntry
  remove-renames-for-apat (rn) (p) =
   when p
    is AVarPat (n) (s) -> remove-rename rn (n.value)
    is ACtorPat (n) (subs) (s) -> remove-renames-for-apats rn subs 0
    is ALitPat (v) (k) (s) -> rn
    is AWildPat (s) -> rn

  remove-renames-for-apats : List RenameEntry -> List APat -> Integer -> List RenameEntry
  remove-renames-for-apats (rn) (pats) (i) =
   if i == list-length pats then rn
   else remove-renames-for-apats (remove-renames-for-apat rn (list-at pats i)) pats (i + 1)

  rename-act-stmts : List RenameEntry -> List AActStmt -> Integer -> List AActStmt -> List AActStmt
  rename-act-stmts (rn) (stmts) (i) (acc) =
   if i == list-length stmts then acc
   else let s = list-at stmts i
   in when s
    is AActBindStmt (nm) (expr) (sp) ->
     let rn2 = remove-rename rn (nm.value)
   in rename-act-stmts rn2 stmts (i + 1) (list-snoc acc (AActBindStmt nm (rename-aexpr rn expr) sp))
    is AActExprStmt (expr) (sp) ->
     rename-act-stmts rn stmts (i + 1) (list-snoc acc (AActExprStmt (rename-aexpr rn expr) sp))

  rename-ahandle-clauses : List RenameEntry -> List AHandleClause -> Integer -> List AHandleClause -> List AHandleClause
  rename-ahandle-clauses (rn) (clauses) (i) (acc) =
   if i == list-length clauses then acc
   else let c = list-at clauses i
   in let rn2 = remove-rename rn (c.resume-name.value)
   in rename-ahandle-clauses rn clauses (i + 1) (list-snoc acc (AHandleClause {
    op-name = c.op-name,
    resume-name = c.resume-name,
    body = rename-aexpr rn2 (c.body),
    span = c.span
   }))

Section: Duplicate Cite Detection
  cite-selects-name : ACitesDecl -> Text -> Boolean
  cite-selects-name (c) (name) =
   cite-selects-name-loop (c.selected-names) name 0 (list-length (c.selected-names))

  cite-selects-name-loop : List Name -> Text -> Integer -> Integer -> Boolean
  cite-selects-name-loop (names) (target) (j) (len) =
   if j == len then False
   else if (list-at names j).value == target then True
   else cite-selects-name-loop names target (j + 1) len

  find-cite-conflict : List ACitesDecl -> Text -> Text -> Integer -> Integer -> Text
  find-cite-conflict (citations) (citing) (name) (k) (total) =
   if k == total then ""
   else let c = list-at citations k
   in if c.citing-chapter == citing then if cite-selects-name c name then c.chapter-name.value
     else find-cite-conflict citations citing name (k + 1) total
     else find-cite-conflict citations citing name (k + 1) total

  add-duplicate-cite-error : DiagnosticBag -> ACitesDecl -> Text -> Text -> DiagnosticBag
  add-duplicate-cite-error (bag) (cite) (name-val) (conflict) =
   bag-add bag (make-error cdx-duplicate-cite ("Name '" ++ name-val ++ "' is cited from both '" ++ (cite.chapter-name.value) ++ "' and '" ++ conflict ++ "' in chapter '" ++ (cite.citing-chapter) ++ "'") (cite.span))

  check-cite-names : ACitesDecl -> Integer -> Integer -> List ACitesDecl -> Integer -> Integer -> DiagnosticBag -> DiagnosticBag
  check-cite-names (cite) (j) (nlen) (all-citations) (i) (total) (bag) =
   if j == nlen then bag
   else let name = list-at (cite.selected-names) j
   in let conflict = find-cite-conflict all-citations (cite.citing-chapter) (name.value) (i + 1) total
   in let bag2 = if conflict == "" then bag else add-duplicate-cite-error bag cite (name.value) conflict
   in check-cite-names cite (j + 1) nlen all-citations i total bag2

  check-duplicate-cites-loop : List ACitesDecl -> Integer -> Integer -> DiagnosticBag -> DiagnosticBag
  check-duplicate-cites-loop (citations) (i) (len) (bag) =
   if i == len then bag
   else let cite-i = list-at citations i
   in let bag2 = check-cite-names cite-i 0 (list-length (cite-i.selected-names)) citations i len bag
   in check-duplicate-cites-loop citations (i + 1) len bag2

  check-duplicate-cites : List ACitesDecl -> DiagnosticBag
  check-duplicate-cites (citations) =
   check-duplicate-cites-loop citations 0 (list-length citations) empty-bag

Section: AST-Level Chapter Scoping
  scope-achapter : AChapter -> List Text -> List ChapterAssignment -> AChapter
  scope-achapter (ast) (colliding) (assignments) =
   AChapter {
    name = ast.name,
    defs = scope-adefs (ast.defs) colliding assignments (ast.citations) "" [] 0 [],
    type-defs = ast.type-defs,
    effect-defs = ast.effect-defs,
    citations = ast.citations,
    chapter-title = ast.chapter-title,
    prose = ast.prose,
    section-titles = ast.section-titles,
    span = ast.span
   }

  scope-adefs : List ADef -> List Text -> List ChapterAssignment -> List ACitesDecl -> Text -> List RenameEntry -> Integer -> List ADef -> List ADef
  scope-adefs (defs) (colliding) (assignments) (citations) (cur-slug) (cur-rn) (i) (acc) =
   if i == list-length defs then acc
   else let d = list-at defs i
   in let rn = if d.chapter-slug == cur-slug then cur-rn
      else apply-cite-overrides (build-chapter-rename-map colliding assignments (d.chapter-slug)) citations colliding assignments (d.chapter-slug) 0
   in let new-name = make-name (rename-lookup rn (d.name.value))
   in let new-body = rename-aexpr rn (d.body)
   in scope-adefs defs colliding assignments citations (d.chapter-slug) rn (i + 1) (list-snoc acc (ADef {
    name = new-name,
    params = d.params,
    declared-type = d.declared-type,
    body = new-body,
    chapter-slug = d.chapter-slug,
    span = d.span
   }))

  apply-cite-overrides : List RenameEntry -> List ACitesDecl -> List Text -> List ChapterAssignment -> Text -> Integer -> List RenameEntry
  apply-cite-overrides (rn) (citations) (colliding) (assignments) (cur-slug) (i) =
   if i == list-length citations then rn
   else let cite = list-at citations i
   in let full-cite-name = (cite.quire.value) ++ "--" ++ (cite.chapter-name.value)
   in let cite-slug = find-slug-for-cite-name full-cite-name assignments 0
   in let rn2 = apply-cite-selected rn (cite.selected-names) cite-slug colliding assignments cur-slug 0
   in apply-cite-overrides rn2 citations colliding assignments cur-slug (i + 1)

  find-slug-for-cite-name : Text -> List ChapterAssignment -> Integer -> Text
  find-slug-for-cite-name (cite-name) (assignments) (i) =
   if i == list-length assignments then ""
   else let a = list-at assignments i
   in if slug-matches-cite (a.chapter-slug) cite-name then a.chapter-slug
      else find-slug-for-cite-name cite-name assignments (i + 1)

  slug-matches-cite : Text -> Text -> Boolean
  slug-matches-cite (slug) (cite-name) =
   slugify slug == slugify cite-name

  apply-cite-selected : List RenameEntry -> List Name -> Text -> List Text -> List ChapterAssignment -> Text -> Integer -> List RenameEntry
  apply-cite-selected (rn) (names) (cite-slug) (colliding) (assignments) (cur-slug) (i) =
   if i == list-length names then rn
   else let n = (list-at names i).value
   in if is-colliding colliding n then if chapter-defines-name assignments cur-slug n
     then apply-cite-selected rn names cite-slug colliding assignments cur-slug (i + 1)
   else let cleaned = remove-rename rn n
   in apply-cite-selected (list-snoc cleaned (RenameEntry {
      original = n,
      mangled = mangle-name cite-slug n
     })) names cite-slug colliding assignments cur-slug (i + 1)
     else apply-cite-selected rn names cite-slug colliding assignments cur-slug (i + 1)

  chapter-defines-name : List ChapterAssignment -> Text -> Text -> Boolean
  chapter-defines-name (assignments) (slug) (name) =
   chapter-defines-loop assignments slug name 0 (list-length assignments)

  chapter-defines-loop : List ChapterAssignment -> Text -> Text -> Integer -> Integer -> Boolean
  chapter-defines-loop (assignments) (slug) (name) (i) (len) =
   if i == len then False
   else let a = list-at assignments i
   in if a.def-name == name then if a.chapter-slug == slug then True
      else chapter-defines-loop assignments slug name (i + 1) len
      else chapter-defines-loop assignments slug name (i + 1) len

Page 1



Chapter: Semantics--Name Resolution
 Checks that every name used in an expression resolves to a definition,
 builtin, constructor, type, or local binding.

Section: Scope
  Scope = record {
   names : List Text
  }

  empty-scope : Scope = Scope { names = [] }

  scope-has : Scope -> Text -> Boolean
  scope-has (sc) (name) =
   let len = list-length (sc.names)
   in if len == 0 then False
   else let pos = bsearch-text-set (sc.names) name 0 len
   in if pos >= len then False
      else list-at (sc.names) pos == name

  scope-add : Scope -> Text -> Scope
  scope-add (sc) (name) =
   let len = list-length (sc.names)
   in let pos = bsearch-text-set (sc.names) name 0 len
   in Scope { names = list-insert-at (sc.names) pos name }

Section: Built-in Names
  builtin-names : List Text
  builtin-names =
   ["show", "negate", "True", "False", "Nothing",
    "print-line", "read-line", "read-file",
    "write-file", "write-binary", "file-exists", "list-files",
    "open-file", "read-all", "close-file",
    "char-at", "char-to-text", "text-length", "substring",
    "is-letter", "is-digit", "is-whitespace",
    "text-to-integer", "integer-to-text", "text-replace",
    "text-split", "text-contains", "text-starts-with",
    "char-code", "char-code-at", "code-to-char",
    "list-length", "list-at", "list-insert-at", "list-set-at", "list-snoc",
    "text-compare",
    "get-args", "get-env", "current-dir",
    "map", "filter", "fold",
    "text-concat-list",
    "record-set",
    "linked-list-empty", "linked-list-push", "linked-list-to-list",
    "bit-and", "bit-or", "bit-xor", "bit-shl", "bit-shr", "bit-not"]

Section: Name Classification
  is-type-name : Text -> Boolean
  is-type-name (name) =
   if text-length name == 0 then False
   else is-letter (char-at name 0) & is-upper-char (char-at name 0)

  is-upper-char : Char -> Boolean
  is-upper-char (c) =
   let code = char-code c
   in code >= char-code 'E' & code <= char-code 'Z'

Section: Resolution Result
  ResolveResult = record {
   bag : DiagnosticBag,
   top-level-names : List Text,
   type-names : List Text,
   ctor-names : List Text
  }

Section: Collect Names
  collect-top-level-names : List ADef -> Integer -> Integer -> List Text -> List Diagnostic -> CollectResult
  collect-top-level-names (defs) (i) (len) (acc) (errs) =
   if i == len then CollectResult {
    names = acc,
    errors = errs
   }
   else let def = list-at defs i
   in let name = def.name.value
   in let acc-len = list-length acc
   in let pos = bsearch-text-set acc name 0 acc-len
   in if pos < acc-len then if list-at acc pos == name then collect-top-level-names defs (i + 1) len acc (errs ++ [make-error cdx-duplicate-definition ("Duplicate definition: " ++ name) (def.span)])
      else collect-top-level-names defs (i + 1) len (list-insert-at acc pos name) errs
      else collect-top-level-names defs (i + 1) len (list-insert-at acc pos name) errs

  CollectResult = record {
   names : List Text,
   errors : List Diagnostic
  }

  list-contains : List Text -> Text -> Boolean
  list-contains (xs) (name) =
   let len = list-length xs
   in if len == 0 then False
   else let pos = bsearch-text-set xs name 0 len
   in if pos >= len then False
      else list-at xs pos == name

  collect-ctor-names : List ATypeDef -> Integer -> Integer -> List Text -> List Text -> CtorCollectResult
  collect-ctor-names (type-defs) (i) (len) (type-acc) (ctor-acc) =
   if i == len then CtorCollectResult {
    type-names = type-acc,
    ctor-names = ctor-acc
   }
   else let td = list-at type-defs i
   in when td
     is AVariantTypeDef (name) (params) (ctors) (s) ->
      let new-type-acc = list-snoc type-acc (name.value)
   in let new-ctor-acc = collect-variant-ctors ctors 0 (list-length ctors) ctor-acc
   in collect-ctor-names type-defs (i + 1) len new-type-acc new-ctor-acc
     is ARecordTypeDef (name) (params) (fields) (s) ->
      collect-ctor-names type-defs (i + 1) len (list-snoc type-acc (name.value)) ctor-acc

  CtorCollectResult = record {
   type-names : List Text,
   ctor-names : List Text
  }

  collect-variant-ctors : List AVariantCtorDef -> Integer -> Integer -> List Text -> List Text
  collect-variant-ctors (ctors) (i) (len) (acc) =
   if i == len then acc
   else let ctor = list-at ctors i
   in collect-variant-ctors ctors (i + 1) len (list-snoc acc (ctor.name.value))

Section: Build Initial Scope
  build-all-names-scope : List Text -> List Text -> List Text -> Scope
  build-all-names-scope (top-names) (ctor-names) (builtins) =
   let sc = add-names-to-scope empty-scope top-names 0 (list-length top-names)
   in let sc2 = add-names-to-scope sc ctor-names 0 (list-length ctor-names)
   in add-names-to-scope sc2 builtins 0 (list-length builtins)

  add-names-to-scope : Scope -> List Text -> Integer -> Integer -> Scope
  add-names-to-scope (sc) (names) (i) (len) =
   if i == len then sc
   else add-names-to-scope (scope-add sc (list-at names i)) names (i + 1) len

Section: Resolve Expressions
  resolve-expr : Scope -> AExpr -> List Diagnostic
  resolve-expr (sc) (expr) =
   when expr
    is ALitExpr (val) (kind) (s) -> []
    is ANameExpr (name) (s) ->
     if scope-has sc (name.value) | is-type-name (name.value) then []
     else [make-error cdx-undefined-name ("Undefined name: " ++ name.value) s]
    is ABinaryExpr (left) (op) (right) (s) ->
     resolve-expr sc left ++ resolve-expr sc right
    is AUnaryExpr (operand) (s) -> resolve-expr sc operand
    is AApplyExpr (func) (arg) (s) ->
     resolve-expr sc func ++ resolve-expr sc arg
    is AIfExpr (cond) (then-e) (else-e) (s) ->
     resolve-expr sc cond ++ resolve-expr sc then-e ++ resolve-expr sc else-e
    is ALetExpr (bindings) (body) (s) ->
     resolve-let sc bindings body 0 (list-length bindings) []
    is ALambdaExpr (params) (body) (s) ->
     let sc2 = add-lambda-params sc params 0 (list-length params)
     in resolve-expr sc2 body
    is AMatchExpr (scrutinee) (arms) (s) ->
     resolve-expr sc scrutinee ++ resolve-match-arms sc arms 0 (list-length arms) []
    is AListExpr (elems) (s) ->
     resolve-list-elems sc elems 0 (list-length elems) []
    is ARecordExpr (name) (fields) (s) ->
     resolve-record-fields sc fields 0 (list-length fields) []
    is AFieldAccess (obj) (field) (s) -> resolve-expr sc obj
    is AActExpr (stmts) (s) -> resolve-act-stmts sc stmts 0 (list-length stmts) []
    is AErrorExpr (msg) (s) -> []

Section: Resolve Let
  resolve-let : Scope -> List ALetBind -> AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-let (sc) (bindings) (body) (i) (len) (errs) =
   if i == len then errs ++ resolve-expr sc body
   else let b = list-at bindings i
   in let bind-errs = resolve-expr sc (b.value)
   in let sc2 = scope-add sc (b.name.value)
   in resolve-let sc2 bindings body (i + 1) len (errs ++ bind-errs)

Section: Resolve Lambda Parameters
  add-lambda-params : Scope -> List Name -> Integer -> Integer -> Scope
  add-lambda-params (sc) (params) (i) (len) =
   if i == len then sc
   else let p = list-at params i
   in add-lambda-params (scope-add sc (p.value)) params (i + 1) len

Section: Resolve Match Arms
  resolve-match-arms : Scope -> List AMatchArm -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-match-arms (sc) (arms) (i) (len) (errs) =
   if i == len then errs
   else let arm = list-at arms i
   in let sc2 = collect-pattern-names sc (arm.pattern)
   in let arm-errs = resolve-expr sc2 (arm.body)
   in resolve-match-arms sc arms (i + 1) len (errs ++ arm-errs)

  collect-pattern-names : Scope -> APat -> Scope
  collect-pattern-names (sc) (pat) =
   when pat
    is AVarPat (name) (s) -> scope-add sc (name.value)
    is ACtorPat (name) (subs) (s) -> collect-ctor-pat-names sc subs 0 (list-length subs)
    is ALitPat (val) (kind) (s) -> sc
    is AWildPat (s) -> sc

  collect-ctor-pat-names : Scope -> List APat -> Integer -> Integer -> Scope
  collect-ctor-pat-names (sc) (subs) (i) (len) =
   if i == len then sc
   else let sub = list-at subs i
   in collect-ctor-pat-names (collect-pattern-names sc sub) subs (i + 1) len

Section: Resolve List Elements
  resolve-list-elems : Scope -> List AExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-list-elems (sc) (elems) (i) (len) (errs) =
   if i == len then errs
   else let errs2 = resolve-expr sc (list-at elems i)
   in resolve-list-elems sc elems (i + 1) len (errs ++ errs2)

Section: Resolve Record Fields
  resolve-record-fields : Scope -> List AFieldExpr -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-record-fields (sc) (fields) (i) (len) (errs) =
   if i == len then errs
   else let f = list-at fields i
   in let errs2 = resolve-expr sc (f.value)
   in resolve-record-fields sc fields (i + 1) len (errs ++ errs2)

Section: Resolve Act Statements
  resolve-act-stmts : Scope -> List AActStmt -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-act-stmts (sc) (stmts) (i) (len) (errs) =
   if i == len then errs
   else let stmt = list-at stmts i
   in when stmt
     is AActExprStmt (e) (s) ->
      let errs2 = resolve-expr sc e
   in resolve-act-stmts sc stmts (i + 1) len (errs ++ errs2)
     is AActBindStmt (name) (e) (s) ->
      let errs2 = resolve-expr sc e
   in let sc2 = scope-add sc (name.value)
   in resolve-act-stmts sc2 stmts (i + 1) len (errs ++ errs2)

Section: Resolve All Definitions
  resolve-all-defs : Scope -> List ADef -> Integer -> Integer -> List Diagnostic -> List Diagnostic
  resolve-all-defs (sc) (defs) (i) (len) (errs) =
   if i == len then errs
   else let def = list-at defs i
   in let def-scope = add-def-params sc (def.params) 0 (list-length (def.params))
   in let errs2 = resolve-expr def-scope (def.body)
   in resolve-all-defs sc defs (i + 1) len (errs ++ errs2)

  add-def-params : Scope -> List AParam -> Integer -> Integer -> Scope
  add-def-params (sc) (params) (i) (len) =
   if i == len then sc
   else let p = list-at params i
   in add-def-params (scope-add sc (p.name.value)) params (i + 1) len

Section: Resolve Chapter
  resolve-chapter : AChapter -> ResolveResult
  resolve-chapter (mod) =
   resolve-chapter-with-citations mod []

  resolve-chapter-with-citations : AChapter -> List ResolveResult -> ResolveResult
  resolve-chapter-with-citations (mod) (imported) =
   let top = collect-top-level-names (mod.defs) 0 (list-length (mod.defs)) [] []
   in let ctors = collect-ctor-names (mod.type-defs) 0 (list-length (mod.type-defs)) [] []
   in let cited-names = collect-cited-names imported 0 (list-length imported) []
   in let all-top = top.names ++ cited-names
   in let sc = build-all-names-scope all-top (ctors.ctor-names) builtin-names
   in let expr-errs = resolve-all-defs sc (mod.defs) 0 (list-length (mod.defs)) []
   in ResolveResult {
     bag = bag-from-list (top.errors ++ expr-errs),
     top-level-names = top.names,
     type-names = ctors.type-names,
     ctor-names = ctors.ctor-names
    }

  collect-cited-names : List ResolveResult -> Integer -> Integer -> List Text -> List Text
  collect-cited-names (results) (i) (len) (acc) =
   if i == len then acc
   else let r = list-at results i
   in let names = r.top-level-names ++ r.ctor-names
   in collect-cited-names results (i + 1) len (acc ++ names)

Page 1



Chapter: Syntax--Lexer
 The lexer converts source text into a flat list of tokens.

Section: Character Code Constants
  cc-newline : Integer
  cc-newline =
   char-code '\n'

  cc-cr : Integer
  cc-cr =
   -1

  cc-space : Integer
  cc-space =
   char-code ' '

  cc-double-quote : Integer
  cc-double-quote =
   char-code '"'

  cc-single-quote : Integer
  cc-single-quote =
   char-code '\''

  cc-ampersand : Integer
  cc-ampersand =
   char-code '&'

  cc-left-paren : Integer
  cc-left-paren =
   char-code '('

  cc-right-paren : Integer
  cc-right-paren =
   char-code ')'

  cc-star : Integer
  cc-star =
   char-code '*'

  cc-plus : Integer
  cc-plus =
   char-code '+'

  cc-comma : Integer
  cc-comma =
   char-code ','

  cc-minus : Integer
  cc-minus =
   char-code '-'

  cc-dot : Integer
  cc-dot =
   char-code '.'

  cc-slash : Integer
  cc-slash =
   char-code '/'

  cc-zero : Integer
  cc-zero =
   char-code '0'

  cc-nine : Integer
  cc-nine =
   char-code '9'

  cc-colon : Integer
  cc-colon =
   char-code ':'

  cc-less : Integer
  cc-less =
   char-code '<'

  cc-equals : Integer
  cc-equals =
   char-code '='

  cc-greater : Integer
  cc-greater =
   char-code '>'

  cc-first-upper : Integer
  cc-first-upper =
   char-code 'E'

  cc-upper-z : Integer
  cc-upper-z =
   char-code 'Z'

  cc-left-bracket : Integer
  cc-left-bracket =
   char-code '['

  cc-backslash : Integer
  cc-backslash =
   char-code '\\'

  cc-right-bracket : Integer
  cc-right-bracket =
   char-code ']'

  cc-caret : Integer
  cc-caret =
   char-code '^'

  cc-underscore : Integer
  cc-underscore =
   char-code '_'

  cc-lower-a : Integer
  cc-lower-a =
   char-code 'a'

  cc-lower-n : Integer
  cc-lower-n =
   char-code 'n'

  cc-lower-r : Integer
  cc-lower-r =
   char-code 'r'

  cc-lower-t : Integer
  cc-lower-t =
   char-code 't'

  cc-lower-z : Integer
  cc-lower-z =
   char-code 'z'

  cc-left-brace : Integer
  cc-left-brace =
   char-code '{'

  cc-pipe : Integer
  cc-pipe =
   char-code '|'

  cc-right-brace : Integer
  cc-right-brace =
   char-code '}'

Section: Character Classification (Integer)
  is-letter-code : Integer -> Boolean
  is-letter-code (c) =
   is-letter (code-to-char c)

  is-digit-code : Integer -> Boolean
  is-digit-code (c) =
   is-digit (code-to-char c)

Section: Lexer State
  LexState = record {
   source : Text,
   offset : Integer,
   line : Integer,
   column : Integer,
   file-id : Integer
  }

  make-lex-state : Text -> Integer -> LexState
  make-lex-state (src) (fid) =
   LexState {
    source = src,
    offset = 0,
    line = 1,
    column = 1,
    file-id = fid
   }

  is-at-end : LexState -> Boolean
  is-at-end (st) =
   st.offset >= text-length (st.source)

  peek-code : LexState -> Integer
  peek-code (st) =
   if is-at-end st then 0
   else char-code-at (st.source) (st.offset)

  advance-char : LexState -> LexState
  advance-char (st) =
   if peek-code st == cc-newline then LexState {
     source = st.source,
     offset = st.offset + 1,
     line = st.line + 1,
     column = 1,
     file-id = st.file-id
    }
    else LexState {
     source = st.source,
     offset = st.offset + 1,
     line = st.line,
     column = st.column + 1,
     file-id = st.file-id
    }

Section: Whitespace
  skip-spaces-end : Text -> Integer -> Integer -> Integer
  skip-spaces-end (source) (offset) (len) =
   if offset >= len then offset
   else if char-code-at source offset == cc-space then skip-spaces-end source (offset + 1) len
   else offset

  skip-spaces : LexState -> LexState
  skip-spaces (st) =
   let len = text-length (st.source)
   in let stop = skip-spaces-end (st.source) (st.offset) len
   in if stop == st.offset then st
      else LexState {
      source = st.source,
      offset = stop,
      line = st.line,
      column = st.column + (stop - st.offset),
      file-id = st.file-id
     }

Section: Character Scanning
  scan-ident-end : Text -> Integer -> Integer -> Integer
  scan-ident-end (source) (offset) (len) =
   if offset >= len then offset
   else let c = char-code-at source offset
   in if is-letter-code c then scan-ident-end source (offset + 1) len
      else if is-digit-code c then scan-ident-end source (offset + 1) len
      else if c == cc-underscore then scan-ident-end source (offset + 1) len
      else if c == cc-minus then if offset + 1 >= len then offset
   else let nc = char-code-at source (offset + 1)
   in if is-letter-code nc | is-digit-code nc then scan-ident-end source (offset + 1) len
          else offset
       else offset

  scan-ident-rest : LexState -> LexState
  scan-ident-rest (st) =
   let len = text-length (st.source)
   in let stop = scan-ident-end (st.source) (st.offset) len
   in if stop == st.offset then st
      else LexState {
      source = st.source,
      offset = stop,
      line = st.line,
      column = st.column + (stop - st.offset),
      file-id = st.file-id
     }

  scan-digits-end : Text -> Integer -> Integer -> Integer
  scan-digits-end (source) (offset) (len) =
   if offset >= len then offset
   else let c = char-code-at source offset
   in if is-digit-code c then scan-digits-end source (offset + 1) len
      else if c == cc-underscore then scan-digits-end source (offset + 1) len
      else offset

  scan-digits : LexState -> LexState
  scan-digits (st) =
   let len = text-length (st.source)
   in let stop = scan-digits-end (st.source) (st.offset) len
   in if stop == st.offset then st
      else LexState {
      source = st.source,
      offset = stop,
      line = st.line,
      column = st.column + (stop - st.offset),
      file-id = st.file-id
     }

  scan-string-end : Text -> Integer -> Integer -> Integer
  scan-string-end (source) (offset) (len) =
   if offset >= len then offset
   else let c = char-code-at source offset
   in if c == cc-double-quote then offset + 1
      else if c == cc-newline then offset
      else if c == cc-backslash then scan-string-end source (offset + 2) len
      else scan-string-end source (offset + 1) len

  scan-string-body : LexState -> LexState
  scan-string-body (st) =
   let len = text-length (st.source)
   in let stop = scan-string-end (st.source) (st.offset) len
   in if stop == st.offset then st
      else LexState {
      source = st.source,
      offset = stop,
      line = st.line,
      column = st.column + (stop - st.offset),
      file-id = st.file-id
     }

  process-escapes-loop : Text -> Integer -> Integer -> List Text -> List Text
  process-escapes-loop (s) (i) (len) (acc) =
   if i >= len then acc
   else let c = char-code-at s i
   in if c == cc-backslash then if i + 1 < len then let nc = char-code-at s (i + 1)
   in if nc == cc-lower-n then process-escapes-loop s (i + 2) len (list-snoc acc (char-to-text '\n'))
          else if nc == cc-lower-t then process-escapes-loop s (i + 2) len (list-snoc acc "  ")
          else if nc == cc-lower-r then process-escapes-loop s (i + 2) len acc
          else if nc == cc-backslash then process-escapes-loop s (i + 2) len (list-snoc acc "\\")
          else if nc == cc-double-quote then process-escapes-loop s (i + 2) len (list-snoc acc "\"")
          else process-escapes-loop s (i + 2) len (list-snoc acc (char-to-text (char-at s (i + 1))))
       else list-snoc acc (char-to-text (char-at s i))
      else process-escapes-loop s (i + 1) len (list-snoc acc (char-to-text (char-at s i)))

  process-escapes : Text -> Integer -> Integer -> Text
  process-escapes (s) (i) (len) =
   text-concat-list (process-escapes-loop s i len [])

Section: Keyword Classification
  classify-word : Text -> TokenKind
  classify-word (w) =
   if w == "let" then LetKeyword
   else if w == "in" then InKeyword
   else if w == "if" then IfKeyword
   else if w == "is" then IsKeyword
   else if w == "otherwise" then OtherwiseKeyword
   else if w == "then" then ThenKeyword
   else if w == "else" then ElseKeyword
   else if w == "when" then WhenKeyword
   else if w == "where" then WhereKeyword
   else if w == "act" then ActKeyword
   else if w == "end" then EndKeyword
   else if w == "record" then RecordKeyword
   else if w == "cites" then CitesKeyword
   else if w == "claim" then ClaimKeyword
   else if w == "proof" then ProofKeyword
   else if w == "qed" then QedKeyword
   else if w == "forall" then ForAllKeyword
   else if w == "exists" then ThereExistsKeyword
   else if w == "linear" then LinearKeyword
   else if w == "effect" then EffectKeyword
   else if w == "with" then WithKeyword
   else if w == "True" then TrueKeyword
   else if w == "False" then FalseKeyword
   else let first-code = char-code-at w 0
   in if first-code >= cc-first-upper then if first-code <= cc-upper-z then TypeIdentifier
      else Identifier
      else Identifier

Section: Single Token Scanning
  LexResult =
   | LexToken (Token) (LexState)
   | LexEnd

  make-token : TokenKind -> Text -> LexState -> Token
  make-token (kind) (text) (st) =
   Token {
    kind = kind,
    text = text,
    offset = st.offset,
    line = st.line,
    column = st.column,
    file-id = st.file-id
   }

  extract-text : LexState -> Integer -> LexState -> Text
  extract-text (st) (start) (end-st) =
   substring (st.source) start (end-st.offset - start)

  scan-token : LexState -> LexResult
  scan-token (st) =
   let s = skip-spaces st
   in if is-at-end s then LexEnd
   else let c = peek-code s
   in if c == cc-cr then scan-token (advance-char s)
         else if c == cc-newline then LexToken (make-token Newline "\n" s) (advance-char s)
         else if c == cc-double-quote then let start = s.offset + 1
   in let after = scan-string-body (advance-char s)
   in let text-len = after.offset - start - 1
   in let raw = substring (s.source) start text-len
   in LexToken (make-token TextLiteral (process-escapes raw 0 (text-length raw)) s) after
         else if c == cc-single-quote then scan-char-literal s
         else if is-letter-code c then let start = s.offset
   in let after = scan-ident-rest (advance-char s)
   in let word = extract-text s start after
   in LexToken (make-token (classify-word word) word s) after
         else if c == cc-underscore then let start = s.offset
   in let after = scan-ident-rest (advance-char s)
   in let word = extract-text s start after
   in if text-length word == 1 then LexToken (make-token Underscore "_" s) after
                 else LexToken (make-token (classify-word word) word s) after
         else if is-digit-code c then let start = s.offset
   in let after = scan-digits (advance-char s)
   in if is-at-end after then LexToken (make-token IntegerLiteral (extract-text s start after) s) after
                 else if peek-code after == cc-dot then let after2 = scan-digits (advance-char after)
   in LexToken (make-token NumberLiteral (extract-text s start after2) s) after2
                else LexToken (make-token IntegerLiteral (extract-text s start after) s) after
         else scan-operator s

  scan-operator : LexState -> LexResult
  scan-operator (s) =
   let c = peek-code s
   in let next = advance-char s
   in if c == cc-left-paren then LexToken (make-token LeftParen "(" s) next
      else if c == cc-right-paren then LexToken (make-token RightParen ")" s) next
      else if c == cc-left-bracket then LexToken (make-token LeftBracket "[" s) next
      else if c == cc-right-bracket then LexToken (make-token RightBracket "]" s) next
      else if c == cc-left-brace then LexToken (make-token LeftBrace "{" s) next
      else if c == cc-right-brace then LexToken (make-token RightBrace "}" s) next
      else if c == cc-comma then LexToken (make-token Comma "," s) next
      else if c == cc-dot then LexToken (make-token Dot "." s) next
      else if c == cc-caret then LexToken (make-token Caret "^" s) next
      else if c == cc-ampersand then LexToken (make-token Ampersand "&" s) next
      else if c == cc-backslash then LexToken (make-token Backslash "\\" s) next
      else scan-multi-char-operator s

  scan-multi-char-operator : LexState -> LexResult
  scan-multi-char-operator (s) =
   let c = peek-code s
   in let next = advance-char s
   in let nc = if is-at-end next then 0 else peek-code next
   in if c == cc-plus then if nc == cc-plus then LexToken (make-token PlusPlus "++" s) (advance-char next)
        else LexToken (make-token Plus "+" s) next
        else if c == cc-minus then if nc == cc-greater then LexToken (make-token Arrow "->" s) (advance-char next)
        else LexToken (make-token Minus "-" s) next
        else if c == cc-star then LexToken (make-token Star "*" s) next
        else if c == cc-slash then if nc == cc-equals then LexToken (make-token NotEquals "/=" s) (advance-char next)
        else LexToken (make-token Slash "/" s) next
        else if c == cc-equals then if nc == cc-equals then let next2 = advance-char next
   in let nc2 = if is-at-end next2 then 0 else peek-code next2
   in if nc2 == cc-equals then LexToken (make-token TripleEquals "===" s) (advance-char next2)
                else LexToken (make-token DoubleEquals "==" s) next2
           else LexToken (make-token Equals "=" s) next
        else if c == cc-colon then if nc == cc-colon then LexToken (make-token ColonColon "::" s) (advance-char next)
        else LexToken (make-token Colon ":" s) next
        else if c == cc-pipe then if nc == cc-minus then LexToken (make-token Turnstile "|-" s) (advance-char next)
        else LexToken (make-token Pipe "|" s) next
        else if c == cc-less then if nc == cc-equals then LexToken (make-token LessOrEqual "<=" s) (advance-char next)
        else if nc == cc-minus then LexToken (make-token LeftArrow "<-" s) (advance-char next)
        else LexToken (make-token LessThan "<" s) next
        else if c == cc-greater then if nc == cc-equals then LexToken (make-token GreaterOrEqual ">=" s) (advance-char next)
        else LexToken (make-token GreaterThan ">" s) next
        else LexToken (make-token ErrorToken (char-to-text (char-at (s.source) (s.offset))) s) next

Section: Char Literal
  scan-char-literal : LexState -> LexResult
  scan-char-literal (s) =
   let s1 = advance-char s
   in if is-at-end s1 then LexToken (make-token ErrorToken "'" s) s1
      else if peek-code s1 == cc-backslash then let s2 = advance-char s1
   in if is-at-end s2 then LexToken (make-token ErrorToken "'\\" s) s2
   else let esc-code = peek-code s2
   in let char-val = if esc-code == cc-lower-n then cc-newline
         else if esc-code == cc-lower-t then cc-space
         else if esc-code == cc-lower-r then cc-newline
         else if esc-code == cc-backslash then cc-backslash
         else if esc-code == cc-single-quote then cc-single-quote
         else esc-code
   in let s3 = advance-char s2
   in let s4 = if is-at-end s3 then s3 else if peek-code s3 == cc-single-quote then advance-char s3 else s3
   in LexToken (make-token CharLiteral (integer-to-text char-val) s) s4
   else let char-val = peek-code s1
   in let s2 = advance-char s1
   in let s3 = if is-at-end s2 then s2 else if peek-code s2 == cc-single-quote then advance-char s2 else s2
   in LexToken (make-token CharLiteral (integer-to-text char-val) s) s3

Section: Tokenize All
  tokenize-loop : LexState -> List Token -> List Token
  tokenize-loop (st) (acc) =
   when scan-token st
    is LexToken (tok) (next) ->
     if tok.kind == EndOfFile then list-snoc acc tok
      else tokenize-loop next (list-snoc acc tok)
    is LexEnd ->
     list-snoc acc (make-token EndOfFile "" st)

  tokenize : Text -> Integer -> List Token
  tokenize (src) (fid) =
   tokenize-loop (make-lex-state src fid) []

Page 1



Chapter: Syntax--Parser
 The parser transforms a flat token list into a concrete syntax tree.

  cites Foreword chapter Maybe

Section: Type Parsing
  parse-type : ParseState -> ParseTypeResult
  parse-type (st) =
   let result = parse-type-atom st
   in unwrap-type-ok result parse-type-continue

  parse-type-continue : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-continue (left) (st) =
   if is-arrow (current-kind st) then let st2 = advance st
     in let right-result = parse-type st2
     in unwrap-type-ok right-result (make-fun-type left)
    else TypeOk left st

  make-fun-type : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  make-fun-type (left) (right) (st) =
   TypeOk (FunType left right) st

  unwrap-type-ok : ParseTypeResult -> (TypeExpr -> ParseState -> ParseTypeResult) -> ParseTypeResult
  unwrap-type-ok (r) (f) =
   when r
    is TypeOk (t) (st) -> f t st

  parse-type-atom : ParseState -> ParseTypeResult
  parse-type-atom (st) =
   if is-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
   in parse-type-args (NamedType tok) (advance st)
   else if is-left-paren (current-kind st) then parse-paren-type (advance st)
   else if is-left-bracket (current-kind st) then parse-effect-type (advance st)
   else let tok = current st
   in TypeOk (NamedType tok) (advance st)

  parse-paren-type : ParseState -> ParseTypeResult
  parse-paren-type (st) =
   let inner = parse-type st
   in unwrap-type-ok inner finish-paren-type

  finish-paren-type : TypeExpr -> ParseState -> ParseTypeResult
  finish-paren-type (t) (st) =
   let st2 = expect RightParen st
   in TypeOk (ParenType t) st2

  parse-effect-type : ParseState -> ParseTypeResult
  parse-effect-type (st) =
   let effs = parse-effect-names st []
   in let ret = parse-type (effs.state)
   in unwrap-type-ok ret (finish-effect-type (effs.names))

  finish-effect-type : List Token -> TypeExpr -> ParseState -> ParseTypeResult
  finish-effect-type (effs) (ret) (st) =
   TypeOk (EffectTypeExpr effs ret) st

  EffectNamesResult = record {
   names : List Token,
   state : ParseState
  }

  parse-effect-names : ParseState -> List Token -> EffectNamesResult
  parse-effect-names (st) (acc) =
   if is-done st then EffectNamesResult { names = acc, state = st }
   else if is-right-bracket (current-kind st) then EffectNamesResult { names = acc, state = advance st }
   else if is-comma (current-kind st) then parse-effect-names (advance st) acc
   else if is-ident (current-kind st) | is-type-ident (current-kind st) then
    let tok = current st
    in parse-effect-names (advance st) (list-snoc acc tok)
   else parse-effect-names (advance st) acc

  parse-type-args : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-args (base-type) (st) =
   if is-done st then TypeOk base-type st
   else if is-type-arg-start (current-kind st) then parse-type-arg-next base-type st
   else TypeOk base-type st

  parse-type-arg-next : TypeExpr -> ParseState -> ParseTypeResult
  parse-type-arg-next (base-type) (st) =
   let arg-result = parse-type-atom st
   in unwrap-type-ok arg-result (continue-type-args base-type)

  continue-type-args : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
  continue-type-args (base-type) (arg) (st) =
   parse-type-args (AppType base-type [arg]) st

Section: Pattern Parsing
  parse-pattern : ParseState -> ParsePatResult
  parse-pattern (st) =
   if is-wildcard-pat (current-kind st) then PatOk (WildPat (current st)) (advance st)
   else if is-literal (current-kind st) then PatOk (LitPat (current st)) (advance st)
   else if is-type-ident (current-kind st) then let tok = current st
       in parse-ctor-pattern-fields tok [] (advance st)
   else if is-ident (current-kind st) then PatOk (VarPat (current st)) (advance st)
       else PatOk (WildPat (current st)) (advance st)

  parse-ctor-pattern-fields : Token -> List Pat -> ParseState -> ParsePatResult
  parse-ctor-pattern-fields (ctor) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
     in let sub = parse-pattern st2
     in unwrap-pat-ok sub (continue-ctor-fields ctor acc)
    else PatOk (CtorPat ctor acc) st

  continue-ctor-fields : Token -> List Pat -> Pat -> ParseState -> ParsePatResult
  continue-ctor-fields (ctor) (acc) (p) (st) =
   let st2 = expect RightParen st
   in parse-ctor-pattern-fields ctor (list-snoc acc p) st2

  unwrap-pat-ok : ParsePatResult -> (Pat -> ParseState -> ParsePatResult) -> ParsePatResult
  unwrap-pat-ok (r) (f) =
   when r
    is PatOk (p) (st) -> f p st

Section: Definition Parsing
  parse-type-annotation : ParseState -> ParseTypeResult
  parse-type-annotation (st) =
   let st2 = advance st
   in let st3 = expect Colon st2
   in parse-type st3

  parse-definition : ParseState -> ParseDefResult
  parse-definition (st) =
   if is-done st then ParseDefResult { maybe-def = None, state = st }
   else if is-ident (current-kind st) then try-parse-def st
   else if is-type-ident (current-kind st) then try-parse-def st
     else ParseDefResult { maybe-def = None, state = st }

  try-parse-def : ParseState -> ParseDefResult
  try-parse-def (st) =
   if is-colon (peek-kind st 1) then let first-name = current st
     in let ann-result = parse-type-annotation st
     in unwrap-type-for-def first-name ann-result
    else parse-def-body-with-ann [] st

  unwrap-type-for-def : Token -> ParseTypeResult -> ParseDefResult
  unwrap-type-for-def (first-name) (r) =
   when r
    is TypeOk (ann-type) (st) ->
     if is-equals (current-kind st) then
      let ann = [TypeAnn {
       name = first-name,
       type-expr = ann-type
      }]
      in let st2 = advance st
      in let st3 = skip-newlines st2
      in let body-result = parse-expr-col st3 (first-name.column)
      in unwrap-def-body body-result ann first-name []
     else
      let name-tok = Token {
       kind = Identifier,
       text = "",
       offset = 0,
       line = 0,
       column = 0,
       file-id = 0
      }
      in let ann = [TypeAnn {
       name = name-tok,
       type-expr = ann-type
      }]
      in let st2 = skip-newlines st
      in parse-def-body-with-ann ann st2

  parse-def-body-with-ann : List TypeAnn -> ParseState -> ParseDefResult
  parse-def-body-with-ann (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in parse-def-params-then ann name-tok [] st2

  parse-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  parse-def-params-then (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then parse-def-params-after-lparen ann name-tok acc (advance st)
   else finish-def ann name-tok acc st

  parse-def-params-after-lparen : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  parse-def-params-after-lparen (ann) (name-tok) (acc) (st) =
   if is-ident (current-kind st) then let param = current st
     in let st2 = expect RightParen (advance st)
     in parse-def-params-then ann name-tok (list-snoc acc param) st2
    else if is-reserved-keyword (current-kind st) then
     let st2 = report-reserved-keyword "a parameter name" st
     in let st3 = expect RightParen (advance st2)
     in parse-def-params-then ann name-tok acc st3
      else finish-def ann name-tok acc st

  finish-def : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
  finish-def (ann) (name-tok) (params) (st) =
   if is-equals (current-kind st) then
    let st2 = advance st
    in let st3 = skip-newlines st2
    in let body-result = parse-expr-col st3 (name-tok.column)
    in unwrap-def-body body-result ann name-tok params
   else let tok = current st
    in let err-st = expect Equals st
    in let st2 = skip-body-tokens err-st (name-tok.column)
    in ParseDefResult {
     maybe-def = Just (Def {
      name = name-tok,
      params = params,
      ann = ann,
      body = ErrExpr tok,
      chapter-slug = ""
     }),
     state = st2
    }

  unwrap-def-body : ParseExprResult -> List TypeAnn -> Token -> List Token -> ParseDefResult
  unwrap-def-body (r) (ann) (name-tok) (params) =
   when r
    is ExprOk (b) (st) ->
     ParseDefResult {
      maybe-def = Just (Def {
       name = name-tok,
       params = params,
       ann = ann,
       body = b,
       chapter-slug = ""
      }),
      state = st
     }

Section: Type Definition Parsing
  is-paren-type-param : ParseState -> Boolean
  is-paren-type-param (st) =
   if is-left-paren (current-kind st) then let k1 = peek-kind st 1
   in if is-ident k1 then is-right-paren (peek-kind st 2)
      else if is-type-ident k1 then is-right-paren (peek-kind st 2)
      else False
    else False

  is-type-param-pattern : ParseState -> Boolean
  is-type-param-pattern (st) =
   if is-paren-type-param st then True
   else is-ident (current-kind st)

  parse-type-params : ParseState -> List Token -> ParseState
  parse-type-params (st) (acc) =
   if is-paren-type-param st then parse-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then parse-type-params (advance st) (list-snoc acc (current st))
   else st

  collect-type-params : ParseState -> List Token -> List Token
  collect-type-params (st) (acc) =
   if is-paren-type-param st then collect-type-params (advance (advance (advance st))) (list-snoc acc (list-at (st.tokens) (st.pos + 1)))
   else if is-ident (current-kind st) then collect-type-params (advance st) (list-snoc acc (current st))
   else acc

  parse-type-def : ParseState -> ParseTypeDefResult
  parse-type-def (st) =
   if is-type-ident (current-kind st) then let name-tok = current st
     in let st2 = advance st
     in let tparams = collect-type-params st2 []
     in let st3 = parse-type-params st2 []
     in if is-equals (current-kind st3) then let st4 = skip-newlines (advance st3)
     in if is-record-keyword (current-kind st4) then parse-record-type name-tok tparams st4
            else if is-pipe (current-kind st4) then parse-variant-type name-tok tparams st4
            else if is-type-ident (current-kind st4) & looks-like-variant st4 then parse-variant-type name-tok tparams st4
            else ParseTypeDefResult { maybe-type-def = None, state = st }
         else ParseTypeDefResult { maybe-type-def = None, state = st }
    else ParseTypeDefResult { maybe-type-def = None, state = st }

  parse-record-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-record-type (name-tok) (tparams) (st) =
   let st2 = advance st
   in let st3 = expect LeftBrace st2
   in let st4 = skip-newlines st3
   in parse-record-fields-loop name-tok tparams [] st4

  parse-record-fields-loop : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-record-fields-loop (name-tok) (tparams) (acc) (st) =
   if is-right-brace (current-kind st) then ParseTypeDefResult {
    maybe-type-def = Just (TypeDef {
     name = name-tok,
     type-params = tparams,
     body = RecordBody acc
    }),
    state = advance st
   }
   else if is-ident-like (current-kind st) then parse-one-record-field name-tok tparams acc st
   else ParseTypeDefResult {
    maybe-type-def = Just (TypeDef {
     name = name-tok,
     type-params = tparams,
     body = RecordBody acc
    }),
    state = st
   }

  parse-one-record-field : Token -> List Token -> List RecordFieldDef -> ParseState -> ParseTypeDefResult
  parse-one-record-field (name-tok) (tparams) (acc) (st) =
   let field-name = current st
   in let st2 = advance st
   in let st3 = expect Colon st2
   in let field-type-result = parse-type st3
   in unwrap-record-field-type name-tok tparams acc field-name field-type-result

  unwrap-record-field-type : Token -> List Token -> List RecordFieldDef -> Token -> ParseTypeResult -> ParseTypeDefResult
  unwrap-record-field-type (name-tok) (tparams) (acc) (field-name) (r) =
   when r
    is TypeOk (ft) (st) ->
     let field = RecordFieldDef {
      name = field-name,
      type-expr = ft
     }
     in let st2 = skip-newlines st
     in if is-comma (current-kind st2) then parse-record-fields-loop name-tok tparams (list-snoc acc field) (skip-newlines (advance st2))
         else parse-record-fields-loop name-tok tparams (list-snoc acc field) st2

  looks-like-variant : ParseState -> Boolean
  looks-like-variant (st) =
   looks-like-variant-scan (st.tokens) (st.pos + 1) (list-length (st.tokens))

  looks-like-variant-scan : List Token -> Integer -> Integer -> Boolean
  looks-like-variant-scan (tokens) (i) (len) =
   if i >= len then False
   else let k = (list-at tokens i).kind
   in if is-pipe k then True
      else when k
      is Newline -> False
      is EndOfFile -> False
      is otherwise -> looks-like-variant-scan tokens (i + 1) len

  parse-variant-type : Token -> List Token -> ParseState -> ParseTypeDefResult
  parse-variant-type (name-tok) (tparams) (st) =
   if is-type-ident (current-kind st) then let ctor-name = current st
     in let st2 = advance st
     in parse-ctor-fields ctor-name [] st2 name-tok tparams []
    else parse-variant-ctors name-tok tparams [] st

  parse-variant-ctors : Token -> List Token -> List VariantCtorDef -> ParseState -> ParseTypeDefResult
  parse-variant-ctors (name-tok) (tparams) (acc) (st) =
   if is-pipe (current-kind st) then let st2 = skip-newlines (advance st)
     in let ctor-name = current st2
     in let st3 = advance st2
     in parse-ctor-fields ctor-name [] st3 name-tok tparams acc
    else ParseTypeDefResult {
     maybe-type-def = Just (TypeDef {
      name = name-tok,
      type-params = tparams,
      body = VariantBody acc
     }),
     state = st
    }

  parse-ctor-fields : Token -> List TypeExpr -> ParseState -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  parse-ctor-fields (ctor-name) (fields) (st) (name-tok) (tparams) (acc) =
   if is-left-paren (current-kind st) then let field-result = parse-type (advance st)
     in unwrap-ctor-field field-result ctor-name fields name-tok tparams acc
    else let st2 = skip-newlines st
    in let ctor = VariantCtorDef {
      name = ctor-name,
      fields = fields
     }
    in parse-variant-ctors name-tok tparams (list-snoc acc ctor) st2

  unwrap-ctor-field : ParseTypeResult -> Token -> List TypeExpr -> Token -> List Token -> List VariantCtorDef -> ParseTypeDefResult
  unwrap-ctor-field (r) (ctor-name) (fields) (name-tok) (tparams) (acc) =
   when r
    is TypeOk (ty) (st) ->
     let st2 = expect RightParen st
      in parse-ctor-fields ctor-name (fields ++ [ty]) st2 name-tok tparams acc

Section: Document Parsing
  parse-document : ParseState -> Document
  parse-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-citations st2 "" []
   in parse-top-level [] [] [] (imp-result.imports) "" [] (imp-result.state)

  CiteTitleResult = record { title : Text, state : ParseState }

  collect-cite-title : ParseState -> Text -> CiteTitleResult
  collect-cite-title (st) (acc) =
   if is-done st then CiteTitleResult { title = acc, state = st }
    else when current-kind st
     is Newline -> CiteTitleResult { title = acc, state = st }
     is LeftParen -> CiteTitleResult { title = acc, state = st }
     is otherwise -> let tok = current st
      in collect-cite-title (advance st) (join-title-parts acc (tok.text))

  parse-citations : ParseState -> Text -> List CitesDecl -> ImportParseResult
  parse-citations (st) (citing) (acc) =
   if is-cites-keyword (current-kind st) then let st2 = advance st
     in let quire-tok = current st2
     in let st3 = advance st2
     in let st4 = advance st3
     in let title-result = collect-cite-title st4 ""
     in let st5 = title-result.state
     in if is-left-paren (current-kind st5) then let sel = parse-selected-names (advance st5) []
     in let st6 = skip-newlines (sel.state)
     in parse-citations st6 citing (list-snoc acc (CitesDecl {
           quire = quire-tok,
           chapter-name = title-result.title,
           selected-names = sel.names,
           citing-chapter = citing
          }))
     else let st6 = skip-newlines st5
     in parse-citations st6 citing (list-snoc acc (CitesDecl {
          quire = quire-tok,
          chapter-name = title-result.title,
          selected-names = [],
          citing-chapter = citing
         }))
    else ImportParseResult {
     imports = acc,
     state = st
    }

  SelectedNamesResult = record { names : List Token, state : ParseState }

  parse-selected-names : ParseState -> List Token -> SelectedNamesResult
  parse-selected-names (st) (acc) =
   if is-ident (current-kind st) then let tok = current st
     in let st2 = advance st
     in if is-comma (current-kind st2) then parse-selected-names (skip-newlines (advance st2)) (list-snoc acc tok)
         else SelectedNamesResult {
          names = list-snoc acc tok,
          state = st2
         }
    else if is-right-paren (current-kind st) then SelectedNamesResult {
     names = acc,
     state = advance st
    }
    else SelectedNamesResult {
     names = acc,
     state = st
    }

  ImportParseResult = record { imports : List CitesDecl, state : ParseState }

  is-chapter-header : ParseState -> Boolean
  is-chapter-header (st) =
   if is-type-ident (current-kind st) then if (current st).text == "Chapter" then is-colon (peek-kind st 1)
      else False
    else False

  is-section-header : ParseState -> Boolean
  is-section-header (st) =
   if is-type-ident (current-kind st) then if (current st).text == "Section" then is-colon (peek-kind st 1)
      else False
    else False

  is-page-marker : ParseState -> Boolean
  is-page-marker (st) =
   if is-type-ident (current-kind st) then (current st).text == "Page"
    else False

  extract-header-title : ParseState -> Text
  extract-header-title (st) =
   let st2 = advance (advance st)
   in collect-title-tokens st2 ""

  join-title-parts : Text -> Text -> Text
  join-title-parts (acc) (next) =
   if text-length acc == 0 then next
    else if text-length next == 0 then acc
    else let prev-last = char-code-at acc (text-length acc - 1)
     in let next-first = char-code-at next 0
     in if (is-letter-code prev-last | is-digit-code prev-last) & (is-letter-code next-first | is-digit-code next-first)
        then acc ++ " " ++ next
        else acc ++ next

  collect-title-tokens : ParseState -> Text -> Text
  collect-title-tokens (st) (acc) =
   if is-done st then acc
   else when current-kind st
    is Newline -> acc
    is otherwise -> let tok = current st
     in collect-title-tokens (advance st) (join-title-parts acc (tok.text))

  is-prose-line : ParseState -> Boolean
  is-prose-line (st) = (current st).column == 2

  skip-prose-lines : ParseState -> ParseState
  skip-prose-lines (st) =
   let st2 = skip-newlines st
   in if is-done st2 then st2
      else if is-prose-line st2 then skip-prose-lines (skip-to-next-line st2)
      else st2

  skip-to-next-line : ParseState -> ParseState
  skip-to-next-line (st) =
   if is-done st then st
   else when current-kind st
    is Newline -> advance st
    is otherwise -> skip-to-next-line (advance st)

  parse-top-level : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  parse-top-level (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   if is-done st then Document {
    defs = defs,
    type-defs = type-defs,
    effect-defs = effect-defs,
    citations = imports,
    chapter-title = ch-title,
    section-titles = sec-titles,
    parse-bag = st.bag
   }
   else if is-chapter-header st then let title = extract-header-title st
     in parse-top-level defs type-defs effect-defs imports title sec-titles (skip-prose-lines (skip-to-next-line st))
   else if is-section-header st then let title = extract-header-title st
     in parse-top-level defs type-defs effect-defs imports ch-title (sec-titles ++ [title]) (skip-prose-lines (skip-to-next-line st))
   else if is-page-marker st then parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-to-next-line st)
   else if is-cites-keyword (current-kind st) then let cite-result = parse-citations st ch-title []
     in parse-top-level defs type-defs effect-defs (imports ++ cite-result.imports) ch-title sec-titles (cite-result.state)
   else if is-effect-keyword (current-kind st) then parse-top-level-effect defs type-defs effect-defs imports ch-title sec-titles st
   else if is-prose-line st then parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-prose-lines st)
   else try-top-level-type-def defs type-defs effect-defs imports ch-title sec-titles st

  parse-top-level-effect : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  parse-top-level-effect (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
   in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
   in let ops = parse-effect-ops st3 []
   in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
   in parse-top-level defs type-defs (effect-defs ++ [ed]) imports ch-title sec-titles (skip-newlines (ops.state))

  EffectOpsResult = record { ops : List EffectOpDef, state : ParseState }

  parse-effect-ops : ParseState -> List EffectOpDef -> EffectOpsResult
  parse-effect-ops (st) (acc) =
   if is-ident (current-kind st) then if is-colon (peek-kind st 1) then let op-tok = current st
      in let st2 = advance (advance st)
      in let type-result = parse-type st2
      in when type-result
         is TypeOk (ty) (st3) ->
          let op = EffectOpDef {
           name = op-tok,
           type-expr = ty
          }
      in parse-effect-ops (skip-newlines st3) (list-snoc acc op)
     else EffectOpsResult {
      ops = acc,
      state = st
     }
    else EffectOpsResult {
     ops = acc,
     state = st
    }

  try-top-level-type-def : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  try-top-level-type-def (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let td-result = parse-type-def st
   in let st2 = td-result.state
   in when td-result.maybe-type-def
    is Just (td) ->
     parse-top-level defs (type-defs ++ [td]) effect-defs imports ch-title sec-titles (skip-newlines st2)
    is None ->
     try-top-level-def defs type-defs effect-defs imports ch-title sec-titles st

  try-top-level-def : List Def -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> List Text -> ParseState -> Document
  try-top-level-def (defs) (type-defs) (effect-defs) (imports) (ch-title) (sec-titles) (st) =
   let def-result = parse-definition st
   in let st2 = def-result.state
   in when def-result.maybe-def
    is Just (d) ->
     let tagged = Def {
      name = d.name,
      params = d.params,
      ann = d.ann,
      body = d.body,
      chapter-slug = ch-title
     }
     in parse-top-level (defs ++ [tagged]) type-defs effect-defs imports ch-title sec-titles (skip-newlines st2)
    is None ->
     parse-top-level defs type-defs effect-defs imports ch-title sec-titles (skip-newlines (advance st2))

Section: Header Scanning (streaming)
  scan-document : ParseState -> ScanResult
  scan-document (st) =
   let st2 = skip-newlines st
   in let imp-result = parse-citations st2 "" []
   in scan-top-level [] [] [] (imp-result.imports) "" "" [] (imp-result.state)

  scan-top-level : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  scan-top-level (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   if is-done st then ScanResult {
    type-defs = type-defs,
    effect-defs = effect-defs,
    def-headers = headers,
    citations = imports,
    chapter-title = ch-title,
    section-titles = sec-titles
   }
   else if is-chapter-header st then let title = extract-header-title st
     in scan-top-level headers type-defs effect-defs imports title title sec-titles (skip-prose-lines (skip-to-next-line st))
   else if is-section-header st then let title = extract-header-title st
     in scan-top-level headers type-defs effect-defs imports cur-chap ch-title (sec-titles ++ [title]) (skip-prose-lines (skip-to-next-line st))
   else if is-page-marker st then scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-to-next-line st)
   else if is-cites-keyword (current-kind st) then let cite-result = parse-citations st cur-chap []
     in scan-top-level headers type-defs effect-defs (imports ++ cite-result.imports) cur-chap ch-title sec-titles (cite-result.state)
   else if is-effect-keyword (current-kind st) then scan-top-level-effect headers type-defs effect-defs imports cur-chap ch-title sec-titles st
   else if is-prose-line st then scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-prose-lines st)
   else try-scan-type-def headers type-defs effect-defs imports cur-chap ch-title sec-titles st

  scan-top-level-effect : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  scan-top-level-effect (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let st1 = advance st
   in let name-tok = current st1
   in let st2 = advance st1
   in let st3 = if is-where-keyword (current-kind st2) then skip-newlines (advance st2) else st2
   in let ops = parse-effect-ops st3 []
   in let ed = EffectDef {
        name = name-tok,
        ops = ops.ops
       }
   in scan-top-level headers type-defs (effect-defs ++ [ed]) imports cur-chap ch-title sec-titles (skip-newlines (ops.state))

  try-scan-type-def : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  try-scan-type-def (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let td-result = parse-type-def st
   in let st2 = td-result.state
   in when td-result.maybe-type-def
    is Just (td) ->
     scan-top-level headers (type-defs ++ [td]) effect-defs imports cur-chap ch-title sec-titles (skip-newlines st2)
    is None ->
     try-scan-def-header headers type-defs effect-defs imports cur-chap ch-title sec-titles st

  try-scan-def-header : List DefHeader -> List TypeDef -> List EffectDef -> List CitesDecl -> Text -> Text -> List Text -> ParseState -> ScanResult
  try-scan-def-header (headers) (type-defs) (effect-defs) (imports) (cur-chap) (ch-title) (sec-titles) (st) =
   let hdr-result = scan-definition cur-chap st
   in let st2 = hdr-result.state
   in when hdr-result.maybe-header
    is Just (hdr) ->
     scan-top-level (headers ++ [hdr]) type-defs effect-defs imports cur-chap ch-title sec-titles (skip-newlines st2)
    is None ->
     scan-top-level headers type-defs effect-defs imports cur-chap ch-title sec-titles (skip-newlines (advance st2))

  scan-definition : Text -> ParseState -> ScanDefResult
  scan-definition (cur-chap) (st) =
   if is-done st then ScanDefResult { maybe-header = None, state = st }
   else if is-ident (current-kind st) then try-scan-def cur-chap st
   else if is-type-ident (current-kind st) then try-scan-def cur-chap st
     else ScanDefResult { maybe-header = None, state = st }

  try-scan-def : Text -> ParseState -> ScanDefResult
  try-scan-def (cur-chap) (st) =
   if is-colon (peek-kind st 1) then let first-name = current st
     in let ann-result = parse-type-annotation st
     in unwrap-type-for-scan cur-chap first-name ann-result
    else scan-def-body-with-ann cur-chap [] st

  unwrap-type-for-scan : Text -> Token -> ParseTypeResult -> ScanDefResult
  unwrap-type-for-scan (cur-chap) (first-name) (r) =
   when r
    is TypeOk (ann-type) (st) ->
     if is-equals (current-kind st) then
      let ann = [TypeAnn {
       name = first-name,
       type-expr = ann-type
      }]
      in let st2 = advance st
      in let st3 = skip-newlines st2
      in let body-pos = st3.pos
      in let st4 = skip-body-tokens st3 (first-name.column)
      in ScanDefResult {
          maybe-header = Just (DefHeader {
           name = first-name,
           params = [],
           ann = ann,
           body-pos = body-pos,
           chapter-slug = cur-chap
          }),
          state = st4
         }
     else
      let name-tok = Token {
       kind = Identifier,
       text = "",
       offset = 0,
       line = 0,
       column = 0,
       file-id = 0
      }
      in let ann = [TypeAnn {
       name = name-tok,
       type-expr = ann-type
      }]
      in let st2 = skip-newlines st
      in scan-def-body-with-ann cur-chap ann st2

  scan-def-body-with-ann : Text -> List TypeAnn -> ParseState -> ScanDefResult
  scan-def-body-with-ann (cur-chap) (ann) (st) =
   let name-tok = current st
   in let st2 = advance st
   in scan-def-params-then cur-chap ann name-tok [] st2

  scan-def-params-then : Text -> List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  scan-def-params-then (cur-chap) (ann) (name-tok) (acc) (st) =
   if is-left-paren (current-kind st) then let st2 = advance st
   in if is-ident (current-kind st2) then let param = current st2
   in let st3 = advance st2
   in let st4 = expect RightParen st3
   in scan-def-params-then cur-chap ann name-tok (list-snoc acc param) st4
      else finish-def-scan cur-chap ann name-tok acc st
    else finish-def-scan cur-chap ann name-tok acc st

  finish-def-scan : Text -> List TypeAnn -> Token -> List Token -> ParseState -> ScanDefResult
  finish-def-scan (cur-chap) (ann) (name-tok) (params) (st) =
   if is-equals (current-kind st) == False then ScanDefResult { maybe-header = None, state = st }
   else let st2 = advance st
   in let st3 = skip-newlines st2
   in let body-pos = st3.pos
   in let st4 = skip-body-tokens st3 (name-tok.column)
   in ScanDefResult {
       maybe-header = Just (DefHeader {
        name = name-tok,
        params = params,
        ann = ann,
        body-pos = body-pos,
        chapter-slug = cur-chap
       }),
       state = st4
      }

  skip-body-tokens : ParseState -> Integer -> ParseState
  skip-body-tokens (st) (name-col) =
   if is-done st then st
   else let tok = current st
   in when tok.kind
     is Newline -> skip-body-tokens (advance st) name-col
     is Indent -> skip-body-tokens (advance st) name-col
     is Dedent -> skip-body-tokens (advance st) name-col
     is otherwise -> if tok.column <= name-col then st
      else skip-body-tokens (advance st) name-col

