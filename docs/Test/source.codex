   in let st16 = st-append-text st15 (mov-rr reg-r13 reg-r10)
   in let st17 = st-append-text st16 (mov-store reg-r13 reg-r12 0)
   in let st18 = st-append-text st17 (mov-rr reg-rax reg-r12)
   in let st19 = st-append-text st18 (add-ri reg-rax 1)
