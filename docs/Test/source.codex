   }

  emit-builtin : CodegenState -> Text -> List IRExpr -> EmitResult
  emit-builtin (st) (name) (args) =
    if name == "print-line" then emit-print-line-builtin st args
    else if name == "read-file" then emit-read-file-builtin st args
    else if name == "write-file" then emit-write-file-builtin st args
    else if name == "read-line" then emit-read-line-builtin st
    else if name == "write-binary" then emit-write-binary-builtin st args
    else if name == "text-length" then emit-text-length-builtin st args
    else if name == "integer-to-text" then emit-helper-call-1 st args "__itoa"
    else if name == "show" then emit-show-builtin st args
    else if name == "text-to-integer" then emit-helper-call-1 st args "__text_to_int"
    else if name == "text-replace" then emit-helper-call-3 st args "__str_replace"
    else if name == "text-contains" then emit-helper-call-2 st args "__text_contains"
    else if name == "text-starts-with" then emit-helper-call-2 st args "__text_starts_with"
    else if name == "text-compare" then emit-helper-call-2 st args "__text_compare"
    else if name == "text-concat-list" then emit-helper-call-1 st args "__text_concat_list"
    else if name == "text-split" then emit-helper-call-2 st args "__text_split"
    else if name == "substring" then emit-substring-builtin st args
    else if name == "list-length" then emit-list-length-builtin st args
    else if name == "list-at" then emit-list-at-builtin st args
    else if name == "list-cons" then emit-helper-call-2 st args "__list_cons"
    else if name == "list-append" then emit-helper-call-2 st args "__list_append"
    else if name == "list-snoc" then emit-helper-call-2 st args "__list_snoc"
    else if name == "list-insert-at" then emit-helper-call-3 st args "__list_insert_at"
    else if name == "list-set-at" then emit-helper-call-3 st args "__list_set_at"
    else if name == "list-contains" then emit-helper-call-2 st args "__list_contains"
    else if name == "char-at" then emit-char-at-builtin st args
    else if name == "char-code-at" then emit-char-code-at-builtin st args
    else if name == "char-code" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "code-to-char" then emit-expr (st-set-tail-pos st False) (list-at args 0)
    else if name == "char-to-text" then emit-char-to-text-builtin st args
    else if name == "is-letter" then emit-is-letter-builtin st args
    else if name == "is-digit" then emit-is-digit-builtin st args
    else if name == "is-whitespace" then emit-is-whitespace-builtin st args
    else if name == "negate" then emit-negate-builtin st args
    else if name == "get-args" then emit-get-args-builtin st
    else if name == "current-dir" then emit-current-dir-builtin st
    else if name == "record-set" then emit-record-set-builtin st args
    else if name == "linked-list-empty" then emit-linked-list-empty-builtin st args
    else if name == "linked-list-push" then emit-linked-list-push-builtin st args
    else if name == "linked-list-to-list" then emit-linked-list-to-list-builtin st args
    else if name == "heap-save" then emit-heap-save-builtin st
    else if name == "heap-restore" then emit-heap-restore-builtin st args
    else if name == "heap-advance" then emit-heap-advance-builtin st args
    else if name == "list-with-capacity" then emit-list-with-capacity-builtin st args
    else if name == "buf-write-byte" then emit-buf-write-byte-builtin st args
    else if name == "buf-write-bytes" then emit-buf-write-bytes-builtin st args
    else if name == "buf-read-bytes" then emit-buf-read-bytes-builtin st args
    else if name == "bit-and" then emit-bit-op-2 st args and-rr
    else if name == "bit-or" then emit-bit-op-2 st args or-rr
    else if name == "bit-xor" then emit-bit-op-2 st args xor-rr
    else if name == "bit-shl" then emit-bit-shift st args shl-cl
    else if name == "bit-shr" then emit-bit-shift st args shr-cl
    else if name == "bit-not" then emit-bit-not st args
    else emit-file-exists-builtin st args

Section: Function Application
  flatten-apply : IRExpr -> List IRExpr -> FlatApply
  flatten-apply (expr) (acc) =
   when expr
    is IrApply (f) (a) (t) (sp) -> flatten-apply f ([a] ++ acc)
    is IrName (n) (t) (sp) -> FlatApply {
     func-name = n,
     args = acc
    }
    is otherwise -> FlatApply {
     func-name = "",
     args = acc
    }

  save-args-loop : CodegenState -> List IRExpr -> Integer -> List Integer -> SavedArgs
  save-args-loop (st) (args) (i) (acc) =
   if i == list-length args then SavedArgs {
   state = st,
   locals = acc
  }
   else let r = emit-expr st (list-at args i)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in save-args-loop st1 args (i + 1) (list-snoc acc (loc.reg))

  push-reg-args : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  push-reg-args (st) (arg-locals) (i) (count) =
   if i == count then st
   else let loaded = load-local st (list-at arg-locals i)
   in push-reg-args (st-append-text (loaded.state) (push-r (loaded.reg))) arg-locals (i + 1) count

  pop-to-arg-regs : CodegenState -> Integer -> CodegenState
  pop-to-arg-regs (st) (i) =
   if i < 0 then st
   else pop-to-arg-regs (st-append-text st (pop-r (list-at arg-regs i))) (i - 1)

  push-stack-args : CodegenState -> List Integer -> Integer -> CodegenState
  push-stack-args (st) (arg-locals) (i) =
   if i < 6 then st
   else let loaded = load-local st (list-at arg-locals i)
   in push-stack-args (st-append-text (loaded.state) (push-r (loaded.reg))) arg-locals (i - 1)

  emit-apply : CodegenState -> IRExpr -> IRExpr -> CodexType -> EmitResult
  emit-apply (st) (func-expr) (arg-expr) (result-ty) =
   let saved-tail = st.tco.in-tail-pos
   in let full-expr = IrApply func-expr arg-expr result-ty (ir-expr-span func-expr)
   in let r = if st.tco.active & saved-tail & is-self-call full-expr (st.tco.current-func) then emit-tail-call st func-expr arg-expr
              else let flat = flatten-apply func-expr [arg-expr]
              in if is-builtin (flat.func-name) then emit-builtin st (flat.func-name) (flat.args)
                    else let resolved-result-ty = resolve-constructed-ty st result-ty
                    in when resolved-result-ty
                     is SumTy (sname) (ctors) ->
                      let tag = find-ctor-tag ctors (flat.func-name) 0
              in if tag >= 0 then emit-sum-ctor st (flat.args) tag
                         else let is-local-sum = lookup-local (st.locals) (flat.func-name) >= 0
                         in if is-local-sum then emit-indirect-call st flat
                         else emit-direct-call st flat
                     is FunTy (pt) (rt) ->
                      let is-local = lookup-local (st.locals) (flat.func-name) >= 0
              in if is-local then emit-indirect-call st flat
                         else emit-partial-application st (flat.func-name) (flat.args)
                     is otherwise ->
                      let is-local = lookup-local (st.locals) (flat.func-name) >= 0
              in if is-local then emit-indirect-call st flat
                         else emit-direct-call st flat
   in EmitResult {
    state = st-set-tail-pos (r.state) saved-tail,
    reg = r.reg
   }

  emit-direct-call : CodegenState -> FlatApply -> EmitResult
  emit-direct-call (st) (flat) =
   let saved = save-args-loop (st-set-tail-pos st False) (flat.args) 0 []
   in let arg-count = list-length (flat.args)
   in let st1 = push-stack-args (saved.state) (saved.locals) (arg-count - 1)
   in let reg-count = if arg-count < 6 then arg-count else 6
   in let st2 = push-reg-args st1 (saved.locals) 0 reg-count
   in let st3 = pop-to-arg-regs st2 (reg-count - 1)
   in let st4 = emit-call-to st3 (flat.func-name)
   in let stack-arg-count = arg-count - 6
   in let st5 = if stack-arg-count > 0 then st-append-text st4 (add-ri reg-rsp (stack-arg-count * 8))
    else st4
   in let tmp = alloc-temp st5
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  emit-indirect-call : CodegenState -> FlatApply -> EmitResult
  emit-indirect-call (st) (flat) =
   let saved = save-args-loop (st-set-tail-pos st False) (flat.args) 0 []
   in let arg-count = list-length (flat.args)
   in let reg-count = if arg-count < 6 then arg-count else 6
   in let st1 = push-reg-args (saved.state) (saved.locals) 0 reg-count
   in let st2 = pop-to-arg-regs st1 (reg-count - 1)
   in let closure-load = load-local st2 (lookup-local (st2.locals) (flat.func-name))
   in let st3 = st-append-text (closure-load.state) (mov-rr reg-r11 (closure-load.reg))
   in let st4 = st-append-text st3 (mov-load reg-rax reg-r11 0)
   in let st5 = st-append-text st4 [255, 208]
   in let tmp = alloc-temp st5
   in EmitResult {
   state = st-append-text (tmp.state) (mov-rr (tmp.reg) reg-rax),
   reg = tmp.reg
  }

  flatten-tail-args : IRExpr -> List IRExpr -> List IRExpr
  flatten-tail-args (expr) (acc) =
   when expr
    is IrApply (f) (a) (t) (sp) -> flatten-tail-args f ([a] ++ acc)
    is otherwise -> acc

  eval-tail-args : CodegenState -> List IRExpr -> List Integer -> Integer -> CodegenState
  eval-tail-args (st) (args) (temp-locals) (i) =
   if i == list-length args then st
   else let st-notail = st-set-tail-pos st False
   in let r = emit-expr st-notail (list-at args i)
   in let st1 = store-local (r.state) (list-at temp-locals i) (r.reg)
   in eval-tail-args st1 args temp-locals (i + 1)

  copy-temps-to-params : CodegenState -> List Integer -> List Integer -> Integer -> CodegenState
  copy-temps-to-params (st) (temp-locals) (param-locals) (i) =
   if i == list-length temp-locals then st
   else let loaded = load-local st (list-at temp-locals i)
   in let st1 = store-local (loaded.state) (list-at param-locals i) (loaded.reg)
   in copy-temps-to-params st1 temp-locals param-locals (i + 1)

  emit-tail-call : CodegenState -> IRExpr -> IRExpr -> EmitResult
  emit-tail-call (st) (func-expr) (arg-expr) =
   let args = flatten-tail-args func-expr [arg-expr]
   in let st1 = eval-tail-args st args (st.tco.temp-locals) 0
   in let st2 = copy-temps-to-params st1 (st.tco.temp-locals) (st.tco.param-locals) 0
   in let rel32 = st.tco.loop-top - (st2.text-len + 5)
   in let st3 = st-append-text st2 (jmp rel32)
   in let dummy = alloc-temp st3
   in EmitResult {
   state = st-append-text (dummy.state) (li (dummy.reg) 0),
   reg = dummy.reg
  }

  emit-sum-ctor : CodegenState -> List IRExpr -> Integer -> EmitResult
  emit-sum-ctor (st) (args) (tag) =
   let saved = save-args-loop st args 0 []
   in let field-count = list-length args
   in let total-size = (1 + field-count) * 8
   in let ptr-loc = alloc-local (saved.state)
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 total-size)
   in let tag-tmp = alloc-temp st3
   in let st4 = st-append-text (tag-tmp.state) (li (tag-tmp.reg) tag)
   in let ptr-load1 = load-local st4 (ptr-loc.reg)
   in let st5 = st-append-text (ptr-load1.state) (mov-store (ptr-load1.reg) (tag-tmp.reg) 0)
   in let st6 = emit-store-ctor-fields st5 (saved.locals) (ptr-loc.reg) 0
   in load-local st6 (ptr-loc.reg)

  emit-store-ctor-fields : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-ctor-fields (st) (field-locals) (ptr-loc) (i) =
   if i == list-length field-locals then st
   else let val = load-local st (list-at field-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-ctor-fields st1 field-locals ptr-loc (i + 1)

Section: Closures and Partial Application
  emit-load-rodata-addr : CodegenState -> Integer -> Integer -> CodegenState
  emit-load-rodata-addr (st) (reg) (rodata-off) =
   let fixup = RodataFixup {
    patch-offset = st.text-len + 2,
    rodata-offset = rodata-off
  }
   in let st1 = st-append-text st (mov-ri64 reg 0)
   in record-set st1 "rodata-fixups" (list-snoc (st1.rodata-fixups) fixup)

  emit-load-func-addr : CodegenState -> Integer -> Text -> CodegenState
  emit-load-func-addr (st) (reg) (func-name) =
   let fixup = FuncAddrFixup {
    patch-offset = st.text-len + 2,
    target = func-name
  }
   in let st1 = st-append-text st (mov-ri64 reg 0)
   in record-set st1 "func-addr-fixups" (list-snoc (st1.func-addr-fixups) fixup)

  emit-trampoline-shift-args : CodegenState -> Integer -> Integer -> CodegenState
  emit-trampoline-shift-args (st) (i) (num-captures) =
   if i < 0 then st
   else if i + num-captures < 6 then emit-trampoline-shift-args (st-append-text st (mov-rr (list-at arg-regs (i + num-captures)) (list-at arg-regs i))) (i - 1) num-captures
   else emit-trampoline-shift-args st (i - 1) num-captures

  emit-trampoline-load-captures : CodegenState -> Integer -> Integer -> CodegenState
  emit-trampoline-load-captures (st) (i) (num-captures) =
   if i == num-captures then st
   else if i < 6 then emit-trampoline-load-captures (st-append-text st (mov-load (list-at arg-regs i) reg-r11 (8 + i * 8))) (i + 1) num-captures
   else st

  emit-partial-application : CodegenState -> Text -> List IRExpr -> EmitResult
  emit-partial-application (st) (func-name) (captured-args) =
   let saved = save-args-loop (st-set-tail-pos st False) captured-args 0 []
   in let num-captures = list-length captured-args
   in let tramp-name = func-name ++ "__tramp__" ++ integer-to-text num-captures ++ "__" ++ integer-to-text (saved.state.text-len)
   in let jmp-over-pos = saved.state.text-len
   in let st1 = st-append-text (saved.state) (jmp 0)
   in let st2 = record-func-offset st1 tramp-name
   in let st3 = emit-trampoline-shift-args st2 5 num-captures
   in let st4 = emit-trampoline-load-captures st3 0 num-captures
   in let st5 = emit-load-func-addr st4 reg-rax func-name
   in let st6 = st-append-text st5 [255, 224]
   in let st7 = patch-jmp-at st6 jmp-over-pos (st6.text-len)
   in let closure-size = (1 + num-captures) * 8
   in let ptr-loc = alloc-local st7
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st8 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st9 = store-local st8 (ptr-loc.reg) (ptr-tmp.reg)
   in let st10 = st-append-text st9 (add-ri reg-r10 closure-size)
   in let st11 = emit-load-func-addr st10 reg-rax tramp-name
   in let ptr-load1 = load-local st11 (ptr-loc.reg)
   in let st12 = st-append-text (ptr-load1.state) (mov-store (ptr-load1.reg) reg-rax 0)
   in let st13 = emit-store-closure-captures st12 (saved.locals) (ptr-loc.reg) 0
   in load-local st13 (ptr-loc.reg)

  emit-store-closure-captures : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-closure-captures (st) (cap-locals) (ptr-loc) (i) =
   if i == list-length cap-locals then st
   else let val = load-local st (list-at cap-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-closure-captures st1 cap-locals ptr-loc (i + 1)

  collect-func-addr-patches : List FuncAddrFixup -> OffsetTable -> Integer -> Integer -> List PatchEntry -> List PatchEntry
  collect-func-addr-patches (fixups) (offset-map) (text-base) (i) (acc) =
   if i == list-length fixups then acc
   else let f = list-at fixups i
   in let func-offset = offset-table-lookup offset-map (f.target)
   in let addr = text-base + func-offset
   in let addr-bytes = write-i64 addr
   in let p0 = PatchEntry {
    pos = f.patch-offset,
    b0 = list-at addr-bytes 0,
    b1 = list-at addr-bytes 1,
    b2 = list-at addr-bytes 2,
    b3 = list-at addr-bytes 3
  }
   in let p1 = PatchEntry {
    pos = f.patch-offset + 4,
    b0 = list-at addr-bytes 4,
    b1 = list-at addr-bytes 5,
    b2 = list-at addr-bytes 6,
    b3 = list-at addr-bytes 7
  }
   in collect-func-addr-patches fixups offset-map text-base (i + 1) (acc ++ [p0, p1])

  collect-rodata-patches : List RodataFixup -> Integer -> Integer -> List PatchEntry -> List PatchEntry
  collect-rodata-patches (fixups) (rodata-vaddr) (i) (acc) =
   if i == list-length fixups then acc
   else let f = list-at fixups i
   in let addr = rodata-vaddr + f.rodata-offset
   in let addr-bytes = write-i64 addr
   in let p0 = PatchEntry {
    pos = f.patch-offset,
    b0 = list-at addr-bytes 0,
    b1 = list-at addr-bytes 1,
    b2 = list-at addr-bytes 2,
    b3 = list-at addr-bytes 3
  }
   in let p1 = PatchEntry {
    pos = f.patch-offset + 4,
    b0 = list-at addr-bytes 4,
    b1 = list-at addr-bytes 5,
    b2 = list-at addr-bytes 6,
    b3 = list-at addr-bytes 7
  }
   in collect-rodata-patches fixups rodata-vaddr (i + 1) (acc ++ [p0, p1])

Section: Record Emission
  resolve-constructed-raw : CodexType -> CodexType -> CodexType
  resolve-constructed-raw (raw) (fallback) =
   when raw
    is RecordTy (rn) (rf) -> raw
    is SumTy (sn) (sc) -> raw
    is FunTy (p) (r) -> strip-fun-args-emitter r
    is otherwise -> fallback

  resolve-constructed-ty : CodegenState -> CodexType -> CodexType
  resolve-constructed-ty (st) (ty) =
   when ty
    is RecordTy (rn) (rf) -> ty
    is SumTy (sn) (sc) -> ty
    is ConstructedTy (cname) (cargs) ->
     let raw = lookup-type-binding (st.type-defs) (cname.value)
     in resolve-constructed-raw raw ty
    is EffectfulTy (effs) (ret) -> resolve-constructed-ty st ret
    is ForAllTy (id) (body) -> resolve-constructed-ty st body
    is otherwise -> ty

  strip-fun-args-emitter : CodexType -> CodexType
  strip-fun-args-emitter (ty) =
   when ty
    is FunTy (p) (r) -> strip-fun-args-emitter r
    is otherwise -> ty

  lookup-type-binding : List TypeBinding -> Text -> CodexType
  lookup-type-binding (bindings) (name) =
   lookup-type-binding-loop bindings name 0 (list-length bindings)

  lookup-type-binding-loop : List TypeBinding -> Text -> Integer -> Integer -> CodexType
  lookup-type-binding-loop (bindings) (name) (i) (len) =
   if i == len then ErrorTy
   else let b = list-at bindings i
   in if b.name == name then b.bound-type
      else lookup-type-binding-loop bindings name (i + 1) len

  find-record-field-index : List RecordField -> Text -> Integer -> Integer
  find-record-field-index (fields) (name) (i) =
   if i == list-length fields then 0
   else let f = list-at fields i
   in if f.name.value == name then i
      else find-record-field-index fields name (i + 1)

  emit-eval-record-fields : CodegenState -> List IRFieldVal -> Integer -> List FieldLocal -> EvalFieldsResult
  emit-eval-record-fields (st) (fields) (i) (acc) =
   if i == list-length fields then EvalFieldsResult {
   state = st,
    field-locals = acc
  }
   else let fv = list-at fields i
   in let r = emit-expr st (fv.value)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in emit-eval-record-fields st1 fields (i + 1) (list-snoc acc (FieldLocal {
    name = fv.name,
    slot = loc.reg
   }))

  find-field-local-slot : List FieldLocal -> Text -> Integer -> Integer
  find-field-local-slot (fls) (name) (i) =
   if i == list-length fls then -1
   else let fl = list-at fls i
   in if fl.name == name then fl.slot
      else find-field-local-slot fls name (i + 1)

  emit-store-record-fields-by-type : CodegenState -> List RecordField -> List FieldLocal -> Integer -> Integer -> CodegenState
  emit-store-record-fields-by-type (st) (type-fields) (field-locals) (ptr-loc) (i) =
   if i == list-length type-fields then st
   else let tf = list-at type-fields i
   in let slot = find-field-local-slot field-locals (tf.name.value) 0
   in if slot >= 0 then let val = load-local st slot
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (i * 8))
   in emit-store-record-fields-by-type st1 type-fields field-locals ptr-loc (i + 1)
     else emit-store-record-fields-by-type st type-fields field-locals ptr-loc (i + 1)

  emit-store-record-fields-by-list : CodegenState -> List FieldLocal -> Integer -> Integer -> CodegenState
  emit-store-record-fields-by-list (st) (field-locals) (ptr-loc) (i) =
   if i == list-length field-locals then st
   else let fl = list-at field-locals i
   in let val = load-local st (fl.slot)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (i * 8))
   in emit-store-record-fields-by-list st1 field-locals ptr-loc (i + 1)

  emit-record : CodegenState -> List IRFieldVal -> CodexType -> EmitResult
  emit-record (st) (fields) (ty) =
   let evaled = emit-eval-record-fields st fields 0 []
   in let field-count = list-length fields
   in let total-size = field-count * 8
   in let ptr-loc = alloc-local (evaled.state)
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st1 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st2 = store-local st1 (ptr-loc.reg) (ptr-tmp.reg)
   in let st3 = st-append-text st2 (add-ri reg-r10 total-size)
   in let resolved-ty = resolve-constructed-ty st ty
   in let st4 = when resolved-ty
    is RecordTy (rname) (type-fields) -> emit-store-record-fields-by-type st3 type-fields (evaled.field-locals) (ptr-loc.reg) 0
    is otherwise -> emit-store-record-fields-by-list st3 (evaled.field-locals) (ptr-loc.reg) 0
   in load-local st4 (ptr-loc.reg)

  emit-field-access : CodegenState -> IRExpr -> Text -> EmitResult
  emit-field-access (st) (rec-expr) (field-name) =
   let rec-ty = resolve-constructed-ty st (ir-expr-type rec-expr)
   in let rec-result = emit-expr st rec-expr
   in when rec-ty
    is RecordTy (rname) (rfields) ->
     let field-idx = find-record-field-index rfields field-name 0
     in let rd = alloc-temp (rec-result.state)
     in EmitResult {
      state = st-append-text (rd.state) (mov-load (rd.reg) (rec-result.reg) (field-idx * 8)),
      reg = rd.reg
     }
    is otherwise ->
     let st-err = st-add-error (rec-result.state) cdx-ir-error ("emit-field-access: unresolved type for field '" ++ field-name ++ "'") (ir-expr-span rec-expr)
     in let rd = alloc-temp st-err
     in EmitResult {
      state = st-append-text (rd.state) [15, 11],
      reg = rd.reg
     }

Section: Pattern Matching
  emit-match : CodegenState -> IRExpr -> List IRBranch -> EmitResult
  emit-match (st) (scrut-expr) (branches) =
   let saved-tail = st.tco.in-tail-pos
   in let scrut-ty = resolve-constructed-ty st (ir-expr-type scrut-expr)
   in let scrut-result = emit-expr (st-set-tail-pos st False) scrut-expr
   in let scrut-loc = alloc-local (scrut-result.state)
   in let st1 = store-local (scrut-loc.state) (scrut-loc.reg) (scrut-result.reg)
   in let st1a = st-set-tail-pos st1 saved-tail
   in let result-loc = alloc-local st1a
   in let mbs = MatchBranchState {
    cg-state = st1a,
    end-patches = []
  }
   in let mbs-final = emit-match-branch-loop mbs (scrut-loc.reg) (result-loc.reg) branches 0 (list-length branches) scrut-ty
   in let st-end = patch-match-end-jumps (mbs-final.cg-state) (mbs-final.end-patches) 0
   in load-local st-end (result-loc.reg)

  emit-match-branch-loop : MatchBranchState -> Integer -> Integer -> List IRBranch -> Integer -> Integer -> CodexType -> MatchBranchState
  emit-match-branch-loop (mbs) (scrut-loc) (result-loc) (branches) (i) (total) (scrut-ty) =
   if i == total then mbs
   else let b = list-at branches i
   in let mbs1 = emit-one-match-branch mbs scrut-loc result-loc b (i < total - 1) scrut-ty
   in emit-match-branch-loop mbs1 scrut-loc result-loc branches (i + 1) total scrut-ty

  emit-one-match-branch : MatchBranchState -> Integer -> Integer -> IRBranch -> Boolean -> CodexType -> MatchBranchState
  emit-one-match-branch (mbs) (scrut-loc) (result-loc) (branch) (needs-jmp-end) (scrut-ty) =
   let pat-result = emit-pattern (mbs.cg-state) scrut-loc (branch.pattern) scrut-ty
   in let body-result = emit-expr (pat-result.state) (branch.body)
   in let st1 = store-local (body-result.state) result-loc (body-result.reg)
   in let st2 = if needs-jmp-end then let jmp-pos = st1.text-len
   in MatchBranchState {
      cg-state = st-append-text st1 (jmp 0),
      end-patches = list-snoc (mbs.end-patches) jmp-pos
     }
    else MatchBranchState {
     cg-state = st1,
     end-patches = mbs.end-patches
    }
   in let st3 = if pat-result.next-branch-patch >= 0 then MatchBranchState {
     cg-state = patch-jcc-at (st2.cg-state) (pat-result.next-branch-patch) (st2.cg-state.text-len),
     end-patches = st2.end-patches
    }
    else st2
   in st3

  EmitPatternResult = record {
   state : CodegenState,
   next-branch-patch : Integer
  }

  emit-pattern : CodegenState -> Integer -> IRPat -> CodexType -> EmitPatternResult
  emit-pattern (st) (scrut-loc) (pat) (scrut-ty) =
   when pat
    is IrWildPat (sp) -> EmitPatternResult {
     state = st,
     next-branch-patch = -1
    }
    is IrVarPat (name) (ty) (sp) ->
     let var-loc = alloc-local st
     in let loaded = load-local (var-loc.state) scrut-loc
     in let st1 = store-local (loaded.state) (var-loc.reg) (loaded.reg)
     in EmitPatternResult {
      state = add-local st1 name (var-loc.reg),
      next-branch-patch = -1
     }
    is IrCtorPat (name) (sub-pats) (ty) (sp) ->
     let scrut-load = load-local st scrut-loc
     in let tag-reg = alloc-temp (scrut-load.state)
     in let st1 = st-append-text (tag-reg.state) (mov-load (tag-reg.reg) (scrut-load.reg) 0)
     in let resolve-ty = when scrut-ty
      is SumTy (sn) (cs) -> scrut-ty
      is otherwise -> resolve-constructed-ty st ty
     in let expected-tag = when resolve-ty
      is SumTy (sname) (ctors) -> find-ctor-tag ctors name 0
      is otherwise -> 0
     in let st2 = st-append-text st1 (cmp-ri (tag-reg.reg) expected-tag)
     in let jcc-pos = st2.text-len
     in let st3 = st-append-text st2 (jcc cc-ne 0)
     in let st4 = bind-ctor-fields st3 scrut-loc sub-pats 0
     in EmitPatternResult {
      state = st4,
      next-branch-patch = jcc-pos
     }
    is IrLitPat (value) (ty) (sp) ->
     EmitPatternResult {
      state = st,
      next-branch-patch = -1
     }

  bind-ctor-fields : CodegenState -> Integer -> List IRPat -> Integer -> CodegenState
  bind-ctor-fields (st) (scrut-loc) (sub-pats) (i) =
   if i == list-length sub-pats then st
   else let sub = list-at sub-pats i
   in when sub
     is IrVarPat (name) (ty) (sp) ->
      let field-loc = alloc-local st
   in let scrut-load = load-local (field-loc.state) scrut-loc
   in let field-val = alloc-temp (scrut-load.state)
   in let st1 = st-append-text (field-val.state) (mov-load (field-val.reg) (scrut-load.reg) ((1 + i) * 8))
   in let st2 = store-local st1 (field-loc.reg) (field-val.reg)
   in bind-ctor-fields (add-local st2 name (field-loc.reg)) scrut-loc sub-pats (i + 1)
     is otherwise -> bind-ctor-fields st scrut-loc sub-pats (i + 1)

  patch-match-end-jumps : CodegenState -> List Integer -> Integer -> CodegenState
  patch-match-end-jumps (st) (patches) (i) =
   if i == list-length patches then st
   else patch-match-end-jumps (patch-jmp-at st (list-at patches i) (st.text-len)) patches (i + 1)

Section: List Emission
  emit-eval-list-elems : CodegenState -> List IRExpr -> Integer -> List Integer -> SavedArgs
  emit-eval-list-elems (st) (elems) (i) (acc) =
   if i == list-length elems then SavedArgs {
   state = st,
   locals = acc
  }
   else let r = emit-expr st (list-at elems i)
   in let loc = alloc-local (r.state)
   in let st1 = store-local (loc.state) (loc.reg) (r.reg)
   in emit-eval-list-elems st1 elems (i + 1) (list-snoc acc (loc.reg))

  emit-store-list-elems : CodegenState -> List Integer -> Integer -> Integer -> CodegenState
  emit-store-list-elems (st) (elem-locals) (ptr-loc) (i) =
   if i == list-length elem-locals then st
   else let val = load-local st (list-at elem-locals i)
   in let ptr = load-local (val.state) ptr-loc
   in let st1 = st-append-text (ptr.state) (mov-store (ptr.reg) (val.reg) (8 + i * 8))
   in emit-store-list-elems st1 elem-locals ptr-loc (i + 1)

  emit-list : CodegenState -> List IRExpr -> EmitResult
  emit-list (st) (elems) =
   let saved = emit-eval-list-elems st elems 0 []
   in let count = list-length elems
   in let cap-tmp = alloc-temp (saved.state)
   in let st1 = st-append-text (cap-tmp.state) (li (cap-tmp.reg) count)
   in let st2 = st-append-text st1 (mov-store reg-r10 (cap-tmp.reg) 0)
   in let st3 = st-append-text st2 (add-ri reg-r10 8)
   in let ptr-loc = alloc-local st3
   in let ptr-tmp = alloc-temp (ptr-loc.state)
   in let st4 = st-append-text (ptr-tmp.state) (mov-rr (ptr-tmp.reg) reg-r10)
   in let st5 = store-local st4 (ptr-loc.reg) (ptr-tmp.reg)
   in let st6 = st-append-text st5 (add-ri reg-r10 ((count + 1) * 8))
   in let len-tmp = alloc-temp st6
   in let st7 = st-append-text (len-tmp.state) (li (len-tmp.reg) count)
   in let ptr-load = load-local st7 (ptr-loc.reg)
   in let st8 = st-append-text (ptr-load.state) (mov-store (ptr-load.reg) (len-tmp.reg) 0)
   in let st9 = emit-store-list-elems st8 (saved.locals) (ptr-loc.reg) 0
   in load-local st9 (ptr-loc.reg)

Section: 32-bit Bare-Metal Trampoline
  multiboot-header : List Integer
  multiboot-header =
   write-i32 464367618 ++ write-i32 0 ++ write-i32 3830599678

  tramp-clear-pages : List Integer
  tramp-clear-pages =
   [250, 191, 0, 16, 0, 0, 185, 0, 12, 0, 0, 49, 192, 243, 171]

  tramp-page-tables : List Integer
  tramp-page-tables =
   [199, 5, 0, 16, 0, 0, 3, 32, 0, 0, 199, 5, 0, 32, 0, 0, 3, 48, 0, 0, 191, 0, 48, 0, 0, 185, 0, 1, 0, 0, 184, 131, 0, 0, 0, 137, 7, 199, 71, 4, 0, 0, 0, 0, 131, 199, 8, 5, 0, 0, 32, 0, 73, 117, 236]

  tramp-enable-long-mode : List Integer
  tramp-enable-long-mode =
   [184, 0, 16, 0, 0, 15, 34, 216, 15, 32, 224, 131, 200, 32, 15, 34, 224, 185, 128, 0, 0, 192, 15, 50, 13, 0, 1, 0, 0, 15, 48, 15, 32, 192, 13, 0, 0, 0, 128, 15, 34, 192]

  trampoline-code : List Integer
  trampoline-code =
   tramp-clear-pages ++ tramp-page-tables ++ tramp-enable-long-mode

  tramp-gdt-data : List Integer
  tramp-gdt-data =
   [235, 30, 0, 0, 0, 0, 0, 0, 0, 0, 255, 255, 0, 0, 0, 154, 175, 0, 255, 255, 0, 0, 0, 146, 207, 0]

  trampoline-gdt-section : List Integer
  trampoline-gdt-section =
   tramp-gdt-data ++ write-i16 23 ++ write-i32 (bare-metal-load-addr + 126) ++ [15, 1, 21] ++ write-i32 (bare-metal-load-addr + 150) ++ [234, 0, 0, 0, 0, 8, 0]

  bare-metal-trampoline : TrampolineResult
  bare-metal-trampoline =
   let bytes = multiboot-header ++ trampoline-code ++ trampoline-gdt-section
   in TrampolineResult {
    bytes = bytes,
    far-jump-patch-pos = 163
  }

Section: Serial I/O
  emit-out-byte : CodegenState -> Integer -> Integer -> CodegenState
  emit-out-byte (st) (port) (value) =
   let st1 = st-append-text st (li reg-rdx port)
   in let st2 = st-append-text st1 (li reg-rax value)
   in st-append-text st2 out-dx-al

  emit-com1-init : CodegenState -> CodegenState
  emit-com1-init (st) =
   let st1 = emit-out-byte st 1019 128
   in let st2 = emit-out-byte st1 1016 1
   in let st3 = emit-out-byte st2 1017 0
   in let st4 = emit-out-byte st3 1019 3
   in let st5 = emit-out-byte st4 1018 199
   in emit-out-byte st5 1020 11

  emit-serial-wait-and-send : CodegenState -> Integer -> CodegenState
  emit-serial-wait-and-send (st) (byte-val) =
   let wait-top = st.text-len
   in let st1 = st-append-text st (li reg-rdx 1021)
   in let st2 = st-append-text st1 [236]
   in let st3 = st-append-text st2 [168, 32]
   in let jne-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ne 0)
   in let st5 = st-append-text st4 (jmp (wait-top - (st4.text-len + 5)))
   in let st6 = patch-jcc-at st5 jne-pos (st5.text-len)
   in let st7 = st-append-text st6 (li reg-rdx 1016)
   in let st8 = st-append-text st7 (li reg-rax byte-val)
   in st-append-text st8 out-dx-al

  emit-serial-send-rdi : CodegenState -> CodegenState
  emit-serial-send-rdi (st) =
   let wait-top = st.text-len
   in let st1 = st-append-text st (li reg-rdx 1021)
   in let st2 = st-append-text st1 [236]
   in let st3 = st-append-text st2 [168, 32]
   in let jne-pos = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ne 0)
   in let st5 = st-append-text st4 (jmp (wait-top - (st4.text-len + 5)))
   in let st6 = patch-jcc-at st5 jne-pos (st5.text-len)
   in let st7 = st-append-text st6 (li reg-rdx 1016)
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rdi)
   in st-append-text st8 out-dx-al

Section: Inline Integer Print
  ItoaState = record {
   cg : CodegenState,
   jmp-done-zero-pos : Integer
  }

  emit-itoa-zero-check : CodegenState -> ItoaState
  emit-itoa-zero-check (st) =
   let st1 = st-append-text st (mov-rr reg-rbx reg-rax)
   in let st2 = st-append-text st1 (test-rr reg-rbx reg-rbx)
   in let jne-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ne 0)
   in let st4 = emit-serial-wait-and-send st3 48
   in let jmp-pos = st4.text-len
   in let st5 = st-append-text st4 (jmp 0)
   in let st6 = patch-jcc-at st5 jne-pos (st5.text-len)
   in ItoaState {
    cg = st6,
    jmp-done-zero-pos = jmp-pos
  }

  emit-itoa-sign-and-digits : CodegenState -> CodegenState
  emit-itoa-sign-and-digits (st) =
   let st1 = st-append-text st (test-rr reg-rbx reg-rbx)
   in let jns-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = emit-serial-wait-and-send st2 45
   in let st4 = st-append-text st3 (neg-r reg-rbx)
   in let st5 = patch-jcc-at st4 jns-pos (st4.text-len)
   in let st6 = st-append-text st5 (li reg-rcx 0)
   in let st7 = st-append-text st6 (li reg-r11 10)
   in let loop-top = st7.text-len
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rbx)
   in let st9 = st-append-text st8 cqo
   in let st10 = st-append-text st9 (idiv-r reg-r11)
   in let st11 = st-append-text st10 (mov-rr reg-rbx reg-rax)
   in let st12 = st-append-text st11 (add-ri reg-rdx 48)
   in let st13 = st-append-text st12 (push-r reg-rdx)
   in let st14 = st-append-text st13 (add-ri reg-rcx 1)
   in let st15 = st-append-text st14 (test-rr reg-rbx reg-rbx)
   in st-append-text st15 (jcc cc-ne (loop-top - (st15.text-len + 6)))

  emit-itoa-print-loop : CodegenState -> CodegenState
  emit-itoa-print-loop (st) =
   let loop-top = st.text-len
   in let st1 = st-append-text st (test-rr reg-rcx reg-rcx)
   in let je-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let st3 = st-append-text st2 (pop-r reg-rdi)
   in let st4 = st-append-text st3 (push-r reg-rcx)
   in let st5 = emit-serial-send-rdi st4
   in let st6 = st-append-text st5 (pop-r reg-rcx)
   in let st7 = st-append-text st6 (sub-ri reg-rcx 1)
   in let st8 = st-append-text st7 (jmp (loop-top - (st7.text-len + 5)))
   in patch-jcc-at st8 je-pos (st8.text-len)

  emit-inline-itoa-and-print : CodegenState -> CodegenState
  emit-inline-itoa-and-print (st) =
   let zero = emit-itoa-zero-check st
   in let st1 = emit-itoa-sign-and-digits (zero.cg)
   in let st2 = emit-itoa-print-loop st1
   in patch-jmp-at st2 (zero.jmp-done-zero-pos) (st2.text-len)

Section: Print Text
  emit-serial-wait-thr : CodegenState -> CodegenState
  emit-serial-wait-thr (st) =
   let st1 = st-append-text st (push-r reg-rax)
   in let wait-top = st1.text-len
   in let st2 = st-append-text st1 (li reg-rdx 1021)
   in let st3 = st-append-text st2 [236]
   in let st4 = st-append-text st3 [168, 32]
   in let jne-pos = st4.text-len
   in let st5 = st-append-text st4 (jcc cc-ne 0)
   in let st6 = st-append-text st5 (jmp (wait-top - (st5.text-len + 5)))
   in let st7 = patch-jcc-at st6 jne-pos (st6.text-len)
   in st-append-text st7 (pop-r reg-rax)

  emit-print-newline : CodegenState -> CodegenState
  emit-print-newline (st) =
   let st1 = emit-serial-wait-thr st
   in let st2 = st-append-text st1 (li reg-rax 10)
   in let st3 = st-append-text st2 (li reg-rdx 1016)
   in st-append-text st3 out-dx-al

  emit-print-text-loop : CodegenState -> Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-print-text-loop (st) (saved-ptr) (saved-table) (saved-len) (saved-idx) =
   let loop-top = st.text-len
   in let idx = load-local st saved-idx
   in let len-check = load-local (idx.state) saved-len
   in let st1 = st-append-text (len-check.state) (cmp-rr (idx.reg) (len-check.reg))
   in let done-jump = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let ptr-l = load-local st2 saved-ptr
   in let idx2 = load-local (ptr-l.state) saved-idx
   in let st3 = st-append-text (idx2.state) (lea reg-rsi (ptr-l.reg) 8)
   in let st4 = st-append-text st3 (add-rr reg-rsi (idx2.reg))
   in let st5 = st-append-text st4 (movzx-byte reg-rax reg-rsi 0)
   in let tbl = load-local st5 saved-table
   in let st6 = st-append-text (tbl.state) (add-rr reg-rax (tbl.reg))
   in let st7 = st-append-text st6 (movzx-byte reg-rax reg-rax 0)
   in let st8 = emit-serial-wait-thr st7
   in let st9 = st-append-text st8 (li reg-rdx 1016)
   in let st10 = st-append-text st9 out-dx-al
   in let idx3 = load-local st10 saved-idx
   in let st11 = st-append-text (idx3.state) (add-ri (idx3.reg) 1)
   in let st12 = store-local st11 saved-idx (idx3.reg)
   in let st13 = st-append-text st12 (jmp (loop-top - (st12.text-len + 5)))
   in patch-jcc-at st13 done-jump (st13.text-len)

  emit-print-text : CodegenState -> Integer -> CodegenState
  emit-print-text (st) (ptr-reg) =
   let saved-ptr = alloc-local st
   in let st1 = store-local (saved-ptr.state) (saved-ptr.reg) ptr-reg
   in let saved-table = alloc-local st1
   in let st2 = emit-load-rodata-addr (saved-table.state) reg-r11 cce-to-unicode-rodata-offset
   in let st2a = store-local st2 (saved-table.reg) reg-r11
   in let ptr-ld = load-local st2a (saved-ptr.reg)
   in let tmp-len = alloc-temp (ptr-ld.state)
   in let st3 = st-append-text (tmp-len.state) (mov-load (tmp-len.reg) (ptr-ld.reg) 0)
   in let saved-len = alloc-local st3
   in let st4 = store-local (saved-len.state) (saved-len.reg) (tmp-len.reg)
   in let saved-idx = alloc-local st4
   in let st5 = st-append-text (saved-idx.state) (li reg-r11 0)
   in let st6 = store-local st5 (saved-idx.reg) reg-r11
   in let st7 = emit-print-text-loop st6 (saved-ptr.reg) (saved-table.reg) (saved-len.reg) (saved-idx.reg)
   in emit-print-newline st7

  emit-print-text-no-newline : CodegenState -> Integer -> CodegenState
  emit-print-text-no-newline (st) (ptr-reg) =
   let saved-ptr = alloc-local st
   in let st1 = store-local (saved-ptr.state) (saved-ptr.reg) ptr-reg
   in let saved-table = alloc-local st1
   in let st2 = emit-load-rodata-addr (saved-table.state) reg-r11 cce-to-unicode-rodata-offset
   in let st2a = store-local st2 (saved-table.reg) reg-r11
   in let ptr-ld = load-local st2a (saved-ptr.reg)
   in let tmp-len = alloc-temp (ptr-ld.state)
   in let st3 = st-append-text (tmp-len.state) (mov-load (tmp-len.reg) (ptr-ld.reg) 0)
   in let saved-len = alloc-local st3
   in let st4 = store-local (saved-len.state) (saved-len.reg) (tmp-len.reg)
   in let saved-idx = alloc-local st4
   in let st5 = st-append-text (saved-idx.state) (li reg-r11 0)
   in let st6 = store-local st5 (saved-idx.reg) reg-r11
   in emit-print-text-loop st6 (saved-ptr.reg) (saved-table.reg) (saved-len.reg) (saved-idx.reg)

Section: Call Emission
  emit-call-to : CodegenState -> Text -> CodegenState
  emit-call-to (st) (target) =
   let patch-pos = st.text-len
   in let st1 = st-append-text st (x86-call 0)
   in record-set st1 "call-patches" (list-snoc (st1.call-patches) (CallPatch {
     patch-offset = patch-pos,
     target = target
    }))

Section: Bare-Metal Start
  bare-metal-heap-base : Integer
  bare-metal-heap-base =
   4194304

  emit-oom-string : CodegenState -> List Integer -> Integer -> CodegenState
  emit-oom-string (st) (chars) (i) =
   if i >= list-length chars then st
   else emit-oom-string (emit-serial-wait-and-send st (list-at chars i)) chars (i + 1)

  emit-out-of-memory-handler : CodegenState -> CodegenState
  emit-out-of-memory-handler (st) =
   let st1 = record-func-offset st "__out_of_memory"
   in let st2 = st-append-text st1 (mov-rr reg-rbx reg-rsp)
   in let st3 = st-append-text st2 (mov-rr reg-r12 reg-r10)
   in let st4 = st-append-text st3 (li reg-rsp bare-metal-stack-top)
   in let st5 = st-append-text st4 (mov-rr reg-rbp reg-rsp)
   in let st6 = emit-oom-string st5 [79, 85, 84, 32, 79, 70, 32, 77, 69, 77, 79, 82, 89, 10] 0
   in let st7 = st-append-text st6 [244]
   in st-append-text st7 (jmp (0 - 6))

  collect-overflow-patches : List Integer -> Integer -> Integer -> List PatchEntry -> List PatchEntry
  collect-overflow-patches (checks) (oom-offset) (i) (acc) =
   if i >= list-length checks then acc
   else let pos = list-at checks i
    in let rel32 = oom-offset - (pos + 6)
    in collect-overflow-patches checks oom-offset (i + 1) (list-snoc acc (make-i32-patch (pos + 2) rel32))

  emit-start : CodegenState -> Integer -> Integer -> CodegenState
  emit-start (st) (first-stub-vaddr) (syscall-handler-offset) =
   let st1 = record-func-offset st "__start"
   in let st2 = st-append-text st1 cli
   in let st3 = st-append-text st2 (li reg-rsp bare-metal-stack-top)
   in let st4 = st-append-text st3 (mov-rr reg-rbp reg-rsp)
   in let st5 = st-append-text st4 (li reg-r10 bare-metal-heap-base)
   in let st6 = st-append-text st5 (mov-rr reg-r15 reg-r10)
   in let st7 = st-append-text st6 (li reg-r11 stack-min-rsp-addr)
   in let st8 = st-append-text st7 (li reg-rax bare-metal-stack-top)
   in let st9 = st-append-text st8 (mov-store reg-r11 reg-rax 0)
   in let st10 = emit-load-rodata-addr st9 reg-r11 result-base-rodata-offset
   in let st11 = st-append-text st10 (mov-store reg-r11 reg-r15 0)
   in let st12 = emit-process-setup st11
   in let st13 = emit-grant-capability st12 0 cap-console
   in let st14 = emit-grant-capability st13 0 cap-concurrent
   in let st15 = emit-grant-capability st14 1 cap-console
   in let syscall-vaddr = bare-metal-load-addr + syscall-handler-offset
   in let st16 = emit-write-msr st15 3221225601 (8 * 4294967296)
   in let st17 = emit-write-msr st16 3221225602 syscall-vaddr
   in let st18 = emit-write-msr st17 3221225604 512
   in let st19 = st-append-text st18 (li reg-rcx 3221225600)
   in let st20 = st-append-text st19 [15, 50]
   in let st21 = st-append-text st20 [72, 131, 200, 1]
   in let st22 = st-append-text st21 [15, 48]
   in let st23 = emit-out-byte st22 1019 128
   in let st24 = emit-out-byte st23 1016 1
   in let st25 = emit-out-byte st24 1017 0
   in let st26 = emit-out-byte st25 1019 3
   in let st27 = emit-out-byte st26 1018 199
   in let st28 = emit-out-byte st27 1020 11
   in let st29 = emit-out-byte st28 1017 1
   in let st30 = st-append-text st29 (li reg-rdi serial-write-pos-addr)
   in let st31 = st-append-text st30 (li reg-rax 0)
   in let st32 = st-append-text st31 (mov-store reg-rdi reg-rax 0)
   in let st33 = st-append-text st32 (li reg-rdi serial-read-pos-addr)
   in let st34 = st-append-text st33 (mov-store reg-rdi reg-rax 0)
   in let st35 = emit-idt-entries st34 first-stub-vaddr
   in let st36 = emit-interrupt-setup st35
   in let st37 = emit-serial-string st36 [82, 69, 65, 68, 89, 10]
   in let st38 = st-append-text st37 (li reg-rdi arena-base-addr)
   in let st39 = st-append-text st38 (mov-store reg-rdi reg-r10 0)
   in let st40 = st-append-text st39 (li reg-rdi result-arena-base-addr)
   in let st41 = st-append-text st40 (mov-store reg-rdi reg-r15 0)
   in let repl-loop = st41.text-len
   in let st42 = st-append-text st41 (li reg-rdi arena-base-addr)
   in let st43 = st-append-text st42 (mov-load reg-r10 reg-rdi 0)
   in let st44 = st-append-text st43 (li reg-rdi result-arena-base-addr)
   in let st45 = st-append-text st44 (mov-load reg-r15 reg-rdi 0)
   in let st46 = st-append-text st45 (li reg-rdi heap-hwm-addr)
   in let st47 = st-append-text st46 (mov-store reg-rdi reg-r10 0)
   in let st48 = emit-call-to st47 "main"
   in let st48a = emit-inline-itoa-and-print st48
   in let st48b = emit-serial-wait-and-send st48a 10
   in let st49 = emit-update-heap-hwm st48b
   in let st50 = emit-serial-string st49 [72, 69, 65, 80, 58]
   in let st51 = st-append-text st50 (li reg-rdi heap-hwm-addr)
   in let st52 = st-append-text st51 (mov-load reg-rax reg-rdi 0)
   in let st53 = emit-inline-itoa-and-print st52
   in let st54 = emit-serial-wait-and-send st53 10
   in let st55 = emit-serial-string st54 [83, 84, 65, 67, 75, 58]
   in let st56 = st-append-text st55 (li reg-rsi bare-metal-stack-top)
   in let st57 = st-append-text st56 (li reg-rdi stack-min-rsp-addr)
   in let st58 = st-append-text st57 (mov-load reg-rdi reg-rdi 0)
   in let st59 = st-append-text st58 (sub-rr reg-rsi reg-rdi)
   in let st60 = st-append-text st59 (mov-rr reg-rax reg-rsi)
   in let st61 = emit-inline-itoa-and-print st60
   in let st62 = emit-serial-wait-and-send st61 10
   in let st63 = st-append-text st62 (li reg-r11 stack-min-rsp-addr)
   in let st64 = st-append-text st63 (li reg-rax bare-metal-stack-top)
   in let st65 = st-append-text st64 (mov-store reg-r11 reg-rax 0)
   in st-append-text st65 (jmp (repl-loop - (st65.text-len + 5)))

Section: Chapter Entry Point
  flatten-chunks : LinkedList (List Integer) -> List Integer
  flatten-chunks (chunks) =
   let chunk-list = linked-list-to-list chunks
   in flatten-chunks-loop chunk-list 0 (list-length chunk-list) []

  flatten-chunks-loop : List (List Integer) -> Integer -> Integer -> List Integer -> List Integer
  flatten-chunks-loop (chunks) (i) (len) (acc) =
   if i == len then acc
   else flatten-one-chunk (list-at chunks i) 0 (list-length (list-at chunks i)) acc chunks (i + 1) len

  flatten-one-chunk : List Integer -> Integer -> Integer -> List Integer -> List (List Integer) -> Integer -> Integer -> List Integer
  flatten-one-chunk (chunk) (j) (clen) (acc) (chunks) (next-i) (len) =
   if j == clen then flatten-chunks-loop chunks next-i len acc
   else flatten-one-chunk chunk (j + 1) clen (list-snoc acc (list-at chunk j)) chunks next-i len

  text-buf-size : Integer = 2097152

  rodata-buf-size : Integer = 524288

  apply-one-patch-buf : Integer -> PatchEntry -> Integer
  apply-one-patch-buf (base-addr) (p) =
   buf-write-byte base-addr (p.pos) (p.b0)
   + buf-write-byte base-addr (p.pos + 1) (p.b1)
   + buf-write-byte base-addr (p.pos + 2) (p.b2)
   + buf-write-byte base-addr (p.pos + 3) (p.b3)

  apply-all-patches-buf : Integer -> List PatchEntry -> Integer -> Integer
  apply-all-patches-buf (base-addr) (patches) (i) =
   if i >= list-length patches then 0
   else let r = apply-one-patch-buf base-addr (list-at patches i)
   in apply-all-patches-buf base-addr patches (i + 1)

  x86-64-init-codegen-streaming : List TypeBinding -> Integer -> CodegenState
  x86-64-init-codegen-streaming (tdefs) (n-defs) =
   let tramp = bare-metal-trampoline
   in let text-addr = heap-save
   in let ha1 = heap-advance text-buf-size
   in let rodata-addr = heap-save
   in let ha2 = heap-advance rodata-buf-size
   in let bw1 = buf-write-bytes text-addr 0 (tramp.bytes)
   in let bw2 = buf-write-bytes rodata-addr 0 init-rodata
   in CodegenState {
   text-buf-addr = text-addr,
   text-len = list-length (tramp.bytes),
   rodata-buf-addr = rodata-addr,
   rodata-len = list-length init-rodata,
   func-offsets = list-with-capacity (n-defs + 64),
   call-patches = list-with-capacity (n-defs * 12),
   func-addr-fixups = list-with-capacity (n-defs * 4),
   rodata-fixups = list-with-capacity (n-defs * 8),
   deferred-patches = list-with-capacity (n-defs * 4),
   locals = [],
   next-temp = 0,
   next-local = 0,
   spill-count = 0,
   load-local-toggle = 0,
   tco = TcoState {
    active = False,
    in-tail-pos = False,
    loop-top = 0,
    param-locals = [],
    temp-locals = [],
    current-func = "",
    saved-next-local = 0,
    saved-next-temp = 0
   },
   type-defs = tdefs,
   stack-overflow-checks = list-with-capacity (n-defs + 16),
   bag = empty-bag
  }

  x86-64-init-codegen : List TypeBinding -> CodegenState
  x86-64-init-codegen (tdefs) =
   let tramp = bare-metal-trampoline
   in let text-addr = heap-save
   in let ha1 = heap-advance text-buf-size
   in let rodata-addr = heap-save
   in let ha2 = heap-advance rodata-buf-size
   in let bw1 = buf-write-bytes text-addr 0 (tramp.bytes)
   in let bw2 = buf-write-bytes rodata-addr 0 init-rodata
   in CodegenState {
   text-buf-addr = text-addr,
   text-len = list-length (tramp.bytes),
   rodata-buf-addr = rodata-addr,
   rodata-len = list-length init-rodata,
   func-offsets = [],
   call-patches = [],
   func-addr-fixups = [],
   rodata-fixups = [],
   deferred-patches = [],
   locals = [],
   next-temp = 0,
   next-local = 0,
   spill-count = 0,
   load-local-toggle = 0,
   tco = TcoState {
    active = False,
    in-tail-pos = False,
    loop-top = 0,
    param-locals = [],
    temp-locals = [],
    current-func = "",
    saved-next-local = 0,
    saved-next-temp = 0
   },
   type-defs = tdefs,
   stack-overflow-checks = [],
   bag = empty-bag
  }

  x86-64-finalize : CodegenState -> Integer -> EmitChapterResult
  x86-64-finalize (st1) (far-jump-patch-pos) =
   let st1a = emit-out-of-memory-handler st1
   in let isr-result = emit-isr-stubs st1a
   in let syscall-result = emit-syscall-handler (isr-result.state)
   in let st2 = emit-start (syscall-result.state) (isr-result.first-stub-vaddr) (syscall-result.handler-offset)
   in let func-map = build-offset-table (st2.func-offsets)
   in let st2a = check-call-patch-targets st2 func-map 0
   in let st2b = check-func-addr-targets st2a func-map 0
   in let st2c = check-runtime-symbol st2b func-map "__start"
   in let st2d = check-runtime-symbol st2c func-map "__out_of_memory"
   in let start-offset = offset-table-lookup func-map "__start"
   in let start-addr = bare-metal-load-addr + start-offset
   in let far-jump-entry = make-i32-patch (far-jump-patch-pos + 1) start-addr
   in let n-call = list-length (st2d.call-patches)
   in let call-entries = collect-call-patches (st2d.call-patches) func-map 0 (list-with-capacity n-call)
   in let n-addr = list-length (st2d.func-addr-fixups)
   in let addr-entries = collect-func-addr-patches (st2d.func-addr-fixups) func-map bare-metal-load-addr 0 (list-with-capacity (n-addr * 2))
   in let rodata-vaddr = compute-rodata-vaddr-bare (st2d.text-len)
   in let n-rodata = list-length (st2d.rodata-fixups)
   in let rodata-entries = collect-rodata-patches (st2d.rodata-fixups) rodata-vaddr 0 (list-with-capacity (n-rodata * 2))
   in let oom-offset = offset-table-lookup func-map "__out_of_memory"
   in let n-overflow = list-length (st2d.stack-overflow-checks)
   in let overflow-entries = collect-overflow-patches (st2d.stack-overflow-checks) oom-offset 0 (list-with-capacity n-overflow)
   in let all-patches = [far-jump-entry] ++ call-entries ++ addr-entries ++ rodata-entries ++ overflow-entries ++ (st2d.deferred-patches)
   in let patched = apply-all-patches-buf (st2d.text-buf-addr) all-patches 0
   in let text-len = st2d.text-len
   in let rodata-len = st2d.rodata-len
   in let load-addr = bare-metal-load-addr
   in let headers-end = elf32-header-size + elf32-phdr-size * 2
   in let note-offset = elf-align headers-end 4
   in let text-start = elf-align (note-offset + 20) 16
   in let text-end = text-start + text-len
   in let rodata-start = elf-align text-end 8
   in let file-size = rodata-start + rodata-len
   in let entry = load-addr + 12
   in let seg-filesz = file-size - text-start
   in let seg-memsz = seg-filesz + elf-bare-metal-heap-size
   in let elf-buf = heap-save
   in let ha = heap-advance file-size
   in let hdr = elf32-header-bytes entry elf32-header-size 2
   in let bw0 = buf-write-bytes elf-buf 0 hdr
   in let ph1 = phdr-32 pt-load text-start load-addr load-addr seg-filesz seg-memsz pf-rwx elf-page-size
   in let bw1 = buf-write-bytes elf-buf elf32-header-size ph1
   in let ph2 = phdr-32 pt-note note-offset 0 0 20 20 pf-r 4
   in let bw2 = buf-write-bytes elf-buf (elf32-header-size + elf32-phdr-size) ph2
   in let note = pvh-note entry
   in let bw3 = buf-write-bytes elf-buf note-offset note
   in let bw4 = buf-write-bytes elf-buf text-start (buf-read-bytes (st2d.text-buf-addr) 0 text-len)
   in let bw5 = buf-write-bytes elf-buf rodata-start (buf-read-bytes (st2d.rodata-buf-addr) 0 rodata-len)
   in let elf-bytes = buf-read-bytes elf-buf 0 file-size
   in EmitChapterResult {
    bytes = elf-bytes,
    bag = st2d.bag
   }

Section: ConstructedTy Rewrite Pass

  resolve-ty-deep : List TypeBinding -> CodexType -> CodexType
  resolve-ty-deep (tdefs) (ty) =
   when ty
    is ConstructedTy (cname) (cargs) ->
     let raw = lookup-type-binding tdefs (cname.value)
     in when raw
      is RecordTy (rn) (rf) -> raw
      is SumTy (sn) (sc) -> raw
      is FunTy (p) (r) -> strip-fun-args-emitter r
      is otherwise -> ConstructedTy cname (resolve-ty-list tdefs cargs 0 (list-length cargs) [])
    is FunTy (p) (r) -> FunTy (resolve-ty-deep tdefs p) (resolve-ty-deep tdefs r)
    is ListTy (e) -> ListTy (resolve-ty-deep tdefs e)
    is LinkedListTy (e) -> LinkedListTy (resolve-ty-deep tdefs e)
    is ForAllTy (id) (body) -> ForAllTy id (resolve-ty-deep tdefs body)
    is EffectfulTy (effs) (ret) -> EffectfulTy effs (resolve-ty-deep tdefs ret)
    is otherwise -> ty

  resolve-ty-list : List TypeBinding -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
  resolve-ty-list (tdefs) (tys) (i) (len) (acc) =
   if i == len then acc
   else resolve-ty-list tdefs tys (i + 1) len (list-snoc acc (resolve-ty-deep tdefs (list-at tys i)))

  rewrite-ir-pat : List TypeBinding -> IRPat -> IRPat
  rewrite-ir-pat (tdefs) (p) =
   when p
    is IrVarPat (name) (t) (s) -> IrVarPat name (resolve-ty-deep tdefs t) s
    is IrLitPat (v) (t) (s) -> IrLitPat v (resolve-ty-deep tdefs t) s
    is IrCtorPat (name) (subs) (t) (s) -> IrCtorPat name (rewrite-ir-pat-list tdefs subs 0 (list-length subs) []) (resolve-ty-deep tdefs t) s
    is IrWildPat (s) -> p

  rewrite-ir-pat-list : List TypeBinding -> List IRPat -> Integer -> Integer -> List IRPat -> List IRPat
  rewrite-ir-pat-list (tdefs) (ps) (i) (len) (acc) =
   if i == len then acc
   else rewrite-ir-pat-list tdefs ps (i + 1) len (list-snoc acc (rewrite-ir-pat tdefs (list-at ps i)))

  rewrite-ir-expr : List TypeBinding -> IRExpr -> IRExpr
  rewrite-ir-expr (tdefs) (e) =
   when e
    is IrIntLit (v) (s) -> e
    is IrNumLit (v) (s) -> e
    is IrTextLit (v) (s) -> e
    is IrBoolLit (v) (s) -> e
    is IrCharLit (v) (s) -> e
    is IrName (n) (t) (s) -> IrName n (resolve-ty-deep tdefs t) s
    is IrBinary (op) (l) (r) (t) (s) -> IrBinary op (rewrite-ir-expr tdefs l) (rewrite-ir-expr tdefs r) (resolve-ty-deep tdefs t) s
    is IrNegate (x) (s) -> IrNegate (rewrite-ir-expr tdefs x) s
    is IrIf (c) (th) (el) (t) (s) -> IrIf (rewrite-ir-expr tdefs c) (rewrite-ir-expr tdefs th) (rewrite-ir-expr tdefs el) (resolve-ty-deep tdefs t) s
    is IrLet (n) (t) (v) (b) (s) -> IrLet n (resolve-ty-deep tdefs t) (rewrite-ir-expr tdefs v) (rewrite-ir-expr tdefs b) s
    is IrApply (f) (a) (t) (s) -> IrApply (rewrite-ir-expr tdefs f) (rewrite-ir-expr tdefs a) (resolve-ty-deep tdefs t) s
    is IrLambda (ps) (b) (t) (s) -> IrLambda (rewrite-ir-params tdefs ps 0 (list-length ps) []) (rewrite-ir-expr tdefs b) (resolve-ty-deep tdefs t) s
    is IrList (es) (t) (s) -> IrList (rewrite-ir-expr-list tdefs es 0 (list-length es) []) (resolve-ty-deep tdefs t) s
    is IrMatch (sc) (bs) (t) (s) -> IrMatch (rewrite-ir-expr tdefs sc) (rewrite-ir-branches tdefs bs 0 (list-length bs) []) (resolve-ty-deep tdefs t) s
    is IrAct (ss) (t) (s) -> IrAct (rewrite-ir-act-stmts tdefs ss 0 (list-length ss) []) (resolve-ty-deep tdefs t) s
    is IrHandle (eff) (h) (cs) (t) (s) -> IrHandle eff (rewrite-ir-expr tdefs h) (rewrite-ir-handle-clauses tdefs cs 0 (list-length cs) []) (resolve-ty-deep tdefs t) s
    is IrRecord (n) (fs) (t) (s) -> IrRecord n (rewrite-ir-record-fields tdefs fs 0 (list-length fs) []) (resolve-ty-deep tdefs t) s
    is IrFieldAccess (r) (f) (t) (s) -> IrFieldAccess (rewrite-ir-expr tdefs r) f (resolve-ty-deep tdefs t) s
    is IrFork (body) (t) (s) -> IrFork (rewrite-ir-expr tdefs body) (resolve-ty-deep tdefs t) s
    is IrAwait (task) (t) (s) -> IrAwait (rewrite-ir-expr tdefs task) (resolve-ty-deep tdefs t) s
    is IrError (m) (t) (s) -> IrError m (resolve-ty-deep tdefs t) s

  rewrite-ir-expr-list : List TypeBinding -> List IRExpr -> Integer -> Integer -> List IRExpr -> List IRExpr
  rewrite-ir-expr-list (tdefs) (es) (i) (len) (acc) =
   if i == len then acc
   else rewrite-ir-expr-list tdefs es (i + 1) len (list-snoc acc (rewrite-ir-expr tdefs (list-at es i)))

  rewrite-ir-params : List TypeBinding -> List IRParam -> Integer -> Integer -> List IRParam -> List IRParam
  rewrite-ir-params (tdefs) (ps) (i) (len) (acc) =
   if i == len then acc
   else let p = list-at ps i
   in rewrite-ir-params tdefs ps (i + 1) len (list-snoc acc (IRParam {
    name = p.name,
    type-val = resolve-ty-deep tdefs (p.type-val),
    span = p.span
   }))

  rewrite-ir-branches : List TypeBinding -> List IRBranch -> Integer -> Integer -> List IRBranch -> List IRBranch
  rewrite-ir-branches (tdefs) (bs) (i) (len) (acc) =
   if i == len then acc
   else let b = list-at bs i
   in rewrite-ir-branches tdefs bs (i + 1) len (list-snoc acc (IRBranch {
    pattern = rewrite-ir-pat tdefs (b.pattern),
    body = rewrite-ir-expr tdefs (b.body),
    span = b.span
   }))

  rewrite-ir-act-stmts : List TypeBinding -> List IRActStmt -> Integer -> Integer -> List IRActStmt -> List IRActStmt
  rewrite-ir-act-stmts (tdefs) (ss) (i) (len) (acc) =
   if i == len then acc
   else let s = list-at ss i
   in let ns = when s
    is IrDoBind (n) (t) (v) (sp) -> IrDoBind n (resolve-ty-deep tdefs t) (rewrite-ir-expr tdefs v) sp
    is IrDoExec (v) (sp) -> IrDoExec (rewrite-ir-expr tdefs v) sp
   in rewrite-ir-act-stmts tdefs ss (i + 1) len (list-snoc acc ns)

  rewrite-ir-handle-clauses : List TypeBinding -> List IRHandleClause -> Integer -> Integer -> List IRHandleClause -> List IRHandleClause
  rewrite-ir-handle-clauses (tdefs) (cs) (i) (len) (acc) =
   if i == len then acc
   else let c = list-at cs i
   in rewrite-ir-handle-clauses tdefs cs (i + 1) len (list-snoc acc (IRHandleClause {
    op-name = c.op-name,
    resume-name = c.resume-name,
    body = rewrite-ir-expr tdefs (c.body),
    span = c.span
   }))

  rewrite-ir-record-fields : List TypeBinding -> List IRFieldVal -> Integer -> Integer -> List IRFieldVal -> List IRFieldVal
  rewrite-ir-record-fields (tdefs) (fs) (i) (len) (acc) =
   if i == len then acc
   else let f = list-at fs i
   in rewrite-ir-record-fields tdefs fs (i + 1) len (list-snoc acc (IRFieldVal {
    name = f.name,
    value = rewrite-ir-expr tdefs (f.value),
    span = f.span
   }))

  rewrite-ir-def : List TypeBinding -> IRDef -> IRDef
  rewrite-ir-def (tdefs) (d) =
   IRDef {
    name = d.name,
    params = rewrite-ir-params tdefs (d.params) 0 (list-length (d.params)) [],
    type-val = resolve-ty-deep tdefs (d.type-val),
    body = rewrite-ir-expr tdefs (d.body),
    chapter-slug = d.chapter-slug,
    span = d.span
   }

  rewrite-ir-defs : List TypeBinding -> List IRDef -> Integer -> Integer -> List IRDef -> List IRDef
  rewrite-ir-defs (tdefs) (defs) (i) (len) (acc) =
   if i == len then acc
   else rewrite-ir-defs tdefs defs (i + 1) len (list-snoc acc (rewrite-ir-def tdefs (list-at defs i)))

Section: ErrorTy Boundary Check

  type-has-errorty : CodexType -> Boolean
  type-has-errorty (ty) =
   when ty
    is ErrorTy -> True
    is FunTy (p) (r) -> if type-has-errorty p then True else type-has-errorty r
    is ListTy (e) -> type-has-errorty e
    is LinkedListTy (e) -> type-has-errorty e
    is ForAllTy (id) (body) -> type-has-errorty body
    is EffectfulTy (effs) (ret) -> type-has-errorty ret
    is otherwise -> False

  check-ir-expr-errorty : CodegenState -> IRExpr -> CodegenState
  check-ir-expr-errorty (st) (e) =
   let ty = ir-expr-type e
   in let st1 = if type-has-errorty ty
    then st-add-error st cdx-error-type-in-ir "IR node reached codegen with ErrorTy in its type" (ir-expr-span e)
    else st
   in when e
    is IrBinary (op) (l) (r) (t) (s) -> check-ir-expr-errorty (check-ir-expr-errorty st1 l) r
    is IrNegate (x) (s) -> check-ir-expr-errorty st1 x
    is IrIf (c) (th) (el) (t) (s) -> check-ir-expr-errorty (check-ir-expr-errorty (check-ir-expr-errorty st1 c) th) el
    is IrLet (n) (t) (v) (b) (s) -> check-ir-expr-errorty (check-ir-expr-errorty st1 v) b
    is IrApply (f) (a) (t) (s) -> check-ir-expr-errorty (check-ir-expr-errorty st1 f) a
    is IrLambda (ps) (b) (t) (s) -> check-ir-expr-errorty st1 b
    is IrList (es) (t) (s) -> check-ir-list-errorty st1 es 0
    is IrMatch (sc) (bs) (t) (s) -> check-ir-branches-errorty (check-ir-expr-errorty st1 sc) bs 0
    is IrAct (ss) (t) (s) -> check-ir-act-stmts-errorty st1 ss 0
    is IrHandle (eff) (h) (cs) (t) (s) -> check-ir-handle-clauses-errorty (check-ir-expr-errorty st1 h) cs 0
    is IrRecord (n) (fs) (t) (s) -> check-ir-record-fields-errorty st1 fs 0
    is IrFieldAccess (r) (f) (t) (s) -> check-ir-expr-errorty st1 r
    is IrFork (body) (t) (s) -> check-ir-expr-errorty st1 body
    is IrAwait (task) (t) (s) -> check-ir-expr-errorty st1 task
    is otherwise -> st1

  check-ir-list-errorty : CodegenState -> List IRExpr -> Integer -> CodegenState
  check-ir-list-errorty (st) (es) (i) =
   if i == list-length es then st
   else check-ir-list-errorty (check-ir-expr-errorty st (list-at es i)) es (i + 1)

  check-ir-branches-errorty : CodegenState -> List IRBranch -> Integer -> CodegenState
  check-ir-branches-errorty (st) (bs) (i) =
   if i == list-length bs then st
   else let b = list-at bs i
   in check-ir-branches-errorty (check-ir-expr-errorty st (b.body)) bs (i + 1)

  check-ir-act-stmts-errorty : CodegenState -> List IRActStmt -> Integer -> CodegenState
  check-ir-act-stmts-errorty (st) (ss) (i) =
   if i == list-length ss then st
   else let s = list-at ss i
   in when s
    is IrDoBind (n) (t) (v) (sp) -> check-ir-act-stmts-errorty (check-ir-expr-errorty st v) ss (i + 1)
    is IrDoExec (v) (sp) -> check-ir-act-stmts-errorty (check-ir-expr-errorty st v) ss (i + 1)

  check-ir-handle-clauses-errorty : CodegenState -> List IRHandleClause -> Integer -> CodegenState
  check-ir-handle-clauses-errorty (st) (cs) (i) =
   if i == list-length cs then st
   else let c = list-at cs i
   in check-ir-handle-clauses-errorty (check-ir-expr-errorty st (c.body)) cs (i + 1)

  check-ir-record-fields-errorty : CodegenState -> List IRFieldVal -> Integer -> CodegenState
  check-ir-record-fields-errorty (st) (fs) (i) =
   if i == list-length fs then st
   else let f = list-at fs i
   in check-ir-record-fields-errorty (check-ir-expr-errorty st (f.value)) fs (i + 1)

  check-ir-defs-errorty : CodegenState -> List IRDef -> Integer -> CodegenState
  check-ir-defs-errorty (st) (defs) (i) =
   if i == list-length defs then st
   else let d = list-at defs i
   in let st1 = if type-has-errorty (d.type-val)
    then st-add-error st cdx-error-type-in-ir ("Definition '" ++ (d.name) ++ "' has ErrorTy in its type") (d.span)
    else st
   in check-ir-defs-errorty (check-ir-expr-errorty st1 (d.body)) defs (i + 1)

  x86-64-emit-chapter : IRChapter -> List TypeBinding -> EmitChapterResult
  x86-64-emit-chapter (m) (tdefs) =
   let tramp = bare-metal-trampoline
   in let st0 = x86-64-init-codegen tdefs
   in let defs-resolved = rewrite-ir-defs tdefs (m.defs) 0 (list-length (m.defs)) []
   in let st-checked = check-ir-defs-errorty st0 defs-resolved 0
   in let st0a = emit-runtime-helpers st-checked
   in let st1 = emit-all-defs st0a defs-resolved 0
   in x86-64-finalize st1 (tramp.far-jump-patch-pos)

