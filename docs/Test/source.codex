Chapter: Emit--X86-64 Code Generator
 Runtime helper functions: hand-assembled x86-64 byte sequences
 emitted into the text section.

Section: State Records
  StrEqHeadResult = record {
    cg : CodegenState,
    len-ne-pos : Integer
  }

  StrEqLoopResult = record {
    cg : CodegenState,
    loop-done-pos : Integer,
    byte-ne-pos : Integer
  }

  ItoaZeroResult = record {
    cg : CodegenState,
    skip-digits-pos : Integer
  }

  StrConcatCheckResult = record {
    cg : CodegenState,
    slow-path-pos : Integer
  }

  StrConcatFastResult = record {
    cg : CodegenState,
    fast-done-pos : Integer
  }

  HelpResult1 = record {
    cg : CodegenState,
    p1 : Integer
  }

  HelpResult2 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer
  }

  HelpResult3 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer,
    p3 : Integer
  }

  HelpResult4 = record {
    cg : CodegenState,
    p1 : Integer,
    p2 : Integer,
    p3 : Integer,
    p4 : Integer
  }

Section: __str_eq
  emit-str-eq-head : CodegenState -> StrEqHeadResult
  emit-str-eq-head (st) =
    let st0 = record-func-offset st "__str_eq"
   in let st1 = st-append-text st0 (cmp-rr reg-rdi reg-rsi)
   in let not-same-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ne 0)
   in let st3 = st-append-text st2 (li reg-rax 1)
   in let st4 = st-append-text st3 x86-ret
   in let st5 = patch-jcc-at st4 not-same-pos (st4.text-len)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rdi 0)
   in let st7 = st-append-text st6 (mov-load reg-rdx reg-rsi 0)
   in let st8 = st-append-text st7 (cmp-rr reg-rcx reg-rdx)
   in let len-ne-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ne 0)
   in StrEqHeadResult {
    cg = st9,
    len-ne-pos = len-ne-pos
   }

  emit-str-eq-byte-loop : CodegenState -> StrEqLoopResult
  emit-str-eq-byte-loop (st) =
    let st0 = st-append-text st (li reg-r11 0)
   in let loop-pos = st0.text-len
   in let st1 = st-append-text st0 (cmp-rr reg-r11 reg-rcx)
   in let loop-done-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-ge 0)
   in let st3 = st-append-text st2 (mov-rr reg-rax reg-rdi)
   in let st4 = st-append-text st3 (add-rr reg-rax reg-r11)
   in let st5 = st-append-text st4 (movzx-byte reg-rax reg-rax 8)
   in let st6 = st-append-text st5 (mov-rr reg-rdx reg-rsi)
   in let st7 = st-append-text st6 (add-rr reg-rdx reg-r11)
   in let st8 = st-append-text st7 (movzx-byte reg-rdx reg-rdx 8)
   in let st9 = st-append-text st8 (cmp-rr reg-rax reg-rdx)
   in let byte-ne-pos = st9.text-len
   in let st10 = st-append-text st9 (jcc cc-ne 0)
   in let st11 = st-append-text st10 (add-ri reg-r11 1)
   in let st12 = st-append-text st11 (jmp (loop-pos - (st11.text-len + 5)))
