Chapter: Emit--X86-64 Boot Infrastructure
 Bare-metal boot sequence, interrupt handling, process management,
 syscall dispatch, and capability model.

Section: Memory Layout Constants
  idt-base : Integer = 24576

  tick-count-addr : Integer = 28672

  key-buffer-addr : Integer = 28680

  current-proc-addr : Integer = 28688

  arena-base-addr : Integer = 28696

  serial-write-pos-addr : Integer = 28704

  serial-read-pos-addr : Integer = 28712

  result-arena-base-addr : Integer = 28720

  heap-hwm-addr : Integer = 28728

  stack-min-rsp-addr : Integer = 28736

  serial-ring-buf-addr : Integer = 3145728

  serial-ring-buf-size : Integer = 1048576

  serial-ring-buf-mask : Integer = 1048575

  proc-table-base : Integer = 20480

  proc-entry-size : Integer = 256

  proc-cap-offset : Integer = 56

  cap-console : Integer = 0

  cap-concurrent : Integer = 3

Section: PIC Initialization
  emit-pic-init : CodegenState -> CodegenState
  emit-pic-init (st) =
   let st1 = emit-out-byte st 32 17
   in let st2 = emit-out-byte st1 160 17
   in let st3 = emit-out-byte st2 33 32
   in let st4 = emit-out-byte st3 161 40
   in let st5 = emit-out-byte st4 33 4
   in let st6 = emit-out-byte st5 161 2
   in let st7 = emit-out-byte st6 33 1
   in let st8 = emit-out-byte st7 161 1
   in let st9 = emit-out-byte st8 33 236
   in emit-out-byte st9 161 255

Section: CPU Exception Dump
  emit-print-hex-nibble-rdi : CodegenState -> CodegenState
  emit-print-hex-nibble-rdi (st) =
   let st1 = st-append-text st (and-ri reg-rdi 15)
   in let st2 = st-append-text st1 (cmp-ri reg-rdi 10)
   in let jge-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-ge 0)
   in let st4 = st-append-text st3 (add-ri reg-rdi 48)
   in let jmp-pos = st4.text-len
   in let st5 = st-append-text st4 (jmp 0)
   in let st6 = patch-jcc-at st5 jge-pos (st5.text-len)
   in let st7 = st-append-text st6 (add-ri reg-rdi 87)
   in let st8 = patch-jmp-at st7 jmp-pos (st7.text-len)
   in emit-serial-send-rdi st8

  emit-print-hex-qword-rdi-loop : CodegenState -> Integer -> CodegenState
  emit-print-hex-qword-rdi-loop (st) (nibble-idx) =
   if nibble-idx < 0 then st
   else let st1 = st-append-text st (push-r reg-rdi)
   in let shift = nibble-idx * 4
   in let st2 = if shift == 0 then st1 else st-append-text st1 (shr-ri reg-rdi shift)
   in let st3 = emit-print-hex-nibble-rdi st2
   in let st4 = st-append-text st3 (pop-r reg-rdi)
   in emit-print-hex-qword-rdi-loop st4 (nibble-idx - 1)

  emit-print-hex-qword-rdi : CodegenState -> CodegenState
  emit-print-hex-qword-rdi (st) =
   emit-print-hex-qword-rdi-loop st 15

  emit-print-hex-byte-rdi : CodegenState -> CodegenState
  emit-print-hex-byte-rdi (st) =
   let st1 = st-append-text st (push-r reg-rdi)
   in let st2 = st-append-text st1 (shr-ri reg-rdi 4)
   in let st3 = emit-print-hex-nibble-rdi st2
   in let st4 = st-append-text st3 (pop-r reg-rdi)
   in emit-print-hex-nibble-rdi st4

  emit-cpu-exception-dump : CodegenState -> CodegenState
  emit-cpu-exception-dump (st) =
   let st0 = st-append-text st (mov-rr reg-rdi reg-rax)
   in let st1 = emit-serial-wait-and-send st0 33
   in let st2 = emit-serial-wait-and-send st1 69
   in let st3 = emit-serial-wait-and-send st2 88
   in let st4 = emit-serial-wait-and-send st3 67
   in let st5 = emit-serial-wait-and-send st4 61
   in let st6 = emit-print-hex-byte-rdi st5
   in let st7 = emit-serial-wait-and-send st6 32
   in let st8 = emit-serial-wait-and-send st7 82
   in let st9 = emit-serial-wait-and-send st8 73
   in let st10 = emit-serial-wait-and-send st9 80
   in let st11 = emit-serial-wait-and-send st10 61
   in let st12 = st-append-text st11 (mov-load reg-rdi reg-rsp 40)
   in let st13 = emit-print-hex-qword-rdi st12
   in let st13a = emit-serial-wait-and-send st13 32
   in let st13b = emit-serial-wait-and-send st13a 82
   in let st13c = emit-serial-wait-and-send st13b 66
   in let st13d = emit-serial-wait-and-send st13c 88
   in let st13e = emit-serial-wait-and-send st13d 61
   in let st13f = st-append-text st13e (mov-rr reg-rdi reg-rbx)
   in let st13g = emit-print-hex-qword-rdi st13f
   in let st13h = emit-serial-wait-and-send st13g 32
   in let st13i = emit-serial-wait-and-send st13h 82
   in let st13j = emit-serial-wait-and-send st13i 49
   in let st13k = emit-serial-wait-and-send st13j 50
   in let st13l = emit-serial-wait-and-send st13k 61
   in let st13m = st-append-text st13l (mov-rr reg-rdi reg-r12)
   in let st13n = emit-print-hex-qword-rdi st13m
   in let st13o = emit-serial-wait-and-send st13n 32
   in let st13p = emit-serial-wait-and-send st13o 82
   in let st13q = emit-serial-wait-and-send st13p 49
   in let st13r = emit-serial-wait-and-send st13q 51
   in let st13s = emit-serial-wait-and-send st13r 61
   in let st13t = st-append-text st13s (mov-rr reg-rdi reg-r13)
   in let st13u = emit-print-hex-qword-rdi st13t
   in let st13v = emit-serial-wait-and-send st13u 32
   in let st13w = emit-serial-wait-and-send st13v 82
   in let st13x = emit-serial-wait-and-send st13w 49
   in let st13y = emit-serial-wait-and-send st13x 52
   in let st13z = emit-serial-wait-and-send st13y 61
   in let st13aa = st-append-text st13z (mov-rr reg-rdi reg-r14)
   in let st13ab = emit-print-hex-qword-rdi st13aa
   in let st13ac = emit-serial-wait-and-send st13ab 32
   in let st13ad = emit-serial-wait-and-send st13ac 82
   in let st13ae = emit-serial-wait-and-send st13ad 49
   in let st13af = emit-serial-wait-and-send st13ae 48
   in let st13ag = emit-serial-wait-and-send st13af 61
   in let st13ah = st-append-text st13ag (mov-rr reg-rdi reg-r10)
   in let st13ai = emit-print-hex-qword-rdi st13ah
   in let st13aj = emit-serial-wait-and-send st13ai 32
   in let st13ak = emit-serial-wait-and-send st13aj 82
   in let st13al = emit-serial-wait-and-send st13ak 68
   in let st13am = emit-serial-wait-and-send st13al 73
   in let st13an = emit-serial-wait-and-send st13am 61
   in let st13ao = st-append-text st13an (mov-load reg-rdi reg-rsp 0)
   in let st13ap = emit-print-hex-qword-rdi st13ao
   in let st13aq = emit-serial-wait-and-send st13ap 32
   in let st13ar = emit-serial-wait-and-send st13aq 82
   in let st13as = emit-serial-wait-and-send st13ar 83
   in let st13at = emit-serial-wait-and-send st13as 73
   in let st13au = emit-serial-wait-and-send st13at 61
   in let st13av = st-append-text st13au (mov-load reg-rdi reg-rsp 8)
   in let st13aw = emit-print-hex-qword-rdi st13av
   in let st13ax = emit-serial-wait-and-send st13aw 32
   in let st13ay = emit-serial-wait-and-send st13ax 67
   in let st13az = emit-serial-wait-and-send st13ay 97
   in let st13ba = emit-serial-wait-and-send st13az 108
   in let st13bb = emit-serial-wait-and-send st13ba 108
   in let st13bc = emit-serial-wait-and-send st13bb 82
   in let st13bd = emit-serial-wait-and-send st13bc 61
   in let st13be = st-append-text st13bd (mov-load reg-rdi reg-rsp 64)
   in let st13bf = emit-print-hex-qword-rdi st13be
   in let st14 = emit-serial-wait-and-send st13bf 10
   in let st15 = st-append-text st14 cli
   in let halt-pos = st15.text-len
   in let st16 = st-append-text st15 hlt
   in st-append-text st16 (jmp (halt-pos - (st16.text-len + 5)))

Section: Common Interrupt Handler
  emit-common-interrupt-handler : CodegenState -> CodegenState
  emit-common-interrupt-handler (st) =
   let st1 = st-append-text st (push-r reg-rcx)
   in let st2 = st-append-text st1 (push-r reg-rdx)
   in let st3 = st-append-text st2 (push-r reg-rsi)
   in let st4 = st-append-text st3 (push-r reg-rdi)
   in let st5 = st-append-text st4 [15, 182, 192]
   in let st6 = st-append-text st5 (cmp-ri reg-rax 32)
   in let exc-jcc = st6.text-len
   in let st6a = st-append-text st6 (jcc cc-b 0)
   in let not-timer = st6a.text-len
   in let st7 = st-append-text st6a (jcc cc-ne 0)
   in let st8 = st-append-text st7 (li reg-rdi tick-count-addr)
   in let st9 = st-append-text st8 (mov-load reg-rsi reg-rdi 0)
   in let st10 = st-append-text st9 (add-ri reg-rsi 1)
   in let st11 = st-append-text st10 (mov-store reg-rdi reg-rsi 0)
   in let st12 = emit-out-byte st11 32 32
   in let st13 = st-append-text st12 (pop-r reg-rdi)
   in let st14 = st-append-text st13 (pop-r reg-rsi)
   in let st15 = st-append-text st14 (pop-r reg-rdx)
   in let st16 = st-append-text st15 (pop-r reg-rcx)
   in let st17 = st-append-text st16 (pop-r reg-rax)
   in let st18 = st-append-text st17 iretq
   in let st19 = patch-jcc-at st18 not-timer (st18.text-len)
   in let st20 = st-append-text st19 (cmp-ri reg-rax 33)
   in let not-keyboard = st20.text-len
   in let st21 = st-append-text st20 (jcc cc-ne 0)
   in let st22 = st-append-text st21 (li reg-rdx 96)
   in let st23 = st-append-text st22 in-al-dx
   in let st24 = st-append-text st23 (li reg-rdi key-buffer-addr)
   in let st25 = st-append-text st24 [72, 15, 182, 192]
   in let st26 = st-append-text st25 (mov-store reg-rdi reg-rax 0)
   in let st27 = patch-jcc-at st26 not-keyboard (st26.text-len)
   in let st28 = st-append-text st27 (cmp-ri reg-rax 36)
   in let not-serial = st28.text-len
   in let st29 = st-append-text st28 (jcc cc-ne 0)
   in let serial-drain-loop = st29.text-len
   in let st30 = st-append-text st29 (li reg-rdx 1021)
   in let st31 = st-append-text st30 in-al-dx
   in let st32 = st-append-text st31 (li reg-rcx 1)
   in let st33 = st-append-text st32 (and-rr reg-rax reg-rcx)
   in let st34 = st-append-text st33 (test-rr reg-rax reg-rax)
   in let serial-drain-done = st34.text-len
   in let st35 = st-append-text st34 (jcc cc-e 0)
   in let st36 = st-append-text st35 (li reg-rdx 1016)
   in let st37 = st-append-text st36 in-al-dx
   in let st38 = st-append-text st37 [72, 15, 182, 192]
   in let st39 = st-append-text st38 (li reg-rdi serial-write-pos-addr)
   in let st40 = st-append-text st39 (mov-load reg-rcx reg-rdi 0)
   in let st41 = st-append-text st40 (mov-rr reg-rsi reg-rcx)
   in let st42 = st-append-text st41 (and-ri reg-rsi serial-ring-buf-mask)
   in let st43 = st-append-text st42 (add-ri reg-rsi serial-ring-buf-addr)
   in let st44 = st-append-text st43 [136, 6]
   in let st45 = st-append-text st44 (add-ri reg-rcx 1)
   in let st46 = st-append-text st45 (mov-store reg-rdi reg-rcx 0)
   in let st47 = st-append-text st46 (jmp (serial-drain-loop - (st46.text-len + 5)))
   in let st48 = patch-jcc-at st47 serial-drain-done (st47.text-len)
   in let st49 = patch-jcc-at st48 not-serial (st48.text-len)
   in let st50 = emit-out-byte st49 32 32
   in let st51 = st-append-text st50 (pop-r reg-rdi)
   in let st52 = st-append-text st51 (pop-r reg-rsi)
   in let st53 = st-append-text st52 (pop-r reg-rdx)
   in let st54 = st-append-text st53 (pop-r reg-rcx)
   in let st55 = st-append-text st54 (pop-r reg-rax)
   in let st56 = st-append-text st55 iretq
   in let exc-handler-pos = st56.text-len
   in let st57 = emit-cpu-exception-dump st56
   in patch-jcc-at st57 exc-jcc exc-handler-pos

Section: ISR Stubs
  IsrStubResult = record {
   state : CodegenState,
   first-stub-vaddr : Integer
  }

  has-error-code : Integer -> Boolean
  has-error-code (vec) =
   if vec == 8 then True
   else if vec == 10 then True
   else if vec == 11 then True
   else if vec == 12 then True
   else if vec == 13 then True
   else if vec == 14 then True
   else if vec == 17 then True
   else if vec == 21 then True
   else if vec == 29 then True
   else if vec == 30 then True
   else False

  emit-isr-stub : CodegenState -> Integer -> Integer -> CodegenState
  emit-isr-stub (st) (vec) (common-handler-offset) =
   let st1 = if has-error-code vec then st-append-text st (add-ri reg-rsp 8)
             else st-append-text st [15, 31, 64, 0]
   in let st2 = st-append-text st1 (push-r reg-rax)
   in let st3 = st-append-text st2 [176, vec]
   in let rel = common-handler-offset - (st3.text-len + 5)
   in st-append-text st3 (jmp rel)

  emit-isr-stubs-loop : CodegenState -> Integer -> Integer -> CodegenState
  emit-isr-stubs-loop (st) (vec) (common-handler-offset) =
   if vec == 256 then st
   else emit-isr-stubs-loop (emit-isr-stub st vec common-handler-offset) (vec + 1) common-handler-offset

  emit-isr-stubs : CodegenState -> IsrStubResult
  emit-isr-stubs (st) =
   let common-handler-offset = st.text-len
   in let st1 = emit-common-interrupt-handler st
   in let first-stub-offset = st1.text-len
   in let st2 = emit-isr-stubs-loop st1 0 common-handler-offset
   in IsrStubResult {
    state = st2,
    first-stub-vaddr = bare-metal-load-addr + first-stub-offset
  }

Section: IDT Construction
  emit-idt-entries : CodegenState -> Integer -> CodegenState
  emit-idt-entries (st) (first-stub-vaddr) =
   let st1 = st-append-text st (li reg-rcx 256)
   in let st2 = st-append-text st1 (li reg-rdi idt-base)
   in let st3 = st-append-text st2 (li reg-rsi first-stub-vaddr)
   in let loop-top = st3.text-len
   in let st4 = st-append-text st3 (mov-rr reg-rax reg-rsi)
   in let st5 = st-append-text st4 (and-ri reg-rax 65535)
   in let st6 = st-append-text st5 (add-ri reg-rax 524288)
   in let st7 = st-append-text st6 (mov-store reg-rdi reg-rax 0)
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rsi)
   in let st9 = st-append-text st8 (shr-ri reg-rax 16)
   in let st10 = st-append-text st9 (shl-ri reg-rax 16)
   in let st11 = st-append-text st10 (add-ri reg-rax 36352)
   in let st12 = st-append-text st11 (mov-store reg-rdi reg-rax 4)
   in let st13 = st-append-text st12 (li reg-rax 0)
   in let st14 = st-append-text st13 (mov-store reg-rdi reg-rax 8)
   in let st15 = st-append-text st14 (add-ri reg-rdi 16)
   in let st16 = st-append-text st15 (add-ri reg-rsi 12)
   in let st17 = st-append-text st16 (sub-ri reg-rcx 1)
   in let jcc-pos = st17.text-len
   in let st18 = st-append-text st17 (jcc cc-ne 0)
   in patch-jcc-at st18 jcc-pos loop-top

Section: Interrupt Setup
  emit-interrupt-setup : CodegenState -> CodegenState
  emit-interrupt-setup (st) =
   let st1 = emit-pic-init st
   in let st2 = st-append-text st1 (sub-ri reg-rsp 16)
   in let idtr-low = int-mod (256 * 16 - 1) 65536 + idt-base * 65536
   in let st3 = st-append-text st2 (li reg-rax idtr-low)
   in let st4 = st-append-text st3 (mov-store reg-rsp reg-rax 0)
   in let st5 = st-append-text st4 (li reg-rax 0)
   in let st6 = st-append-text st5 (mov-store reg-rsp reg-rax 8)
   in let st7 = st-append-text st6 (mov-rr reg-rdi reg-rsp)
   in let st8 = st-append-text st7 lidt-rdi
   in let st9 = st-append-text st8 (add-ri reg-rsp 16)
   in let st10 = st-append-text st9 (li reg-rdi tick-count-addr)
   in let st11 = st-append-text st10 (li reg-rax 0)
   in let st12 = st-append-text st11 (mov-store reg-rdi reg-rax 0)
   in let st13 = st-append-text st12 (li reg-rdi key-buffer-addr)
   in let st14 = st-append-text st13 (mov-store reg-rdi reg-rax 0)
   in let st15 = st-append-text st14 (li reg-rdi arena-base-addr)
   in let st16 = st-append-text st15 (mov-store reg-rdi reg-rax 0)
   in let st17 = st-append-text st16 (li reg-rdi result-arena-base-addr)
   in let st18 = st-append-text st17 (mov-store reg-rdi reg-rax 0)
   in st-append-text st18 sti

Section: Process Management
  emit-zero-region : CodegenState -> Integer -> Integer -> CodegenState
  emit-zero-region (st) (addr) (qwords) =
   let st1 = st-append-text st (li reg-rdi addr)
   in let st2 = st-append-text st1 (li reg-rcx qwords)
   in let st3 = st-append-text st2 (li reg-rax 0)
   in st-append-text st3 [72, 243, 171]

  emit-pd-entries : CodegenState -> Integer -> Integer -> CodegenState
  emit-pd-entries (st) (i) (n) =
   let count = n - i
   in if count <= 0 then st
   else let phys-start = i * 2097152
   in let st1 = st-append-text st (li reg-rax (phys-start + 131))
   in let st2 = st-append-text st1 (li reg-rcx count)
   in let loop-start = st2.text-len
   in let st3 = st-append-text st2 (mov-store reg-rdi reg-rax 0)
   in let st4 = st-append-text st3 (add-ri reg-rdi 8)
   in let st5 = st-append-text st4 (add-ri reg-rax 2097152)
   in let st6 = st-append-text st5 (sub-ri reg-rcx 1)
   in let cur = st6.text-len
   in st-append-text st6 (jcc cc-ne (loop-start - (cur + 6)))

  emit-build-process-page-tables : CodegenState -> Integer -> Integer -> CodegenState
  emit-build-process-page-tables (st) (pml4-addr) (heap-phys) =
   let st1 = emit-zero-region st pml4-addr 1536
   in let st2 = st-append-text st1 (li reg-rdi pml4-addr)
   in let st3 = st-append-text st2 (li reg-rax (pml4-addr + 4096 + 3))
   in let st4 = st-append-text st3 (mov-store reg-rdi reg-rax 0)
   in let st5 = st-append-text st4 (li reg-rdi (pml4-addr + 4096))
   in let st6 = st-append-text st5 (li reg-rax (pml4-addr + 8192 + 3))
   in let st7 = st-append-text st6 (mov-store reg-rdi reg-rax 0)
   in let pd-addr = pml4-addr + 8192
   in let st8 = st-append-text st7 (li reg-rdi pd-addr)
   in emit-pd-entries st8 0 512

  emit-create-process : CodegenState -> Integer -> Integer -> Integer -> Integer -> CodegenState
  emit-create-process (st) (proc-index) (state-val) (cr3-val) (heap-base) =
   let entry-addr = proc-table-base + proc-index * proc-entry-size
   in let st1 = st-append-text st (li reg-rdi entry-addr)
   in let st2 = st-append-text st1 (li reg-rax state-val)
   in let st3 = st-append-text st2 (mov-store reg-rdi reg-rax 0)
   in let st4 = st-append-text st3 (li reg-rdi (entry-addr + 16))
   in let st5 = st-append-text st4 (li reg-rax cr3-val)
   in let st6 = st-append-text st5 (mov-store reg-rdi reg-rax 0)
   in let st7 = st-append-text st6 (li reg-rdi (entry-addr + 40))
   in let st8 = st-append-text st7 (li reg-rax heap-base)
   in let st9 = st-append-text st8 (mov-store reg-rdi reg-rax 0)
   in let st10 = st-append-text st9 (li reg-rdi (entry-addr + 48))
   in st-append-text st10 (mov-store reg-rdi reg-rax 0)

  emit-process-setup : CodegenState -> CodegenState
  emit-process-setup (st) =
   let st1 = emit-zero-region st proc-table-base (16 * proc-entry-size / 8)
   in let st2 = st-append-text st1 (li reg-rdi current-proc-addr)
   in let st3 = st-append-text st2 (li reg-rax 0)
   in let st4 = st-append-text st3 (mov-store reg-rdi reg-rax 0)
   in let st5 = emit-build-process-page-tables st4 32768 4194304
   in let st6 = emit-create-process st5 0 1 32768 4194304
   in let st7 = st-append-text st6 (li reg-rax 32768)
   in let st8 = st-append-text st7 [15, 34, 216]
   in st-append-text st8 (li reg-r10 4194304)

Section: Capabilities
  emit-grant-capability : CodegenState -> Integer -> Integer -> CodegenState
  emit-grant-capability (st) (proc-index) (cap-bit) =
   let cap-addr = proc-table-base + proc-index * proc-entry-size + proc-cap-offset
   in let st1 = st-append-text st (li reg-rdi cap-addr)
   in let st2 = st-append-text st1 (mov-load reg-rax reg-rdi 0)
   in let bit-mask = shl-1 cap-bit
   in let st3 = st-append-text st2 (or-ri reg-rax bit-mask)
   in st-append-text st3 (mov-store reg-rdi reg-rax 0)

  shl-1 : Integer -> Integer
  shl-1 (n) =
   if n == 0 then 1
   else 2 * shl-1 (n - 1)

Section: MSR and Syscall
  emit-write-msr : CodegenState -> Integer -> Integer -> CodegenState
  emit-write-msr (st) (msr-addr) (value) =
   let low32 = int-mod value 4294967296
   in let high32 = value / 4294967296
   in let st1 = st-append-text st (li reg-rcx msr-addr)
   in let st2 = st-append-text st1 (li reg-rax low32)
   in let st3 = st-append-text st2 (li reg-rdx high32)
   in st-append-text st3 [15, 48]

  SyscallResult = record {
   state : CodegenState,
   handler-offset : Integer
  }

  emit-check-capability : CodegenState -> CodegenState
  emit-check-capability (st) =
   let st1 = st-append-text st (push-r reg-rcx)
   in let st2 = st-append-text st1 (li reg-rcx proc-table-base)
   in let st3 = st-append-text st2 (push-r reg-r11)
   in let st4 = st-append-text st3 (li reg-r11 current-proc-addr)
   in let st5 = st-append-text st4 (mov-load reg-r11 reg-r11 0)
   in let st6 = st-append-text st5 (li reg-rcx proc-entry-size)
   in let st7 = st-append-text st6 [72, 15, 175, 203]
   in let st8 = st-append-text st7 (add-ri reg-rcx proc-table-base)
   in let st9 = st-append-text st8 (add-ri reg-rcx proc-cap-offset)
   in let st10 = st-append-text st9 (mov-load reg-rcx reg-rcx 0)
   in let st11 = st-append-text st10 [72, 15, 163, 209]
   in let st12 = st-append-text st11 (pop-r reg-r11)
   in st-append-text st12 (pop-r reg-rcx)

  emit-syscall-handler : CodegenState -> SyscallResult
  emit-syscall-handler (st) =
   let handler-offset = st.text-len
   in let st1 = st-append-text st (push-r reg-rcx)
   in let st2 = st-append-text st1 (push-r reg-r11)
   in let st3 = st-append-text st2 (cmp-ri reg-rax 1)
   in let not-write = st3.text-len
   in let st4 = st-append-text st3 (jcc cc-ne 0)
   in let st5 = st-append-text st4 (mov-rr reg-rdx reg-rdi)
   in let st6 = emit-check-capability st5
   in let no-write-cap = st6.text-len
   in let st7 = st-append-text st6 (jcc cc-e 0)
   in let st8 = st-append-text st7 (mov-rr reg-rax reg-rdx)
   in let st9 = st-append-text st8 (li reg-rdx 1016)
   in let st10 = st-append-text st9 out-dx-al
   in let st11 = patch-jcc-at st10 no-write-cap (st10.text-len)
   in let st12 = st-append-text st11 (li reg-rax 0)
   in let write-done = st12.text-len
   in let st13 = st-append-text st12 (jmp 0)
   in let st14 = patch-jcc-at st13 not-write (st13.text-len)
   in let st15 = st-append-text st14 (cmp-ri reg-rax 2)
   in let not-read-key = st15.text-len
   in let st16 = st-append-text st15 (jcc cc-ne 0)
   in let st17 = st-append-text st16 (li reg-rdi key-buffer-addr)
   in let st18 = st-append-text st17 (mov-load reg-rax reg-rdi 0)
   in let read-done = st18.text-len
   in let st19 = st-append-text st18 (jmp 0)
   in let st20 = patch-jcc-at st19 not-read-key (st19.text-len)
   in let st21 = st-append-text st20 (cmp-ri reg-rax 3)
   in let not-get-ticks = st21.text-len
   in let st22 = st-append-text st21 (jcc cc-ne 0)
   in let st23 = st-append-text st22 (li reg-rdi tick-count-addr)
   in let st24 = st-append-text st23 (mov-load reg-rax reg-rdi 0)
   in let ticks-done = st24.text-len
   in let st25 = st-append-text st24 (jmp 0)
   in let st26 = patch-jcc-at st25 not-get-ticks (st25.text-len)
   in let st27 = st-append-text st26 (li reg-rax (-1))
   in let common-exit = st27.text-len
   in let st28 = patch-jmp-at st27 write-done common-exit
   in let st29 = patch-jmp-at st28 read-done common-exit
   in let st30 = patch-jmp-at st29 ticks-done common-exit
   in let st31 = st-append-text st30 (pop-r reg-r11)
   in let st32 = st-append-text st31 (pop-r reg-rcx)
   in let st33 = st-append-text st32 (push-r reg-r11)
   in let st34 = st-append-text st33 [157]
   in let st35 = st-append-text st34 [255, 225]
   in SyscallResult {
    state = st35,
    handler-offset = handler-offset
  }

Section: Serial String
  emit-serial-string-loop : CodegenState -> List Integer -> Integer -> CodegenState
  emit-serial-string-loop (st) (chars) (i) =
   if i == list-length chars then st
   else let st1 = emit-serial-wait-and-send st (list-at chars i)
   in emit-serial-string-loop st1 chars (i + 1)

  emit-serial-string : CodegenState -> List Integer -> CodegenState
  emit-serial-string (st) (chars) =
   emit-serial-string-loop st chars 0

Section: Heap High-Water Mark
  emit-update-heap-hwm : CodegenState -> CodegenState
  emit-update-heap-hwm (st) =
   let st1 = st-append-text st (push-r reg-r11)
   in let st2 = st-append-text st1 (li reg-r11 heap-hwm-addr)
   in let st3 = st-append-text st2 (push-r reg-rax)
   in let st4 = st-append-text st3 (mov-load reg-rax reg-r11 0)
   in let st5 = st-append-text st4 (cmp-rr reg-r10 reg-rax)
   in let skip-update = st5.text-len
   in let st6 = st-append-text st5 (jcc cc-le 0)
   in let st7 = st-append-text st6 (mov-store reg-r11 reg-r10 0)
   in let st8 = patch-jcc-at st7 skip-update (st7.text-len)
   in let st9 = st-append-text st8 (pop-r reg-rax)
   in st-append-text st9 (pop-r reg-r11)

Page 1


Chapter: Emit--X86-64 Code Generator
 Pure-functional x86-64 instruction encoder. Each function takes register
 IDs and immediates, returns a List Integer (byte sequence).

Section: Arithmetic Helpers
  int-mod : Integer -> Integer -> Integer
  int-mod (n) (d) =
   let abs-d = if d < 0 then 0 - d else d
   in let r = n - n / d * d
   in if r < 0 then r + abs-d else r

  floor-div : Integer -> Integer -> Integer
  floor-div (n) (d) =
   if n >= 0 then n / d else (n - d + 1) / d

  to-byte : Integer -> Integer
  to-byte (n) =
   int-mod n 256

Section: Encoding Primitives
  rex : Boolean -> Boolean -> Boolean -> Boolean -> Integer
  rex (w) (r) (x) (b) =
   let wv = if w then 8 else 0
   in let rv = if r then 4 else 0
   in let xv = if x then 2 else 0
   in let bv = if b then 1 else 0
   in 64 + wv + rv + xv + bv

  rex-w : Integer -> Integer -> Integer
  rex-w (reg) (rm) =
   rex True (reg >= 8) False (rm >= 8)

  modrm : Integer -> Integer -> Integer -> Integer
  modrm (m) (reg) (rm) =
   m * 64 + int-mod reg 8 * 8 + int-mod rm 8

  sib : Integer -> Integer -> Integer -> Integer
  sib (scale) (index) (base-reg) =
   scale * 64 + int-mod index 8 * 8 + int-mod base-reg 8

Section: Immediate Encoding
  write-bytes : Integer -> Integer -> List Integer
  write-bytes (v) (n) =
   if n == 0 then []
   else [to-byte v] ++ write-bytes (floor-div v 256) (n - 1)

  write-i8 : Integer -> List Integer
  write-i8 (v) =
   [to-byte v]

  write-i32 : Integer -> List Integer
  write-i32 (v) =
   write-bytes v 4

  write-i64 : Integer -> List Integer
  write-i64 (v) =
   write-bytes v 8

Section: Memory Operand Encoding
  emit-mem-operand : Integer -> Integer -> Integer -> List Integer
  emit-mem-operand (reg) (rm) (offset) =
   let rm-low = int-mod rm 8
   in let needs-sib = rm-low == 4
   in let rbp-base = rm-low == 5
   in let sib-byte = if needs-sib then [sib 0 4 rm-low] else []
   in if offset == 0 & rbp-base == False then [modrm 0 reg rm] ++ sib-byte
      else if offset >= -128 & offset <= 127 then [modrm 1 reg rm] ++ sib-byte ++ write-i8 offset
      else [modrm 2 reg rm] ++ sib-byte ++ write-i32 offset

Section: Register Constants
  reg-rax : Integer
  reg-rax =
   0

  reg-rcx : Integer
  reg-rcx =
   1

  reg-rdx : Integer
  reg-rdx =
   2

  reg-rbx : Integer
  reg-rbx =
   3

  reg-rsp : Integer
  reg-rsp =
   4

  reg-rbp : Integer
  reg-rbp =
   5

  reg-rsi : Integer
  reg-rsi =
   6

  reg-rdi : Integer
  reg-rdi =
   7

  reg-r8 : Integer
  reg-r8 =
   8

  reg-r9 : Integer
  reg-r9 =
   9

  reg-r10 : Integer
  reg-r10 =
   10

  reg-r11 : Integer
  reg-r11 =
   11

  reg-r12 : Integer
  reg-r12 =
   12

  reg-r13 : Integer
  reg-r13 =
   13

  reg-r14 : Integer
  reg-r14 =
   14

  reg-r15 : Integer
  reg-r15 =
   15

  arg-regs : List Integer
  arg-regs =
   [7, 6, 2, 1, 8, 9]

  callee-saved-regs : List Integer
  callee-saved-regs =
   [3, 12, 13, 14, 15]

Section: Condition Codes
  cc-b : Integer
  cc-b =
   2

  cc-ae : Integer
  cc-ae =
   3

  cc-e : Integer
  cc-e =
   4

  cc-ne : Integer
  cc-ne =
   5

  cc-be : Integer
  cc-be =
   6

  cc-a : Integer
  cc-a =
   7

  cc-l : Integer
  cc-l =
   12

  cc-ge : Integer
  cc-ge =
   13

  cc-le : Integer
  cc-le =
   14

  cc-g : Integer
  cc-g =
   15

Section: MOV Instructions
  mov-rr : Integer -> Integer -> List Integer
  mov-rr (rd) (rs) =
   [rex-w rs rd, 137, modrm 3 rs rd]

  mov-ri64 : Integer -> Integer -> List Integer
  mov-ri64 (rd) (imm) =
   [rex True False False (rd >= 8), 184 + int-mod rd 8]
   ++ write-i64 imm

  mov-ri32 : Integer -> Integer -> List Integer
  mov-ri32 (rd) (imm) =
   [rex-w 0 rd, 199, modrm 3 0 rd] ++ write-i32 imm

  mov-load : Integer -> Integer -> Integer -> List Integer
  mov-load (rd) (rs) (offset) =
   [rex-w rd rs, 139] ++ emit-mem-operand rd rs offset

  mov-store : Integer -> Integer -> Integer -> List Integer
  mov-store (rd) (rs) (offset) =
   [rex-w rs rd, 137] ++ emit-mem-operand rs rd offset

  mov-load-rip-rel : Integer -> Integer -> List Integer
  mov-load-rip-rel (rd) (disp32) =
   [rex True (rd >= 8) False False, 139, modrm 0 rd 5] ++ write-i32 disp32

  mov-store-rip-rel : Integer -> Integer -> List Integer
  mov-store-rip-rel (rs) (disp32) =
   [rex True (rs >= 8) False False, 137, modrm 0 rs 5] ++ write-i32 disp32

  movzx-byte : Integer -> Integer -> Integer -> List Integer
  movzx-byte (rd) (rs) (offset) =
   [rex-w rd rs, 15, 182] ++ emit-mem-operand rd rs offset

  mov-store-byte : Integer -> Integer -> Integer -> List Integer
  mov-store-byte (rd) (rs) (offset) =
   let rex-byte = rex False (rs >= 8) False (rd >= 8)
   in let pfx = if rex-byte /= 64 | rs >= 4 then [rex-byte] else []
   in pfx ++ [136] ++ emit-mem-operand rs rd offset

Section: Arithmetic Instructions
  alu-ri : Integer -> Integer -> Integer -> List Integer
  alu-ri (ext) (rd) (imm) =
   if imm >= -128 & imm <= 127 then [rex-w 0 rd, 131, modrm 3 ext rd] ++ write-i8 imm
   else [rex-w 0 rd, 129, modrm 3 ext rd] ++ write-i32 imm

  add-rr : Integer -> Integer -> List Integer
  add-rr (rd) (rs) =
   [rex-w rs rd, 1, modrm 3 rs rd]

  add-ri : Integer -> Integer -> List Integer
  add-ri (rd) (imm) =
   alu-ri 0 rd imm

  sub-rr : Integer -> Integer -> List Integer
  sub-rr (rd) (rs) =
   [rex-w rs rd, 41, modrm 3 rs rd]

  sub-ri : Integer -> Integer -> List Integer
  sub-ri (rd) (imm) =
   alu-ri 5 rd imm

  imul-rr : Integer -> Integer -> List Integer
  imul-rr (rd) (rs) =
   [rex-w rd rs, 15, 175, modrm 3 rd rs]

  neg-r : Integer -> List Integer
  neg-r (rd) =
   [rex-w 0 rd, 247, modrm 3 3 rd]

  cqo : List Integer
  cqo =
   [rex True False False False, 153]

  idiv-r : Integer -> List Integer
  idiv-r (rs) =
   [rex-w 0 rs, 247, modrm 3 7 rs]

  and-rr : Integer -> Integer -> List Integer
  and-rr (rd) (rs) =
   [rex-w rs rd, 33, modrm 3 rs rd]

  and-ri : Integer -> Integer -> List Integer
  and-ri (rd) (imm) =
   alu-ri 4 rd imm

  or-rr : Integer -> Integer -> List Integer
  or-rr (rd) (rs) =
   [rex-w rs rd, 9, modrm 3 rs rd]

  or-ri : Integer -> Integer -> List Integer
  or-ri (rd) (imm) =
   alu-ri 1 rd imm

  shl-ri : Integer -> Integer -> List Integer
  shl-ri (rd) (imm) =
   [rex-w 0 rd, 193, modrm 3 4 rd, imm]

  shr-ri : Integer -> Integer -> List Integer
  shr-ri (rd) (imm) =
   [rex-w 0 rd, 193, modrm 3 5 rd, imm]

  shl-cl : Integer -> List Integer
  shl-cl (rd) =
   [rex-w 0 rd, 211, modrm 3 4 rd]

  shr-cl : Integer -> List Integer
  shr-cl (rd) =
   [rex-w 0 rd, 211, modrm 3 5 rd]

  not-r : Integer -> List Integer
  not-r (rd) =
   [rex-w 0 rd, 247, modrm 3 2 rd]

  sar-ri : Integer -> Integer -> List Integer
  sar-ri (rd) (imm) =
   [rex-w 0 rd, 193, modrm 3 7 rd, imm]

Section: Compare and Test
  cmp-rr : Integer -> Integer -> List Integer
  cmp-rr (rd) (rs) =
   [rex-w rs rd, 57, modrm 3 rs rd]

  cmp-ri : Integer -> Integer -> List Integer
  cmp-ri (rd) (imm) =
   alu-ri 7 rd imm

  test-rr : Integer -> Integer -> List Integer
  test-rr (rd) (rs) =
   [rex-w rs rd, 133, modrm 3 rs rd]

Section: Setcc
  setcc : Integer -> Integer -> List Integer
  setcc (cc) (rd) =
   let pfx = if rd >= 4 then [rex False False False (rd >= 8)] else []
   in pfx ++ [15, 144 + cc, modrm 3 0 rd]

  movzx-byte-self : Integer -> List Integer
  movzx-byte-self (rd) =
   [rex-w rd rd, 15, 182, modrm 3 rd rd]

Section: Branches and Jumps
  jcc : Integer -> Integer -> List Integer
  jcc (cc) (rel32) =
   [15, 128 + cc] ++ write-i32 rel32

  jmp : Integer -> List Integer
  jmp (rel32) =
   [233] ++ write-i32 rel32

  x86-call : Integer -> List Integer
  x86-call (rel32) =
   [232] ++ write-i32 rel32

  x86-ret : List Integer
  x86-ret =
   [195]

  x86-nop : List Integer
  x86-nop =
   [144]

Section: Stack
  push-r : Integer -> List Integer
  push-r (rd) =
   let pfx = if rd >= 8 then [rex False False False True] else []
   in pfx ++ [80 + int-mod rd 8]

  pop-r : Integer -> List Integer
  pop-r (rd) =
   let pfx = if rd >= 8 then [rex False False False True] else []
   in pfx ++ [88 + int-mod rd 8]

Section: LEA
  lea : Integer -> Integer -> Integer -> List Integer
  lea (rd) (rs) (offset) =
   [rex-w rd rs, 141] ++ emit-mem-operand rd rs offset

Section: Load Immediate
  li : Integer -> Integer -> List Integer
  li (rd) (value) =
   if value == 0 then xor-rr rd rd
   else if value >= 0 - 2147483648 & value <= 2147483647 then mov-ri32 rd value
   else mov-ri64 rd value

  xor-rr : Integer -> Integer -> List Integer
  xor-rr (rd) (rs) =
   let rex-byte = rex False (rs >= 8) False (rd >= 8)
   in let pfx = if rex-byte /= 64 then [rex-byte] else []
   in pfx ++ [49, modrm 3 rs rd]

Section: System
  x86-syscall : List Integer
  x86-syscall =
   [15, 5]

  out-dx-al : List Integer
  out-dx-al =
   [238]

  in-al-dx : List Integer
  in-al-dx =
   [236]

Section: Privileged Instructions
  hlt : List Integer
  hlt =
   [244]

  x86-pause : List Integer
  x86-pause =
   [243, 144]

  cli : List Integer
  cli =
   [250]

  sti : List Integer
  sti =
   [251]

  iretq : List Integer
  iretq =
   [72, 207]

  lidt-rdi : List Integer
  lidt-rdi =
   [15, 1, 31]

  swapgs : List Integer
  swapgs =
   [15, 1, 248]

Section: SSE2 Instructions

  movq-to-xmm : Integer -> Integer -> List Integer
  movq-to-xmm (xmm) (gpr) =
   [102, rex-w xmm gpr, 15, 110, modrm 3 xmm gpr]

  movq-from-xmm : Integer -> Integer -> List Integer
  movq-from-xmm (gpr) (xmm) =
   [102, rex-w xmm gpr, 15, 126, modrm 3 xmm gpr]

  addsd-xmm : Integer -> Integer -> List Integer
  addsd-xmm (dst) (src) =
   [242, 15, 88, modrm 3 dst src]

  subsd-xmm : Integer -> Integer -> List Integer
  subsd-xmm (dst) (src) =
   [242, 15, 92, modrm 3 dst src]

  mulsd-xmm : Integer -> Integer -> List Integer
  mulsd-xmm (dst) (src) =
   [242, 15, 89, modrm 3 dst src]

  divsd-xmm : Integer -> Integer -> List Integer
  divsd-xmm (dst) (src) =
   [242, 15, 94, modrm 3 dst src]

  ucomisd-xmm : Integer -> Integer -> List Integer
  ucomisd-xmm (a) (b) =
   [102, 15, 46, modrm 3 a b]

