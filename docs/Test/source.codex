Chapter: Syntax--Parser
 Core parser utilities: state, results, predicates, helpers.

  cites Foreword chapter Maybe

Section: Parser State
  ParseState = record {
   tokens : List Token,
   pos : Integer,
   bag : DiagnosticBag,
   paren-depth : Integer
  }

  make-parse-state : List Token -> ParseState
  make-parse-state (toks) =
   ParseState {
    tokens = toks,
    pos = 0,
    bag = empty-bag,
    paren-depth = 0
   }

  current : ParseState -> Token
  current (st) =
   list-at (st.tokens) (st.pos)

  current-kind : ParseState -> TokenKind
  current-kind (st) = (current st).kind

  advance : ParseState -> ParseState
  advance (st) =
   if st.pos >= list-length (st.tokens) - 1 then st
   else ParseState {
    tokens = st.tokens,
    pos = st.pos + 1,
    bag = st.bag,
    paren-depth = st.paren-depth
   }

  enter-paren : ParseState -> ParseState
  enter-paren (st) =
   ParseState {
    tokens = st.tokens,
    pos = st.pos,
    bag = st.bag,
    paren-depth = st.paren-depth + 1
   }

  exit-paren : ParseState -> ParseState
  exit-paren (st) =
   ParseState {
    tokens = st.tokens,
    pos = st.pos,
    bag = st.bag,
    paren-depth = st.paren-depth - 1
   }

  is-done : ParseState -> Boolean
  is-done (st) =
   when current-kind st
    is EndOfFile -> True
    is otherwise -> False

  peek-kind : ParseState -> Integer -> TokenKind
  peek-kind (st) (offset) =
   let idx = st.pos + offset
   in if idx >= list-length (st.tokens) then EndOfFile
      else (list-at (st.tokens) idx).kind

Section: Parse Results
  ParseExprResult =
   | ExprOk (Expr) (ParseState)

  ParsePatResult =
   | PatOk (Pat) (ParseState)

  ParseTypeResult =
   | TypeOk (TypeExpr) (ParseState)

  ParseDefResult = record {
   maybe-def : Maybe Def,
   state : ParseState
  }

  ParseTypeDefResult = record {
   maybe-type-def : Maybe TypeDef,
   state : ParseState
  }

Section: TokenKind Predicates
  is-ident : TokenKind -> Boolean
  is-ident (k) =
   when k
    is Identifier -> True
    is otherwise -> False

  is-ident-like : TokenKind -> Boolean
  is-ident-like (k) =
   when k
    is Identifier -> True
    is ActKeyword -> True
    is EndKeyword -> True
    is QedKeyword -> True
    is otherwise -> False

  is-type-ident : TokenKind -> Boolean
  is-type-ident (k) =
   when k
    is TypeIdentifier -> True
    is otherwise -> False

  is-arrow : TokenKind -> Boolean
  is-arrow (k) =
   when k
    is Arrow -> True
    is otherwise -> False

  is-equals : TokenKind -> Boolean
  is-equals (k) =
   when k
    is Equals -> True
    is otherwise -> False

  is-colon : TokenKind -> Boolean
  is-colon (k) =
   when k
    is Colon -> True
    is otherwise -> False

  is-comma : TokenKind -> Boolean
  is-comma (k) =
   when k
    is Comma -> True
    is otherwise -> False

  is-pipe : TokenKind -> Boolean
  is-pipe (k) =
   when k
    is Pipe -> True
    is otherwise -> False

  is-dot : TokenKind -> Boolean
  is-dot (k) =
   when k
    is Dot -> True
    is otherwise -> False

  is-left-paren : TokenKind -> Boolean
  is-left-paren (k) =
   when k
    is LeftParen -> True
    is otherwise -> False

  is-left-brace : TokenKind -> Boolean
  is-left-brace (k) =
   when k
    is LeftBrace -> True
    is otherwise -> False

  is-left-bracket : TokenKind -> Boolean
  is-left-bracket (k) =
   when k
    is LeftBracket -> True
    is otherwise -> False

  is-right-brace : TokenKind -> Boolean
  is-right-brace (k) =
   when k
    is RightBrace -> True
    is otherwise -> False

  is-right-bracket : TokenKind -> Boolean
  is-right-bracket (k) =
   when k
    is RightBracket -> True
    is otherwise -> False

  is-right-paren : TokenKind -> Boolean
  is-right-paren (k) =
   when k
    is RightParen -> True
    is otherwise -> False

  is-if-keyword : TokenKind -> Boolean
  is-if-keyword (k) =
   when k
    is IfKeyword -> True
    is otherwise -> False

  is-is-keyword : TokenKind -> Boolean
  is-is-keyword (k) =
   when k
    is IsKeyword -> True
    is otherwise -> False

  is-match-arm-start : TokenKind -> Boolean
  is-match-arm-start (k) =
   is-is-keyword k

  is-otherwise-keyword : TokenKind -> Boolean
  is-otherwise-keyword (k) =
   when k
    is OtherwiseKeyword -> True
    is otherwise -> False

  is-wildcard-pat : TokenKind -> Boolean
  is-wildcard-pat (k) =
   is-otherwise-keyword k

  is-let-keyword : TokenKind -> Boolean
  is-let-keyword (k) =
   when k
    is LetKeyword -> True
    is otherwise -> False

  is-when-keyword : TokenKind -> Boolean
  is-when-keyword (k) =
   when k
    is WhenKeyword -> True
    is otherwise -> False

  is-act-keyword : TokenKind -> Boolean
  is-act-keyword (k) =
   when k
    is ActKeyword -> True
    is otherwise -> False

  is-end-keyword : TokenKind -> Boolean
  is-end-keyword (k) =
   when k
    is EndKeyword -> True
    is otherwise -> False

  is-with-keyword : TokenKind -> Boolean
  is-with-keyword (k) =
   when k
    is WithKeyword -> True
    is otherwise -> False

  is-effect-keyword : TokenKind -> Boolean
  is-effect-keyword (k) =
   when k
    is EffectKeyword -> True
    is otherwise -> False

  is-cites-keyword : TokenKind -> Boolean
  is-cites-keyword (k) =
   when k
    is CitesKeyword -> True
    is otherwise -> False

  is-where-keyword : TokenKind -> Boolean
  is-where-keyword (k) =
   when k
    is WhereKeyword -> True
    is otherwise -> False

  is-in-keyword : TokenKind -> Boolean
  is-in-keyword (k) =
   when k
    is InKeyword -> True
    is otherwise -> False

  is-else-keyword : TokenKind -> Boolean
  is-else-keyword (k) =
   when k
    is ElseKeyword -> True
    is otherwise -> False

  is-reserved-keyword : TokenKind -> Boolean
  is-reserved-keyword (k) =
   when k
    is LetKeyword -> True
    is InKeyword -> True
    is IfKeyword -> True
    is IsKeyword -> True
    is OtherwiseKeyword -> True
    is ThenKeyword -> True
    is ElseKeyword -> True
    is WhenKeyword -> True
    is WhereKeyword -> True
    is SuchThatKeyword -> True
    is ActKeyword -> True
    is EndKeyword -> True
    is RecordKeyword -> True
    is CitesKeyword -> True
    is ClaimKeyword -> True
    is ProofKeyword -> True
    is QedKeyword -> True
    is ForAllKeyword -> True
    is ThereExistsKeyword -> True
    is LinearKeyword -> True
    is EffectKeyword -> True
    is WithKeyword -> True
    is TrueKeyword -> True
    is FalseKeyword -> True
    is otherwise -> False

  is-minus : TokenKind -> Boolean
  is-minus (k) =
   when k
    is Minus -> True
    is otherwise -> False

  is-dedent : TokenKind -> Boolean
  is-dedent (k) =
   when k
    is Dedent -> True
    is otherwise -> False

  is-left-arrow : TokenKind -> Boolean
  is-left-arrow (k) =
   when k
    is LeftArrow -> True
    is otherwise -> False

  is-record-keyword : TokenKind -> Boolean
  is-record-keyword (k) =
   when k
    is RecordKeyword -> True
    is otherwise -> False

  is-underscore : TokenKind -> Boolean
  is-underscore (k) =
   when k
    is Underscore -> True
    is otherwise -> False

  is-backslash : TokenKind -> Boolean
  is-backslash (k) =
   when k
    is Backslash -> True
    is otherwise -> False

  is-literal : TokenKind -> Boolean
  is-literal (k) =
   when k
    is IntegerLiteral -> True
    is NumberLiteral -> True
    is TextLiteral -> True
    is CharLiteral -> True
    is TrueKeyword -> True
    is FalseKeyword -> True
    is otherwise -> False

  is-app-start : TokenKind -> Boolean
  is-app-start (k) =
   when k
    is Identifier -> True
    is TypeIdentifier -> True
    is IntegerLiteral -> True
    is NumberLiteral -> True
    is TextLiteral -> True
    is CharLiteral -> True
    is TrueKeyword -> True
    is FalseKeyword -> True
    is LeftParen -> True
    is LeftBracket -> True
    is ActKeyword -> True
    is WithKeyword -> True
    is otherwise -> False

  is-compound : Expr -> Boolean
  is-compound (e) =
   when e
    is MatchExpr (s) (arms) -> True
    is IfExpr (c) (t) (el) -> True
    is LetExpr (binds) (body) -> True
    is ActExpr (stmts) -> True
    is otherwise -> False

  is-type-arg-start : TokenKind -> Boolean
  is-type-arg-start (k) =
   when k
    is TypeIdentifier -> True
    is Identifier -> True
    is LeftParen -> True
    is IntegerLiteral -> True
    is otherwise -> False

  operator-precedence : TokenKind -> Integer
  operator-precedence (k) =
   when k
    is PlusPlus -> 5
    is ColonColon -> 5
    is Plus -> 6
    is Minus -> 6
    is Star -> 7
    is Slash -> 7
    is Caret -> 8
    is DoubleEquals -> 4
    is NotEquals -> 4
    is LessThan -> 4
    is GreaterThan -> 4
    is LessOrEqual -> 4
    is GreaterOrEqual -> 4
    is TripleEquals -> 4
    is Ampersand -> 3
    is Pipe -> 2
    is otherwise -> -1

  is-right-assoc : TokenKind -> Boolean
  is-right-assoc (k) =
   when k
    is PlusPlus -> True
    is ColonColon -> True
    is Caret -> True
    is Arrow -> True
    is otherwise -> False

Section: Token Helpers
  expect : TokenKind -> ParseState -> ParseState
  expect (kind) (st) =
   if is-done st then st
   else if current-kind st == kind then advance st
   else let tok = current st
   in ParseState {
    tokens = st.tokens,
    pos = st.pos,
    bag = bag-add (st.bag) (make-error cdx-expected-token-kind ("Expected token kind mismatch, got '" ++ tok.text ++ "'") (span-at (tok.line) (tok.column) (tok.offset) (text-length (tok.text)) (tok.file-id))),
    paren-depth = st.paren-depth
   }

  report-reserved-keyword : Text -> ParseState -> ParseState
  report-reserved-keyword (context) (st) =
   let tok = current st
   in ParseState {
    tokens = st.tokens,
    pos = st.pos,
    bag = bag-add (st.bag) (make-error cdx-reserved-keyword-as-identifier ("'" ++ tok.text ++ "' is a reserved keyword and cannot be used as " ++ context ++ "; rename it") (span-at (tok.line) (tok.column) (tok.offset) (text-length (tok.text)) (tok.file-id))),
    paren-depth = st.paren-depth
   }

  skip-newlines-pos : List Token -> Integer -> Integer -> Integer
  skip-newlines-pos (tokens) (pos) (len) =
   if pos >= len - 1 then pos
   else let kind = (list-at tokens pos).kind
   in when kind
     is Newline -> skip-newlines-pos tokens (pos + 1) len
     is Indent -> skip-newlines-pos tokens (pos + 1) len
     is Dedent -> skip-newlines-pos tokens (pos + 1) len
     is otherwise -> pos

  skip-newlines : ParseState -> ParseState
  skip-newlines (st) =
   let end-pos = skip-newlines-pos (st.tokens) (st.pos) (list-length (st.tokens))
   in if end-pos == st.pos then st
      else ParseState {
       tokens = st.tokens,
       pos = end-pos,
       bag = st.bag,
       paren-depth = st.paren-depth
      }

Page 2 of 3



Chapter: Syntax--Parser
 Expression and compound expression parsing.

Section: Expression Parsing
  parse-expr : ParseState -> ParseExprResult
  parse-expr (st) =
   parse-expr-col st 0

  parse-expr-col : ParseState -> Integer -> ParseExprResult
  parse-expr-col (st) (min-col) =
   parse-binary st 0 min-col

  unwrap-expr-ok : ParseExprResult -> (Expr -> ParseState -> ParseExprResult) -> ParseExprResult
  unwrap-expr-ok (r) (f) =
   when r
    is ExprOk (e) (st) -> f e st

  parse-binary : ParseState -> Integer -> Integer -> ParseExprResult
  parse-binary (st) (min-prec) (min-col) =
   let left-result = parse-unary st
   in unwrap-expr-ok left-result (start-binary-loop min-prec min-col)

  start-binary-loop : Integer -> Integer -> Expr -> ParseState -> ParseExprResult
  start-binary-loop (min-prec) (min-col) (left) (st) =
   parse-binary-loop left st min-prec min-col

  parse-binary-loop : Expr -> ParseState -> Integer -> Integer -> ParseExprResult
  parse-binary-loop (left) (st) (min-prec) (min-col) =
   let st1 = skip-newlines st
   in if is-done st1 then ExprOk left st1
      else if min-col > 0 & (current st1).column > 0 & (current st1).column <= min-col then ExprOk left st1
   else let prec = operator-precedence (current-kind st1)
   in if prec < min-prec then ExprOk left st1
   else let op = current st1
   in let st2 = skip-newlines (advance st1)
   in let next-min = if is-right-assoc (op.kind) then prec else prec + 1
   in let right-result = parse-binary st2 next-min min-col
   in unwrap-expr-ok right-result (continue-binary left op min-prec min-col)

  continue-binary : Expr -> Token -> Integer -> Integer -> Expr -> ParseState -> ParseExprResult
  continue-binary (left) (op) (min-prec) (min-col) (right) (st) =
   parse-binary-loop (BinExpr left op right) st min-prec min-col

  parse-unary : ParseState -> ParseExprResult
  parse-unary (st) =
   if is-minus (current-kind st) then let op = current st
     in let result = parse-unary (advance st)
     in unwrap-expr-ok result (finish-unary op)
    else parse-application st

  finish-unary : Token -> Expr -> ParseState -> ParseExprResult
  finish-unary (op) (operand) (st) =
   ExprOk (UnaryExpr op operand) st

  parse-application : ParseState -> ParseExprResult
  parse-application (st) =
   let func-result = parse-atom st
   in unwrap-expr-ok func-result parse-app-loop

  parse-app-loop : Expr -> ParseState -> ParseExprResult
  parse-app-loop (func) (st) =
   if is-compound func then parse-dot-only func st
   else if is-done st then ExprOk func st
   else let st1 = if st.paren-depth > 0 then skip-newlines st else st
   in if is-app-start (current-kind st1) then
     let arg-result = parse-atom st1
     in unwrap-expr-ok arg-result (continue-app func)
   else parse-field-access func st1

  continue-app : Expr -> Expr -> ParseState -> ParseExprResult
  continue-app (func) (arg) (st) =
   parse-app-loop (AppExpr func arg) st

  parse-atom : ParseState -> ParseExprResult
  parse-atom (st) =
   if is-literal (current-kind st) then ExprOk (LitExpr (current st)) (advance st)
   else if is-ident (current-kind st) then parse-field-access (NameExpr (current st)) (advance st)
   else if is-type-ident (current-kind st) then parse-atom-type-ident st
   else if is-left-paren (current-kind st) then parse-paren-expr (advance st)
   else if is-left-bracket (current-kind st) then parse-list-expr st
   else if is-if-keyword (current-kind st) then parse-if-expr st
   else if is-let-keyword (current-kind st) then parse-let-expr st
   else if is-when-keyword (current-kind st) then parse-match-expr st
   else if is-act-keyword (current-kind st) then parse-act-expr st
   else if is-with-keyword (current-kind st) then parse-handle-expr st
   else if is-backslash (current-kind st) then parse-lambda-expr st
              else ExprOk (ErrExpr (current st)) (advance st)

  parse-field-access : Expr -> ParseState -> ParseExprResult
  parse-field-access (node) (st) =
   if is-dot (current-kind st) then let st2 = advance st
     in if is-ident-like (current-kind st2) then let field = current st2
     in let st3 = advance st2
     in parse-field-access (FieldExpr node field) st3
        else ExprOk node st
    else ExprOk node st

  parse-dot-only : Expr -> ParseState -> ParseExprResult
  parse-dot-only (node) (st) =
   if is-dot (current-kind st) then let st2 = advance st
     in if is-ident-like (current-kind st2) then let field = current st2
     in let st3 = advance st2
     in parse-dot-only (FieldExpr node field) st3
        else ExprOk node st
    else ExprOk node st

  parse-atom-type-ident : ParseState -> ParseExprResult
  parse-atom-type-ident (st) =
   let tok = current st
   in let st2 = advance st
   in if is-left-brace (current-kind st2) then
       let rec-result = parse-record-expr tok st2
       in unwrap-expr-ok rec-result parse-field-access
      else parse-field-access (NameExpr tok) st2

  parse-paren-expr : ParseState -> ParseExprResult
  parse-paren-expr (st) =
   let st2 = skip-newlines (enter-paren st)
   in let inner = parse-expr st2
   in unwrap-expr-ok inner finish-paren-expr

  finish-paren-expr : Expr -> ParseState -> ParseExprResult
  finish-paren-expr (e) (st) =
   let st2 = skip-newlines st
   in let st3 = expect RightParen st2
   in parse-field-access (ParenExpr e) (exit-paren st3)

Section: Compound Expression Parsing
  parse-record-expr : Token -> ParseState -> ParseExprResult
  parse-record-expr (type-name) (st) =
   let st2 = advance st
   in let st3 = skip-newlines st2
   in parse-record-expr-fields type-name [] st3

  parse-record-expr-fields : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
  parse-record-expr-fields (type-name) (acc) (st) =
   let kind = current-kind st
   in if is-right-brace kind then ExprOk (RecordExpr type-name acc) (advance st)
      else if is-ident-like kind then parse-record-field type-name acc st
      else ExprOk (RecordExpr type-name acc) st

  parse-record-field : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
  parse-record-field (type-name) (acc) (st) =
   let field-name = current st
   in let st2 = advance st
   in let st3 = expect Equals st2
   in let val-result = parse-expr st3
   in unwrap-expr-ok val-result (finish-record-field type-name acc field-name)

  finish-record-field : Token -> List RecordFieldExpr -> Token -> Expr -> ParseState -> ParseExprResult
  finish-record-field (type-name) (acc) (field-name) (v) (st) =
   let field = RecordFieldExpr {
    name = field-name,
    value = v
   }
   in let st2 = skip-newlines st
   in if is-comma (current-kind st2) then parse-record-expr-fields type-name (list-snoc acc field) (skip-newlines (advance st2))
      else parse-record-expr-fields type-name (list-snoc acc field) st2

  parse-list-expr : ParseState -> ParseExprResult
  parse-list-expr (st) =
   let st2 = advance st
   in let st3 = skip-newlines st2
   in parse-list-elements [] st3

  parse-list-elements : List Expr -> ParseState -> ParseExprResult
  parse-list-elements (acc) (st) =
   if is-right-bracket (current-kind st) then ExprOk (ListExpr acc) (advance st)
   else let elem = parse-expr st
   in unwrap-expr-ok elem (finish-list-element acc)

  finish-list-element : List Expr -> Expr -> ParseState -> ParseExprResult
  finish-list-element (acc) (e) (st) =
   let st2 = skip-newlines st
   in if is-comma (current-kind st2) then parse-list-elements (list-snoc acc e) (skip-newlines (advance st2))
      else parse-list-elements (list-snoc acc e) st2

  parse-if-expr : ParseState -> ParseExprResult
  parse-if-expr (st) =
   let st2 = skip-newlines (advance st)
   in let cond = parse-expr st2
   in unwrap-expr-ok cond parse-if-then

  parse-if-then : Expr -> ParseState -> ParseExprResult
  parse-if-then (c) (st) =
   let st2 = skip-newlines st
   in let st3 = expect ThenKeyword st2
   in let st4 = skip-newlines st3
   in let then-result = parse-expr st4
   in unwrap-expr-ok then-result (parse-if-else c)

  parse-if-else : Expr -> Expr -> ParseState -> ParseExprResult
  parse-if-else (c) (t) (st) =
   let st2 = skip-newlines st
   in let st3 = expect ElseKeyword st2
   in let st4 = skip-newlines st3
   in let else-result = parse-expr st4
   in unwrap-expr-ok else-result (finish-if c t)

  finish-if : Expr -> Expr -> Expr -> ParseState -> ParseExprResult
  finish-if (c) (t) (e) (st) = ExprOk (IfExpr c t e) st

  parse-let-expr : ParseState -> ParseExprResult
  parse-let-expr (st) =
   let st2 = skip-newlines (advance st)
   in parse-let-bindings [] st2

  parse-let-bindings : List LetBind -> ParseState -> ParseExprResult
  parse-let-bindings (acc) (st) =
   if is-ident (current-kind st) then parse-let-binding acc st
   else if is-reserved-keyword-let-name st then parse-let-binding acc (report-reserved-keyword "a let-binding name" st)
   else if is-in-keyword (current-kind st) then let st2 = skip-newlines (advance st)
      in let body = parse-expr st2
      in unwrap-expr-ok body (finish-let acc)
     else let body = parse-expr st
     in unwrap-expr-ok body (finish-let acc)

  is-reserved-keyword-let-name : ParseState -> Boolean
  is-reserved-keyword-let-name (st) =
   if is-reserved-keyword (current-kind st) then is-equals (peek-kind st 1)
   else False

  finish-let : List LetBind -> Expr -> ParseState -> ParseExprResult
  finish-let (acc) (b) (st) = ExprOk (LetExpr acc b) st

  parse-let-binding : List LetBind -> ParseState -> ParseExprResult
  parse-let-binding (acc) (st) =
   let name-tok = current st
   in let st2 = advance st
   in let st3 = expect Equals st2
   in let val-result = parse-expr st3
   in unwrap-expr-ok val-result (finish-let-binding acc name-tok)

  finish-let-binding : List LetBind -> Token -> Expr -> ParseState -> ParseExprResult
  finish-let-binding (acc) (name-tok) (v) (st) =
   let binding = LetBind {
    name = name-tok,
    value = v
   }
   in let st2 = skip-newlines st
   in if is-comma (current-kind st2) then parse-let-bindings (list-snoc acc binding) (skip-newlines (advance st2))
      else parse-let-bindings (list-snoc acc binding) st2

  parse-match-expr : ParseState -> ParseExprResult
  parse-match-expr (st) =
   let st2 = advance st
   in let scrut = parse-expr st2
   in unwrap-expr-ok scrut start-match-branches

  start-match-branches : Expr -> ParseState -> ParseExprResult
  start-match-branches (s) (st) =
   let st2 = skip-newlines st
   in let tok = current st2
   in parse-match-branches s [] (tok.column) (tok.line) st2

  parse-match-branches : Expr -> List MatchArm -> Integer -> Integer -> ParseState -> ParseExprResult
  parse-match-branches (scrut) (acc) (col) (ln) (st) =
   let tok = current st
   in if is-match-arm-start (current-kind st) & (tok.line == ln | tok.column == col)
      then parse-one-match-branch scrut acc col ln st
      else ExprOk (MatchExpr scrut acc) st

  unwrap-pat-for-expr : ParsePatResult -> (Pat -> ParseState -> ParseExprResult) -> ParseExprResult
  unwrap-pat-for-expr (r) (f) =
   when r
    is PatOk (p) (st) -> f p st

  parse-one-match-branch : Expr -> List MatchArm -> Integer -> Integer -> ParseState -> ParseExprResult
  parse-one-match-branch (scrut) (acc) (col) (ln) (st) =
   let st2 = advance st
   in let pat = parse-pattern st2
   in unwrap-pat-for-expr pat (parse-match-branch-body scrut acc col ln)

  parse-match-branch-body : Expr -> List MatchArm -> Integer -> Integer -> Pat -> ParseState -> ParseExprResult
  parse-match-branch-body (scrut) (acc) (col) (ln) (p) (st) =
   let st2 = expect Arrow st
   in let st3 = skip-newlines st2
   in let body = parse-expr st3
   in unwrap-expr-ok body (finish-match-branch scrut acc col ln p)

  finish-match-branch : Expr -> List MatchArm -> Integer -> Integer -> Pat -> Expr -> ParseState -> ParseExprResult
  finish-match-branch (scrut) (acc) (col) (ln) (p) (b) (st) =
   let arm = MatchArm {
    pattern = p,
    body = b
   }
   in let st2 = skip-newlines st
   in parse-match-branches scrut (list-snoc acc arm) col ln st2

  looks-like-top-level-def : ParseState -> Boolean
  looks-like-top-level-def (st) =
   if is-ident (current-kind st) | is-type-ident (current-kind st) then is-colon (peek-kind st 1)
   else False

  is-act-bind : ParseState -> Boolean
  is-act-bind (st) =
   if is-ident (current-kind st) then is-left-arrow (peek-kind st 1)
   else False

  parse-act-expr : ParseState -> ParseExprResult
  parse-act-expr (st) =
   let st2 = skip-newlines (advance st)
   in parse-act-stmts [] st2

  parse-act-stmts : List ActStmt -> ParseState -> ParseExprResult
  parse-act-stmts (acc) (st) =
   if is-done st then ExprOk (ActExpr acc) st
   else if is-end-keyword (current-kind st) then ExprOk (ActExpr acc) (advance st)
     else if is-act-bind st then parse-act-bind-stmt acc st
      else parse-act-expr-stmt acc st

  parse-act-bind-stmt : List ActStmt -> ParseState -> ParseExprResult
  parse-act-bind-stmt (acc) (st) =
   let name-tok = current st
   in let st2 = advance (advance st)
   in let val-result = parse-expr st2
   in unwrap-expr-ok val-result (finish-act-bind acc name-tok)

  finish-act-bind : List ActStmt -> Token -> Expr -> ParseState -> ParseExprResult
  finish-act-bind (acc) (name-tok) (v) (st) =
   let st2 = skip-newlines st
   in parse-act-stmts (list-snoc acc (ActBindStmt name-tok v)) st2

  parse-act-expr-stmt : List ActStmt -> ParseState -> ParseExprResult
  parse-act-expr-stmt (acc) (st) =
   let expr-result = parse-expr st
   in unwrap-expr-ok expr-result (finish-act-expr acc)

  finish-act-expr : List ActStmt -> Expr -> ParseState -> ParseExprResult
  finish-act-expr (acc) (e) (st) =
   let st2 = skip-newlines st
   in parse-act-stmts (list-snoc acc (ActExprStmt e)) st2

  parse-handle-expr : ParseState -> ParseExprResult
  parse-handle-expr (st) =
   let st1 = advance st
   in let eff-tok = current st1
   in let st2 = advance st1
   in let body-result = parse-expr st2
   in unwrap-expr-ok body-result (finish-handle-body eff-tok)

  finish-handle-body : Token -> Expr -> ParseState -> ParseExprResult
  finish-handle-body (eff-tok) (body) (st) =
   let st2 = skip-newlines st
   in let clauses = parse-handle-clauses st2 []
   in ExprOk (HandleExpr eff-tok body (clauses.clauses)) (clauses.state)

  HandleParseResult = record { clauses : List HandleClause, state : ParseState }

  parse-handle-clauses : ParseState -> List HandleClause -> HandleParseResult
  parse-handle-clauses (st) (acc) =
   if is-ident (current-kind st) then let op-tok = current st
     in let st1 = advance st
     in let params = parse-handle-params st1 []
     in if list-length (params.toks) > 0 then let resume-tok = list-at (params.toks) (list-length (params.toks) - 1)
          in let st5 = expect Equals (params.state)
          in let st6 = skip-newlines st5
          in let body-result = parse-expr st6
          in unwrap-handle-clause-body op-tok resume-tok body-result acc
        else HandleParseResult {
         clauses = acc,
         state = st
        }
   else HandleParseResult {
    clauses = acc,
    state = st
   }

  HandleParamsResult = record { toks : List Token, state : ParseState }

  parse-handle-params : ParseState -> List Token -> HandleParamsResult
  parse-handle-params (st) (acc) =
   if is-left-paren (current-kind st) then let st1 = advance st
     in let tok = current st1
     in let st2 = advance st1
     in let st3 = expect RightParen st2
     in parse-handle-params st3 (list-snoc acc tok)
    else HandleParamsResult {
     toks = acc,
     state = st
    }

  unwrap-handle-clause-body : Token -> Token -> ParseExprResult -> List HandleClause -> HandleParseResult
  unwrap-handle-clause-body (op-tok) (resume-tok) (result) (acc) =
   when result
    is ExprOk (body) (st) ->
     let clause = HandleClause {
      op-name = op-tok,
      resume-name = resume-tok,
      body = body
     }
     in let st2 = skip-newlines st
     in parse-handle-clauses st2 (list-snoc acc clause)

  parse-lambda-expr : ParseState -> ParseExprResult
  parse-lambda-expr (st) =
   let st2 = advance st
   in let params-result = collect-lambda-params st2 []
   in let st3 = expect Arrow (params-result.state)
   in let st4 = skip-newlines st3
   in let body = parse-expr st4
   in unwrap-expr-ok body (finish-lambda (params-result.toks))

  LambdaParamsResult = record { toks : List Token, state : ParseState }

  collect-lambda-params : ParseState -> List Token -> LambdaParamsResult
  collect-lambda-params (st) (acc) =
   if is-ident (current-kind st) then let tok = current st
     in collect-lambda-params (advance st) (list-snoc acc tok)
    else LambdaParamsResult {
     toks = acc,
     state = st
    }

  finish-lambda : List Token -> Expr -> ParseState -> ParseExprResult
  finish-lambda (params) (body) (st) =
   ExprOk (LambdaExpr params body) st

Page 3 of 3



Chapter: Syntax--Syntax Nodes
 The concrete syntax tree represents the structure of a parsed Codex
 source file. Each node carries position information for diagnostics.

  cites Foreword chapter Maybe

Section: Expressions
  Expr =
   | LitExpr (Token)
   | NameExpr (Token)
   | AppExpr (Expr) (Expr)
   | BinExpr (Expr) (Token) (Expr)
   | UnaryExpr (Token) (Expr)
   | IfExpr (Expr) (Expr) (Expr)
   | LetExpr (List LetBind) (Expr)
   | MatchExpr (Expr) (List MatchArm)
   | ListExpr (List Expr)
   | RecordExpr (Token) (List RecordFieldExpr)
   | FieldExpr (Expr) (Token)
   | ParenExpr (Expr)
   | ActExpr (List ActStmt)
   | HandleExpr (Token) (Expr) (List HandleClause)
   | LambdaExpr (List Token) (Expr)
   | ErrExpr (Token)

  LetBind = record {
   name : Token,
   value : Expr
  }

  MatchArm = record {
   pattern : Pat,
   body : Expr
  }

  RecordFieldExpr = record {
   name : Token,
   value : Expr
  }

  ActStmt =
   | ActBindStmt (Token) (Expr)
   | ActExprStmt (Expr)

  HandleClause = record {
   op-name : Token,
   resume-name : Token,
   body : Expr
  }

Section: Patterns
  Pat =
   | VarPat (Token)
   | LitPat (Token)
   | CtorPat (Token) (List Pat)
   | WildPat (Token)

Section: Types
  TypeExpr =
   | NamedType (Token)
   | FunType (TypeExpr) (TypeExpr)
   | AppType (TypeExpr) (List TypeExpr)
   | ParenType (TypeExpr)
   | ListType (TypeExpr)
   | LinearTypeExpr (TypeExpr)
   | EffectTypeExpr (List Token) (TypeExpr)

Section: Definitions
  TypeAnn = record {
   name : Token,
   type-expr : TypeExpr
  }

  Def = record {
   name : Token,
   params : List Token,
   ann : List TypeAnn,
   body : Expr,
   chapter-slug : Text
  }

  RecordFieldDef = record {
   name : Token,
   type-expr : TypeExpr
  }

  VariantCtorDef = record {
   name : Token,
   fields : List TypeExpr
  }

  EffectOpDef = record {
   name : Token,
   type-expr : TypeExpr
  }

  EffectDef = record {
   name : Token,
   ops : List EffectOpDef
  }

  TypeBody =
   | RecordBody (List RecordFieldDef)
   | VariantBody (List VariantCtorDef)

  TypeDef = record {
   name : Token,
   type-params : List Token,
   body : TypeBody
  }

Section: Document
  CitesDecl = record {
   quire : Token,
   chapter-name : Text,
   selected-names : List Token,
   citing-chapter : Text
  }

  Document = record {
   defs : List Def,
   type-defs : List TypeDef,
   effect-defs : List EffectDef,
   citations : List CitesDecl,
   chapter-title : Text,
   section-titles : List Text,
   parse-bag : DiagnosticBag
  }

Section: Definition Headers (for streaming)
  DefHeader = record {
   name : Token,
   params : List Token,
   ann : List TypeAnn,
   body-pos : Integer,
   chapter-slug : Text
  }

  ScanDefResult = record {
   maybe-header : Maybe DefHeader,
   state : ParseState
  }

  ScanResult = record {
   type-defs : List TypeDef,
   effect-defs : List EffectDef,
   def-headers : List DefHeader,
   citations : List CitesDecl,
   chapter-title : Text,
   section-titles : List Text
  }

