  emit-text-compare-len (st) (cmp-done-pos) =
    let st0 = patch-jcc-at st cmp-done-pos (st.text-len)
   in let st1 = st-append-text st0 (cmp-rr reg-r12 reg-rcx)
   in let len-eq-pos = st1.text-len
   in let st2 = st-append-text st1 (jcc cc-e 0)
   in let len-gt-pos = st2.text-len
   in let st3 = st-append-text st2 (jcc cc-g 0)
   in let st4 = st-append-text st3 (li reg-rax (-1))
   in let ret-len1 = st4.text-len
   in let st5 = st-append-text st4 (jmp 0)
   in let st6 = patch-jcc-at st5 len-gt-pos (st5.text-len)
   in let st7 = st-append-text st6 (li reg-rax 1)
   in let ret-len2 = st7.text-len
   in let st8 = st-append-text st7 (jmp 0)
   in let st9 = patch-jcc-at st8 len-eq-pos (st8.text-len)
   in let st10 = st-append-text st9 (li reg-rax 0)
