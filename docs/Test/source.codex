    let a-greater-pos = st.text-len
   in let st0 = st-append-text st (jcc cc-g 0)
   in let st1 = st-append-text st0 (li reg-rax (-1))
   in let ret-early1 = st1.text-len
   in let st2 = st-append-text st1 (jmp 0)
   in let st3 = patch-jcc-at st2 a-greater-pos (st2.text-len)
   in let st4 = st-append-text st3 (li reg-rax 1)
   in let ret-early2 = st4.text-len
   in let st5 = st-append-text st4 (jmp 0)
   in let st6 = patch-jcc-at st5 bytes-equal-pos (st5.text-len)
   in let st7 = st-append-text st6 (add-ri reg-r11 1)
   in let st8 = st-append-text st7 (jmp (cmp-loop - (st7.text-len + 5)))
   in HelpResult2 {
