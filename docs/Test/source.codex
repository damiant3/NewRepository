Page 1



Chapter: Types--Unification
 Type unification for the Codex type checker. The UnificationState
 is threaded through all operations — it tracks type variable
 substitutions, a counter for generating fresh variables, and
 accumulated diagnostics.

 Naming convention: the state is called a UnificationState because
 its mutations serve a specific purpose — unifying type variables
 with concrete types during type inference. It is not a general
 mutable reference.

Section: State
  UnificationState = record {
   substitutions : List SubstEntry,
   next-id : Integer,
   bag : DiagnosticBag
  }

  SubstEntry = record {
   var-id : Integer,
   resolved-type : CodexType
  }

  UnifyResult = record {
   success : Boolean,
   state : UnificationState
  }

Section: Construction
  empty-unification-state : UnificationState
  empty-unification-state =
   UnificationState {
    substitutions = [],
    next-id = 2,
    bag = empty-bag
   }

Section: Fresh Variables
  fresh-var : UnificationState -> CodexType
  fresh-var (st) =
   TypeVar (st.next-id)

  advance-id : UnificationState -> UnificationState
  advance-id (st) =
   UnificationState {
    substitutions = st.substitutions,
    next-id = st.next-id + 1,
    bag = st.bag
   }

  fresh-and-advance : UnificationState -> FreshResult
  fresh-and-advance (st) =
   FreshResult {
    var-type = TypeVar (st.next-id),
    state = advance-id st
   }

  FreshResult = record {
   var-type : CodexType,
   state : UnificationState
  }

Section: Substitution Lookup (binary search on sorted substitutions)
  subst-lookup : Integer -> List SubstEntry -> CodexType
  subst-lookup (var-id) (entries) =
   let len = list-length entries
   in if len == 0 then ErrorTy
   else let pos = bsearch-int-pos entries var-id 0 len
   in if pos >= len then ErrorTy
   else let entry = list-at entries pos
   in if entry.var-id == var-id then entry.resolved-type else ErrorTy

  has-subst : Integer -> List SubstEntry -> Boolean
  has-subst (var-id) (entries) =
   let len = list-length entries
   in if len == 0 then False
   else let pos = bsearch-int-pos entries var-id 0 len
   in if pos >= len then False
      else (list-at entries pos).var-id == var-id

Section: Resolve
  resolve : UnificationState -> CodexType -> CodexType
  resolve (st) (ty) =
   when ty
    is TypeVar (id) ->
     let entries = st.substitutions
     in let len = list-length entries
     in if len == 0 then ty
     else let pos = bsearch-int-pos entries id 0 len
     in if pos >= len then ty
     else let entry = list-at entries pos
     in if entry.var-id == id then resolve st (entry.resolved-type) else ty
    is otherwise -> ty

Section: Add Substitution
  add-subst : UnificationState -> Integer -> CodexType -> UnificationState
  add-subst (st) (var-id) (ty) =
   let entry = SubstEntry {
    var-id = var-id,
    resolved-type = ty
   }
   in let pos = bsearch-int-pos (st.substitutions) var-id 0 (list-length (st.substitutions))
   in UnificationState {
    substitutions = list-insert-at (st.substitutions) pos entry,
    next-id = st.next-id,
    bag = st.bag
   }

Section: Add Error
  add-unify-error : UnificationState -> Integer -> Text -> SourceSpan -> UnificationState
  add-unify-error (st) (code) (msg) (span) =
   UnificationState {
    substitutions = st.substitutions,
    next-id = st.next-id,
    bag = bag-add (st.bag) (make-error code msg span)
   }

Section: Occurs Check
  occurs-in : UnificationState -> Integer -> CodexType -> Boolean
  occurs-in (st) (var-id) (ty) =
   let resolved = resolve st ty
   in when resolved
    is TypeVar (id) -> id == var-id
    is FunTy (param) (ret) -> occurs-in st var-id param | occurs-in st var-id ret
    is ListTy (elem) -> occurs-in st var-id elem
    is LinkedListTy (elem) -> occurs-in st var-id elem
    is otherwise -> False

Section: Unify
  unify : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify (st) (a) (b) (span) =
   let ra = resolve st a
   in let rb = resolve st b
   in unify-resolved st ra rb span

  unify-resolved : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-resolved (st) (a) (b) (span) =
   if types-equal a b then UnifyResult {
    success = True,
    state = st
   }
   else when a
    is TypeVar (id-a) ->
     if occurs-in st id-a b then UnifyResult {
      success = False,
      state = add-unify-error st cdx-infinite-type "Infinite type" span
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-a b
      }
    is otherwise -> unify-rhs st a b span

  types-equal : CodexType -> CodexType -> Boolean
  types-equal (a) (b) =
   when a
    is TypeVar (id-a) -> when b
     is TypeVar (id-b) -> id-a == id-b
     is otherwise -> False
    is IntegerTy -> when b
     is IntegerTy -> True
     is otherwise -> False
    is NumberTy -> when b
     is NumberTy -> True
     is otherwise -> False
    is TextTy -> when b
     is TextTy -> True
     is otherwise -> False
    is BooleanTy -> when b
     is BooleanTy -> True
     is otherwise -> False
    is CharTy -> when b
     is CharTy -> True
     is otherwise -> False
    is NothingTy -> when b
     is NothingTy -> True
     is otherwise -> False
    is VoidTy -> when b
     is VoidTy -> True
     is otherwise -> False
    is ErrorTy -> when b
     is ErrorTy -> True
     is otherwise -> False
    is otherwise -> False

  unify-rhs : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-rhs (st) (a) (b) (span) =
   when b
    is TypeVar (id-b) ->
     if occurs-in st id-b a then UnifyResult {
      success = False,
      state = add-unify-error st cdx-infinite-type "Infinite type" span
     }
      else UnifyResult {
       success = True,
       state = add-subst st id-b a
      }
    is otherwise -> unify-structural st a b span

  unify-structural : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-structural (st) (a) (b) (span) =
   when a
    is IntegerTy -> when b
     is IntegerTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is NumberTy -> when b
     is NumberTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is TextTy -> when b
     is TextTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is BooleanTy -> when b
     is BooleanTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is NothingTy -> when b
     is NothingTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is VoidTy -> when b
     is VoidTy -> UnifyResult {
      success = True,
      state = st
     }
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ErrorTy -> UnifyResult {
     success = True,
     state = st
    }
    is FunTy (pa) (ra) -> when b
     is FunTy (pb) (rb) -> unify-fun st pa ra pb rb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ListTy (ea) -> when b
     is ListTy (eb) -> unify st ea eb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is LinkedListTy (ea) -> when b
     is LinkedListTy (eb) -> unify st ea eb span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ConstructedTy (na) (args-a) -> when b
     is ConstructedTy (nb) (args-b) ->
      if na.value == nb.value then unify-constructed-args st args-a args-b 0 (list-length args-a) span
       else unify-mismatch st a b span
     is SumTy (sb-name) (sb-ctors) ->
      if na.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is RecordTy (rb-name) (rb-fields) ->
      if na.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is SumTy (sa-name) (sa-ctors) -> when b
     is SumTy (sb-name) (sb-ctors) ->
      if sa-name.value == sb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ConstructedTy (nb) (args-b) ->
      if sa-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is RecordTy (ra-name) (ra-fields) -> when b
     is RecordTy (rb-name) (rb-fields) ->
      if ra-name.value == rb-name.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ConstructedTy (nb) (args-b) ->
      if ra-name.value == nb.value then UnifyResult {
       success = True,
       state = st
      }
      else unify-mismatch st a b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span
    is ForAllTy (id) (body) -> unify st body b span
    is EffectfulTy (effs-a) (ret-a) -> when b
     is EffectfulTy (effs-b) (ret-b) -> unify st ret-a ret-b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify st ret-a b span
    is otherwise -> when b
     is EffectfulTy (effs-b) (ret-b) -> unify st a ret-b span
     is ErrorTy -> UnifyResult {
      success = True,
      state = st
     }
     is otherwise -> unify-mismatch st a b span

  unify-constructed-args : UnificationState -> List CodexType -> List CodexType -> Integer -> Integer -> SourceSpan -> UnifyResult
  unify-constructed-args (st) (args-a) (args-b) (i) (len) (span) =
   if i == len then UnifyResult {
    success = True,
    state = st
   }
   else if i >= list-length args-b then UnifyResult {
    success = True,
    state = st
   }
   else let r = unify st (list-at args-a i) (list-at args-b i) span
   in if r.success then unify-constructed-args (r.state) args-a args-b (i + 1) len span
        else r

  unify-fun : UnificationState -> CodexType -> CodexType -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-fun (st) (pa) (ra) (pb) (rb) (span) =
   let r1 = unify st pa pb span
   in if r1.success then unify (r1.state) ra rb span
      else r1

  unify-mismatch : UnificationState -> CodexType -> CodexType -> SourceSpan -> UnifyResult
  unify-mismatch (st) (a) (b) (span) =
   UnifyResult {
    success = False,
    state = add-unify-error st cdx-type-mismatch ("Type mismatch: " ++ type-tag a ++ " vs " ++ type-tag b) span
   }

  type-tag : CodexType -> Text
  type-tag (ty) =
   when ty
    is IntegerTy -> "Integer"
    is NumberTy -> "Number"
    is TextTy -> "Text"
    is BooleanTy -> "Boolean"
    is CharTy -> "Char"
    is VoidTy -> "Void"
    is NothingTy -> "Nothing"
    is ErrorTy -> "Error"
    is FunTy (p) (r) -> "Fun"
    is ListTy (e) -> "List"
    is LinkedListTy (e) -> "LinkedList"
    is TypeVar (id) -> "T" ++ integer-to-text id
    is ForAllTy (id) (body) -> "ForAll"
    is SumTy (name) (ctors) -> "Sum:" ++ name.value
    is RecordTy (name) (fields) -> "Rec:" ++ name.value
    is ConstructedTy (name) (args) -> "Con:" ++ name.value
    is EffectfulTy (effs) (ret) -> "Effectful"

Section: Deep Resolve
  deep-resolve : UnificationState -> CodexType -> CodexType
  deep-resolve (st) (ty) =
   let resolved = resolve st ty
   in when resolved
    is FunTy (param) (ret) -> FunTy (deep-resolve st param) (deep-resolve st ret)
    is ListTy (elem) -> ListTy (deep-resolve st elem)
    is LinkedListTy (elem) -> LinkedListTy (deep-resolve st elem)
    is ConstructedTy (name) (args) -> ConstructedTy name (deep-resolve-list st args 0 (list-length args) [])
    is ForAllTy (id) (body) -> ForAllTy id (deep-resolve st body)
    is EffectfulTy (effs) (ret) -> EffectfulTy effs (deep-resolve st ret)
    is SumTy (name) (ctors) -> resolved
    is RecordTy (name) (fields) -> resolved
    is otherwise -> resolved

  deep-resolve-list : UnificationState -> List CodexType -> Integer -> Integer -> List CodexType -> List CodexType
  deep-resolve-list (st) (args) (i) (len) (acc) =
   if i == len then acc
   else deep-resolve-list st args (i + 1) len (list-snoc acc (deep-resolve st (list-at args i)))

Page 1



Chapter: Main

 Entry point for the Codex compiler.

  cites Emit chapter Codex Emitter (emit-type-defs, emit-def, collect-ctor-names)
  cites Emit chapter X86-64 Code Generator (x86-64-emit-chapter)

Section: Pipeline

  compile-text : Text -> Text -> Text
  compile-text (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0 []
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
   in let ast = desugar-document doc chapter-name
   in let scoped = scope-achapter ast colliding assignments
   in let check-result = check-chapter scoped
   in let ir = lower-chapter scoped (check-result.types) (check-result.state)
   in let ctor-names = collect-ctor-names (scoped.type-defs) 0
   in emit-type-defs (scoped.type-defs) 0 ++ emit-text-defs (ir.defs) ctor-names 0

  emit-text-defs : List IRDef -> List Text -> Integer -> Text
  emit-text-defs (defs) (ctor-names) (i) =
   if i == list-length defs then ""
   else emit-def (list-at defs i) ctor-names ++ "\n" ++ emit-text-defs defs ctor-names (i + 1)

Section: Whitespace Normalization

  normalize-whitespace : Text -> Text
  normalize-whitespace (s) =
   let r = text-replace s "\n\n\n" "\n\n"
   in if text-length r == text-length s then s
      else normalize-whitespace r

Section: Binary Compilation

  compile-to-binary : Text -> Text -> EmitChapterResult
  compile-to-binary (source) (chapter-name) =
   let tokens = tokenize source 1
   in let st = make-parse-state tokens
   in let scan = scan-document st
   in let assignments = build-all-assignments (scan.def-headers) 0 []
   in let colliding = find-colliding-names assignments
   in let doc = parse-document (make-parse-state tokens)
   in let ast = desugar-document doc chapter-name
   in let scoped = scope-achapter ast colliding assignments
   in let cite-bag = check-duplicate-cites (scoped.citations)
   in let check-result = check-chapter scoped
   in let ir = lower-chapter scoped (check-result.types) (check-result.state)
   in let ctor-types = collect-ctor-bindings (scoped.type-defs) 0 (list-length (scoped.type-defs)) []
   in let emit-result = x86-64-emit-chapter ir ctor-types
   in EmitChapterResult {
    bytes = emit-result.bytes,
    bag = bag-merge cite-bag (emit-result.bag)
   }

Section: Codegen Diagnostics

  print-codegen-errors : List Diagnostic -> Integer -> Integer -> [Console] Nothing
  print-codegen-errors (errs) (i) (len) =
   if i == len then print-line ""
   else act
    print-line (diagnostic-display (list-at errs i) empty-file-table)
    print-codegen-errors errs (i + 1) len
   end

  print-codegen-error-header : List Diagnostic -> [Console] Nothing
  print-codegen-error-header (errs) =
   let n = list-length errs
   in if n == 0 then print-line ""
   else act
    print-line ("CODEGEN-ERRORS:" ++ integer-to-text n)
    print-codegen-errors errs 0 n
   end

Section: Entry Point

  emit-binary : Text -> [Console, FileSystem] Nothing
  emit-binary (source) =
   let result = compile-to-binary source "Codex_Codex"
   in act
    print-codegen-error-header (bag-diagnostics (result.bag))
    print-line ("SIZE:" ++ integer-to-text (list-length (result.bytes)))
    write-binary (result.bytes)
   end

  main : [Console, FileSystem] Nothing = act
   mode <- read-line
   source <- read-file mode
   let clean = normalize-whitespace source
   in if mode == "BINARY" then emit-binary clean
      else print-line (compile-text clean "Program")
  end

