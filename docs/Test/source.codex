  emit-bit-op-2 : CodegenState -> List IRExpr -> (Integer -> Integer -> List Integer) -> EmitResult
  emit-bit-op-2 (st) (args) (op-bytes) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let ld0 = load-local (r1.state) (loc0.reg)
   in let rd = alloc-temp (ld0.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-rr (rd.reg) (ld0.reg) ++ op-bytes (rd.reg) (r1.reg)),
    reg = rd.reg
   }

  emit-bit-shift : CodegenState -> List IRExpr -> (Integer -> List Integer) -> EmitResult
  emit-bit-shift (st) (args) (shift-bytes) =
    let r0 = emit-expr (st-set-tail-pos st False) (list-at args 0)
   in let loc0 = alloc-local (r0.state)
   in let st1 = store-local (loc0.state) (loc0.reg) (r0.reg)
   in let r1 = emit-expr st1 (list-at args 1)
   in let st2 = st-append-text (r1.state) (mov-rr reg-rcx (r1.reg))
   in let ld0 = load-local st2 (loc0.reg)
   in let rd = alloc-temp (ld0.state)
   in EmitResult {
    state = st-append-text (rd.state) (mov-rr (rd.reg) (ld0.reg) ++ shift-bytes (rd.reg)),
    reg = rd.reg
