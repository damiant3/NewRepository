   in let thr-ready = st17.text-len
   in let st18 = st-append-text st17 (jcc cc-ne 0)
   in let st19 = st-append-text st18 (jmp (wait-top - (st18.text-len + 5)))
   in let st20 = patch-jcc-at st19 thr-ready (st19.text-len)
