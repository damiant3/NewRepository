Chapter: Types--Codex Types
 Type representations used by the type checker and later stages.

Section: Primitive Types
  CodexType =
   | IntegerTy
   | NumberTy
   | TextTy
   | BooleanTy
   | CharTy
   | VoidTy
   | NothingTy
   | ErrorTy
   | FunTy (CodexType) (CodexType)
   | ListTy (CodexType)
   | LinkedListTy (CodexType)
   | TypeVar (Integer)
   | ForAllTy (Integer) (CodexType)
   | SumTy (Name) (List SumCtor)
   | RecordTy (Name) (List RecordField)
   | ConstructedTy (Name) (List CodexType)
   | EffectfulTy (List Name) (CodexType)

  SumCtor = record {
   name : Name,
   fields : List CodexType
  }

  RecordField = record {
   name : Name,
   type-val : CodexType
  }

Page 1



Chapter: Types--Type Checker
 Bidirectional type checker for Codex.

Section: Resolve Type Expression
  resolve-type-expr : List TypeBinding -> ATypeExpr -> CodexType
  resolve-type-expr (tdm) (texpr) =
   when texpr
    is ANamedType (name) (s) -> resolve-type-name tdm (name.value)
    is AFunType (param) (ret) (s) -> FunTy (resolve-type-expr tdm param) (resolve-type-expr tdm ret)
    is AAppType (ctor) (args) (s) -> resolve-applied-type tdm ctor args
    is AEffectType (effs) (ret) (s) -> EffectfulTy effs (resolve-type-expr tdm ret)

  resolve-applied-type : List TypeBinding -> ATypeExpr -> List ATypeExpr -> CodexType
  resolve-applied-type (tdm) (ctor) (args) =
   when ctor
    is ANamedType (name) (s) ->
     if name.value == "List" then if list-length args == 1 then ListTy (resolve-type-expr tdm (list-at args 0))
       else ListTy ErrorTy
      else if name.value == "LinkedList" then if list-length args == 1 then LinkedListTy (resolve-type-expr tdm (list-at args 0))
       else LinkedListTy ErrorTy
      else ConstructedTy name (resolve-type-expr-list tdm args 0 (list-length args) [])
    is otherwise -> resolve-type-expr tdm ctor

  resolve-type-expr-list : List TypeBinding -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List CodexType
  resolve-type-expr-list (tdm) (args) (i) (len) (acc) =
   if i == len then acc
   else resolve-type-expr-list tdm args (i + 1) len (list-snoc acc (resolve-type-expr tdm (list-at args i)))

  resolve-type-name : List TypeBinding -> Text -> CodexType
  resolve-type-name (tdm) (name) =
   if name == "Integer" then IntegerTy
   else if name == "Number" then NumberTy
   else if name == "Text" then TextTy
   else if name == "Boolean" then BooleanTy
   else if name == "Char" then CharTy
   else if name == "Nothing" then NothingTy
   else lookup-type-def tdm name

  lookup-type-def : List TypeBinding -> Text -> CodexType
  lookup-type-def (tdm) (name) =
   let len = list-length tdm
   in if len == 0 then ConstructedTy (Name { value = name }) []
   else let pos = bsearch-text-pos tdm name 0 len
   in if pos >= len then ConstructedTy (Name { value = name }) []
   else let b = list-at tdm pos
   in if b.name == name then b.bound-type
         else ConstructedTy (Name { value = name }) []

Section: Parameterize Type
  is-value-name : Text -> Boolean
  is-value-name (name) =
   if text-length name == 0 then False
   else let code = char-code (char-at name 0)
   in code >= char-code 'e' & code <= char-code 'z'

  ParamEntry = record {
   param-name : Text,
   var-id : Integer
  }

  ParamResult = record {
   parameterized : CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-type : UnificationState -> CodexType -> ParamResult
  parameterize-type (st) (ty) =
   let r = parameterize-walk st [] ty
   in let wrapped = wrap-forall-from-entries (r.walked) (r.entries) 0 (list-length (r.entries))
   in ParamResult {
    parameterized = wrapped,
    entries = r.entries,
    state = r.state
   }

  wrap-forall-from-entries : CodexType -> List ParamEntry -> Integer -> Integer -> CodexType
  wrap-forall-from-entries (ty) (entries) (i) (len) =
   if i == len then ty
   else let e = list-at entries i
   in ForAllTy (e.var-id) (wrap-forall-from-entries ty entries (i + 1) len)

  WalkResult = record {
   walked : CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-walk : UnificationState -> List ParamEntry -> CodexType -> WalkResult
  parameterize-walk (st) (entries) (ty) =
   when ty
    is ConstructedTy (name) (args) ->
     if list-length args == 0 & is-value-name (name.value)
      then
       let looked = find-param-entry entries (name.value) 0 (list-length entries)
       in if looked >= 0 then WalkResult {
        walked = TypeVar looked,
        entries = entries,
        state = st
       }
       else let fr = fresh-and-advance st
       in when fr.var-type
          is TypeVar (new-id) ->
           let new-entry = ParamEntry {
            param-name = name.value,
            var-id = new-id
           }
       in WalkResult {
            walked = fr.var-type,
            entries = entries ++ [new-entry],
            state = fr.state
           }
          is otherwise -> WalkResult {
           walked = ty,
           entries = entries,
           state = fr.state
          }
      else let args-r = parameterize-walk-list st entries args 0 (list-length args) []
      in WalkResult {
        walked = ConstructedTy name (args-r.walked-list),
        entries = args-r.entries,
        state = args-r.state
       }
    is FunTy (param) (ret) ->
     let pr = parameterize-walk st entries param
     in let rr = parameterize-walk (pr.state) (pr.entries) ret
     in WalkResult {
      walked = FunTy (pr.walked) (rr.walked),
      entries = rr.entries,
      state = rr.state
     }
    is ListTy (elem) ->
     let er = parameterize-walk st entries elem
     in WalkResult {
      walked = ListTy (er.walked),
      entries = er.entries,
      state = er.state
     }
    is LinkedListTy (elem) ->
     let er = parameterize-walk st entries elem
     in WalkResult {
      walked = LinkedListTy (er.walked),
      entries = er.entries,
      state = er.state
     }
    is ForAllTy (id) (body) ->
     let br = parameterize-walk st entries body
     in WalkResult {
      walked = ForAllTy id (br.walked),
      entries = br.entries,
      state = br.state
     }
    is otherwise -> WalkResult {
     walked = ty,
     entries = entries,
     state = st
    }

  find-param-entry : List ParamEntry -> Text -> Integer -> Integer -> Integer
  find-param-entry (entries) (name) (i) (len) =
   if i == len then -1
   else let e = list-at entries i
   in if e.param-name == name then e.var-id
      else find-param-entry entries name (i + 1) len

  WalkListResult = record {
   walked-list : List CodexType,
   entries : List ParamEntry,
   state : UnificationState
  }

  parameterize-walk-list : UnificationState -> List ParamEntry -> List CodexType -> Integer -> Integer -> List CodexType -> WalkListResult
  parameterize-walk-list (st) (entries) (args) (i) (len) (acc) =
   if i == len then WalkListResult {
    walked-list = acc,
    entries = entries,
    state = st
   }
   else let r = parameterize-walk st entries (list-at args i)
   in parameterize-walk-list (r.state) (r.entries) args (i + 1) len (list-snoc acc (r.walked))

Section: Check Definition
  check-def : UnificationState -> TypeEnv -> ADef -> CheckResult
  check-def (st) (env) (def) =
   let declared = resolve-declared-type st env def
   in let env2 = bind-def-params (declared.state) (declared.env) (def.params) (declared.expected-type) 0 (list-length (def.params))
   in let body-r = infer-expr (env2.state) (env2.env) (def.body)
   in let u = unify (body-r.state) (env2.remaining-type) (body-r.inferred-type) (aexpr-span (def.body))
   in CheckResult {
    inferred-type = declared.expected-type,
    state = u.state
   }

  DefSetup = record {
   expected-type : CodexType,
   remaining-type : CodexType,
   state : UnificationState,
   env : TypeEnv
  }

  resolve-declared-type : UnificationState -> TypeEnv -> ADef -> DefSetup
  resolve-declared-type (st) (env) (def) =
   if list-length (def.declared-type) == 0
    then
     let fr = fresh-and-advance st
     in DefSetup {
      expected-type = fr.var-type,
      remaining-type = fr.var-type,
      state = fr.state,
      env = env
     }
    else let env-type = env-lookup env (def.name.value)
    in let inst = instantiate-type st env-type
    in DefSetup {
      expected-type = inst.var-type,
      remaining-type = inst.var-type,
      state = inst.state,
      env = env
     }

  DefParamResult = record {
   state : UnificationState,
   env : TypeEnv,
   remaining-type : CodexType
  }

  bind-def-params : UnificationState -> TypeEnv -> List AParam -> CodexType -> Integer -> Integer -> DefParamResult
  bind-def-params (st) (env) (params) (remaining) (i) (len) =
   if i == len then DefParamResult {
    state = st,
    env = env,
    remaining-type = remaining
   }
   else let p = list-at params i
   in when remaining
     is FunTy (param-ty) (ret-ty) ->
      let env2 = env-bind env (p.name.value) param-ty
   in bind-def-params st env2 params ret-ty (i + 1) len
     is otherwise ->
      let fr = fresh-and-advance st
   in let env2 = env-bind env (p.name.value) (fr.var-type)
   in bind-def-params (fr.state) env2 params remaining (i + 1) len

Section: Check Chapter
  ChapterResult = record {
   types : List TypeBinding,
   state : UnificationState
  }

  check-chapter : AChapter -> ChapterResult
  check-chapter (mod) =
   let tdm = build-type-def-map (mod.type-defs) 0 (list-length (mod.type-defs)) []
   in let tenv = register-type-defs empty-unification-state builtin-type-env tdm (mod.type-defs) 0 (list-length (mod.type-defs))
   in let env = register-all-defs (tenv.state) (tenv.env) tdm (mod.defs) 0 (list-length (mod.defs))
   in check-all-defs (env.state) (env.env) (mod.defs) 0 (list-length (mod.defs)) []

  register-all-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ADef -> Integer -> Integer -> LetBindResult
  register-all-defs (st) (env) (tdm) (defs) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let def = list-at defs i
   in let ty = if list-length (def.declared-type) == 0 then let fr = fresh-and-advance st
   in let env2 = env-bind env (def.name.value) (fr.var-type)
   in LetBindResult {
          state = fr.state,
          env = env2
         }
   else let resolved = resolve-type-expr tdm (list-at (def.declared-type) 0)
   in let pr = parameterize-type st resolved
   in LetBindResult {
          state = pr.state,
          env = env-bind env (def.name.value) (pr.parameterized)
         }
   in register-all-defs (ty.state) (ty.env) tdm defs (i + 1) len

  check-all-defs : UnificationState -> TypeEnv -> List ADef -> Integer -> Integer -> List TypeBinding -> ChapterResult
  check-all-defs (st) (env) (defs) (i) (len) (acc) =
   if i == len then ChapterResult {
    types = acc,
    state = st
   }
   else let def = list-at defs i
   in let r = check-def st env def
   in let resolved = deep-resolve (r.state) (r.inferred-type)
   in let entry = TypeBinding {
    name = def.name.value,
    bound-type = resolved
   }
   in check-all-defs (r.state) env defs (i + 1) len (list-snoc acc entry)

Section: Register Type Definitions
  build-type-def-map : List ATypeDef -> Integer -> Integer -> List TypeBinding -> List TypeBinding
  build-type-def-map (tdefs) (i) (len) (acc) =
   if i == len then acc
   else let td = list-at tdefs i
   in let entry = when td
       is AVariantTypeDef (name) (type-params) (ctors) (s) ->
        let sum-ctors = build-sum-ctors tdefs ctors 0 (list-length ctors) [] acc
   in TypeBinding {
         name = name.value,
         bound-type = SumTy name sum-ctors
        }
       is ARecordTypeDef (name) (type-params) (fields) (s) ->
        let rec-fields = build-record-fields-for-map tdefs fields 0 (list-length fields) [] acc
   in TypeBinding {
         name = name.value,
         bound-type = RecordTy name rec-fields
        }
   in build-type-def-map tdefs (i + 1) len (list-insert-at acc (bsearch-text-pos acc (entry.name) 0 (list-length acc)) entry)

  build-sum-ctors : List ATypeDef -> List AVariantCtorDef -> Integer -> Integer -> List SumCtor -> List TypeBinding -> List SumCtor
  build-sum-ctors (tdefs) (ctors) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else let c = list-at ctors i
   in let field-types = resolve-type-expr-list-for-map tdefs (c.fields) 0 (list-length (c.fields)) [] partial-tdm
   in let sc = SumCtor {
    name = c.name,
    fields = field-types
   }
   in build-sum-ctors tdefs ctors (i + 1) len (list-snoc acc sc) partial-tdm

  build-record-fields-for-map : List ATypeDef -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List TypeBinding -> List RecordField
  build-record-fields-for-map (tdefs) (fields) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else let f = list-at fields i
   in let rfield = RecordField {
    name = f.name,
    type-val = resolve-type-expr partial-tdm (f.type-expr)
   }
   in build-record-fields-for-map tdefs fields (i + 1) len (list-snoc acc rfield) partial-tdm

  resolve-type-expr-list-for-map : List ATypeDef -> List ATypeExpr -> Integer -> Integer -> List CodexType -> List TypeBinding -> List CodexType
  resolve-type-expr-list-for-map (tdefs) (args) (i) (len) (acc) (partial-tdm) =
   if i == len then acc
   else resolve-type-expr-list-for-map tdefs args (i + 1) len (list-snoc acc (resolve-type-expr partial-tdm (list-at args i))) partial-tdm

  register-type-defs : UnificationState -> TypeEnv -> List TypeBinding -> List ATypeDef -> Integer -> Integer -> LetBindResult
  register-type-defs (st) (env) (tdm) (tdefs) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let td = list-at tdefs i
   in let r = register-one-type-def st env tdm td
   in register-type-defs (r.state) (r.env) tdm tdefs (i + 1) len

  register-one-type-def : UnificationState -> TypeEnv -> List TypeBinding -> ATypeDef -> LetBindResult
  register-one-type-def (st) (env) (tdm) (td) =
   when td
    is AVariantTypeDef (name) (type-params) (ctors) (s) ->
     let result-ty = lookup-type-def tdm (name.value)
     in register-variant-ctors st env tdm ctors result-ty 0 (list-length ctors)
    is ARecordTypeDef (name) (type-params) (fields) (s) ->
     let resolved-fields = build-record-fields tdm fields 0 (list-length fields) []
     in let result-ty = RecordTy name resolved-fields
     in let ctor-ty = build-record-ctor-type tdm fields result-ty 0 (list-length fields)
     in let pr = parameterize-type st ctor-ty
     in LetBindResult {
      state = pr.state,
      env = env-bind env (name.value) (pr.parameterized)
     }

  build-record-fields : List TypeBinding -> List ARecordFieldDef -> Integer -> Integer -> List RecordField -> List RecordField
  build-record-fields (tdm) (fields) (i) (len) (acc) =
   if i == len then acc
   else let f = list-at fields i
   in let rfield = RecordField {
    name = f.name,
    type-val = resolve-type-expr tdm (f.type-expr)
   }
   in build-record-fields tdm fields (i + 1) len (list-snoc acc rfield)

  lookup-record-field : List RecordField -> Text -> CodexType
  lookup-record-field (fields) (name) =
   if list-length fields == 0 then ErrorTy
   else let f = list-at fields 0
   in if f.name.value == name then f.type-val
      else lookup-record-field-loop fields name 1 (list-length fields)

  lookup-record-field-loop : List RecordField -> Text -> Integer -> Integer -> CodexType
  lookup-record-field-loop (fields) (name) (i) (len) =
   if i == len then ErrorTy
   else let f = list-at fields i
   in if f.name.value == name then f.type-val
      else lookup-record-field-loop fields name (i + 1) len

  register-variant-ctors : UnificationState -> TypeEnv -> List TypeBinding -> List AVariantCtorDef -> CodexType -> Integer -> Integer -> LetBindResult
  register-variant-ctors (st) (env) (tdm) (ctors) (result-ty) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let ctor = list-at ctors i
   in let ctor-ty = build-ctor-type tdm (ctor.fields) result-ty 0 (list-length (ctor.fields))
   in let pr = parameterize-type st ctor-ty
   in let env2 = env-bind env (ctor.name.value) (pr.parameterized)
   in register-variant-ctors (pr.state) env2 tdm ctors result-ty (i + 1) len

  build-ctor-type : List TypeBinding -> List ATypeExpr -> CodexType -> Integer -> Integer -> CodexType
  build-ctor-type (tdm) (fields) (result) (i) (len) =
   if i == len then result
   else let rest = build-ctor-type tdm fields result (i + 1) len
   in FunTy (resolve-type-expr tdm (list-at fields i)) rest

  build-record-ctor-type : List TypeBinding -> List ARecordFieldDef -> CodexType -> Integer -> Integer -> CodexType
  build-record-ctor-type (tdm) (fields) (result) (i) (len) =
   if i == len then result
   else let f = list-at fields i
   in let rest = build-record-ctor-type tdm fields result (i + 1) len
   in FunTy (resolve-type-expr tdm (f.type-expr)) rest

Page 1 of 2



Chapter: Types--Type Checker
 Expression type inference dispatch.

Section: Check Result
  CheckResult = record {
   inferred-type : CodexType,
   state : UnificationState
  }

Section: Infer Literal
  infer-literal : UnificationState -> LiteralKind -> CheckResult
  infer-literal (st) (kind) =
   when kind
    is IntLit -> CheckResult {
     inferred-type = IntegerTy,
     state = st
    }
    is NumLit -> CheckResult {
     inferred-type = NumberTy,
     state = st
    }
    is TextLit -> CheckResult {
     inferred-type = TextTy,
     state = st
    }
    is CharLit -> CheckResult {
     inferred-type = CharTy,
     state = st
    }
    is BoolLit -> CheckResult {
     inferred-type = BooleanTy,
     state = st
    }

Section: Infer Name
  infer-name : UnificationState -> TypeEnv -> Text -> SourceSpan -> CheckResult
  infer-name (st) (env) (name) (span) =
   if env-has env name
    then
     let raw = env-lookup env name
     in let inst = instantiate-type st raw
     in CheckResult {
      inferred-type = inst.var-type,
      state = inst.state
     }
    else CheckResult {
     inferred-type = ErrorTy,
     state = add-unify-error st cdx-unknown-name ("Unknown name: " ++ name) span
    }

  instantiate-type : UnificationState -> CodexType -> FreshResult
  instantiate-type (st) (ty) =
   when ty
    is ForAllTy (var-id) (body) ->
     let fr = fresh-and-advance st
     in let substituted = subst-type-var body var-id (fr.var-type)
     in instantiate-type (fr.state) substituted
    is otherwise -> FreshResult {
     var-type = ty,
     state = st
    }

  subst-type-var : CodexType -> Integer -> CodexType -> CodexType
  subst-type-var (ty) (var-id) (replacement) =
   when ty
    is TypeVar (id) -> if id == var-id then replacement else ty
    is FunTy (param) (ret) -> FunTy (subst-type-var param var-id replacement) (subst-type-var ret var-id replacement)
    is ListTy (elem) -> ListTy (subst-type-var elem var-id replacement)
    is LinkedListTy (elem) -> LinkedListTy (subst-type-var elem var-id replacement)
    is ForAllTy (inner-id) (body) ->
     if inner-id == var-id then ty
     else ForAllTy inner-id (subst-type-var body var-id replacement)
    is ConstructedTy (name) (args) -> ConstructedTy name (map-subst-type-var args var-id replacement 0 (list-length args) [])
    is SumTy (name) (ctors) -> ty
    is RecordTy (name) (fields) -> ty
    is otherwise -> ty

  map-subst-type-var : List CodexType -> Integer -> CodexType -> Integer -> Integer -> List CodexType -> List CodexType
  map-subst-type-var (args) (var-id) (replacement) (i) (len) (acc) =
   if i == len then acc
   else map-subst-type-var args var-id replacement (i + 1) len (list-snoc acc (subst-type-var (list-at args i) var-id replacement))

Section: Infer Binary
  infer-binary : UnificationState -> TypeEnv -> AExpr -> BinaryOp -> AExpr -> SourceSpan -> CheckResult
  infer-binary (st) (env) (left) (op) (right) (span) =
   let lr = infer-expr st env left
   in let rr = infer-expr (lr.state) env right
   in infer-binary-op (rr.state) (lr.inferred-type) (rr.inferred-type) op span

  infer-binary-op : UnificationState -> CodexType -> CodexType -> BinaryOp -> SourceSpan -> CheckResult
  infer-binary-op (st) (lt) (rt) (op) (span) =
   when op
    is OpAdd -> infer-arithmetic st lt rt span
    is OpSub -> infer-arithmetic st lt rt span
    is OpMul -> infer-arithmetic st lt rt span
    is OpDiv -> infer-arithmetic st lt rt span
    is OpPow -> infer-arithmetic st lt rt span
    is OpEq -> infer-comparison st lt rt span
    is OpNotEq -> infer-comparison st lt rt span
    is OpLt -> infer-comparison st lt rt span
    is OpGt -> infer-comparison st lt rt span
    is OpLtEq -> infer-comparison st lt rt span
    is OpGtEq -> infer-comparison st lt rt span
    is OpAnd -> infer-logical st lt rt span
    is OpOr -> infer-logical st lt rt span
    is OpAppend -> infer-append st lt rt span
    is OpCons -> infer-cons st lt rt span
    is OpDefEq -> infer-comparison st lt rt span

  infer-arithmetic : UnificationState -> CodexType -> CodexType -> SourceSpan -> CheckResult
  infer-arithmetic (st) (lt) (rt) (span) =
   let r = unify st lt rt span
   in CheckResult {
    inferred-type = lt,
    state = r.state
   }

  infer-comparison : UnificationState -> CodexType -> CodexType -> SourceSpan -> CheckResult
  infer-comparison (st) (lt) (rt) (span) =
   let r = unify st lt rt span
   in CheckResult {
    inferred-type = BooleanTy,
    state = r.state
   }

  infer-logical : UnificationState -> CodexType -> CodexType -> SourceSpan -> CheckResult
  infer-logical (st) (lt) (rt) (span) =
   let r1 = unify st lt BooleanTy span
   in let r2 = unify (r1.state) rt BooleanTy span
   in CheckResult {
    inferred-type = BooleanTy,
    state = r2.state
   }

  infer-append : UnificationState -> CodexType -> CodexType -> SourceSpan -> CheckResult
  infer-append (st) (lt) (rt) (span) =
   let resolved = resolve st lt
   in when resolved
    is TextTy ->
     let r = unify st rt TextTy span
   in CheckResult {
      inferred-type = TextTy,
      state = r.state
     }
    is otherwise ->
     let r = unify st lt rt span
   in CheckResult {
      inferred-type = lt,
      state = r.state
     }

  infer-cons : UnificationState -> CodexType -> CodexType -> SourceSpan -> CheckResult
  infer-cons (st) (lt) (rt) (span) =
   let list-ty = ListTy lt
   in let r = unify st rt list-ty span
   in CheckResult {
    inferred-type = list-ty,
    state = r.state
   }

Section: Infer If
  infer-if : UnificationState -> TypeEnv -> AExpr -> AExpr -> AExpr -> SourceSpan -> CheckResult
  infer-if (st) (env) (cond) (then-e) (else-e) (span) =
   let cr = infer-expr st env cond
   in let r1 = unify (cr.state) (cr.inferred-type) BooleanTy (aexpr-span cond)
   in let tr = infer-expr (r1.state) env then-e
   in let er = infer-expr (tr.state) env else-e
   in let r2 = unify (er.state) (tr.inferred-type) (er.inferred-type) span
   in CheckResult {
    inferred-type = tr.inferred-type,
    state = r2.state
   }

Section: Infer Let
  infer-let : UnificationState -> TypeEnv -> List ALetBind -> AExpr -> CheckResult
  infer-let (st) (env) (bindings) (body) =
   let env2 = infer-let-bindings st env bindings 0 (list-length bindings)
   in infer-expr (env2.state) (env2.env) body

  LetBindResult = record {
   state : UnificationState,
   env : TypeEnv
  }

  infer-let-bindings : UnificationState -> TypeEnv -> List ALetBind -> Integer -> Integer -> LetBindResult
  infer-let-bindings (st) (env) (bindings) (i) (len) =
   if i == len then LetBindResult {
    state = st,
    env = env
   }
   else let b = list-at bindings i
   in let vr = infer-expr st env (b.value)
   in let bound-ty = unwrap-effectful-or-error (vr.inferred-type) (b.name.value) (aexpr-span (b.value)) (vr.state)
   in let env2 = env-bind env (b.name.value) (bound-ty.ty)
   in infer-let-bindings (bound-ty.state) env2 bindings (i + 1) len

  UnwrapResult = record {
   ty : CodexType,
   state : UnificationState
  }

  unwrap-effectful-or-error : CodexType -> Text -> SourceSpan -> UnificationState -> UnwrapResult
  unwrap-effectful-or-error (ty) (name) (span) (st) =
   when ty
    is EffectfulTy (effs) (inner) ->
     if list-length effs == 0 then UnwrapResult { ty = ty, state = st }
     else UnwrapResult {
      ty = inner,
      state = add-unify-error st cdx-let-binds-effectful-value ("let-binding '" ++ name ++ "' to an effectful value is not allowed outside an act-bind. Use '" ++ name ++ " <- ...' inside an act block.") span
     }
    is otherwise -> UnwrapResult { ty = ty, state = st }

Section: Infer Lambda
  infer-lambda : UnificationState -> TypeEnv -> List Name -> AExpr -> CheckResult
  infer-lambda (st) (env) (params) (body) =
   let pr = bind-lambda-params st env params 0 (list-length params) []
   in let br = infer-expr (pr.state) (pr.env) body
   in let fun-ty = wrap-fun-type (pr.param-types) (br.inferred-type)
   in CheckResult {
    inferred-type = fun-ty,
    state = br.state
   }

  LambdaBindResult = record {
   state : UnificationState,
   env : TypeEnv,
   param-types : List CodexType
  }

  bind-lambda-params : UnificationState -> TypeEnv -> List Name -> Integer -> Integer -> List CodexType -> LambdaBindResult
  bind-lambda-params (st) (env) (params) (i) (len) (acc) =
   if i == len then LambdaBindResult {
    state = st,
    env = env,
    param-types = acc
   }
   else let p = list-at params i
   in let fr = fresh-and-advance st
   in let env2 = env-bind env (p.value) (fr.var-type)
   in bind-lambda-params (fr.state) env2 params (i + 1) len (list-snoc acc (fr.var-type))

  wrap-fun-type : List CodexType -> CodexType -> CodexType
  wrap-fun-type (param-types) (result) =
   wrap-fun-type-loop param-types result (list-length param-types - 1)

  wrap-fun-type-loop : List CodexType -> CodexType -> Integer -> CodexType
  wrap-fun-type-loop (param-types) (result) (i) =
   if i < 0 then result
   else wrap-fun-type-loop param-types (FunTy (list-at param-types i) result) (i - 1)

Section: Infer Application
  infer-application : UnificationState -> TypeEnv -> AExpr -> AExpr -> SourceSpan -> CheckResult
  infer-application (st) (env) (func) (arg) (span) =
   let fr = infer-expr st env func
   in let ar = infer-expr (fr.state) env arg
   in let ret = fresh-and-advance (ar.state)
   in let r = unify (ret.state) (fr.inferred-type) (FunTy (ar.inferred-type) (ret.var-type)) span
   in CheckResult {
    inferred-type = ret.var-type,
    state = r.state
   }

Section: Infer List
  infer-list : UnificationState -> TypeEnv -> List AExpr -> CheckResult
  infer-list (st) (env) (elems) =
   if list-length elems == 0
    then
     let fr = fresh-and-advance st
     in CheckResult {
      inferred-type = ListTy (fr.var-type),
      state = fr.state
     }
    else let first = infer-expr st env (list-at elems 0)
    in let st2 = unify-list-elems (first.state) env elems (first.inferred-type) 1 (list-length elems)
    in CheckResult {
      inferred-type = ListTy (first.inferred-type),
      state = st2
     }

  unify-list-elems : UnificationState -> TypeEnv -> List AExpr -> CodexType -> Integer -> Integer -> UnificationState
  unify-list-elems (st) (env) (elems) (elem-ty) (i) (len) =
   if i == len then st
   else let e = list-at elems i
   in let er = infer-expr st env e
   in let r = unify (er.state) (er.inferred-type) elem-ty (aexpr-span e)
   in unify-list-elems (r.state) env elems elem-ty (i + 1) len

Section: Infer Match
  infer-match : UnificationState -> TypeEnv -> AExpr -> List AMatchArm -> CheckResult
  infer-match (st) (env) (scrutinee) (arms) =
   let sr = infer-expr st env scrutinee
   in let fr = fresh-and-advance (sr.state)
   in let st2 = infer-match-arms (fr.state) env (sr.inferred-type) (fr.var-type) arms 0 (list-length arms)
   in CheckResult {
    inferred-type = fr.var-type,
    state = st2
   }

  infer-match-arms : UnificationState -> TypeEnv -> CodexType -> CodexType -> List AMatchArm -> Integer -> Integer -> UnificationState
  infer-match-arms (st) (env) (scrut-ty) (result-ty) (arms) (i) (len) =
   if i == len then st
   else let arm = list-at arms i
   in let pr = bind-pattern st env (arm.pattern) scrut-ty
   in let br = infer-expr (pr.state) (pr.env) (arm.body)
   in let r = unify (br.state) (br.inferred-type) result-ty (aexpr-span (arm.body))
   in infer-match-arms (r.state) env scrut-ty result-ty arms (i + 1) len

  PatBindResult = record {
   state : UnificationState,
   env : TypeEnv
  }

  bind-pattern : UnificationState -> TypeEnv -> APat -> CodexType -> PatBindResult
  bind-pattern (st) (env) (pat) (ty) =
   when pat
    is AVarPat (name) (s) -> PatBindResult {
     state = st,
     env = env-bind env (name.value) ty
    }
    is AWildPat (s) -> PatBindResult {
     state = st,
     env = env
    }
    is ALitPat (val) (kind) (s) -> PatBindResult {
     state = st,
     env = env
    }
    is ACtorPat (ctor-name) (sub-pats) (s) ->
     let ctor-lookup = instantiate-type st (env-lookup env (ctor-name.value))
     in bind-ctor-sub-patterns (ctor-lookup.state) env sub-pats (ctor-lookup.var-type) 0 (list-length sub-pats)

  bind-ctor-sub-patterns : UnificationState -> TypeEnv -> List APat -> CodexType -> Integer -> Integer -> PatBindResult
  bind-ctor-sub-patterns (st) (env) (sub-pats) (ctor-ty) (i) (len) =
   if i == len then PatBindResult {
    state = st,
    env = env
   }
   else when ctor-ty
     is FunTy (param-ty) (ret-ty) ->
      let pr = bind-pattern st env (list-at sub-pats i) param-ty
      in bind-ctor-sub-patterns (pr.state) (pr.env) sub-pats ret-ty (i + 1) len
     is otherwise ->
      let fr = fresh-and-advance st
      in let pr = bind-pattern (fr.state) env (list-at sub-pats i) (fr.var-type)
      in bind-ctor-sub-patterns (pr.state) (pr.env) sub-pats ctor-ty (i + 1) len

Section: Infer Act
  infer-act : UnificationState -> TypeEnv -> List AActStmt -> CheckResult
  infer-act (st) (env) (stmts) =
   infer-act-loop st env stmts 0 (list-length stmts) NothingTy

  infer-act-loop : UnificationState -> TypeEnv -> List AActStmt -> Integer -> Integer -> CodexType -> CheckResult
  infer-act-loop (st) (env) (stmts) (i) (len) (last-ty) =
   if i == len then CheckResult {
    inferred-type = last-ty,
    state = st
   }
   else let stmt = list-at stmts i
   in when stmt
     is AActExprStmt (e) (s) ->
      let er = infer-expr st env e
   in infer-act-loop (er.state) env stmts (i + 1) len (er.inferred-type)
     is AActBindStmt (name) (e) (s) ->
      let er = infer-expr st env e
   in let env2 = env-bind env (name.value) (er.inferred-type)
   in infer-act-loop (er.state) env2 stmts (i + 1) len (er.inferred-type)

Section: Infer Expression (dispatch)
  infer-expr : UnificationState -> TypeEnv -> AExpr -> CheckResult
  infer-expr (st) (env) (expr) =
   when expr
    is ALitExpr (val) (kind) (s) -> infer-literal st kind
    is ANameExpr (name) (s) -> infer-name st env (name.value) s
    is ABinaryExpr (left) (op) (right) (s) -> infer-binary st env left op right s
    is AUnaryExpr (operand) (s) ->
     let r = infer-expr st env operand
     in let u = unify (r.state) (r.inferred-type) IntegerTy (aexpr-span operand)
     in CheckResult {
      inferred-type = IntegerTy,
      state = u.state
     }
    is AApplyExpr (func) (arg) (s) -> infer-application st env func arg s
    is AIfExpr (cond) (then-e) (else-e) (s) -> infer-if st env cond then-e else-e s
    is ALetExpr (bindings) (body) (s) -> infer-let st env bindings body
    is ALambdaExpr (params) (body) (s) -> infer-lambda st env params body
    is AMatchExpr (scrutinee) (arms) (s) -> infer-match st env scrutinee arms
    is AListExpr (elems) (s) -> infer-list st env elems
    is AActExpr (stmts) (s) -> infer-act st env stmts
    is AFieldAccess (obj) (field) (s) ->
     let r = infer-expr st env obj
     in let resolved = deep-resolve (r.state) (r.inferred-type)
     in when resolved
      is RecordTy (rname) (rfields) ->
       let ftype = lookup-record-field rfields (field.value)
     in CheckResult {
        inferred-type = ftype,
        state = r.state
       }
      is ConstructedTy (cname) (cargs) ->
       let record-type = resolve-constructed-to-record env (cname.value)
     in when record-type
        is RecordTy (rname) (rfields) ->
         let ftype = lookup-record-field rfields (field.value)
     in CheckResult {
          inferred-type = ftype,
          state = r.state
         }
        is otherwise ->
         let fr = fresh-and-advance (r.state)
     in CheckResult {
          inferred-type = fr.var-type,
          state = fr.state
         }
      is otherwise ->
       let fr = fresh-and-advance (r.state)
     in CheckResult {
        inferred-type = fr.var-type,
        state = fr.state
       }

    is ARecordExpr (name) (fields) (s) ->
     let st2 = infer-record-fields st env fields 0 (list-length fields)
     in let ctor-type = if env-has env (name.value) then env-lookup env (name.value) else ErrorTy
     in let result-type = strip-fun-args ctor-type
     in CheckResult {
      inferred-type = result-type,
      state = st2
     }
    is AErrorExpr (msg) (s) -> CheckResult {
     inferred-type = ErrorTy,
     state = st
    }

  resolve-constructed-to-record : TypeEnv -> Text -> CodexType
  resolve-constructed-to-record (env) (name) =
   if env-has env name then strip-fun-args (env-lookup env name)
   else ErrorTy

  infer-record-fields : UnificationState -> TypeEnv -> List AFieldExpr -> Integer -> Integer -> UnificationState
  infer-record-fields (st) (env) (fields) (i) (len) =
   if i == len then st
   else let f = list-at fields i
   in let r = infer-expr st env (f.value)
   in infer-record-fields (r.state) env fields (i + 1) len

  strip-fun-args : CodexType -> CodexType
  strip-fun-args (ty) =
   when ty
    is FunTy (p) (r) -> strip-fun-args r
    is otherwise -> ty

Page 2 of 2



Chapter: Types--Type Environment
 An immutable mapping from names to types.

Section: Environment Type
  TypeEnv = record {
   bindings : List TypeBinding
  }

  TypeBinding = record {
   name : Text,
   bound-type : CodexType
  }

Section: Construction
  empty-type-env : TypeEnv = TypeEnv { bindings = [] }

Section: Lookup (binary search on sorted bindings)
  env-lookup : TypeEnv -> Text -> CodexType
  env-lookup (env) (name) =
   let len = list-length (env.bindings)
   in if len == 0 then ErrorTy
   else let pos = bsearch-text-pos (env.bindings) name 0 len
   in if pos >= len then ErrorTy
   else let b = list-at (env.bindings) pos
   in if b.name == name then b.bound-type else ErrorTy

  env-has : TypeEnv -> Text -> Boolean
  env-has (env) (name) =
   let len = list-length (env.bindings)
   in if len == 0 then False
   else let pos = bsearch-text-pos (env.bindings) name 0 len
   in if pos >= len then False
      else (list-at (env.bindings) pos).name == name

Section: Bind (sorted insert via list-insert-at)
  env-bind : TypeEnv -> Text -> CodexType -> TypeEnv
  env-bind (env) (name) (ty) =
   let len = list-length (env.bindings)
   in let pos = bsearch-text-pos (env.bindings) name 0 len
   in TypeEnv { bindings = list-insert-at (env.bindings) pos (TypeBinding {
    name = name,
    bound-type = ty
   }) }

Section: Builtins
  builtin-type-env : TypeEnv
  builtin-type-env =
   let e = empty-type-env
   in let e2 = env-bind e "negate" (FunTy IntegerTy IntegerTy)
   in let e3 = env-bind e2 "text-length" (FunTy TextTy IntegerTy)
