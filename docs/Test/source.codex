   in let st4 = st-append-text st3 (push-r reg-r11)
   in let st5 = st-append-text st4 (mov-rr reg-rbx reg-rdi)
   in let st6 = st-append-text st5 (mov-load reg-rcx reg-rbx 0)
   in let st7 = st-append-text st6 (li reg-r11 0)
   in let loop-top = st7.text-len
   in let st8 = st-append-text st7 (cmp-rr reg-r11 reg-rcx)
   in let done-pos = st8.text-len
   in let st9 = st-append-text st8 (jcc cc-ge 0)
   in let st10 = st-append-text st9 (mov-rr reg-rax reg-r11)
   in let st11 = st-append-text st10 (shl-ri reg-rax 3)
   in let st12 = st-append-text st11 (add-rr reg-rax reg-rbx)
   in let st13 = st-append-text st12 (mov-load reg-rax reg-rax 8)
   in let st14 = st-append-text st13 (push-r reg-rax)
   in let wait-top = st14.text-len
   in let st15 = st-append-text st14 (li reg-rdx 1021)
   in let st16 = st-append-text st15 [236]
