cites Maybe


text-contains : Text -> Text -> Boolean
text-contains (haystack) (needle) =
  if text-length needle == 0 then True
  else if text-length needle > text-length haystack then False
  else text-contains-loop haystack needle 0 (text-length haystack - text-length needle + 1)

text-contains-loop : Text -> Text -> Integer -> Integer -> Boolean
text-contains-loop (haystack) (needle) (i) (limit) =
  if i == limit then False
  else if text-matches-at haystack needle i then True
  else text-contains-loop haystack needle (i + 1) limit

text-matches-at : Text -> Text -> Integer -> Boolean
text-matches-at (haystack) (needle) (start) =
  if start + text-length needle > text-length haystack then False
  else text-matches-at-loop haystack needle start 0 (text-length needle)

text-matches-at-loop : Text -> Text -> Integer -> Integer -> Integer -> Boolean
text-matches-at-loop (haystack) (needle) (start) (i) (len) =
  if i == len then True
  else if char-at haystack (start + i) == char-at needle i
    then text-matches-at-loop haystack needle start (i + 1) len
  else False

starts-with : Text -> Text -> Boolean
starts-with (s) (prefix) =
  if text-length prefix > text-length s then False
  else text-matches-at s prefix 0

ends-with : Text -> Text -> Boolean
ends-with (s) (suffix) =
  if text-length suffix > text-length s then False
  else text-matches-at s suffix (text-length s - text-length suffix)

index-of : Text -> Text -> Maybe Integer
index-of (haystack) (needle) =
  if text-length needle == 0 then Just 0
  else if text-length needle > text-length haystack then None
  else index-of-loop haystack needle 0 (text-length haystack - text-length needle + 1)

index-of-loop : Text -> Text -> Integer -> Integer -> Maybe Integer
index-of-loop (haystack) (needle) (i) (limit) =
  if i == limit then None
  else if text-matches-at haystack needle i then Just i
  else index-of-loop haystack needle (i + 1) limit

text-split : Text -> Text -> List Text
text-split (s) (sep) =
  if text-length sep == 0 then [s]
  else text-split-loop s sep 0 0 []

text-split-loop : Text -> Text -> Integer -> Integer -> List Text -> List Text
text-split-loop (s) (sep) (start) (i) (acc) =
  if i > text-length s - text-length sep
    then acc ++ [substring s start (text-length s - start)]
  else if text-matches-at s sep i
    then text-split-loop s sep (i + text-length sep) (i + text-length sep) (acc ++ [substring s start (i - start)])
  else text-split-loop s sep start (i + 1) acc

text-join : Text -> List Text -> Text
text-join (sep) (parts) = text-join-loop sep parts 0 (list-length parts) ""

text-join-loop : Text -> List Text -> Integer -> Integer -> Text -> Text
text-join-loop (sep) (parts) (i) (len) (acc) =
  if i == len then acc
  else if i == 0 then text-join-loop sep parts 1 len (list-at parts 0)
  else text-join-loop sep parts (i + 1) len (acc ++ sep ++ list-at parts i)

text-trim : Text -> Text
text-trim (s) =
  let start = text-trim-start-index s 0 (text-length s)
  in let end = text-trim-end-index s (text-length s - 1)
  in if start > end then ""
  else substring s start (end - start + 1)

text-trim-start-index : Text -> Integer -> Integer -> Integer
text-trim-start-index (s) (i) (len) =
  if i == len then i
  else if is-whitespace (char-at s i) then text-trim-start-index s (i + 1) len
  else i

text-trim-end-index : Text -> Integer -> Integer
text-trim-end-index (s) (i) =
  if i < 0 then i
  else if is-whitespace (char-at s i) then text-trim-end-index s (i - 1)
  else i

text-repeat : Text -> Integer -> Text
text-repeat (s) (n) = text-repeat-loop s n ""

text-repeat-loop : Text -> Integer -> Text -> Text
text-repeat-loop (s) (n) (acc) =
  if n <= 0 then acc
  else text-repeat-loop s (n - 1) (acc ++ s)

text-to-upper : Text -> Text
text-to-upper (s) = text-map-chars s to-upper-char 0 (text-length s) ""

text-to-lower : Text -> Text
text-to-lower (s) = text-map-chars s to-lower-char 0 (text-length s) ""

text-map-chars : Text -> (Text -> Text) -> Integer -> Integer -> Text -> Text
text-map-chars (s) (f) (i) (len) (acc) =
  if i == len then acc
  else text-map-chars s f (i + 1) len (acc ++ f (char-at s i))

to-upper-char : Text -> Text
to-upper-char (c) =
  let code = char-code c
  in if code >= 97 & code <= 122 then code-to-char (code - 32)
  else c

to-lower-char : Text -> Text
to-lower-char (c) =
  let code = char-code c
  in if code >= 65 & code <= 90 then code-to-char (code + 32)
  else c

text-pad-left : Text -> Integer -> Text -> Text
text-pad-left (s) (target-len) (pad) =
  if text-length s >= target-len then s
  else text-pad-left (pad ++ s) target-len pad

text-pad-right : Text -> Integer -> Text -> Text
text-pad-right (s) (target-len) (pad) =
  if text-length s >= target-len then s
  else text-pad-right (s ++ pad) target-len pad

count-occurrences : Text -> Text -> Integer
count-occurrences (haystack) (needle) =
  if text-length needle == 0 then 0
  else count-occurrences-loop haystack needle 0 0

count-occurrences-loop : Text -> Text -> Integer -> Integer -> Integer
count-occurrences-loop (haystack) (needle) (i) (count) =
  if i > text-length haystack - text-length needle then count
  else if text-matches-at haystack needle i
    then count-occurrences-loop haystack needle (i + text-length needle) (count + 1)
  else count-occurrences-loop haystack needle (i + 1) count
