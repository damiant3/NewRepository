cites Maybe


Queue a = record {
  front : List a,
  back : List a
}

queue-empty : Queue a
queue-empty = Queue { front = [], back = [] }

queue-is-empty : Queue a -> Boolean
queue-is-empty (q) = list-length q.front == 0 & list-length q.back == 0

queue-size : Queue a -> Integer
queue-size (q) = list-length q.front + list-length q.back

queue-enqueue : Queue a -> a -> Queue a
queue-enqueue (q) (x) = Queue { front = q.front, back = [x] ++ q.back }

queue-dequeue : Queue a -> Maybe (DequeueResult a)
queue-dequeue (q) =
  if list-length q.front > 0
    then Just (DequeueResult { value = list-at q.front 0, rest = Queue { front = list-tail q.front, back = q.back } })
  else if list-length q.back > 0
    then let reversed = reverse-list q.back 0 (list-length q.back) []
      in Just (DequeueResult { value = list-at reversed 0, rest = Queue { front = list-tail reversed, back = [] } })
  else None

DequeueResult a = record {
  value : a,
  rest : Queue a
}

queue-peek : Queue a -> Maybe a
queue-peek (q) =
  if list-length q.front > 0 then Just (list-at q.front 0)
  else if list-length q.back > 0
    then Just (list-at q.back (list-length q.back - 1))
  else None

queue-from-list : List a -> Queue a
queue-from-list (xs) = Queue { front = xs, back = [] }

queue-to-list : Queue a -> List a
queue-to-list (q) = q.front ++ reverse-list q.back 0 (list-length q.back) []

reverse-list : List a -> Integer -> Integer -> List a -> List a
reverse-list (xs) (i) (len) (acc) =
  if i == len then acc
  else reverse-list xs (i + 1) len ([list-at xs i] ++ acc)
