unicode-to-cce-tier0 : Integer -> Integer
unicode-to-cce-tier0 (u) =
  if u == 0 then 0
  else if u == 10 then 1
  else if u == 13 then 2
  else if u == 9 then 3
  else if u == 32 then 4
  else if u == 160 then 5
  else if u == 8201 then 6
  else if u == 8239 then 7
  else if (if u >= 48 then u <= 57 else False) then u - 40
  else if u == 101 then 18
  else if u == 116 then 19
