CCEClass =
  | CCEWhitespace
  | CCEDigit
  | CCELower
  | CCEUpper
  | CCEPunct
  | CCEAccented
  | CCECyrillic
  | CCEOther

is-cce-whitespace : Integer -> Boolean
is-cce-whitespace (b) = b <= 7

is-cce-digit : Integer -> Boolean
is-cce-digit (b) = if b >= 8 then b <= 17 else False

cce-digit-value : Integer -> Integer
cce-digit-value (b) = b - 8

is-cce-lower : Integer -> Boolean
is-cce-lower (b) = if b >= 18 then b <= 43 else False

is-cce-upper : Integer -> Boolean
is-cce-upper (b) = if b >= 44 then b <= 69 else False

is-cce-letter : Integer -> Boolean
is-cce-letter (b) = if b >= 18 then b <= 69 else False

is-cce-punct : Integer -> Boolean
is-cce-punct (b) = if b >= 70 then b <= 89 else False

is-cce-accented : Integer -> Boolean
is-cce-accented (b) = if b >= 90 then b <= 111 else False

is-cce-cyrillic : Integer -> Boolean
is-cce-cyrillic (b) = if b >= 112 then b <= 127 else False

cce-to-lower : Integer -> Integer
cce-to-lower (b) = if is-cce-upper b then b - 26 else b

cce-to-upper : Integer -> Integer
cce-to-upper (b) = if is-cce-lower b then b + 26 else b

cce-classify : Integer -> CCEClass
cce-classify (b) =
  if b <= 7 then CCEWhitespace
  else if b <= 17 then CCEDigit
  else if b <= 43 then CCELower
  else if b <= 69 then CCEUpper
  else if b <= 89 then CCEPunct
  else if b <= 111 then CCEAccented
  else if b <= 127 then CCECyrillic
  else CCEOther

cce-to-unicode : Integer -> Integer
cce-to-unicode (b) =
  if b == 0 then 0
  else if b == 1 then 10
  else if b == 2 then 13
  else if b == 3 then 9
  else if b == 4 then 32
  else if b == 5 then 160
  else if b == 6 then 8201
  else if b == 7 then 8239
  else if is-cce-digit b then b + 40
  else if b == 18 then 101
  else if b == 19 then 116
  else if b == 20 then 97
  else if b == 21 then 111
  else if b == 22 then 105
