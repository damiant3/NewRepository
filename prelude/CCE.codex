cce-class-name : CCEClass -> Text
cce-class-name (c) = when c
  if CCEWhitespace -> "whitespace"
  if CCEDigit -> "digit"
  if CCELower -> "lowercase"
  if CCEUpper -> "uppercase"
  if CCEPunct -> "punctuation"
  if CCEAccented -> "accented"
  if CCECyrillic -> "cyrillic"
  if CCEOther -> "other"

test-roundtrip : Integer -> Integer -> Text
test-roundtrip (cce) (max) =
  if cce > max then "PASS (128/128)"
  else let uni = cce-to-unicode cce
    in let back = unicode-to-cce-tier0 uni
    in if back == cce then test-roundtrip (cce + 1) max
      else "FAIL at cce=" ++ show cce ++ " uni=" ++ show uni ++ " back=" ++ show back

test-classify : Integer -> Text
test-classify (b) =
  let cls = cce-classify b
  in let name = cce-class-name cls
  in let uni = cce-to-unicode b
  in let ch = code-to-char uni
  in "  cce " ++ show b ++ " -> U+" ++ show uni ++ " '" ++ ch ++ "' [" ++ name ++ "]"

main : [Console] Nothing
main = do
  print-line "=== Codex Character Encoding — Tier 0 ==="
  print-line ""
  print-line "Classification (single comparison, no table lookup):"
  print-line ("  is-cce-whitespace 4  = " ++ show (is-cce-whitespace 4))
  print-line ("  is-cce-digit 12      = " ++ show (is-cce-digit 12))
  print-line ("  cce-digit-value 12   = " ++ show (cce-digit-value 12))
  print-line ("  is-cce-letter 18     = " ++ show (is-cce-letter 18))
  print-line ("  is-cce-letter 44     = " ++ show (is-cce-letter 44))
  print-line ("  is-cce-letter 70     = " ++ show (is-cce-letter 70))
  print-line ""
  print-line "Case conversion (arithmetic, no table):"
  print-line ("  cce-to-upper 18 = " ++ show (cce-to-upper 18))
  print-line ("  cce-to-lower 44 = " ++ show (cce-to-lower 44))
  print-line ""
  print-line "Sample mappings:"
  print-line (test-classify 4)
  print-line (test-classify 12)
  print-line (test-classify 18)
  print-line (test-classify 44)
  print-line (test-classify 70)
  print-line (test-classify 90)
  print-line (test-classify 112)
  print-line ""
  print-line ("Roundtrip (all 128 Tier 0): " ++ test-roundtrip 0 127)
