Chapter: Parser

  The parser transforms a flat token list into a concrete syntax tree.
  It is a recursive descent parser threading state through pure functions.

  Rule: no when-expression may contain another when-expression in a
  non-final branch body, because the Stage 0 parser greedily consumes
  if-branches without checking indentation.

Section: Parser State

    ParseState = record {
      tokens : List Token,
      pos : Integer
    }

    make-parse-state : List Token -> ParseState
    make-parse-state (toks) = ParseState { tokens = toks, pos = 0 }

    current : ParseState -> Token
    current (st) = list-at st.tokens st.pos

    current-kind : ParseState -> TokenKind
    current-kind (st) = (current st).kind

    advance : ParseState -> ParseState
    advance (st) = ParseState { tokens = st.tokens, pos = st.pos + 1 }

    is-done : ParseState -> Boolean
    is-done (st) = when current-kind st
      if EndOfFile -> True
      if _ -> False

    peek-kind : ParseState -> Integer -> TokenKind
    peek-kind (st) (offset) = (list-at st.tokens (st.pos + offset)).kind

Section: Parse Results

  Each parse function returns the parsed node and the updated state.

    ParseExprResult =
      | ExprOk (Expr) (ParseState)

    ParsePatResult =
      | PatOk (Pat) (ParseState)

    ParseTypeResult =
      | TypeOk (TypeExpr) (ParseState)

    ParseDefResult =
      | DefOk (Def) (ParseState)
      | DefNone (ParseState)

    ParseTypeDefResult =
      | TypeDefOk (TypeDef) (ParseState)
      | TypeDefNone (ParseState)

Section: TokenKind Predicates

    is-ident : TokenKind -> Boolean
    is-ident (k) = when k
      if Identifier -> True
      if _ -> False

    is-type-ident : TokenKind -> Boolean
    is-type-ident (k) = when k
      if TypeIdentifier -> True
      if _ -> False

    is-arrow : TokenKind -> Boolean
    is-arrow (k) = when k
      if Arrow -> True
      if _ -> False

    is-equals : TokenKind -> Boolean
    is-equals (k) = when k
      if Equals -> True
      if _ -> False

    is-colon : TokenKind -> Boolean
    is-colon (k) = when k
      if Colon -> True
      if _ -> False

    is-comma : TokenKind -> Boolean
    is-comma (k) = when k
      if Comma -> True
      if _ -> False

    is-pipe : TokenKind -> Boolean
    is-pipe (k) = when k
      if Pipe -> True
      if _ -> False

    is-left-paren : TokenKind -> Boolean
    is-left-paren (k) = when k
      if LeftParen -> True
      if _ -> False

    is-left-brace : TokenKind -> Boolean
    is-left-brace (k) = when k
      if LeftBrace -> True
      if _ -> False

    is-left-bracket : TokenKind -> Boolean
    is-left-bracket (k) = when k
      if LeftBracket -> True
      if _ -> False

    is-right-brace : TokenKind -> Boolean
    is-right-brace (k) = when k
      if RightBrace -> True
      if _ -> False

    is-right-bracket : TokenKind -> Boolean
    is-right-bracket (k) = when k
      if RightBracket -> True
      if _ -> False

    is-if-keyword : TokenKind -> Boolean
    is-if-keyword (k) = when k
      if IfKeyword -> True
      if _ -> False

    is-let-keyword : TokenKind -> Boolean
    is-let-keyword (k) = when k
      if LetKeyword -> True
      if _ -> False

    is-when-keyword : TokenKind -> Boolean
    is-when-keyword (k) = when k
      if WhenKeyword -> True
      if _ -> False

    is-do-keyword : TokenKind -> Boolean
    is-do-keyword (k) = when k
      if DoKeyword -> True
      if _ -> False

    is-in-keyword : TokenKind -> Boolean
    is-in-keyword (k) = when k
      if InKeyword -> True
      if _ -> False

    is-minus : TokenKind -> Boolean
    is-minus (k) = when k
      if Minus -> True
      if _ -> False

    is-dedent : TokenKind -> Boolean
    is-dedent (k) = when k
      if Dedent -> True
      if _ -> False

    is-left-arrow : TokenKind -> Boolean
    is-left-arrow (k) = when k
      if LeftArrow -> True
      if _ -> False

    is-record-keyword : TokenKind -> Boolean
    is-record-keyword (k) = when k
      if RecordKeyword -> True
      if _ -> False

    is-underscore : TokenKind -> Boolean
    is-underscore (k) = when k
      if Underscore -> True
      if _ -> False

    is-literal : TokenKind -> Boolean
    is-literal (k) = when k
      if IntegerLiteral -> True
      if NumberLiteral -> True
      if TextLiteral -> True
      if TrueKeyword -> True
      if FalseKeyword -> True
      if _ -> False

    is-app-start : TokenKind -> Boolean
    is-app-start (k) = when k
      if Identifier -> True
      if TypeIdentifier -> True
      if IntegerLiteral -> True
      if NumberLiteral -> True
      if TextLiteral -> True
      if TrueKeyword -> True
      if FalseKeyword -> True
      if LeftParen -> True
      if LeftBracket -> True
      if _ -> False

    is-type-arg-start : TokenKind -> Boolean
    is-type-arg-start (k) = when k
      if TypeIdentifier -> True
      if Identifier -> True
      if LeftParen -> True
      if _ -> False

    operator-precedence : TokenKind -> Integer
    operator-precedence (k) = when k
      if PlusPlus -> 5
      if ColonColon -> 5
      if Plus -> 6
      if Minus -> 6
      if Star -> 7
      if Slash -> 7
      if Caret -> 8
      if DoubleEquals -> 4
      if NotEquals -> 4
      if LessThan -> 4
      if GreaterThan -> 4
      if LessOrEqual -> 4
      if GreaterOrEqual -> 4
      if TripleEquals -> 4
      if Ampersand -> 3
      if Pipe -> 2
      if _ -> 0 - 1

Section: Token Helpers

    expect : TokenKind -> ParseState -> ParseState
    expect (kind) (st) =
      if is-done st then st
      else advance st

    skip-newlines : ParseState -> ParseState
    skip-newlines (st) =
      if is-done st then st
      else when current-kind st
        if Newline -> skip-newlines (advance st)
        if Indent -> skip-newlines (advance st)
        if Dedent -> skip-newlines (advance st)
        if _ -> st

Section: Type Parsing

    parse-type : ParseState -> ParseTypeResult
    parse-type (st) =
      let result = parse-type-atom st
      in unwrap-type-ok result parse-type-continue

    parse-type-continue : TypeExpr -> ParseState -> ParseTypeResult
    parse-type-continue (left) (st) =
      if is-arrow (current-kind st)
        then let st2 = advance st
          in let right-result = parse-type st2
            in unwrap-type-ok right-result (make-fun-type left)
        else TypeOk left st

    make-fun-type : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
    make-fun-type (left) (right) (st) = TypeOk (FunType left right) st

    unwrap-type-ok : ParseTypeResult -> (TypeExpr -> ParseState -> ParseTypeResult) -> ParseTypeResult
    unwrap-type-ok (r) (f) =
      when r
        if TypeOk (t) (st) -> f t st

    parse-type-atom : ParseState -> ParseTypeResult
    parse-type-atom (st) =
      if is-ident (current-kind st)
        then let tok = current st
          in parse-type-args (NamedType tok) (advance st)
        else if is-type-ident (current-kind st)
          then let tok = current st
            in parse-type-args (NamedType tok) (advance st)
          else if is-left-paren (current-kind st)
            then parse-paren-type (advance st)
            else let tok = current st
              in TypeOk (NamedType tok) (advance st)

    parse-paren-type : ParseState -> ParseTypeResult
    parse-paren-type (st) =
      let inner = parse-type st
      in unwrap-type-ok inner finish-paren-type

    finish-paren-type : TypeExpr -> ParseState -> ParseTypeResult
    finish-paren-type (t) (st) =
      let st2 = expect RightParen st
      in TypeOk (ParenType t) st2

    parse-type-args : TypeExpr -> ParseState -> ParseTypeResult
    parse-type-args (base-type) (st) =
      if is-done st then TypeOk base-type st
      else if is-type-arg-start (current-kind st)
        then parse-type-arg-next base-type st
        else TypeOk base-type st

    parse-type-arg-next : TypeExpr -> ParseState -> ParseTypeResult
    parse-type-arg-next (base-type) (st) =
      let arg-result = parse-type-atom st
      in unwrap-type-ok arg-result (continue-type-args base-type)

    continue-type-args : TypeExpr -> TypeExpr -> ParseState -> ParseTypeResult
    continue-type-args (base-type) (arg) (st) =
      parse-type-args (AppType base-type [arg]) st

Section: Pattern Parsing

    parse-pattern : ParseState -> ParsePatResult
    parse-pattern (st) =
      if is-underscore (current-kind st)
        then PatOk (WildPat (current st)) (advance st)
        else if is-literal (current-kind st)
          then PatOk (LitPat (current st)) (advance st)
          else if is-type-ident (current-kind st)
            then let tok = current st
              in parse-ctor-pattern-fields tok [] (advance st)
            else if is-ident (current-kind st)
              then PatOk (VarPat (current st)) (advance st)
              else PatOk (WildPat (current st)) (advance st)

    parse-ctor-pattern-fields : Token -> List Pat -> ParseState -> ParsePatResult
    parse-ctor-pattern-fields (ctor) (acc) (st) =
      if is-left-paren (current-kind st)
        then let st2 = advance st
          in let sub = parse-pattern st2
            in unwrap-pat-ok sub (continue-ctor-fields ctor acc)
        else PatOk (CtorPat ctor acc) st

    continue-ctor-fields : Token -> List Pat -> Pat -> ParseState -> ParsePatResult
    continue-ctor-fields (ctor) (acc) (p) (st) =
      let st2 = expect RightParen st
      in parse-ctor-pattern-fields ctor (acc ++ [p]) st2

    unwrap-pat-ok : ParsePatResult -> (Pat -> ParseState -> ParsePatResult) -> ParsePatResult
    unwrap-pat-ok (r) (f) =
      when r
        if PatOk (p) (st) -> f p st

Section: Expression Parsing

    parse-expr : ParseState -> ParseExprResult
    parse-expr (st) = parse-binary st 0

    unwrap-expr-ok : ParseExprResult -> (Expr -> ParseState -> ParseExprResult) -> ParseExprResult
    unwrap-expr-ok (r) (f) =
      when r
        if ExprOk (e) (st) -> f e st

    parse-binary : ParseState -> Integer -> ParseExprResult
    parse-binary (st) (min-prec) =
      let left-result = parse-unary st
      in unwrap-expr-ok left-result (start-binary-loop min-prec)

    start-binary-loop : Integer -> Expr -> ParseState -> ParseExprResult
    start-binary-loop (min-prec) (left) (st) =
      parse-binary-loop left st min-prec

    parse-binary-loop : Expr -> ParseState -> Integer -> ParseExprResult
    parse-binary-loop (left) (st) (min-prec) =
      if is-done st then ExprOk left st
      else let prec = operator-precedence (current-kind st)
        in if prec < min-prec then ExprOk left st
          else let op = current st
            in let st2 = skip-newlines (advance st)
              in let right-result = parse-binary st2 (prec + 1)
                in unwrap-expr-ok right-result (continue-binary left op min-prec)

    continue-binary : Expr -> Token -> Integer -> Expr -> ParseState -> ParseExprResult
    continue-binary (left) (op) (min-prec) (right) (st) =
      parse-binary-loop (BinExpr left op right) st min-prec

    parse-unary : ParseState -> ParseExprResult
    parse-unary (st) =
      if is-minus (current-kind st)
        then let op = current st
          in let result = parse-unary (advance st)
            in unwrap-expr-ok result (finish-unary op)
        else parse-application st

    finish-unary : Token -> Expr -> ParseState -> ParseExprResult
    finish-unary (op) (operand) (st) = ExprOk (UnaryExpr op operand) st

    parse-application : ParseState -> ParseExprResult
    parse-application (st) =
      let func-result = parse-atom st
      in unwrap-expr-ok func-result parse-app-loop

    parse-app-loop : Expr -> ParseState -> ParseExprResult
    parse-app-loop (func) (st) =
      if is-done st then ExprOk func st
      else if is-app-start (current-kind st)
        then let arg-result = parse-atom st
          in unwrap-expr-ok arg-result (continue-app func)
        else ExprOk func st

    continue-app : Expr -> Expr -> ParseState -> ParseExprResult
    continue-app (func) (arg) (st) =
      parse-app-loop (AppExpr func arg) st

    parse-atom : ParseState -> ParseExprResult
    parse-atom (st) =
      if is-literal (current-kind st)
        then ExprOk (LitExpr (current st)) (advance st)
        else if is-ident (current-kind st)
          then ExprOk (NameExpr (current st)) (advance st)
          else if is-type-ident (current-kind st)
            then parse-atom-type-ident st
            else if is-left-paren (current-kind st)
              then parse-paren-expr (advance st)
              else if is-left-bracket (current-kind st)
                then parse-list-expr st
                else if is-if-keyword (current-kind st)
                  then parse-if-expr st
                  else if is-let-keyword (current-kind st)
                    then parse-let-expr st
                    else if is-when-keyword (current-kind st)
                      then parse-match-expr st
                      else if is-do-keyword (current-kind st)
                        then parse-do-expr st
                        else ExprOk (ErrExpr (current st)) (advance st)

    parse-atom-type-ident : ParseState -> ParseExprResult
    parse-atom-type-ident (st) =
      let tok = current st
      in let st2 = advance st
        in if is-left-brace (current-kind st2)
          then parse-record-expr tok st2
          else ExprOk (NameExpr tok) st2

    parse-paren-expr : ParseState -> ParseExprResult
    parse-paren-expr (st) =
      let st2 = skip-newlines st
      in let inner = parse-expr st2
        in unwrap-expr-ok inner finish-paren-expr

    finish-paren-expr : Expr -> ParseState -> ParseExprResult
    finish-paren-expr (e) (st) =
      let st2 = skip-newlines st
      in let st3 = expect RightParen st2
        in ExprOk (ParenExpr e) st3

Section: Compound Expression Parsing

    parse-record-expr : Token -> ParseState -> ParseExprResult
    parse-record-expr (type-name) (st) =
      let st2 = advance st
      in let st3 = skip-newlines st2
        in parse-record-expr-fields type-name [] st3

    parse-record-expr-fields : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
    parse-record-expr-fields (type-name) (acc) (st) =
      if is-right-brace (current-kind st)
        then ExprOk (RecordExpr type-name acc) (advance st)
        else if is-ident (current-kind st)
          then parse-record-field type-name acc st
          else ExprOk (RecordExpr type-name acc) st

    parse-record-field : Token -> List RecordFieldExpr -> ParseState -> ParseExprResult
    parse-record-field (type-name) (acc) (st) =
      let field-name = current st
      in let st2 = advance st
        in let st3 = expect Equals st2
          in let val-result = parse-expr st3
            in unwrap-expr-ok val-result (finish-record-field type-name acc field-name)

    finish-record-field : Token -> List RecordFieldExpr -> Token -> Expr -> ParseState -> ParseExprResult
    finish-record-field (type-name) (acc) (field-name) (v) (st) =
      let field = RecordFieldExpr { name = field-name, value = v }
      in let st2 = skip-newlines st
        in if is-comma (current-kind st2)
          then parse-record-expr-fields type-name (acc ++ [field]) (skip-newlines (advance st2))
          else parse-record-expr-fields type-name (acc ++ [field]) st2

    parse-list-expr : ParseState -> ParseExprResult
    parse-list-expr (st) =
      let st2 = advance st
      in let st3 = skip-newlines st2
        in parse-list-elements [] st3

    parse-list-elements : List Expr -> ParseState -> ParseExprResult
    parse-list-elements (acc) (st) =
      if is-right-bracket (current-kind st)
        then ExprOk (ListExpr acc) (advance st)
        else let elem = parse-expr st
          in unwrap-expr-ok elem (finish-list-element acc)

    finish-list-element : List Expr -> Expr -> ParseState -> ParseExprResult
    finish-list-element (acc) (e) (st) =
      let st2 = skip-newlines st
      in if is-comma (current-kind st2)
        then parse-list-elements (acc ++ [e]) (skip-newlines (advance st2))
        else parse-list-elements (acc ++ [e]) st2

    parse-if-expr : ParseState -> ParseExprResult
    parse-if-expr (st) =
      let st2 = skip-newlines (advance st)
      in let cond = parse-expr st2
        in unwrap-expr-ok cond parse-if-then

    parse-if-then : Expr -> ParseState -> ParseExprResult
    parse-if-then (c) (st) =
      let st2 = skip-newlines st
      in let st3 = expect ThenKeyword st2
        in let st4 = skip-newlines st3
          in let then-result = parse-expr st4
            in unwrap-expr-ok then-result (parse-if-else c)

    parse-if-else : Expr -> Expr -> ParseState -> ParseExprResult
    parse-if-else (c) (t) (st) =
      let st2 = skip-newlines st
      in let st3 = expect ElseKeyword st2
        in let st4 = skip-newlines st3
          in let else-result = parse-expr st4
            in unwrap-expr-ok else-result (finish-if c t)

    finish-if : Expr -> Expr -> Expr -> ParseState -> ParseExprResult
    finish-if (c) (t) (e) (st) = ExprOk (IfExpr c t e) st

    parse-let-expr : ParseState -> ParseExprResult
    parse-let-expr (st) =
      let st2 = skip-newlines (advance st)
      in parse-let-bindings [] st2

    parse-let-bindings : List LetBind -> ParseState -> ParseExprResult
    parse-let-bindings (acc) (st) =
      if is-ident (current-kind st)
        then parse-let-binding acc st
        else if is-in-keyword (current-kind st)
          then let st2 = skip-newlines (advance st)
            in let body = parse-expr st2
              in unwrap-expr-ok body (finish-let acc)
          else let body = parse-expr st
            in unwrap-expr-ok body (finish-let acc)

    finish-let : List LetBind -> Expr -> ParseState -> ParseExprResult
    finish-let (acc) (b) (st) = ExprOk (LetExpr acc b) st

    parse-let-binding : List LetBind -> ParseState -> ParseExprResult
    parse-let-binding (acc) (st) =
      let name-tok = current st
      in let st2 = advance st
        in let st3 = expect Equals st2
          in let val-result = parse-expr st3
            in unwrap-expr-ok val-result (finish-let-binding acc name-tok)

    finish-let-binding : List LetBind -> Token -> Expr -> ParseState -> ParseExprResult
    finish-let-binding (acc) (name-tok) (v) (st) =
      let binding = LetBind { name = name-tok, value = v }
      in let st2 = skip-newlines st
        in if is-comma (current-kind st2)
          then parse-let-bindings (acc ++ [binding]) (skip-newlines (advance st2))
          else parse-let-bindings (acc ++ [binding]) st2

    parse-match-expr : ParseState -> ParseExprResult
    parse-match-expr (st) =
      let st2 = advance st
      in let scrut = parse-expr st2
        in unwrap-expr-ok scrut start-match-branches

    start-match-branches : Expr -> ParseState -> ParseExprResult
    start-match-branches (s) (st) =
      let st2 = skip-newlines st
      in parse-match-branches s [] st2

    parse-match-branches : Expr -> List MatchArm -> ParseState -> ParseExprResult
    parse-match-branches (scrut) (acc) (st) =
      if is-if-keyword (current-kind st)
        then parse-one-match-branch scrut acc st
        else ExprOk (MatchExpr scrut acc) st

    unwrap-pat-for-expr : ParsePatResult -> (Pat -> ParseState -> ParseExprResult) -> ParseExprResult
    unwrap-pat-for-expr (r) (f) =
      when r
        if PatOk (p) (st) -> f p st

    parse-one-match-branch : Expr -> List MatchArm -> ParseState -> ParseExprResult
    parse-one-match-branch (scrut) (acc) (st) =
      let st2 = advance st
      in let pat = parse-pattern st2
        in unwrap-pat-for-expr pat (parse-match-branch-body scrut acc)

    parse-match-branch-body : Expr -> List MatchArm -> Pat -> ParseState -> ParseExprResult
    parse-match-branch-body (scrut) (acc) (p) (st) =
      let st2 = expect Arrow st
      in let st3 = skip-newlines st2
        in let body = parse-expr st3
          in unwrap-expr-ok body (finish-match-branch scrut acc p)

    finish-match-branch : Expr -> List MatchArm -> Pat -> Expr -> ParseState -> ParseExprResult
    finish-match-branch (scrut) (acc) (p) (b) (st) =
      let arm = MatchArm { pattern = p, body = b }
      in let st2 = skip-newlines st
        in parse-match-branches scrut (acc ++ [arm]) st2

    parse-do-expr : ParseState -> ParseExprResult
    parse-do-expr (st) =
      let st2 = skip-newlines (advance st)
      in parse-do-stmts [] st2

    parse-do-stmts : List DoStmt -> ParseState -> ParseExprResult
    parse-do-stmts (acc) (st) =
      if is-done st then ExprOk (DoExpr acc) st
      else if is-dedent (current-kind st) then ExprOk (DoExpr acc) st
        else if is-do-bind st
          then parse-do-bind-stmt acc st
          else parse-do-expr-stmt acc st

    is-do-bind : ParseState -> Boolean
    is-do-bind (st) =
      if is-ident (current-kind st)
        then is-left-arrow (peek-kind st 1)
        else False

    parse-do-bind-stmt : List DoStmt -> ParseState -> ParseExprResult
    parse-do-bind-stmt (acc) (st) =
      let name-tok = current st
      in let st2 = advance (advance st)
        in let val-result = parse-expr st2
          in unwrap-expr-ok val-result (finish-do-bind acc name-tok)

    finish-do-bind : List DoStmt -> Token -> Expr -> ParseState -> ParseExprResult
    finish-do-bind (acc) (name-tok) (v) (st) =
      let st2 = skip-newlines st
      in parse-do-stmts (acc ++ [DoBindStmt name-tok v]) st2

    parse-do-expr-stmt : List DoStmt -> ParseState -> ParseExprResult
    parse-do-expr-stmt (acc) (st) =
      let expr-result = parse-expr st
      in unwrap-expr-ok expr-result (finish-do-expr acc)

    finish-do-expr : List DoStmt -> Expr -> ParseState -> ParseExprResult
    finish-do-expr (acc) (e) (st) =
      let st2 = skip-newlines st
      in parse-do-stmts (acc ++ [DoExprStmt e]) st2

Section: Definition Parsing

    parse-type-annotation : ParseState -> ParseTypeResult
    parse-type-annotation (st) =
      let st2 = advance st
      in let st3 = expect Colon st2
        in parse-type st3

    parse-definition : ParseState -> ParseDefResult
    parse-definition (st) =
      if is-done st then DefNone st
      else if is-ident (current-kind st) then try-parse-def st
        else if is-type-ident (current-kind st) then try-parse-def st
          else DefNone st

    try-parse-def : ParseState -> ParseDefResult
    try-parse-def (st) =
      if is-colon (peek-kind st 1)
        then let ann-result = parse-type-annotation st
          in unwrap-type-for-def ann-result
        else parse-def-body-with-ann [] st

    unwrap-type-for-def : ParseTypeResult -> ParseDefResult
    unwrap-type-for-def (r) =
      when r
        if TypeOk (ann-type) (st) ->
          let name-tok = Token { kind = Identifier, text = "", offset = 0, line = 0, column = 0 }
          in let ann = [TypeAnn { name = name-tok, type-expr = ann-type }]
            in let st2 = skip-newlines st
              in parse-def-body-with-ann ann st2

    parse-def-body-with-ann : List TypeAnn -> ParseState -> ParseDefResult
    parse-def-body-with-ann (ann) (st) =
      let name-tok = current st
      in let st2 = advance st
        in parse-def-params-then ann name-tok [] st2

    parse-def-params-then : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
    parse-def-params-then (ann) (name-tok) (acc) (st) =
      if is-left-paren (current-kind st)
        then let st2 = advance st
          in if is-ident (current-kind st2)
            then let param = current st2
              in let st3 = advance st2
                in let st4 = expect RightParen st3
                  in parse-def-params-then ann name-tok (acc ++ [param]) st4
            else finish-def ann name-tok acc st
        else finish-def ann name-tok acc st

    finish-def : List TypeAnn -> Token -> List Token -> ParseState -> ParseDefResult
    finish-def (ann) (name-tok) (params) (st) =
      let st2 = expect Equals st
      in let st3 = skip-newlines st2
        in let body-result = parse-expr st3
          in unwrap-def-body body-result ann name-tok params

    unwrap-def-body : ParseExprResult -> List TypeAnn -> Token -> List Token -> ParseDefResult
    unwrap-def-body (r) (ann) (name-tok) (params) =
      when r
        if ExprOk (b) (st) ->
          DefOk (Def { name = name-tok, params = params, ann = ann, body = b }) st

Section: Type Definition Parsing

    parse-type-def : ParseState -> ParseTypeDefResult
    parse-type-def (st) =
      if is-type-ident (current-kind st)
        then let name-tok = current st
          in let st2 = advance st
            in if is-equals (current-kind st2)
              then let st3 = skip-newlines (advance st2)
                in if is-record-keyword (current-kind st3)
                  then parse-record-type name-tok st3
                  else if is-pipe (current-kind st3)
                    then parse-variant-type name-tok st3
                    else TypeDefNone st
              else TypeDefNone st
        else TypeDefNone st

    parse-record-type : Token -> ParseState -> ParseTypeDefResult
    parse-record-type (name-tok) (st) =
      let st2 = advance st
      in let st3 = expect LeftBrace st2
        in let st4 = skip-newlines st3
          in let fields = parse-record-type-fields [] st4
            in unwrap-type-for-record-type name-tok fields

    unwrap-type-for-record-type : Token -> ParseTypeResult -> ParseTypeDefResult
    unwrap-type-for-record-type (name-tok) (r) =
      when r
        if TypeOk (dummy) (st) ->
          let st2 = expect RightBrace st
          in TypeDefOk (TypeDef { name = name-tok, type-params = [], body = RecordBody [] }) st2

    parse-record-type-fields : List RecordFieldDef -> ParseState -> ParseTypeResult
    parse-record-type-fields (acc) (st) =
      if is-ident (current-kind st)
        then let field-name = current st
          in let st2 = advance st
            in let st3 = expect Colon st2
              in let field-type = parse-type st3
                in unwrap-type-ok field-type (continue-record-fields acc)
        else TypeOk (NamedType (current st)) st

    continue-record-fields : List RecordFieldDef -> TypeExpr -> ParseState -> ParseTypeResult
    continue-record-fields (acc) (ft) (st) =
      let st2 = skip-newlines st
      in if is-comma (current-kind st2)
        then parse-record-type-fields acc (skip-newlines (advance st2))
        else parse-record-type-fields acc st2

    parse-variant-type : Token -> ParseState -> ParseTypeDefResult
    parse-variant-type (name-tok) (st) =
      parse-variant-ctors name-tok [] st

    parse-variant-ctors : Token -> List VariantCtorDef -> ParseState -> ParseTypeDefResult
    parse-variant-ctors (name-tok) (acc) (st) =
      if is-pipe (current-kind st)
        then let st2 = skip-newlines (advance st)
          in let ctor-name = current st2
            in let st3 = advance st2
              in let st4 = skip-newlines st3
                in let ctor = VariantCtorDef { name = ctor-name, fields = [] }
                  in parse-variant-ctors name-tok (acc ++ [ctor]) st4
        else TypeDefOk (TypeDef { name = name-tok, type-params = [], body = VariantBody acc }) st

Section: Document Parsing

    parse-document : ParseState -> Document
    parse-document (st) =
      let st2 = skip-newlines st
      in parse-top-level [] [] st2

    parse-top-level : List Def -> List TypeDef -> ParseState -> Document
    parse-top-level (defs) (type-defs) (st) =
      if is-done st then Document { defs = defs, type-defs = type-defs }
      else try-top-level-type-def defs type-defs st

    try-top-level-type-def : List Def -> List TypeDef -> ParseState -> Document
    try-top-level-type-def (defs) (type-defs) (st) =
      let td-result = parse-type-def st
      in when td-result
        if TypeDefOk (td) (st2) ->
          parse-top-level defs (type-defs ++ [td]) (skip-newlines st2)
        if TypeDefNone (st2) ->
          try-top-level-def defs type-defs st

    try-top-level-def : List Def -> List TypeDef -> ParseState -> Document
    try-top-level-def (defs) (type-defs) (st) =
      let def-result = parse-definition st
      in when def-result
        if DefOk (d) (st2) ->
          parse-top-level (defs ++ [d]) type-defs (skip-newlines st2)
        if DefNone (st2) ->
          parse-top-level defs type-defs (skip-newlines (advance st2))
