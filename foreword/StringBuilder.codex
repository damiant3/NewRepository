Chapter: StringBuilder

Section: Definitions

  StringBuilder = record {
    parts : List Text,
    total-length : Integer
  }

  sb-new : StringBuilder = StringBuilder { parts = [], total-length = 0 }

  sb-append : StringBuilder -> Text -> StringBuilder
  sb-append (sb) (s) =
    if text-length s == 0 then sb
    else StringBuilder { parts = sb.parts ++ [s], total-length = sb.total-length + text-length s }

  sb-append-line : StringBuilder -> Text -> StringBuilder
  sb-append-line (sb) (s) =
    sb-append (sb-append sb s) (code-to-char 10)

  sb-append-int : StringBuilder -> Integer -> StringBuilder
  sb-append-int (sb) (n) = sb-append sb (integer-to-text n)

  sb-prepend : StringBuilder -> Text -> StringBuilder
  sb-prepend (sb) (s) =
    if text-length s == 0 then sb
    else StringBuilder { parts = [s] ++ sb.parts, total-length = sb.total-length + text-length s }

  sb-to-text : StringBuilder -> Text
  sb-to-text (sb) = sb-join-parts sb.parts 0 (list-length sb.parts) ""

  sb-join-parts : List Text -> Integer -> Integer -> Text -> Text
  sb-join-parts (parts) (i) (len) (acc) =
    if i == len then acc
    else sb-join-parts parts (i + 1) len (acc ++ list-at parts i)

  sb-length : StringBuilder -> Integer
  sb-length (sb) = sb.total-length

  sb-is-empty : StringBuilder -> Boolean
  sb-is-empty (sb) = sb.total-length == 0

  sb-clear : StringBuilder -> StringBuilder
  sb-clear (sb) = sb-new

  sb-join : Text -> List Text -> Text
  sb-join (sep) (items) =
    if list-length items == 0 then ""
    else sb-to-text (sb-join-loop sep items 0 (list-length items) sb-new)

  sb-join-loop : Text -> List Text -> Integer -> Integer -> StringBuilder -> StringBuilder
  sb-join-loop (sep) (items) (i) (len) (sb) =
    if i == len then sb
    else if i == 0 then sb-join-loop sep items 1 len (sb-append sb (list-at items 0))
    else sb-join-loop sep items (i + 1) len (sb-append (sb-append sb sep) (list-at items i))

  sb-build : Integer -> (Integer -> Text) -> Text
  sb-build (count) (f) = sb-to-text (sb-build-loop count f 0 sb-new)

  sb-build-loop : Integer -> (Integer -> Text) -> Integer -> StringBuilder -> StringBuilder
  sb-build-loop (count) (f) (i) (sb) =
    if i == count then sb
    else sb-build-loop count f (i + 1) (sb-append sb (f i))

  sb-indent : Integer -> Text -> Text
  sb-indent (spaces) (s) =
    let prefix = text-repeat-spaces spaces
    in let lines = split-newlines s 0 (text-length s) 0 []
    in sb-join (code-to-char 10) (indent-lines prefix lines 0 (list-length lines) [])

  text-repeat-spaces : Integer -> Text
  text-repeat-spaces (n) =
    if n <= 0 then ""
    else " " ++ text-repeat-spaces (n - 1)

  split-newlines : Text -> Integer -> Integer -> Integer -> List Text -> List Text
  split-newlines (s) (i) (len) (start) (acc) =
    if i == len then acc ++ [substring s start (len - start)]
    else if char-code (char-at s i) == 10
      then split-newlines s (i + 1) len (i + 1) (acc ++ [substring s start (i - start)])
    else split-newlines s (i + 1) len start acc

  indent-lines : Text -> List Text -> Integer -> Integer -> List Text -> List Text
  indent-lines (prefix) (lines) (i) (len) (acc) =
    if i == len then acc
    else indent-lines prefix lines (i + 1) len (acc ++ [prefix ++ list-at lines i])

