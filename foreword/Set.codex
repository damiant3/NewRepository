Chapter: Set

  cites Foreword chapter Hamt
  cites Foreword chapter Maybe

Section: Definitions


  TextSet = record {
    store : HamtMap Boolean
  }

  set-empty : TextSet = TextSet { store = hamt-empty }

  set-insert : TextSet -> Text -> TextSet
  set-insert (s) (key) = TextSet { store = hamt-set s.store key True }

  set-contains : TextSet -> Text -> Boolean
  set-contains (s) (key) = hamt-contains s.store key

  set-remove : TextSet -> Text -> TextSet
  set-remove (s) (key) = TextSet { store = hamt-remove s.store key }

  set-size : TextSet -> Integer
  set-size (s) = hamt-size s.store

  set-is-empty : TextSet -> Boolean
  set-is-empty (s) = set-size s == 0

  set-union : TextSet -> TextSet -> TextSet
  set-union (a) (b) =
    let entries = hamt-to-list b.store
    in set-union-loop a entries 0 (list-length entries)

  set-union-loop : TextSet -> List HamtEntry Boolean -> Integer -> Integer -> TextSet
  set-union-loop (acc) (entries) (i) (len) =
    if i == len then acc
    else let e = list-at entries i
      in set-union-loop (set-insert acc e.key) entries (i + 1) len

  set-intersection : TextSet -> TextSet -> TextSet
  set-intersection (a) (b) =
    let entries = hamt-to-list a.store
    in set-intersection-loop set-empty entries b 0 (list-length entries)

  set-intersection-loop : TextSet -> List HamtEntry Boolean -> TextSet -> Integer -> Integer -> TextSet
  set-intersection-loop (acc) (entries) (other) (i) (len) =
    if i == len then acc
    else let e = list-at entries i
      in if set-contains other e.key
        then set-intersection-loop (set-insert acc e.key) entries other (i + 1) len
        else set-intersection-loop acc entries other (i + 1) len

  set-difference : TextSet -> TextSet -> TextSet
  set-difference (a) (b) =
    let entries = hamt-to-list a.store
    in set-difference-loop set-empty entries b 0 (list-length entries)

  set-difference-loop : TextSet -> List HamtEntry Boolean -> TextSet -> Integer -> Integer -> TextSet
  set-difference-loop (acc) (entries) (other) (i) (len) =
    if i == len then acc
    else let e = list-at entries i
      in if set-contains other e.key
        then set-difference-loop acc entries other (i + 1) len
        else set-difference-loop (set-insert acc e.key) entries other (i + 1) len

  set-to-list : TextSet -> List Text
  set-to-list (s) =
    let entries = hamt-to-list s.store
    in set-to-list-loop entries 0 (list-length entries) []

  set-to-list-loop : List HamtEntry Boolean -> Integer -> Integer -> List Text -> List Text
  set-to-list-loop (entries) (i) (len) (acc) =
    if i == len then acc
    else let e = list-at entries i
      in set-to-list-loop entries (i + 1) len (acc ++ [e.key])

  set-from-list : List Text -> TextSet
  set-from-list (keys) = set-from-list-loop keys 0 (list-length keys) set-empty

  set-from-list-loop : List Text -> Integer -> Integer -> TextSet -> TextSet
  set-from-list-loop (keys) (i) (len) (acc) =
    if i == len then acc
    else set-from-list-loop keys (i + 1) len (set-insert acc (list-at keys i))

  set-fold : (b -> Text -> b) -> b -> TextSet -> b
  set-fold (f) (z) (s) = hamt-fold (set-fold-wrapper f) z s.store

  set-fold-wrapper : (b -> Text -> b) -> b -> Text -> Boolean -> b
  set-fold-wrapper (f) (acc) (key) (val) = f acc key

  set-any : (Text -> Boolean) -> TextSet -> Boolean
  set-any (pred) (s) =
    let entries = hamt-to-list s.store
    in set-any-loop pred entries 0 (list-length entries)

  set-any-loop : (Text -> Boolean) -> List HamtEntry Boolean -> Integer -> Integer -> Boolean
  set-any-loop (pred) (entries) (i) (len) =
    if i == len then False
    else if pred (list-at entries i).key then True
      else set-any-loop pred entries (i + 1) len

  set-all : (Text -> Boolean) -> TextSet -> Boolean
  set-all (pred) (s) =
    let entries = hamt-to-list s.store
    in set-all-loop pred entries 0 (list-length entries)

  set-all-loop : (Text -> Boolean) -> List HamtEntry Boolean -> Integer -> Integer -> Boolean
  set-all-loop (pred) (entries) (i) (len) =
    if i == len then True
    else if pred (list-at entries i).key
      then set-all-loop pred entries (i + 1) len
      else False

