Chapter: Maybe

Section: Definitions

  Maybe (a) =
    | Just (a)
    | None

  from-maybe : Maybe a -> a -> a
  from-maybe (m) (default) = when m
    is Just (x) -> x
    is None -> default

  is-just : Maybe a -> Boolean
  is-just (m) = when m
    is Just (x) -> True
    is None -> False

  is-none : Maybe a -> Boolean
  is-none (m) = when m
    is Just (x) -> False
    is None -> True

  maybe-map : (a -> b) -> Maybe a -> Maybe b
  maybe-map (f) (m) = when m
    is Just (x) -> Just (f x)
    is None -> None

  maybe-bind : Maybe a -> (a -> Maybe b) -> Maybe b
  maybe-bind (m) (f) = when m
    is Just (x) -> f x
    is None -> None

