ConsList (a) =
  | Cons (a) (ConsList a)
  | Nil

nil : ConsList a
nil = Nil

cons : a -> ConsList a -> ConsList a
cons (x) (xs) = Cons x xs

is-empty : ConsList a -> Boolean
is-empty (xs) = when xs
  if Cons (h) (t) -> False
  if Nil -> True

head : ConsList a -> a
head (xs) = when xs
  if Cons (h) (t) -> h
  if Nil -> head xs

tail : ConsList a -> ConsList a
tail (xs) = when xs
  if Cons (h) (t) -> t
  if Nil -> Nil

list-length : ConsList a -> Integer
list-length (xs) = list-length-acc xs 0

list-length-acc : ConsList a -> Integer -> Integer
list-length-acc (xs) (acc) = when xs
  if Cons (h) (t) -> list-length-acc t (acc + 1)
  if Nil -> acc

list-map : (a -> b) -> ConsList a -> ConsList b
list-map (f) (xs) = when xs
  if Cons (h) (t) -> Cons (f h) (list-map f t)
  if Nil -> Nil

list-filter : (a -> Boolean) -> ConsList a -> ConsList a
list-filter (pred) (xs) = when xs
  if Cons (h) (t) -> if pred h then Cons h (list-filter pred t) else list-filter pred t
  if Nil -> Nil

list-foldl : (b -> a -> b) -> b -> ConsList a -> b
list-foldl (f) (acc) (xs) = when xs
  if Cons (h) (t) -> list-foldl f (f acc h) t
  if Nil -> acc

list-foldr : (a -> b -> b) -> b -> ConsList a -> b
list-foldr (f) (acc) (xs) = when xs
  if Cons (h) (t) -> f h (list-foldr f acc t)
  if Nil -> acc

list-reverse : ConsList a -> ConsList a
list-reverse (xs) = list-foldl (flip-cons) Nil xs

flip-cons : ConsList a -> a -> ConsList a
flip-cons (acc) (x) = Cons x acc

list-append : ConsList a -> ConsList a -> ConsList a
list-append (xs) (ys) = when xs
  if Cons (h) (t) -> Cons h (list-append t ys)
  if Nil -> ys

list-any : (a -> Boolean) -> ConsList a -> Boolean
list-any (pred) (xs) = when xs
  if Cons (h) (t) -> if pred h then True else list-any pred t
  if Nil -> False

list-all : (a -> Boolean) -> ConsList a -> Boolean
list-all (pred) (xs) = when xs
  if Cons (h) (t) -> if pred h then list-all pred t else False
  if Nil -> True

list-take : Integer -> ConsList a -> ConsList a
list-take (n) (xs) =
  if n <= 0 then Nil
  else when xs
    if Cons (h) (t) -> Cons h (list-take (n - 1) t)
    if Nil -> Nil

list-drop : Integer -> ConsList a -> ConsList a
list-drop (n) (xs) =
  if n <= 0 then xs
  else when xs
    if Cons (h) (t) -> list-drop (n - 1) t
    if Nil -> Nil

list-zip-with : (a -> b -> c) -> ConsList a -> ConsList b -> ConsList c
list-zip-with (f) (xs) (ys) = when xs
  if Cons (hx) (tx) -> when ys
    if Cons (hy) (ty) -> Cons (f hx hy) (list-zip-with f tx ty)
    if Nil -> Nil
  if Nil -> Nil

list-sum : ConsList Integer -> Integer
list-sum (xs) = list-foldl add-int 0 xs

add-int : Integer -> Integer -> Integer
add-int (a) (b) = a + b
