Chapter: Result

Section: Definitions

  Result (a) (e) =
    | Ok (a)
    | Err (e)

  is-ok : Result a e -> Boolean
  is-ok (r) = when r
    is Ok (x) -> True
    is Err (e) -> False

  is-err : Result a e -> Boolean
  is-err (r) = when r
    is Ok (x) -> False
    is Err (e) -> True

  from-ok : Result a e -> a -> a
  from-ok (r) (default) = when r
    is Ok (x) -> x
    is Err (e) -> default

  result-map : (a -> b) -> Result a e -> Result b e
  result-map (f) (r) = when r
    is Ok (x) -> Ok (f x)
    is Err (e) -> Err e

  result-bind : Result a e -> (a -> Result b e) -> Result b e
  result-bind (r) (f) = when r
    is Ok (x) -> f x
    is Err (e) -> Err e

