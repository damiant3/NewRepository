Chapter: Either

Section: Definitions

  Either (a) (b) =
    | Left (a)
    | Right (b)

  is-left : Either a b -> Boolean
  is-left (e) = when e
    if Left (x) -> True
    if Right (y) -> False

  is-right : Either a b -> Boolean
  is-right (e) = when e
    if Left (x) -> False
    if Right (y) -> True

  from-left : Either a b -> a -> a
  from-left (e) (default) = when e
    if Left (x) -> x
    if Right (y) -> default

  from-right : Either a b -> b -> b
  from-right (e) (default) = when e
    if Left (x) -> default
    if Right (y) -> y

  either : (a -> c) -> (b -> c) -> Either a b -> c
  either (f) (g) (e) = when e
    if Left (x) -> f x
    if Right (y) -> g y

