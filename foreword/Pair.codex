Chapter: Pair

Section: Definitions

  Pair (a) (b) = record { fst : a, snd : b }

  make-pair : a -> b -> Pair a b
  make-pair (x) (y) = Pair { fst = x, snd = y }

  pair-fst : Pair a b -> a
  pair-fst (p) = p.fst

  pair-snd : Pair a b -> b
  pair-snd (p) = p.snd

  swap : Pair a b -> Pair b a
  swap (p) = Pair { fst = p.snd, snd = p.fst }

