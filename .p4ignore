# .p4ignore — files p4 reconcile/add should never touch.
# Patterns match relative to this file. A leading / anchors to this dir.

# VCS metadata (git lives alongside; don't import it)
.git/
.gitignore
.gitattributes
.gitmodules

# Editor / IDE
.vs/
.vscode/
.idea/
*.user
*.suo
*.sln.docstates

# .NET build artifacts
bin/
obj/
packages/
TestResults/
*.nupkg
*.snupkg

# Project build outputs
build-output/
generated-output/

# OS clutter
Thumbs.db
Desktop.ini
.DS_Store

# Node (defensive; may not apply)
node_modules/

# Local-only p4 state
.p4config

# Claude Code local machine settings (NOT the shared settings.json)
.claude/settings.local.json

# Published/packaged build outputs under tools (except codex-agent — kept
# intentionally so a fresh clone can orient immediately without a build).
tools/Codex.Mcp/published/
samples/*.exe
samples/*.runtimeconfig.json
samples/list-test


# Debug symbols
*.pdb

# Historical phone firmware blobs (too large, not source)
docs/Done/Phone/phone/flash/

# Top-level tools that aren't part of orient — rebuild on demand.
# (codex-agent/ is deliberately kept so a fresh clone works out of the box.)
tools/wc-matrix.exe
tools/wc-matrix.dll
tools/wc-matrix.runtimeconfig.json
