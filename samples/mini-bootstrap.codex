Chapter: Mini Bootstrap Test

 Minimal type checker test.

Section: Types

  Color =
    | Red
    | Green
    | Blue (Integer)

  Point = record {
    x : Integer,
    y : Integer
  }

Section: Functions

  show-color : Color -> Text
  show-color (c) =
    when c
      is Red -> "red"
      is Green -> "green"
      is Blue (n) -> "blue"

  get-x : Point -> Integer
  get-x (p) = p.x

  add-points : Point -> Point -> Point
  add-points (a) (b) = Point { x = a.x + b.x, y = a.y + b.y }

  map-list : (a -> b) -> List a -> List b
  map-list (f) (xs) = map-list-loop f xs 0 (list-length xs) []

  map-list-loop : (a -> b) -> List a -> Integer -> Integer -> List b -> List b
  map-list-loop (f) (xs) (i) (len) (acc) =
    if i == len then acc
    else map-list-loop f xs (i + 1) len (acc ++ [f (list-at xs i)])

  use-map : List Point -> List Integer
  use-map (pts) = map-list get-x pts

  main = use-map [Point { x = 1, y = 2 }]

