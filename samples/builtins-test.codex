Chapter: Builtin Tests

Section: Arithmetic
  test-mod : Integer = int-mod 17 5

  test-mod-neg : Integer = int-mod (0 - 7) 3

  test-abs-pos : Integer = abs 42

  test-abs-neg : Integer = abs (0 - 42)

  test-min : Integer = min 3 7

  test-max : Integer = max 3 7

Section: Bitwise
  test-and : Integer = bit-and 255 15

  test-or : Integer = bit-or 240 15

  test-xor : Integer = bit-xor 255 15

  test-shl : Integer = bit-shl 1 8

  test-shr : Integer = bit-shr 256 4

  test-not : Integer = bit-and (bit-not 0) 255

Section: Main
  main : Integer = test-mod + test-abs-neg + test-min + test-and + test-shl
