Chapter: Builtin Tests

Section: Arithmetic
  test-mod : Integer
  test-mod = int-mod 17 5

  test-mod-neg : Integer
  test-mod-neg = int-mod (0 - 7) 3

  test-abs-pos : Integer
  test-abs-pos = abs 42

  test-abs-neg : Integer
  test-abs-neg = abs (0 - 42)

  test-min : Integer
  test-min = min 3 7

  test-max : Integer
  test-max = max 3 7

Section: Bitwise
  test-and : Integer
  test-and = bit-and 255 15

  test-or : Integer
  test-or = bit-or 240 15

  test-xor : Integer
  test-xor = bit-xor 255 15

  test-shl : Integer
  test-shl = bit-shl 1 8

  test-shr : Integer
  test-shr = bit-shr 256 4

  test-not : Integer
  test-not = bit-and (bit-not 0) 255

Section: Main
  main : Integer
  main = test-mod + test-abs-neg + test-min + test-and + test-shl
