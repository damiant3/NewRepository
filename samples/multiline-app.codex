Chapter: Multiline Application

Section: Definitions

  add3 : Integer -> Integer -> Integer -> Integer
  add3 (a) (b) (c) = a + b + c

  use-multi-line : Integer -> Integer
  use-multi-line (n) =
   let result = (add3 1
                 2
                 3)
   in result + n

  nested-call : Integer -> Integer
  nested-call (n) =
   (add3 n
         (n + 1)
         (n + 2))

  main : Integer = use-multi-line (nested-call 10)

