Chapter: C5IntField

Section: Types
  Box = record {
   xs : List Integer
  }

Section: Defs
  make-box : Box
  make-box = Box { xs = [1, 2, 3] }

  take-2 : Integer -> List Integer -> Integer
  take-2 (a) (q) = a + list-length q

Section: Callers
  bad : Integer
  bad =
   let b = make-box
   in take-2 0 (b.xs)

Section: Entry
  main : [Console] Nothing
  main = do
   print-line "C5:start"
   let a = bad
   in do
    print-line ("C5:bad=" ++ integer-to-text a)
    print-line "C5:done"

