Chapter: PolymorphismCoverage

 Targeted sweep for parametric polymorphism in both compilers.
 Each definition exercises a distinct shape; if any fail to type-check,
 update `docs/Active/Compiler/SELF-HOST-PARITY-AUDIT.md`.

Section: Identity and constant
  id : a -> a
  id (x) = x

  const-fn : a -> b -> a
  const-fn (x) (y) = x

Section: Polymorphic sum (Maybe-like)
  Opt (a) =
   | Some (a)
   | Nada

  opt-map : (a -> b) -> Opt a -> Opt b
  opt-map (f) (m) = when m
    is Some (x) -> Some (f x)
    is Nada -> Nada

Section: Polymorphic record + accessors
  Box (a) = record {
   value : a
  }

  unbox : Box a -> a
  unbox (b) = b.value

  rebox : (a -> b) -> Box a -> Box b
  rebox (f) (b) = Box { value = f (b.value) }

Section: Nested polymorphism
  Pair-r (a) (b) = record {
   first : a,
   second : b
  }

  swap-pair : Pair-r a b -> Pair-r b a
  swap-pair (p) = Pair-r { first = p.second, second = p.first }

  list-of-opt : List (Opt Integer)
  list-of-opt = [Some 1, Nada, Some 3]

Section: Polymorphic function passed as argument
  apply-fn : (a -> b) -> a -> b
  apply-fn (f) (x) = f x

  inc : Integer -> Integer
  inc (n) = n + 1

  use-apply : Integer
  use-apply = apply-fn inc 41

Section: Concrete instantiations of polymorphic helpers
  sample-some : Opt Integer
  sample-some = opt-map inc (Some 41)

  sample-rebox : Box Integer
  sample-rebox = rebox inc (Box { value = 41 })

  sample-pair : Pair-r Integer Text
  sample-pair = Pair-r { first = 1, second = "two" }

  sample-swap : Pair-r Text Integer
  sample-swap = swap-pair sample-pair

