Chapter: Primality Testing — The Functional Way

 This module demonstrates a more expressive approach to primality testing
 using list operations and higher-order functions written in Codex.

Section: List Building

  range : Integer -> Integer -> List Integer
  range (lo) (hi) =
    if lo > hi then []
    else [lo] ++ range (lo + 1) hi

Section: Primality via Trial Division with Divisor List

  divides : Integer -> Integer -> Boolean
  divides (d) (n) = n / d * d == n

  has-no-divisors-in : List Integer -> Integer -> Integer -> Integer -> Boolean
  has-no-divisors-in (divisors) (n) (i) (len) =
    if i == len then True
    else
      let d = list-at divisors i
      in if divides d n then False
      else has-no-divisors-in divisors n (i + 1) len

  small-divisors : List Integer -> Integer -> Integer -> Integer -> List Integer
  small-divisors (xs) (limit) (i) (len) =
    if i == len then []
    else
      let x = list-at xs i
      in if x * x <= limit
        then [x] ++ small-divisors xs limit (i + 1) len
        else small-divisors xs limit (i + 1) len

  is-prime : Integer -> Boolean
  is-prime (n) =
    if n < 2 then False
    else
      let candidates = range 2 n
      in let small = small-divisors candidates n 0 (list-length candidates)
      in has-no-divisors-in small n 0 (list-length small)

Section: Collecting Primes

  collect-primes : List Integer -> Integer -> Integer -> List Text
  collect-primes (xs) (i) (len) =
    if i == len then []
    else
      let x = list-at xs i
      in if is-prime x
        then [show x] ++ collect-primes xs (i + 1) len
        else collect-primes xs (i + 1) len

  join-with-spaces : List Text -> Integer -> Integer -> Text
  join-with-spaces (xs) (i) (len) =
    if i == len then ""
    else if i == len - 1 then list-at xs i
    else list-at xs i ++ " " ++ join-with-spaces xs (i + 1) len

  main : Text
  main =
    let candidates = range 2 50
    in let primes = collect-primes candidates 0 (list-length candidates)
    in "Primes up to 50: " ++ join-with-spaces primes 0 (list-length primes)
