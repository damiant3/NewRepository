  test-0 : Text
  test-0 =
    let x0 = 0
    in let x1 = x0 + 1
    in let x2 = x1 + 2
    in let s0 = "v0=" ++ show x0
    in let s1 = s0 ++ " v1=" ++ show x1
    in let s2 = s1 ++ " v2=" ++ show x2
    in s2

