  check : Text -> Text -> Text -> Text
  check (name) (actual) (expected) =
    if actual == expected then "PASS: " ++ name
    else "FAIL: " ++ name ++ " expected [" ++ expected ++ "] got [" ++ actual ++ "]"

  main : Integer
  main = 0

