Chapter: Bitwise Ops Test

 Minimal exercise of bit-and, bit-or, bit-xor, bit-not, bit-shl, bit-shr.
 Each test picks values whose expected result is obvious, then sums them
 with 1/2/4/... multipliers so one scalar at the end encodes which ones
 passed.

Section: Main

  test-and : Integer
  test-and = bit-and 12 10

  test-or : Integer
  test-or = bit-or 12 10

  test-xor : Integer
  test-xor = bit-xor 12 10

  test-not : Integer
  test-not = bit-and (bit-not 0) 255

  test-shl : Integer
  test-shl = bit-shl 1 8

  test-shr : Integer
  test-shr = bit-shr 256 4

  score : Integer -> Integer -> Integer -> Integer
  score (x) (expected) (bit) = if x == expected then bit else 0

  main : Integer
  main =
   let s1 = score test-and 8 1
   in let s2 = score test-or 14 2
   in let s3 = score test-xor 6 4
   in let s4 = score test-not 255 8
   in let s5 = score test-shl 256 16
   in let s6 = score test-shr 16 32
   in s1 + s2 + s3 + s4 + s5 + s6
