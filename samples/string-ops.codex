Chapter: String Ops

Section: Definitions

  is-identifier-char : Char -> Boolean
  is-identifier-char (ch) =
    if is-letter ch then True
    else if is-digit ch then True
    else if char-to-text ch == "-" then True
    else False

  count-letters : Text -> Integer -> Integer -> Integer
  count-letters (s) (i) (acc) =
    if i >= text-length s
      then acc
      else let ch = char-at s i
        in if is-letter ch
          then count-letters s (i + 1) (acc + 1)
          else count-letters s (i + 1) acc

  main : Integer
  main = count-letters "hello world 123" 0 0

