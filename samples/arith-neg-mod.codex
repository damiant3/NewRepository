Chapter: ArithNegMod

 Exercise int-mod across sign combinations to probe parity and
 correctness on negative operands.

Section: Driver

  main : [Console] Nothing = act
    print-line "-- int-mod --"
    print-line ("mod pp: " ++ integer-to-text (int-mod 7 3))
    print-line ("mod np: " ++ integer-to-text (int-mod (0 - 7) 3))
    print-line ("mod pn: " ++ integer-to-text (int-mod 7 (0 - 3)))
    print-line ("mod nn: " ++ integer-to-text (int-mod (0 - 7) (0 - 3)))
    print-line ("mod zero-numerator: " ++ integer-to-text (int-mod 0 5))
    print-line ("mod exact-multiple-pos: " ++ integer-to-text (int-mod 6 3))
    print-line ("mod exact-multiple-neg: " ++ integer-to-text (int-mod (0 - 6) 3))
    print-line "-- integer / integer --"
    print-line ("div pp: " ++ integer-to-text (7 / 3))
    print-line ("div np: " ++ integer-to-text ((0 - 7) / 3))
    print-line ("div pn: " ++ integer-to-text (7 / (0 - 3)))
    print-line ("div nn: " ++ integer-to-text ((0 - 7) / (0 - 3)))
  end
