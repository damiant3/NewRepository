is-prime : Integer -> Boolean
is-prime (n) =
  if n < 2 then False
  else check-divisor n 2

check-divisor : Integer -> Integer -> Boolean
check-divisor (n) (d) =
  if d * d > n then True
  else if n / d * d == n then False
  else check-divisor n (d + 1)

main : Text
main =
  let a = is-prime 2
  in let b = is-prime 17
  in let c = is-prime 49
  in let d = is-prime 97
  in show a ++ " " ++ show b ++ " " ++ show c ++ " " ++ show d
