Chapter: Let Effectful Bug

Section: Definitions

  recurse : Integer -> Integer -> [Console] Integer
  recurse (i) (n) =
    if i >= n then i
    else act
      print-line ("step " ++ integer-to-text i)
      recurse (i + 1) n
    end

  use-let : [Console] Nothing = act
    let r = recurse 0 3
    in act
      print-line "let-bound r ="
      print-line (integer-to-text r)
    end
  end

  use-bind : [Console] Nothing = act
    r <- recurse 0 3
    print-line "do-bound r ="
    print-line (integer-to-text r)
  end

  main : [Console] Nothing = act
    print-line "=== use-bind (expected: 3) ==="
    use-bind
    print-line ""
    print-line "=== use-let (expected: 3) ==="
    use-let
  end

