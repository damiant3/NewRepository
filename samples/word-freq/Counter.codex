WordCount = record { word : Text, count : Integer }

FreqMap = record { entries : List WordCount, total-words : Integer }

LookupResult =
  | Found (Integer)
  | NotFound

freq-empty : FreqMap
freq-empty = FreqMap { entries = [], total-words = 0 }

freq-lookup : List WordCount -> Text -> LookupResult
freq-lookup (entries) (word) =
  freq-lookup-loop entries word 0 (list-length entries)

freq-lookup-loop : List WordCount -> Text -> Integer -> Integer -> LookupResult
freq-lookup-loop (entries) (word) (i) (len) =
  if i == len then NotFound
  else let e = list-at entries i
    in if e.word == word then Found e.count
    else freq-lookup-loop entries word (i + 1) len

freq-update : List WordCount -> Text -> List WordCount
freq-update (entries) (word) =
  freq-update-loop entries word 0 (list-length entries) []

freq-update-loop : List WordCount -> Text -> Integer -> Integer -> List WordCount -> List WordCount
freq-update-loop (entries) (word) (i) (len) (acc) =
  if i == len then acc ++ [WordCount { word = word, count = 1 }]
  else let e = list-at entries i
    in if e.word == word
      then acc ++ [WordCount { word = word, count = e.count + 1 }] ++ rest-of-list entries (i + 1) len
    else freq-update-loop entries word (i + 1) len (acc ++ [e])

rest-of-list : List WordCount -> Integer -> Integer -> List WordCount
rest-of-list (entries) (i) (len) =
  if i == len then []
  else [list-at entries i] ++ rest-of-list entries (i + 1) len

freq-add-word : FreqMap -> Text -> FreqMap
freq-add-word (fm) (word) =
  FreqMap { entries = freq-update fm.entries word, total-words = fm.total-words + 1 }

count-words : List Text -> FreqMap
count-words (words) = count-words-loop words 0 (list-length words) freq-empty

count-words-loop : List Text -> Integer -> Integer -> FreqMap -> FreqMap
count-words-loop (words) (i) (len) (fm) =
  if i == len then fm
  else count-words-loop words (i + 1) len (freq-add-word fm (list-at words i))

freq-size : FreqMap -> Integer
freq-size (fm) = list-length fm.entries
