Chapter: Main

Section: Definitions

  sample-text : Text = "The quick brown fox jumps over the lazy dog. The fox was quick and the dog was lazy. A fox is a fox."

  format-entry : WordCount -> Text
  format-entry (wc) = "  " ++ wc.word ++ ": " ++ show wc.count

  format-entries : List WordCount -> Integer -> Integer -> Text -> Text
  format-entries (entries) (i) (len) (acc) =
    if i == len then acc
    else let line = format-entry (list-at entries i)
      in let sep = if i == 0 then "" else char-to-text (code-to-char 10)
      in format-entries entries (i + 1) len (acc ++ sep ++ line)

  show-lookup : LookupResult -> Text
  show-lookup (r) = when r
    if Found (n) -> show n
    if NotFound -> "not found"

  find-max-entry : List WordCount -> Integer -> Integer -> WordCount -> WordCount
  find-max-entry (entries) (i) (len) (best) =
    if i == len then best
    else let e = list-at entries i
      in if e.count > best.count
        then find-max-entry entries (i + 1) len e
        else find-max-entry entries (i + 1) len best

  main : [Console] Nothing
  main =
    let words = tokenize-words sample-text
    in let fm = count-words words
    in let input-line = "Input: " ++ show (text-length sample-text) ++ " chars, " ++ show fm.total-words ++ " words, " ++ show (freq-size fm) ++ " unique"
    in let results = format-entries fm.entries 0 (list-length fm.entries) ""
    in let the-count = "Count for 'the': " ++ show-lookup (freq-lookup fm.entries "the")
    in let fox-count = "Count for 'fox': " ++ show-lookup (freq-lookup fm.entries "fox")
    in let most = if freq-size fm > 0 then find-max-entry fm.entries 1 (list-length fm.entries) (list-at fm.entries 0) else WordCount { word = "", count = 0 }
    in let most-line = "Most frequent: '" ++ most.word ++ "' (" ++ show most.count ++ " times)"
    in do
      print-line "Word Frequency Analysis"
      print-line "======================="
      print-line input-line
      print-line ""
      print-line "Frequencies:"
      print-line results
      print-line ""
      print-line the-count
      print-line fox-count
      print-line most-line

