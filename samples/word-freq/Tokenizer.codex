is-word-char : Text -> Boolean
is-word-char (c) = is-letter c | is-digit c

to-lower-char : Text -> Text
to-lower-char (c) =
  let code = char-code c
  in if code >= 65 & code <= 90 then code-to-char (code + 32) else c

normalize-word : Text -> Integer -> Integer -> Text -> Text
normalize-word (word) (i) (len) (acc) =
  if i == len then acc
  else normalize-word word (i + 1) len (acc ++ to-lower-char (char-at word i))

extract-word : Text -> Integer -> Integer -> Integer -> Text
extract-word (input) (start) (pos) (len) =
  if pos == len then substring input start (pos - start)
  else if is-word-char (char-at input pos)
    then extract-word input start (pos + 1) len
  else substring input start (pos - start)

skip-non-word : Text -> Integer -> Integer -> Integer
skip-non-word (input) (pos) (len) =
  if pos == len then pos
  else if is-word-char (char-at input pos) then pos
  else skip-non-word input (pos + 1) len

tokenize-loop : Text -> Integer -> Integer -> List Text -> List Text
tokenize-loop (input) (pos) (len) (acc) =
  if pos >= len then acc
  else let start = skip-non-word input pos len
    in if start >= len then acc
    else let raw = extract-word input start start len
      in let word = normalize-word raw 0 (text-length raw) ""
      in if text-length word > 0
        then tokenize-loop input (start + text-length raw) len (acc ++ [word])
        else tokenize-loop input (start + 1) len acc

tokenize-words : Text -> List Text
tokenize-words (input) = tokenize-loop input 0 (text-length input) []
