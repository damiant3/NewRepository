cites List

double : Integer -> Integer
double (n) = n * 2

is-even : Integer -> Boolean
is-even (n) = (n / 2) * 2 == n

add : Integer -> Integer -> Integer
add (a) (b) = a + b

show-list : ConsList Integer -> Text
show-list (xs) = when xs
  if Cons (h) (t) -> if is-empty t then show h else show h ++ ", " ++ show-list t
  if Nil -> ""

check : Text -> Text -> Text -> Text
check (name) (actual) (expected) =
  if actual == expected then "PASS: " ++ name
  else "FAIL: " ++ name ++ " expected [" ++ expected ++ "] got [" ++ actual ++ "]"

nums : ConsList Integer
nums = cons 1 (cons 2 (cons 3 (cons 4 (cons 5 nil))))

main : [Console] Nothing
main = do
  print-line "=== ConsList Prelude Module ==="
  print-line ""
  print-line (check "length" (show (list-length nums)) "5")
  print-line (check "head" (show (head nums)) "1")
  print-line (check "tail length" (show (list-length (tail nums))) "4")
  print-line (check "map double" (show-list (list-map double nums)) "2, 4, 6, 8, 10")
  print-line (check "filter even" (show-list (list-filter is-even nums)) "2, 4")
  print-line (check "foldl sum" (show (list-foldl add 0 nums)) "15")
  print-line (check "reverse" (show-list (list-reverse nums)) "5, 4, 3, 2, 1")
  print-line (check "append" (show-list (list-append (cons 1 (cons 2 nil)) (cons 3 (cons 4 nil)))) "1, 2, 3, 4")
  print-line (check "take 3" (show-list (list-take 3 nums)) "1, 2, 3")
  print-line (check "drop 3" (show-list (list-drop 3 nums)) "4, 5")
  print-line (check "any even" (show (list-any is-even nums)) "True")
  print-line (check "all even" (show (list-all is-even nums)) "False")
  print-line (check "sum" (show (list-sum nums)) "15")
  print-line (check "is-empty nil" (show (is-empty nil)) "True")
  print-line (check "is-empty cons" (show (is-empty nums)) "False")
  print-line ""
  print-line "All PASS = functional cons-list with map, filter, fold, reverse, take, drop."
