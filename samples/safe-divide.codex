Chapter: Safe Divide

Section: Definitions

  Result (a) =
    | Success (a)
    | Failure (Text)

  safe-divide (x) (y) = if y == 0 then Failure "division by zero" else Success (x / y)

  describe (result) = when result if Success (n) -> "got " ++ show n if Failure (msg) -> "error: " ++ msg

  main = describe (safe-divide 42 7)

