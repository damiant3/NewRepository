Chapter: Proofs

Section: Definitions

  claim id-nil : Nil === Nil
  proof id-nil = Refl

  claim id-sym : Nil === Nil
  proof id-sym = sym Refl

  claim chain : 5 === 5
  proof chain = trans Refl Refl

  claim wrap-nil : List Nil === List Nil
  proof wrap-nil = cong List Refl

  claim list-id (xs) : xs === xs
  proof list-id (xs) =
    induction xs
      is Nil -> Refl
      is Cons (head) (tail) -> Refl

  claim rev-nil : reverse (reverse Nil) === Nil
  proof rev-nil = assume

  claim rev-cons (head) (tail) : reverse (reverse (Cons head tail)) === Cons head tail
  proof rev-cons (head) (tail) = assume

  claim rev-rev (xs) : reverse (reverse xs) === xs
  proof rev-rev (xs) =
    induction xs
      is Nil -> rev-nil
      is Cons (head) (tail) -> rev-cons head tail

  claim plus-identity (n) : (n + 0) === n
  proof plus-identity (n) =
    induction n
      is 0 -> Refl
      is Cons (head) (tail) -> assume

