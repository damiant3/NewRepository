Chapter: Hamt Test

  cites Foreword chapter Maybe
  cites Foreword chapter Hamt

Section: Definitions

  show-maybe : Maybe Integer -> Text
  show-maybe (m) = when m
    is Just (v) -> show v
    is None -> "None"

  test-basic : Text
  test-basic =
    let m0 = hamt-empty
    in let m1 = hamt-set m0 "hello" 42
    in let m2 = hamt-set m1 "world" 99
    in let m3 = hamt-set m2 "codex" 7
    in let r1 = show-maybe (hamt-get m3 "hello")
    in let r2 = show-maybe (hamt-get m3 "world")
    in let r3 = show-maybe (hamt-get m3 "codex")
    in let r4 = show-maybe (hamt-get m3 "missing")
    in "get hello=" ++ r1 ++ " world=" ++ r2 ++ " codex=" ++ r3 ++ " missing=" ++ r4

  test-overwrite : Text
  test-overwrite =
    let m = hamt-set (hamt-set hamt-empty "k" 1) "k" 2
    in "overwrite k=" ++ show-maybe (hamt-get m "k") ++ " size=" ++ show (hamt-size m)

  test-remove : Text
  test-remove =
    let m = hamt-set (hamt-set (hamt-set hamt-empty "a" 1) "b" 2) "c" 3
    in let m2 = hamt-remove m "b"
    in "after remove b: a=" ++ show-maybe (hamt-get m2 "a") ++ " b=" ++ show-maybe (hamt-get m2 "b") ++ " c=" ++ show-maybe (hamt-get m2 "c") ++ " size=" ++ show (hamt-size m2)

  test-contains : Text
  test-contains =
    let m = hamt-set (hamt-set hamt-empty "x" 10) "y" 20
    in "contains x=" ++ show (hamt-contains m "x") ++ " z=" ++ show (hamt-contains m "z")

  test-many : Integer -> HamtMap Integer -> HamtMap Integer
  test-many (n) (m) =
    if n == 0 then m
    else test-many (n - 1) (hamt-set m ("key-" ++ show n) n)

  test-scale : Text
  test-scale =
    let m = test-many 100 hamt-empty
    in let r50 = show-maybe (hamt-get m "key-50")
    in let r1 = show-maybe (hamt-get m "key-1")
    in let r100 = show-maybe (hamt-get m "key-100")
    in "100 entries: key-50=" ++ r50 ++ " key-1=" ++ r1 ++ " key-100=" ++ r100 ++ " size=" ++ show (hamt-size m)

  test-persistence : Text
  test-persistence =
    let m1 = hamt-set (hamt-set hamt-empty "a" 1) "b" 2
    in let m2 = hamt-set m1 "c" 3
    in let m1-has-c = show (hamt-contains m1 "c")
    in let m2-has-c = show (hamt-contains m2 "c")
    in "persistence: m1 has c=" ++ m1-has-c ++ " m2 has c=" ++ m2-has-c ++ " m1 size=" ++ show (hamt-size m1) ++ " m2 size=" ++ show (hamt-size m2)

  check : Text -> Text -> Text -> Text
  check (name) (actual) (expected) =
    if actual == expected then "PASS: " ++ name
    else "FAIL: " ++ name ++ " expected [" ++ expected ++ "] got [" ++ actual ++ "]"

  main : [Console] Nothing = act
    print-line "=== HAMT (Hash Array Mapped Trie) ==="
    print-line ""
    print-line (check "basic get" test-basic "get hello=42 world=99 codex=7 missing=None")
    print-line (check "overwrite" test-overwrite "overwrite k=2 size=1")
    print-line (check "remove" test-remove "after remove b: a=1 b=None c=3 size=2")
    print-line (check "contains" test-contains "contains x=True z=False")
    print-line (check "100 entries" test-scale "100 entries: key-50=50 key-1=1 key-100=100 size=100")
    print-line (check "persistence" test-persistence "persistence: m1 has c=False m2 has c=True m1 size=2 m2 size=3")
    print-line ""
    print-line "All PASS = persistent immutable trie with O(log32 n) operations."
    print-line "Zero external dependencies. Compiles to all 12 backends."
  end

