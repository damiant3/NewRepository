half-life : Integer -> Integer
half-life (total) = if total <= 1 then 1 else total / 2

slice : List Text -> Integer -> Integer -> List Text -> List Text
slice (cards) (i) (n) (acc) =
  if i >= n then acc
  else if i >= list-length cards then acc
  else slice cards (i + 1) n (list-snoc acc (list-at cards i))

take-cards : Integer -> List Text -> List Text
take-cards (n) (cards) = slice cards 0 n []

drop-cards : Integer -> List Text -> List Text
drop-cards (n) (cards) = slice cards n (list-length cards) []

sign-contract : Integer -> List Text -> List Text -> [Console] Text
sign-contract (life) (library) (hand) =
  if list-length library <= 0
    then "The abyss laughs. You have nothing to offer."
    else
      let cost = half-life life
      in let remaining = life - cost
      in let anted = list-at library 0
      in let rest = drop-cards 1 library
      in let drawn = take-cards 7 rest
      in let new-hand = hand ++ drawn
      in do
        print-line "You sign the contract."
        print-line ("Life paid: " ++ show cost ++ " (remaining: " ++ show remaining ++ ")")
        print-line ("Anted to the abyss: " ++ anted)
        print-line ("Cards drawn: " ++ show (list-length drawn))
        print-line ("Hand size: " ++ show (list-length new-hand))
        "The contract is sealed"

main : [Console] Text
main =
  let life = 20
  in let library = ["Dark Ritual", "Hypnotic Specter", "Black Lotus", "Sinkhole", "Demonic Tutor", "Necropotence", "Drain Life", "Bad Moon", "Terror", "Unholy Strength"]
  in let hand = ["Swamp", "Swamp", "Contract from Below"]
  in sign-contract life library hand
