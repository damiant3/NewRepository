Chapter: Func In Record

 Minimal probe: can bootstrap2 compile a record whose field is a
 top-level function reference, and dispatch through that field?

Section: Types
  Entry = record {
    name : Text,
    emit : Integer -> Text
  }

Section: Emitters
  emit-one : Integer -> Text
  emit-one (x) = "one:" ++ integer-to-text x

  emit-two : Integer -> Text
  emit-two (x) = "two:" ++ integer-to-text (x + x)

Section: Table
  table : List Entry
  table = [
    Entry { name = "one", emit = emit-one },
    Entry { name = "two", emit = emit-two }
  ]

Section: Dispatch
  find-loop : List Entry -> Text -> Integer -> Integer -> Entry
  find-loop (t) (n) (i) (len) =
   if i == len then list-at t 0
   else let e = list-at t i
   in if e.name == n then e
      else find-loop t n (i + 1) len

  dispatch : Text -> Integer -> Text
  dispatch (n) (x) =
   let entry = find-loop table n 0 (list-length table)
   in entry.emit x

Section: Entry Point
  main : [Console] Nothing
  main = act
    print-line (dispatch "one" 5)
    print-line (dispatch "two" 7)
  end
